<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5670> rdfs:label "Post Assertion Note: #5670" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Propraetor (Dio 41.43.2-3). Pompey sent him to Achaea, where he attempted to fortify the Isthmus against the advance of Fufius Calenus (Caes. BC 3.56.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5521> rdfs:label "Post Assertion Note: #5521" ;
