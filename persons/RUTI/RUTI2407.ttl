	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Att. 8.12A.4, cf. 9.1.2; Caes. BC 1.24.3. " .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5142> rdfs:label "Post Assertion Note: #5142" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Attacked Caesar's agrarian law (Cic. QF 2.1.1-3), and supported Pompey's claim to restore the Egyptian King (Cic. Fam. 1.1.3, and 2.2)." .
