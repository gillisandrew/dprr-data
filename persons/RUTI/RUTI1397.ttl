<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2709> rdfs:label "Post Assertion Note: #2709" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prosecuted the Censors for perduellio (see above, Censors). They in turn took away his horse, removed him from his tribe and made him an aerarius (Liv. 44.16.8)." ;
	dprr:hasID 2709 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2708> rdfs:label "Post Assertion Note: #2708" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE 8) suggests that he was not the Pr. of 166, P. Rutilius Calvus, but possibly had the cognomen Rufus and was the father of nos. 33 and 34. Mistakenly called Popillius by Val. Max. (6.5.3)." ;
	dprr:hasID 2708 .
