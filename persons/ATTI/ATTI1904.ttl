<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7426> rdfs:label "Post Assertion Note: #7426" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Delete the cognomen, for which there is no evidence since the gentilicium of the family of the mother of Augustus was Atius and the tribe of Aricia was Hor. not Ouf. (RS, CP). See MRR 2.35, 38, note 8; see also Criniti, L'Epigrafe di Asculum 18, 103-104, and H. B. Mattingly, Athenaeum 53, 1975, 262.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3920> rdfs:label "Post Assertion Note: #3920" ;
