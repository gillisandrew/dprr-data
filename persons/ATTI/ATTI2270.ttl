	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8789> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7318> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4782> ;
	dprr:hasOriginalText "C. Attius Celsus (not in RE)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -65 ;
