<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/473> rdfs:label "Post Assertion Note: #473" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Lacerius and Acutius were coopted contrary to the Trebonian law (see 448), and agitation by Trebonius at this led the other three as a diversion to prosecute and convict Verginius and Sergius (see 402) as responsible for the defeats of that year (Liv. 5.10.10-12.2). The Tribunes proposed an agrarian law (Liv. 5.12.3)." ;
	dprr:hasID 473 .
