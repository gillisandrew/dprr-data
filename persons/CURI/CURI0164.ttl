	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/323> rdfs:label "Primary Source Reference: #323" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Brut. 113ff." ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/318> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/299> rdfs:label "Primary Source Reference: #299" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Att. XIII 6.4" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/294> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/260> rdfs:label "Post Assertion Note: #260" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prepared and caused the enactment of ten tables of laws (Cic. Rep. 2.61; Liv. 3.33.1-36.2; Diod. 12.23.1; Dion. Hal. 10.56.1-2; Tac. Ann. 3.27; Gell. 11.18.6; 17.21.15; 20.1; Dig. 1.2.2.3-4 and 24; Zon. 7.18)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/258> rdfs:label "Post Assertion Note: #258" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "As in 453, Dion. Hal. has Horatius for Curiatius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/252> rdfs:label "Post Assertion Note: #252" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. preserves all or part of eight names, omitting Sestius and Curiatius, Fast. Cap. all or part of six with space for the rest, those of Sestius, Curiatius, Romilius and Postumius, which are supplied from the information on their consulships (Degrassi 26f., 94, 364f.). According to Dion. Hal. (10.56.2) they were all consulars, but this principle was not applied consistently in Livy or Fast. Cap. See notes 3 and 4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/243> rdfs:label "Post Assertion Note: #243" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 3.32.1; Diod. 12.7.1; Fast. Cap. (see note 1); Dion. Hal. 10.53.1; Chr. 354 (Varo et Trigemino); Fast. Hyd. (Festo et Quintillo), so also Chr. Pasc.; Cassiod.; Degrassi 24f., 93, 364f. Quinctilius died in the pestilence of this year (Liv. 3.32.4; Dion. Hal. 10.53.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/242> rdfs:label "Post Assertion Note: #242" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "The names are preserved entire in Fast. Cap. except the filiation of Curiatius. His name appears as Horatius in Dion. Hal., while Diod. has only the cognomen Trigeminus. The cognomen Varus in Chr. 354 arises because it was frequent among the patrician Quinctilii." .
