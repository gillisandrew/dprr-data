	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1995> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1994> ;
	dprr:hasOriginalText "M'. Curius (4)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
	dprr:hasDateStart -198 ;
