<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1995> rdfs:label "Post Assertion Note: #1995" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They opposed for a time the candidacy of Flamininus for the consulship because he had held no curule office (Liv. 32.7.8-11; Plut. Flam. 2.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1994> rdfs:label "Post Assertion Note: #1994" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Münzer (RE) dates these Tribunes in 199, but during this period the new Tribunes were probably in office before the usual time of the elections (cf. Liv. 39.52.4). Accordingly Niccolini (FTP 105) dates them in this year. See Mommsen, Str. 1.585." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2399> rdfs:label "Post Assertion: #2399" ;
	a dprr:PostAssertion ;
