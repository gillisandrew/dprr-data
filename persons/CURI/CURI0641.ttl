	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ovation de Lucaneis. MRR I.183-4 (289), Itgenshorst no. 102 (289?), Rich no. 102 (283)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10058> rdfs:label "Post Assertion Note: #10058" ;
