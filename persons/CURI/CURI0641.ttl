	dprr:hasNoteText "Triumph de Sabineis. MRR I.183-4, Itgenshorst no. 101, Rich no. 101." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10057> rdfs:label "Post Assertion Note: #10057" ;
