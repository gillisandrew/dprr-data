<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2729> rdfs:label "Post Assertion Note: #2729" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "L. Postumius Albinus succeeded P. Quinctilius Varus. Liv. 44.18.7. See Lübker no. 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1842> rdfs:label "Post Assertion Note: #1842" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fought against Mago in Gaul (Liv. 30.18.1-15). See Lübker, no. 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1841> rdfs:label "Post Assertion Note: #1841" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The details of the battle described in Liv. 30.18 have been questioned (Ehrenberg, RE s. v. \"Mago,\" no. 5; cf. De Sanctis, 3.2.540f., note 150), but the occurrence of a battle is reasonable and consistent with the distribution of the legions at this time (Crake, 292)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1838> rdfs:label "Post Assertion Note: #1838" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 29.38.4-5 Provinces 30.1.9, cf. 3.1." .
