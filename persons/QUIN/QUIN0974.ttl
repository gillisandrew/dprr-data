	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Killed in a skirmish while in charge of bringing grain by sea to the garrison at Tarentum (Liv. 26.39.2-19)." .
