<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/298> rdfs:label "Primary Source Reference: #298" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Att. XIII 5.1" ;
