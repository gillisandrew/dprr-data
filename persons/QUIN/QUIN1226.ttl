<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2380> rdfs:label "Post Assertion Note: #2380" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to found Mutina and Parma (Liv. 39.55.7-8). On Quinctius, see Lübker no. 8; Münzer, APF 117." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2356> rdfs:label "Post Assertion Note: #2356" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Hither Spain. Returned to celebrate a triumph (Liv. 39.42.2-3; Degrassi 554). See 185, Praetors; Lübker no. 8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2329> rdfs:label "Post Assertion Note: #2329" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Livy refers to both Piso and his colleague Crispinus (Praetors in 186) as praetores in 185 (39.30.1, and 31.4 and 18), and in 184, when they returned, as veteres praetores (39.42.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2328> rdfs:label "Post Assertion Note: #2328" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor (Praetor,\n     Liv. 39.30.1) of Hither Spain. See above, on Calpurnius Piso." .
