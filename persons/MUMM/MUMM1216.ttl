	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They at first opposed the Petillian rogation (see below), but under Cato's influence withdrew their veto (Liv. 38.54, from Antias)." ;
	dprr:hasID 2299 .
