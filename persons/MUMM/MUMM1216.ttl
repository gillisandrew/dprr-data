<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2508> rdfs:label "Post Assertion Note: #2508" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His province was assigned to the Consul Gracchus, and he was given the duty of prosecuting Latins who had not returned home from Rome (Liv. 41.9.10)." ;
