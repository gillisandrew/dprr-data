<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2362> rdfs:label "Post Assertion Note: #2362" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 185. They were sent by the governors in Spain (see above) to report their victory and ask permission for them to bring their armies home with them (Liv. 39.38.4-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2334> rdfs:label "Post Assertion Note: #2334" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Calpurnius Piso in Farther Spain (Liv. 39.31.4)." .
