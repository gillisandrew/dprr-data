<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/623> rdfs:label "Relationship Assertion Reference: #623" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Antonius scheidet sich von seiner Cousine Antonia, nachdem er ihr Ehebruch mit Dolabella vorgeworfen hatte. Sie ist die Tochter seines Onkels. Nur Dolabella wird mit Namen genannt." ;
	dprr:hasExtraInfo "Cic. Phil. II 99" .
