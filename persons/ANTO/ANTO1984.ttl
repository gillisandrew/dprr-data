	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Issued coins in Rome (Grueber, CRRBM 1.344f.; cf. Val. Max. 7.6.4). Driven from Sardinia by Sulla's Legate, Marcius Philippus, and killed (Liv. Per. 86)." .
