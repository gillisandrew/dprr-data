<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7723> rdfs:label "Post Assertion Note: #7723" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably praetor in Rome by or before 83; his coinage in Rome is dated to 83 by Crawford (RRC 1:379, no. 364). Propraetor in Sardinia in 82 (MRR 2.57; Badian, Studies 100, note 79).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4140> rdfs:label "Post Assertion Note: #4140" ;
