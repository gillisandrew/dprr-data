	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Teilnahme an den Lupercalia des Jahres 44; in den späten dreißiger Jahren ließ er sich im Osten als Neos Dionysos feiern." .
