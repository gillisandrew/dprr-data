<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2777> rdfs:label "Post Assertion Note: #2777" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They vetoed the Praetor's proposal to declare war on Rhodes (Liv. 45.21.1-8; cf. Polyb. 30.4.5-6; Diod. 31.5.3). Antonius introduced Aemilius Paullus to a public meeting (Liv. 45.40.9). On Pomponius, see Lübker no. 2." ;
	dprr:hasID 2777 .
