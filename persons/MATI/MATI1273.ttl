	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The praenomen is given as M. in Liv. 42.1.5; and 43.2.9; cf. Klotz, Hermes 50 (1915) 517, note 1." .
