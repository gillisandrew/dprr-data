<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/360> rdfs:label "Relationship Assertion Reference: #360" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cicero erzählt vom plötzlichen Tod des Q. Metellus Celer, der sich gegen seinen frater Clodius geäußert hat. Clodia wird hier nicht als Ehefrau des Celer bezeichnet, aber zweifellos gilt ihr die Anspielung ex hac ... domo progressa ista mulier. Wortspiel zwischen Q. Caecilius Metellus Celer und veneni celeritate" ;
	dprr:hasID 360 ;
	dprr:hasExtraInfo "Cic. Cael. 60" .
