	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/470> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/469> ;
	dprr:hasOriginalText "[? Capitos Clodius]" ;
