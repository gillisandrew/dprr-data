	dprr:hasOriginalText "Cn. Iulius L. f. (Caesar?) (not in RE) & Cn. Iuli(us) L. f. (Caesar?) (not in RE)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/5> ;
