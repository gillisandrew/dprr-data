<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6286> rdfs:label "Post Assertion Note: #6286" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. A freedman of Octavian who recovered Sardinia from the Pompeians for him, but was soon captured by Sextus Pompey's Legate Menodorus, and in 39 was returned to Octavian without ransom (App. BC 5.66; Dio 48.30.8, and 45.5; cf. CIL 10.5808-ILS 6267; see Ganter 27)." ;
	dprr:hasID 6286 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10293> rdfs:label "Post Assertion Note: #10293" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.177 (MRR lists Helenus as legatus but admits this naval officer's title is not preserved, Suolahti has praefectus classis)." ;
	dprr:hasID 10293 .
