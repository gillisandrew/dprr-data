<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8526> rdfs:label "Post Assertion Note: #8526" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 737" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2975> rdfs:label "Post Assertion Note: #2975" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with others to censure the Achaeans for insults offered to Orestes and his associates, and urge them to avoid hostilities with Rome; but his attempt to arbitrate the dispute with the Lacedaemonians was obstructed by the Achaean leader Critolaus (Polyb. 38.9-11; Dio fr. 72)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2870> rdfs:label "Post Assertion Note: #2870" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., Degrassi 50f., 123, 462f.; Fast. Ant., ib. 160f.; Plin. 33.55; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Iulius, Polyb. 32.10.2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2869> rdfs:label "Post Assertion Note: #2869" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Caesar is named as a witness to the decree of the Senate reported to the People of Tibur (CIL 1(2).2.586- ILS 19), and was probably and ex-Praetor at that time (see 159, Praetors)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2858> rdfs:label "Post Assertion Note: #2858" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The latest possible date for their praetorships under the Lex Villia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2817> rdfs:label "Post Assertion Note: #2817" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Didasc. Ter. Hec. The first unsuccessful performance of the Hecyra of Terence took place under their charge." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2684> rdfs:label "Post Assertion Note: #2684" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to restore the people of Abdera their freedom, and search out and return those who had been sold (Liv. 43.4.12-13)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2424> rdfs:label "Post Assertion Note: #2424" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Aemilius Paulus in Liguria (Liv. 40. 27.4-6)." .
