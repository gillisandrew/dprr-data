	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Though in command in Sicily (of the Cannenses, Liv. 27.22.9), he was sent as an envoy to the wounded Consul Crispinus (27.29.4-6).{291}" .
