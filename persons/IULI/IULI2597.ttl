	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "De Coninck (143 Anm. 74) stellt fest, dass diese Stelle auf einen Senatsbeschluß zurückgeht und es keine parallele Überlieferung gibt. Pater wird aber kaum im Senatus consultum gestanden haben. Sueton kann natürlich geläufig sein, dass es sich bei dem Erwähnten um den Vater von Augustus handelte, er muss sogar davon überzeugt gewesen sein, wenn er das senatus consultum hier auswertet." ;
	dprr:hasExtraInfo "Suet. Aug. 3.1" .
