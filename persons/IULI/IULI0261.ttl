<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/377> rdfs:label "Post Assertion Note: #377" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Rep. 2.60 (with praenomina P. and C., respectively); Liv. 4.30.1; Diod. 12.72.1; Chr. 354 (Crasso et Iulo); Fast. Hyd. (Crasso et Iulio); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 95, 372f. Granted the Aequi a truce for eight years (Liv. 4.30.1-2), and carried a law commuting fines in live stock to cash (Cic. Rep. 2.60; Liv. 4.30.3; cf. Fest. 220 L)." ;
	dprr:hasID 377 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/376> rdfs:label "Post Assertion Note: #376" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. has under this year the names of C. Papirius and L. Iunius, Cassiod. those of L. Papirius and L. Iulius Iullus." ;
	dprr:hasID 376 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/372> rdfs:label "Post Assertion Note: #372" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.26.11, and 27.1; Diod. 12.64.1; Degrassi 95, 372f." ;
	dprr:hasID 372 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/371> rdfs:label "Post Assertion Note: #371" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 438 and 430." ;
	dprr:hasID 371 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/333> rdfs:label "Post Assertion Note: #333" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.16.7-17.1; Diod. 12.38.1; Chr. 354 (Fidenato et Cincinnato); Degrassi 95, 370f." ;
	dprr:hasID 333 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/332> rdfs:label "Post Assertion Note: #332" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "In Diod. Aemilius' name appears as {Gr}, and Iulius' praenomen as {Gr}. Degrassi (95) considers that in Fast. Cap. Iulius' praenomen was more probably C. than L. Either is possible, see 447 and 435, Consuls (C. Iulius), and 430, Consuls (L. Iulius)." ;
	dprr:hasID 332 .
