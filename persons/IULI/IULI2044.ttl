	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6296> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4634> ;
	dprr:hasPosition 0 ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/16> ;
	dprr:hasDateStart -79 ;
	dprr:hasDateEnd -40 .
