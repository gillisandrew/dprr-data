<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6129> rdfs:label "Post Assertion Note: #6129" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate, probably one left in Africa by Calvisius Sabinus, from whom Cornificius removed his insignia (Cic. Fam. 12.30.7; cf. Phil. 3.26, where Cicero speaks of duos legatos: should Fam. 12.30.7 be punctuated to read Venuleius Latinus, Horatius? See above, on Horatius and Latinus)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5927> rdfs:label "Post Assertion Note: #5927" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate under C. Calvisius Sabinus in Africa (Cic. Fam. 12.30.7; cf. Phil. 3.26; see above, on Horatius and Latinus)." .
