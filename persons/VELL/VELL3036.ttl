<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7699> rdfs:label "Post Assertion Note: #7699" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See MRR 2.474. Better to list him as a senator before 77. See Wiseman, NM 271, no. 471.\n" ;
