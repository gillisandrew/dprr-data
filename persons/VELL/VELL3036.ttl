<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6675> rdfs:label "Post Assertion Note: #6675" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Senator (Cic. ND 1.15, cf. 58, and 66, dramatic date 77), and friend of the orator Crassus (Cic. De Or. 3.78, dramatic date, 91). Niccolini (FTP 427) suggests that he held the tribunate before 90, but he may have been enrolled in the Senate by Sulla." ;
	dprr:hasID 6675 .
