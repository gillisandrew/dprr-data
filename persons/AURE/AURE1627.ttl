<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3291> rdfs:label "Post Assertion Note: #3291" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Sardinia, whence he returned to celebrate a triumph (Act. Tr., Degrassi 82f., 560; see 125-123, Promagistrates)." .
