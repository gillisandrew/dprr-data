<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/139> rdfs:label "Relationship Assertion Reference: #139" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die Stelle basiert wohl auf einem Mißverständnis. Es ist sehr unwahrscheinlich, dass Catilina der Vater Aurelias aus einem seiner früheren Verhältnisse ist. Eher zog Asconius die falschen Schlüsse aus den zahlreichen Erwähnungen von Aurelia und ihrer Tochter und den Anspielungen auf ein Verhältnis Catilinas mit seiner Tochter aus erster Ehe." ;
	dprr:hasExtraInfo "Asc. Tog. Cand. 91f.C" .
