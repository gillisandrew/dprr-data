<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1956> rdfs:label "Post Assertion Note: #1956" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "M'. Acilius Glabrio succeeded M. Aurelius Cotta. Liv. 31.50.5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1944> rdfs:label "Post Assertion Note: #1944" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 201, Legates. In a suspect account Livy (31.5.5 and 7) reports letters from him as Legatus after the new Consuls entered office. He died this year (Liv. 31.50.5; see Decemviri s. f.). See 201, note 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1920> rdfs:label "Post Assertion Note: #1920" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Informed Laevinus (see Promagistrates) on his arrival in Greece of the situation in Macedonia (Liv. 31.3.2-6, and 5.5-9; cf. 30.26.4, and 42.1-10). See 203, Legates; below, note 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1862> rdfs:label "Post Assertion Note: #1862" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The accusations brought against Philip by the Greek envoys (Liv. 30.26.2-4) are probably late annalistic fabrications (Holleaux, CAH 8.156, note 1), but the names and the sending of an embassy may be based on archival material (Crake 155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1861> rdfs:label "Post Assertion Note: #1861" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to protest to Philip of Macedon against alleged violations\n     of his treaty with the Romans (Liv. 30.26.2-4; see 202 and 201, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1831> rdfs:label "Post Assertion Note: #1831" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "M. Aurelius Cotta succeeded M. Pomponius Matho. Liv. 29.38.7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1539> rdfs:label "Post Assertion Note: #1539" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Ap. Claudius, who placed him in charge of forwarding supplies from Puteoli (Liv. 25.22.5, cf. 20.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1538> rdfs:label "Post Assertion Note: #1538" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Aurelius and Iunius are not mentioned with titles, but since they were put in charge of their posts by the Consul, they were either Legates or Prefects." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1369> rdfs:label "Post Assertion Note: #1369" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 23.30.17." .
