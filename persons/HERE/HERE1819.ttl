<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8381> rdfs:label "Post Assertion Note: #8381" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See Cic. Mur. 36; Brut. 166." ;
	dprr:hasID 8381 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3759> rdfs:label "Post Assertion Note: #3759" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12 .2.704, 890; I. de Delos 4.1.1764; Fast. Ant., Degrassi 164f., and Fast. Cap., ibid. 54f., 129, 480f.; Plin. NH 19.40; Obseq. 52; Chr. 3.54; Fast. Hyd.; Chr. Pasc.; Cassiod. Flaccus was sent to Spain to quell a Celtiberian revolt, either during or immediately after his consulship (see note 2, and 92, Promagistrates)." ;
	dprr:hasID 3759 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3758> rdfs:label "Post Assertion Note: #3758" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 1 A new man, unexpectedly elected (Cic. Brut. 166) over Marcius Philippus." ;
	dprr:hasID 3758 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3722> rdfs:label "Post Assertion Note: #3722" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 This is the latest possible date under the Leges Annales. If he was a Triumvir Monetalis about 104 (but of. Grueber, CRRBM 1.195-198), he advanced in regular order in his career." ;
	dprr:hasID 3722 .
