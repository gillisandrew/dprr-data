	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Hier lediglich den Namen des Freigelassenen T. Vinium Philopoemenem ohne die Frau des Vinius zu erwähnen." ;
	dprr:hasExtraInfo "Suet. Aug. 27.2" .
