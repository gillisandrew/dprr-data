<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/53> rdfs:label "Relationship Assertion Reference: #53" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ohne die Frau des Vinius zu erwähnen; Der Freigelassene heißt hier Philemon, aber bei Sueton und Dio Philopoimen. Der Fehler liegt bei Appian." ;
	dprr:hasExtraInfo "App. b.c. IV 44 (187)" .
<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1717> rdfs:label "Relationship Assertion Reference: #1717" ;
