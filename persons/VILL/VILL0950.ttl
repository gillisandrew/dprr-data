	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "IIIvir noct. 211 ? The uncertainty of the date of the Tr. pl. P. Aquillius (see MRR 1.273) applies also to Villius.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1583> rdfs:label "Post Assertion Note: #1583" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Condemned by P. Aquillius, tribune of the plebs the same year, for neglecting his watch (Val. Max. 8.1, damn. 6; cf. Niccolini, FTP 398)." .
