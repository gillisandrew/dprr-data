<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9087> rdfs:label "Post Assertion Note: #9087" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 749, footnote 314" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7389> rdfs:label "Post Assertion Note: #7389" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 73. See MRR 2.110. Against Münzer's perhaps (RE nos. 1 and 2) and Wiseman (NM 227, no. 140), Shackleton Bailey (Onom.) thinks it unlikely that a man who had obtained citizenship through a successful prosecution should have risen as far as the praetorship, or that, if he had, he would be described merely as pater huius equitis Romani (Cic. Balb. 53)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4449> rdfs:label "Post Assertion Note: #4449" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A colleague who was sent to advise and assist Varinius against Spartacus, but was almost captured himself and fell in battle (Plut. Crass. 9.4-; cf. Sall. Hist. 3.94 M). See below, on Varinius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4448> rdfs:label "Post Assertion Note: #4448" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "2 As # Cossinius must have been a colleague (Münzer, RE)." .
