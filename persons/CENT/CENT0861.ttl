<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1777> rdfs:label "Primary Source Reference: #1777" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Strab. XI 9.1 (515 C)" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1707> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1345> rdfs:label "Post Assertion Note: #1345" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent in advance by the Consul Servilius with cavalry to aid Flaminius, but was destroyed with his forces by Hannibal (Polyb. 3.86.3-5; Nep. Hann. 4.3; Liv. 22.8.1, pro praetore; App. Hann. 9.10-11, 17; Zon. 8.25; cf. Liv. 25.19.9-17)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1344> rdfs:label "Post Assertion Note: #1344" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Livy designates Centenius pro praetore, Nepos, Praetor, Polybius gives no title, Zonaras, {Gr}, and Appian says {Gr}. Mommsen thinks that if the designation pro praetore is correct Centenius{247} received imperium on the motion of the Pr. Urbanus (Str. 1.681, notes 4 and 6). On the difficulties regarding this incident, see De Sanctis 3.2.122-124." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1707> rdfs:label "Post Assertion: #1707" ;
	a dprr:PostAssertion ;
