<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4178> rdfs:label "Post Assertion Note: #4178" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Legate under Papirius Carbo (App. BC 1.90). When defeated by Pompey at Sena and in Etruria, and deserted by Papirius Carbo, he joined the Samnites and was killed at the Colline Gate (App. BC 1.88, and 90, and 92-93)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4028> rdfs:label "Post Assertion Note: #4028" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded the troop of horse which was sent to kill the Consul Octavius (App. BC 1.71; see above, Consuls)." .
