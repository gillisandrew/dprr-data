<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9807> rdfs:label "Post Assertion Note: #9807" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/24> ;
