	dprr:hasNoteText "See 47, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5752> rdfs:label "Post Assertion Note: #5752" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Cilicia (Cic. Fam. 13.73, and 74; see Syme, Anat. Stud. Buckler 299-332, esp. 306-324, on the date and identification of this governor and his province; and Magie, Roman Rule in Asia Minor 2.1270, note 40)." .
