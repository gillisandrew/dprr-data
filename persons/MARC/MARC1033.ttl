<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8422> rdfs:label "Post Assertion Note: #8422" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
