	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He was collecting a fleet for Dolabella from Rhodes, Lycia, Pamphylia, and Cilicia, and took refuge from Cassius of Parma and other commanders in Corycus (App. BC 4.60; cf. Cic. Fam. 12.13.3, emending the Mss reading Lucilius)." ;
