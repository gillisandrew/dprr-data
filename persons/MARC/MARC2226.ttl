<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2945> rdfs:label "Person Note: #2945" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Note the conjecture, based on the entry Caesare et Turmo in the Chronographer of 354, that he was a Minucius Thermus (60) who had been adopted by a Marcius Figulus and was really the Thermus named in Cic. Att. 1.1.2 as a likely candidate for the consulship of 64 (Shackleton Bailey, CLA 1.292; Studies 121-122)." .
