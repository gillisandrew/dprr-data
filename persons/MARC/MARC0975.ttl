<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1639> rdfs:label "Post Assertion Note: #1639" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.6.16." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1638> rdfs:label "Post Assertion Note: #1638" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Mommsen (RF 1.84, note 25; cf. 104f., note 73) questions this notice because the Rex sacrorum had to be a patrician (Liv. 6.41.9; Cic. Dom. 38) and patrician Marcii are not mentioned in historical times. Münzer however accepts this Marcius as the first plebeian Rex sacrorum, and the ancestor from whom the family drew the cognomen Rex (RE no. 20; APF 81, 409; cf. Klose 11f.)." .
