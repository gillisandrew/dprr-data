<http://romanrepublic.ac.uk/rdf/entity/PersonNote/1406> rdfs:label "Person Note: #1406" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/14> ;
	dprr:hasNoteText "Der erstmals 171 (Liv. 43,1,12) erscheinende Marcische Beiname Rex dürfte auf diesen Rex sacrorum zurückgehen." .
