<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1243> rdfs:label "Primary Source Reference: #1243" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Liv. XXXVII 57.10" ;
