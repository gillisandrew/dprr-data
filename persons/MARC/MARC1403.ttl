<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2832> rdfs:label "Post Assertion Note: #2832" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These men (called Canuleius and Quintus by Polybius) aided in securing the temporary settlement between Ptolemy VI and Ptolemy VII by which the latter received Cyrene, and in 162 witnessed to this in the Senate (Polyb. 31.10.1-5; cf. Liv. Per. 46; Trogus Prol. 34; Zon. 9.25). See Otto, ABAW 11 (1934) 93f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2723> rdfs:label "Post Assertion Note: #2723" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his father in Macedonia (Liv. 44.3.2)." .
