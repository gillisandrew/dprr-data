<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2631> rdfs:label "Post Assertion Note: #2631" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Apulia and Calabria to purchase grain for the fleet and the army (Liv. 42.27.8)." ;
	dprr:hasID 2631 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2601> rdfs:label "Post Assertion Note: #2601" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Early in 173 these reported their failure to meet King Perseus and the Preparations for war in Macedonia (Liv. 42.2.1-2)." ;
	dprr:hasID 2601 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2566> rdfs:label "Post Assertion Note: #2566" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Macedonia to King Perseus (Liv. 41.22.3). See 173, Legates; and on Valerius, Münzer, Gent. Val. 51, no. 53." ;
	dprr:hasID 2566 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2224> rdfs:label "Post Assertion Note: #2224" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of L. Scipio, who brought transports to Brundisium (Liv. 37.4.2)." ;
	dprr:hasID 2224 .
