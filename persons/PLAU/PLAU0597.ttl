<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1207> rdfs:label "Primary Source Reference: #1207" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Liv. XXVIII 43.5" ;
