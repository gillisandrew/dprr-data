	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 64-63, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4871> rdfs:label "Post Assertion Note: #4871" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Pompey in the East (Ascon. 35 C; see 66, Quaestors; 64-62, Promagistrates)." .
