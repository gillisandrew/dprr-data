<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5182> rdfs:label "Post Assertion Note: #5182" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A candidate for the consulship of 52 (Ascon. 30 C). See Liv. Per. 107; Plut. Cat. Min. 47. 1; App. BC 2.90; Dio 40.53. 1; Schol. Gron. 322 Stangl; cf. Val. Max. 9.5.3; Plut. Pomp. 55.3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4949> rdfs:label "Post Assertion Note: #4949" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An issue of coins, distinct from those of his aedileship in 58, is attributed to him this year as Proquaestor under Pompey (Grueber, CRRBM 1. 476f.), but the inscription S. C. is against this view." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4912> rdfs:label "Post Assertion Note: #4912" ;
