<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/825> rdfs:label "Post Assertion Note: #825" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "As the praetorship in this period was normally held by an ex-Consul, Plautius is more probably the Consul of 330 than of 318. See Münzer, APF 39f." ;
	dprr:hasID 825 .
