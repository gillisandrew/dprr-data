<http://romanrepublic.ac.uk/rdf/entity/PersonNote/12> rdfs:label "Person Note: #12" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "On his adoption by L. Calpurnius Bestia (25), and his name, see ILS 9461, and Shackleton Bailey, Studies 129. On his coinage while legatus under Antony in Greece (MRR 2.389), see now Crawford, RRC 1.533, no. 530, ca. 39 B.C. Note the inscription L. ATRATINVS AVGVR On his coins. On his command of a fleet as legatus pro praetore, see ILS 9461, ca. 36. " ;
	dprr:hasID 12 .
