<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/82> rdfs:label "Post Assertion Note: #82" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 2.34.7; Dion. Hal. 7.20.1; Chr. 354 (Augurino II et Atratino II); Fast. Hyd. (Augurino II et Atratio); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 88, 352f. See Tribunes of the Plebs, on Coriolanus." ;
	dprr:hasID 82 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/62> rdfs:label "Post Assertion Note: #62" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Dion. Hal. 6.2.3. See also under 496." ;
	dprr:hasID 62 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/56> rdfs:label "Post Assertion Note: #56" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 2.21.1; Dion. Hal. 6.1.1-4; cf. 7.20.1; Chr. 354 (Atratino et Augurino), so also Fast. Hyd., and Chr. Pasc.; Cassiod. See Degrassi 88, 352f." ;
	dprr:hasID 56 .
