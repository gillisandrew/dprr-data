<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2061> rdfs:label "Post Assertion Note: #2061" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefecti Socium; killed in battle while serving under Marcellus in Gaul (Liv. 33.36.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2060> rdfs:label "Post Assertion Note: #2060" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The praenomen T. is attested in this gens only in the cases of T. Musca (RE no. 72) and T. Rutilus (no. 83), and not at all among the Gracchi. Münzer doubts the authenticity of these officers in a passage so markedly in the style of the late annalistic." .
