<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7569> rdfs:label "Post Assertion Note: #7569" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator by 140. See SIG(3) 674; MRR 2.496. Badian suggests that he was an Asellio, PACA 11, 1968, 1-2. See Sherk, RDGE no. 9, pp. 49-53. In view of the known tribe of other Sempronii, the reading in SIG(3) 674 is more probably # than #." ;
	dprr:hasID 7569 .
