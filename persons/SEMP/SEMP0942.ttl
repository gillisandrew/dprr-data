<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1625> rdfs:label "Post Assertion Note: #1625" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Fulvius Flaccus, who sent him from Capua to Etruria when he summoned Calpurnius (see above, Promagistrates) from Etruria to take charge at Capua (Liv. 27.6.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1559> rdfs:label "Post Assertion Note: #1559" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Accused Cn. Fulvius Flaccus of perduellio for fleeing from the battle at Herdonea (Liv. 26.2.7-3.12; see 212, note 2)." .
