<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2401> rdfs:label "Post Assertion Note: #2401" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Died in his province of Farther Spain after a long illness late in 183 or early in 182 (Liv. 40.2.5).{383}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2372> rdfs:label "Post Assertion Note: #2372" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain, kept inactive by illness (Liv. 39.45.4, and 56.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2342> rdfs:label "Post Assertion Note: #2342" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Both governors in Spain had to levy new armies and bring them there (Liv. 39.38.8-12). Terentius won a success over the Suessetani (39.42.1)." .
