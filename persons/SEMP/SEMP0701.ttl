	a dprr:SecondarySource ;
	dprr:hasName "Rich Triumphs" ;
	dprr:hasBiblio "Rich, J., 'The Triumph in the Roman Republic: Frequency, Fluctuation and Policy' in Carsten Hjort Lange & Frederik Juliaan Vervaet (eds.) The Roman Republican triumph : beyond the spectacle. 197-258. Roma : Edizioni Quasar, 2014." ;
	dprr:hasAbbreviation "Rich 2014" .
