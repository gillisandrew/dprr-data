<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2790> rdfs:label "Post Assertion Note: #2790" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to assist Anicius in making a settlement in Illyria (Liv. 45.17.4, and 26.11-15)." ;
	dprr:hasID 2790 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2636> rdfs:label "Post Assertion Note: #2636" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to King Gentius of Illyria to protest attacks upon Roman allies (Liv. 42.26.6-7)." ;
	dprr:hasID 2636 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2621> rdfs:label "Post Assertion Note: #2621" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Refused a triumph for his exploits in Corsica, he celebrated as Propraetor an ovatio on the Alban Mount (Liv. 42.21.6-7; Act. Tr., Cap. and Urbisalv., Degrassi 80f., 556)." ;
	dprr:hasID 2621 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2585> rdfs:label "Post Assertion Note: #2585" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in command of the war in Corsica, he defeated the insurgents, and compelled them to pay tribute (Liv. 42.1.3, and 7.1-2; cf. Val. Max. 3.5.1; 4.5.3). He vowed a temple to Iuno Moneta (Liv. 42.7.1; cf. 45.15.10)." ;
	dprr:hasID 2585 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2583> rdfs:label "Post Assertion Note: #2583" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 41.28.5 Provinces 42.1.5." ;
	dprr:hasID 2583 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10010> rdfs:label "Post Assertion Note: #10010" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph in Monte Albano ex Corsica. MRR I.412, Itgenshorst no. 199, Rich no. 198." ;
	dprr:hasID 10010 .
