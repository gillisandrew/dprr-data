	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Asculaneis Picentibus. MRR II.32, Itgenshorst no. 241, Rich no. 241." .
