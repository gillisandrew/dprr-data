<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8414> rdfs:label "Post Assertion Note: #8414" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 728" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1892> rdfs:label "Post Assertion Note: #1892" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ordered to bring ships and soldiers home from Sicily (Liv. 30.27.9). See D.- G., 5.5, no. 7; Lübker, no. 8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1857> rdfs:label "Post Assertion Note: #1857" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium as Praetor prorogued with command of a fleet to protect the coast of Sicily, and bring new recruits there (Liv. 30.2.1-3, cf. 27.9). See D.- G., 5.5, no. 7; Lübker, no. 8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1802> rdfs:label "Post Assertion Note: #1802" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to aid in investigating the charges against Scipio and Pleminius (Liv. 29.20-22; 31.12.3; see 205, Legates, on Pleminius; and below, Legates, on Caecilius). Aided in transporting Scipio's army to Africa (Liv. 29.24.8-9, 25.6, and 26.7). See Lübker, no. 8; D.- G. 5.5, no. 7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1798> rdfs:label "Post Assertion Note: #1798" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 29.11.11 Provinces and armies 29.13.1-2, 5-6; cf. 30.1.7, and 2.3 and 5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1787> rdfs:label "Post Assertion Note: #1787" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Brought to Delphi gifts from the booty of Hasdrubal (Liv. 28.45.12). On Pomponius, see D.- G. 5.5, no. 7; Lübker, no. 8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1718> rdfs:label "Post Assertion Note: #1718" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 28.10.3 and 7. On Pomponius, see D.- G. 5.5, no. 7; Lübker, no. 8." .
