<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7978> rdfs:label "Post Assertion Note: #7978" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. 39-38. See MRR 2.389, 394. See below, on Poppaedius (Pompaedius) (- f. Q. n. Ser.) Silo (1)\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7910> rdfs:label "Post Assertion Note: #7910" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. of Mark Antony 39-38. See MRR 2.389, 394. See Syme, PBSR 14, 1938, 21; Wiseman, NM 253, no. 339.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6339> rdfs:label "Post Assertion Note: #6339" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate under Antony and Ventidius, whom the latter summoned from Judaea early in 38 to aid him against the Parthian invasion (Joseph. AJ 14.420-421; BJ 1.309; see 39, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6311> rdfs:label "Post Assertion Note: #6311" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate, probably of Antony (Liv. Per. 127) but under the immediate command of Ventidius (see Ganter 42). He held command of the advance guard of cavalry in the Amanus mountains against the Parthians (Dio 48.41), and was active in Judaea, where he gave Herod quite unreliable aid in the recovery og his kingdom, while keeping secretly in touch with his rival Antigonus (Joseph. AJ 393-419; BJ 1.289-302)." .
