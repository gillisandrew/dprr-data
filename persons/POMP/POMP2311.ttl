<http://romanrepublic.ac.uk/rdf/entity/StatusAssertion/2716> rdfs:label "Status Assertion: #2716" ;
	a dprr:StatusAssertion ;
	dprr:isDateStartUncertain true ;
	dprr:isDateEndUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2311> ;
	dprr:hasStatus <http://romanrepublic.ac.uk/rdf/entity/Status/2> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasDateStart -65 ;
	dprr:hasDateEnd -50 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8800> rdfs:label "Post Assertion Note: #8800" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 753, footnote 426" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7697> rdfs:label "Post Assertion Note: #7697" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 63. Combine the entries under these two names (see MRR 2.125, 167, and Index, 605) as C. Pomptinus, since the text of Frontin. Str. 2.4.7 on the legate of 71 should be emended to Pomptinus.[167]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5481> rdfs:label "Post Assertion Note: #5481" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Cicero in Cilicia, but returned to Italy before him (Cic. Att. 5.21.9; 6.3.1; 7.7.3; Fam. 2.15.4; 3.10.3; see 51, Legates). See Lübker, p. 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5420> rdfs:label "Post Assertion Note: #5420" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Cicero in Cilicia, and important for his military operations (Cic. Att. 5.1.5, 4.2, 5.1, 6.1, 8.1, 10.1, 11.5, 20.3, 21.9; 6.3. 1; Fam. 3.3.2; 15.4.8-9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5249> rdfs:label "Post Assertion Note: #5249" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "With the aid of the Praetor Ser. Galba and the Consul Ap. Claudius, he secured permission to celebrate his triumph for his victory over the Allobroges in 62-61 (Cic. Att. 4.18.4; QF 3.4.6; Dio 39.65; cf. Pis. 58). See Degrassi 84f., 566." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5204> rdfs:label "Post Assertion Note: #5204" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-54, Promagistrates; cf. Cic. Pis. 58." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5153> rdfs:label "Post Assertion Note: #5153" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-54, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5097> rdfs:label "Post Assertion Note: #5097" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-54, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5057> rdfs:label "Post Assertion Note: #5057" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-64, Promagistrates; and Lübker p. 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5021> rdfs:label "Post Assertion Note: #5021" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-54, Promagistrates; cf. Cic. Flacc. 102. Vatinius refused to recognize the validity of the supplicationes for his victory in Gaul (Schol. Bob. 149-150 StangI, on Cic. Vat. 30). See Lilbker 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4979> rdfs:label "Post Assertion Note: #4979" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor in Transalpine Gaul (see 62-61, Promagistrates). Metellus Celer was to succeed him (see above, Consuls), but since he apparently lost his province it is probable that Pomptinus is Caesar's immediate predecessor. It is uncertain when he returned to Rome to demand his triumph (Cic. Att. 1.19.2; cf. Prov. Cons. 32). See59-54, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4952> rdfs:label "Post Assertion Note: #4952" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Transalpine Gaul. See 62, Promagistrates; and Lübker 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4916> rdfs:label "Post Assertion Note: #4916" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor (his title is not preserved) of Transalpine Gaul, where in 62 and 61 he checked and repressed a rebellion of the Allobroges (Cic. Prov. Cow. 32; Dio 37.47-48; 39.65.1-2; Liv. Per. 103; Schol. Bob. 149-150 Stangl). See Lübker 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4850> rdfs:label "Post Assertion Note: #4850" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aided in the arrest of the Allobrogian envoys, and the capture of the letters which incriminated the Catilinarian conspirators (Cic. Cat. 3.5 and 14; Flacc. 102; Sall. Cat. 45; cf. Cic. Prov. Cons. 32). See Lübker 839." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4558> rdfs:label "Post Assertion Note: #4558" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Crassus against Spartacus (Frontin. Str. 2.4.7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10187> rdfs:label "Post Assertion Note: #10187" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Allobrogibus. MRR II.225, Itgenshorst no. 259, Rich no. 259." .
