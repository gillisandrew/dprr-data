<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6391> rdfs:label "Post Assertion Note: #6391" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded a division of Sextus Pompey's fleet at Naulochus (App. BC 5.105-106) and surrendered after the battle." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6340> rdfs:label "Post Assertion Note: #6340" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A freedman of Pompey, appointed with Demochares to command of the fleet in succession to Menodorus and Menecrates (App. BC 5.84; cf. Suet. Aug. 16, praefectus; Dio 48.47). Sextus Pompey also sent him on a mission to Africa (Dio 48.48.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10300> rdfs:label "Post Assertion Note: #10300" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.187, 195 (MRR lists Apollophanes as legatus but admits that this naval commander's title is not preserved, Suolahti has praefectus classis)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10299> rdfs:label "Post Assertion Note: #10299" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.187, 195 (MRR lists Apollophanes as legatus but admits that this naval commander's title is not preserved, Suolahti has praefectus classis)." .
