	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7517> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5884> ;
