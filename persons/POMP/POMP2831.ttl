<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> rdfs:label "Secondary Source: Suolahti 1955" ;
	a dprr:SecondarySource ;
	dprr:hasName "Suolahti" ;
	dprr:hasBiblio "Suolahti, J., The junior officers of the Roman army in the Republican period : a study on social structure. Helsinki : Suomalainen Tiedeakatemia, 1955." ;
	dprr:hasAbbreviation "Suolahti 1955" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6342> rdfs:label "Post Assertion Note: #6342" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An officer, Legate or Prefect, under Sextus Pompey in command Of the fleet that fought and damaged that of Calvisius and Menodorus off Cumae (App. BC 5.81-84; Dio, 48.46.5-6; see above, Promagistrates, on Calvisius; and below, on Menodorus). Menecrates was drowned in the engagement (App.; Dio)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6312> rdfs:label "Post Assertion Note: #6312" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 40, and 35, Legates, Lieutenants." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6288> rdfs:label "Post Assertion Note: #6288" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A freedman Legate or Prefect in the fleet of Sextus Pompey, prominent with Menodorus (Menas) in harrying the coasts of Italy and cutting off supplies by sea (Vell. 2.73.3; Plut. Ant. 32.1; App. BC 5.83, end; cf. Flor. 2.18.2; Plin. NH 35.200; Dio 48.17-19). They incited Sextus Pompey against L. Staius Murcus (Vell. 2.77.3; App. BC 5.70; see Promagistrates, on Murcus)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10296> rdfs:label "Post Assertion Note: #10296" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.178, 183, 189 (MRR lists Menecrates as legatus or prefect, Suolahti has praefectus classis)." .
