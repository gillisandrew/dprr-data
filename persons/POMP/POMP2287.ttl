<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9267> rdfs:label "Post Assertion Note: #9267" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The list of senators in a dated inscription of this year (SIG(3) 747) provides good evidence for the names of a group of ex-magistrates, although it is not wholly conclusive because of the additions to the Senate by the reforms of Sulla." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8793> rdfs:label "Post Assertion Note: #8793" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 753, footnote 423" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5020> rdfs:label "Post Assertion Note: #5020" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Africa (Cic. Cael. 73-74). This is the latest year he may have remained in Africa. See 58, Promagistrates; D.-G. 4.323, no. 14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4978> rdfs:label "Post Assertion Note: #4978" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 62-61, Promagistrates. The duration of his term as governor in Africa remains uncertain. See D.-G. 4.323, no. 14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4951> rdfs:label "Post Assertion Note: #4951" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Africa (Cic. Cael. 73; see 62, Promagistrates). See D.-G. 4.323, no. 14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4915> rdfs:label "Post Assertion Note: #4915" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Africa (Cic. Cael. 73). See R-G. 4.323, no. 14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4849> rdfs:label "Post Assertion Note: #4849" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to guard Capua and its gladiatorial schools against the Catilinarian conspirators (Sall. Cat. 30.5). See D.–G. 4.323, no. 14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4490> rdfs:label "Post Assertion Note: #4490" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
