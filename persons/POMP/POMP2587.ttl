	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. He held command of the half of Caesar's fleet which was based on Messana, and was surprised and burned by C. Cassius and the Syrian squadron of Pompey's fleet (Caes. BC 3. 10 1)." .
