<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7630> rdfs:label "Post Assertion Note: #7630" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. 75, 74 (MRR 2.100). Refer also to SIG(3) 1125, dated by Cichorius (RS 187) to the early first century, a dedication by him and his brothers A. Pompeius (4) and Sex. Pompeius (16) at Eleusis." ;
	dprr:hasID 7630 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4397> rdfs:label "Post Assertion Note: #4397" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably served under Iuncus, either as Quaestor or as Legate, and was active in organizing Bithynia in late 75 or early 74 (Fest. 320L, and see above, Promagistrates, on Iuncus; D.-G. 4.321, no. 12)." ;
	dprr:hasID 4397 .
