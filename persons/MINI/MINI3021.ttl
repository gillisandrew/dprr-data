<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6653> rdfs:label "Post Assertion Note: #6653" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Author of a law defining the status of children of marriages between Romans and non-Romans (Gaius 1.78-80, FIRA 2.24; Ulpian 5.8, FIRA 2.268). Since it applied to Latins Niccolini (FTP 424) is inclined to date it before 90 B. C." ;
	dprr:hasID 6653 .
