<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7294> rdfs:label "Post Assertion Note: #7294" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 59. In MRR 2.179, Aediles, delete this entry, as the reference is to C. Sentius Saturninus (see below); at 2.188, Praetors, delete the cognomen Saturninus and the reference to Cic. Planc. 19; at 2.197, Promagistrates, delete the cognomen Saturninus. See Syme, Historia 13, 1964, 111, 121-122, and on the Sentii, RP 2.582-604; Shackleton Bailey, Studies 14-15. This Appuleius may be L. Appuleius L. f. Ser. listed in Joseph. AJ 14.220.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5054> rdfs:label "Post Assertion Note: #5054" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (Cic. Planc. 28 and 99, praetor, cf. 19; Schol. Bob. 153 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4996> rdfs:label "Post Assertion Note: #4996" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Planc. 19. See 58, Promagistrates." .
