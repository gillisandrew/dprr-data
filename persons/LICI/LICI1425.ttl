<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8585> rdfs:label "Post Assertion Note: #8585" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 736" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2800> rdfs:label "Post Assertion Note: #2800" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in command of Rhizon and Olcinium in Illyria by Anicius (Liv. 45.26.2). See 169, Legates, and above, Ambassadors." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2799> rdfs:label "Post Assertion Note: #2799" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See above, Praetors; and 168, Legates, and note 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2796> rdfs:label "Post Assertion Note: #2796" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Thrace to return to King Cotys his son and the other Thracian hostages (Liv. 45.42.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2774> rdfs:label "Post Assertion Note: #2774" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 168, note 1, and below on Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2772> rdfs:label "Post Assertion Note: #2772" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Provinces Liv. 45.16.3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2755> rdfs:label "Post Assertion Note: #2755" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Rome by Anicius to announce the subjugation of Illyria (Liv. 45.3.1-2, in an annalistic notice; see no. e)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2754> rdfs:label "Post Assertion Note: #2754" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer has shown (RE) that two men of this name held office about this time. The Licinius Nerva who was active in Illyria in 168 is probably not to be identified with the Praetor of 167, who was sent to Spain, but with the Legate who appears in Illyria and Thrace in that year (see 167, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2516> rdfs:label "Post Assertion Note: #2516" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Both attacked Manlius Vulso for his mismanagement in Istria in 178 and proposed to revoke the prorogation of his command (Liv. 41.6.1-3, and 7.4-10). See Lübker no. 16." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2515> rdfs:label "Post Assertion Note: #2515" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The praenomen is not preserved, but the date fits well with the careers of either Aulus or Gaius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2511> rdfs:label "Post Assertion Note: #2511" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "As they were in office at the end of the consular year 178, they are to be listed in 177 (cf. Niccolini, FTP 122)." .
