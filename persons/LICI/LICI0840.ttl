	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1312> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1310> ;
	dprr:hasPosition 5 ;
	dprr:hasOriginalText "C. Licinius (Varus ?) (12, cf. 174)" ;
