<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1746> rdfs:label "Primary Source Reference: #1746" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Sen. dial. X de brev. vit. 17.6" ;
	dprr:hasID 1746 ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1676> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1312> rdfs:label "Post Assertion Note: #1312" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These men, defined by Livy as maiores natu, were sent to Carthage with Rome's ultimatum (Liv. 21.18.1, cf. 21.19.6, and 20.9; Dio fr. 55.10; Zon. 8.22; cf. Polyb. 3.20.6 and 9, and 33.1-4, and 40.2; Frontin. Str. 1.11.4; Sil. Ital. 2.1-390; App. Ib. 13)." ;
	dprr:hasID 1312 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1310> rdfs:label "Post Assertion Note: #1310" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The term maiores natu favors identifying Licinius with the Consul of 236 even though he is listed after the Consuls of 219. Otherwise he would be an unknown ex-Praetor, possibly the father of P. Licinius Crassus, the Consul of 171 (Münzer RE)." ;
	dprr:hasID 1310 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1676> rdfs:label "Post Assertion: #1676" ;
	a dprr:PostAssertion ;
