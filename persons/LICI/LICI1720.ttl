<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7469> rdfs:label "Post Assertion Note: #7469" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. See MRR 1.540. If he was removed from the Senate by the censors of 115 at the same time as C. Licinius Geta (Liv. Per. 62), as suggested by Sumner (Orators 75, see the stemma, 76), his tribunate may be dated closely with that of L. Calpurnius Bestia (23) to ca. 120 (MRR 1.524).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3437> rdfs:label "Post Assertion Note: #3437" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tribune in the general period of Bestia's career (ca. 120-110; Cic. Brut. 129; Niccolini, FTP 417).{541}" .
