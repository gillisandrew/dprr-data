	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 27.21.5 Provinces 27.22.3." ;
	dprr:hasID 1678 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1606> rdfs:label "Post Assertion Note: #1606" ;
