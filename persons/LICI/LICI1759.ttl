<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9009> rdfs:label "Post Assertion Note: #9009" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 746, footnote 242" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3596> rdfs:label "Post Assertion Note: #3596" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Held command, probably as Propraetor ({Gr}, Diod.; praetorii exercitus, Flor.; see 104, Praetors) in Sicily against the slaves (Diod. 36.8.1-8; Flor. 2.7.10-11, who reverses the order of Lucullus and his successor Servilius). He was accused of peculation by an Augur named Servilius, and went into exile (Diod. 36.8.5, and 9.1; Plut. Luc. 1.1; see 102, Praetors, on Servilius)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3556> rdfs:label "Post Assertion Note: #3556" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Received command against the slaves at Capua who revolted under Minucius (Diod. 36.2.2-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3555> rdfs:label "Post Assertion Note: #3555" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Lucullus' date is indicated by the succession of magistrates in Sicily during the second revolt of the slaves. See 103, Promagistrates." .
