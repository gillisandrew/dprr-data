	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/12> ;
	dprr:hasNoteText "Münzer 1920:243 f.; Gruen 1968:128." .
<http://romanrepublic.ac.uk/rdf/entity/PersonNote/1218> rdfs:label "Person Note: #1218" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Dedikation einer kleinen Kultanlage für Bona Dea, die wegen fehlendem Volksbeschluß für ungültig erklärt wurde (123; Cicero)." .
<http://romanrepublic.ac.uk/rdf/entity/PersonNote/1217> rdfs:label "Person Note: #1217" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/10> ;
	dprr:hasNoteText "Cic. domo 136, Brut. 160; Liv. per. 63, Asc. 45 f. C (Freispruch, Verurteilung); Plut. q. R. 83; Dio 26, fr. 87,3 Bossevain (85 Dindorf); Oros. 5,15,22; Obseq. 37, Zon. 7,8 (ohne Namen)." .
