	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Auseinandersetzung mit dem Flamen Martialis (Nr. 3395) über die Frage auswärtiger Missionen (131). Trotz der Ablehnung der pontifikalen Mult gegen den Flamen in dessen provocatio ad populum übernimmt der Konsul und Pontifex maximus das Kriegskommando." ;
	dprr:hasID 1291 .
