<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2516> rdfs:label "Post Assertion Note: #2516" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Both attacked Manlius Vulso for his mismanagement in Istria in 178 and proposed to revoke the prorogation of his command (Liv. 41.6.1-3, and 7.4-10). See Lübker no. 16." ;
	dprr:hasID 2516 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2515> rdfs:label "Post Assertion Note: #2515" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The praenomen is not preserved, but the date fits well with the careers of either Aulus or Gaius." ;
	dprr:hasID 2515 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2511> rdfs:label "Post Assertion Note: #2511" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "As they were in office at the end of the consular year 178, they are to be listed in 177 (cf. Niccolini, FTP 122)." ;
	dprr:hasID 2511 .
