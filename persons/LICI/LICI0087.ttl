	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sought to force a distribution of land by impeding the levy, but was prevented by his colleagues (Liv. 2.43.3-4, and 44.1; Dion. Hal. 9.1.3-2.2)." ;
	dprr:hasID 121 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/120> rdfs:label "Post Assertion Note: #120" ;
