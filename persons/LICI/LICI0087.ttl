	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Dion. Hal. gives the name Sicilius, emended to Icilius by Sydburg and Jacoby." ;
	dprr:hasID 120 .
