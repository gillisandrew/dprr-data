<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8939> rdfs:label "Post Assertion Note: #8939" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 736, footnote 103" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2808> rdfs:label "Post Assertion Note: #2808" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election and provinces: Liv. 45.44.2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2751> rdfs:label "Post Assertion Note: #2751" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They returned to give a critical report on the military situation in Greece and Macedonia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2720> rdfs:label "Post Assertion Note: #2720" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "No title is recorded for any of these three officers, who may therefore, like Popillius, have been Tribunes of the Soldiers." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2719> rdfs:label "Post Assertion Note: #2719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chosen by the Consul Servilius at the request of the Consul-elect Aemilius Paullus to investigate military conditions\n     in Greece and Macedonia (Liv. 44.18.5-6; see 168, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2655> rdfs:label "Post Assertion Note: #2655" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Crete to secure additional auxiliary troops for Licinius' army (Liv. 42.35.7). On Postumius, see Münzer, APF 213ff.; Lübker no. 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2516> rdfs:label "Post Assertion Note: #2516" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Both attacked Manlius Vulso for his mismanagement in Istria in 178 and proposed to revoke the prorogation of his command (Liv. 41.6.1-3, and 7.4-10). See Lübker no. 16." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2515> rdfs:label "Post Assertion Note: #2515" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The praenomen is not preserved, but the date fits well with the careers of either Aulus or Gaius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2511> rdfs:label "Post Assertion Note: #2511" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "As they were in office at the end of the consular year 178, they are to be listed in 177 (cf. Niccolini, FTP 122)." .
