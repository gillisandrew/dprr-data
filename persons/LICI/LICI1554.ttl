<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3048> rdfs:label "Post Assertion Note: #3048" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 143, Praetors, and note 2: possibly Praetor this year." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3023> rdfs:label "Post Assertion Note: #3023" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His Quaestor (see below) crushed a rising in Macedonia led by a pretender (Varro RR 2.4.1-2; Liv. Per. 53; Eutrop. 4.15; cf. Grueber, CRRBM 1.515; Cesano, Stud. Num. 1.211)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3022> rdfs:label "Post Assertion Note: #3022" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The order of events in Livy (Per. 53) leaves uncertain whether Licinius was Praetor in 143 or 142, or in command in Macedonia during both years.{474}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10132> rdfs:label "Post Assertion Note: #10132" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/31> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph? ex Macedonia de Pseudophilippo. Itgenshorst no.212c (triumphus incertus, 142?). Not listed in MRR or Rich." .
