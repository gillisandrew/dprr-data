<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7688> rdfs:label "Post Assertion Note: #7688" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. or pr. before 175. Cato the Elder urged the passage of a Lex Maevia, mentioning a rex Seleucus, who died in 176 or 175 (Priscian 12.17, Malcovati, ORF(2) 92, no. 228). See Wiseman, CQ 14, 1964, 124.\n" ;
	dprr:hasID 7688 .
