	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus pro praetore in Asia under Lucullus, who protected Mysia Abbaeitis and Phrygia Epiktetos during the war with Mithridates (CIL 12.2.743-ILS 37; see Magic, Roman Rule in Asia Minor 2.1208, note 15; and below, additional note, on the date)." .
