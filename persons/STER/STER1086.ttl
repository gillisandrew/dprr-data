<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2056> rdfs:label "Post Assertion Note: #2056" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Hephaestia, Thasos, and Thrace (Polyb. 18.48.2; Liv. 33.35.2; Plut. Flam. 12.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2050> rdfs:label "Post Assertion Note: #2050" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Ten Legati were appointed to assist Flamininus in arranging the peace with Philip and the settlement in Greece (Polyb. 18.42.5; Liv. 33.24.7, cf. 30.1, and 35.1-2). The following are known, and since Livy nowhere lists them in an official order, they are given in alphabetical order." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2044> rdfs:label "Post Assertion Note: #2044" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 197, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2021> rdfs:label "Post Assertion Note: #2021" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain; see 199. Returned late in 197 or early in 196, in time to become a Legate to Macedonia in 196 (Liv. 33.37.3-4; see 196)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1998> rdfs:label "Post Assertion Note: #1998" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued as Proconsul in Farther Spain; see 197." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1974> rdfs:label "Post Assertion Note: #1974" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Given command by plebiscite as Proconsul in Farther Spain (Liv. 31.50.11; cf. 33.27.3-4)." .
