<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3050> rdfs:label "Post Assertion Note: #3050" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Apparently he remained in Spain and served under Servilianus against the Lusitani (Liv. Oxy. Per. 54, 140 B.C.). Note however the name of Oppius, a Tribune of the Soldiers who was killed while serving under Pompeius at Numantia in Hither Spain (App. Ib. 78). Possibly the names have been confused. See 140, Tribunes of the Soldiers." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3032> rdfs:label "Post Assertion Note: #3032" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Metellus Macedonicus in Hither Spain (Val. Max. 3.2.21; see 142 and 141, Legates)." .
