<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5775> rdfs:label "Post Assertion Note: #5775" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commander of a portion of the Pompeian fleet based on Africa, and active in Sardinia (Bell. Afr. 64, and 98; Dio 42.56.3; cf. Cic. Att. 11.17A.3)." ;
	dprr:hasID 5775 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5615> rdfs:label "Post Assertion Note: #5615" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Brought a small fleet from Dyrrachium, capturing a ship at Messana, and reinforced the Massilian fleet against Caesar (Caes. BC 2.3-4, and 7; Schol. Bern. on Lucan 3.524, p. 115 Usener)." ;
	dprr:hasID 5615 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10461> rdfs:label "Post Assertion Note: #10461" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 5.139. Named alongside C. Fannius, Libo, Cassius Parmensis, Antistius, Saturninus, and Thermus as a senior and longstanding associate of Sextus Pompey, all in the East in 35. Following Sextus' downfall, all surrender to Antony." ;
	dprr:hasID 10461 .
