<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6507> rdfs:label "Post Assertion Note: #6507" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He held command of the squadron of Antony's fleet which was defeated by Agrippa in the spring of 31, thus enabling him to capture Patrae (Dio 50.13.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6338> rdfs:label "Post Assertion Note: #6338" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A commander, Legate or Prefect, in Sextus Pompey's fleet (Grueber, CRRBM 2.564f.), who left him for Antony in 35 (App. BC 5.139)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10298> rdfs:label "Post Assertion Note: #10298" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.203 (MRR lists Nasidius as legatus but admits that this naval commander's title is not preserved, Suolahti has praefectus classis)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10297> rdfs:label "Post Assertion Note: #10297" ;
	a dprr:PostAssertionNote ;
