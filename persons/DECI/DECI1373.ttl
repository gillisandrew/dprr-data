<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8178> rdfs:label "Post Assertion Note: #8178" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., amb. 168. See the note on C. Popillius Laenas (18), in MRR 1.430, and below.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2750> rdfs:label "Post Assertion Note: #2750" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Egypt where Popillius by a summary demand compelled Antiochus IV to cease hostilities and retire from Egypt (Polyb. 29.2.1-4, and 27; Liv. 44.19.13, and 29.1-5; 45.10-12.8, and 13.1; cf. Cic. Phil. 8.23; Vell. 1.10.1-2; Val. Max. 6.4.3; Iustin. 34.3.1-4; Dio fr. 68; Zon. 9.25; see Otto, ABAW 11 [1934] 80ff.; Swain, CPh 39 [1944] 89-94). They also ordered Ptolemy to send a hostile Rhodian to Rome (Polyb. 30.9.2). On Popillius, see Lübker no. 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2703> rdfs:label "Post Assertion Note: #2703" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 44.16.7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2700> rdfs:label "Post Assertion Note: #2700" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 43.11.7 Provinces and armies Liv. 43.11.8, 12.1-11, 15.2-3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2655> rdfs:label "Post Assertion Note: #2655" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Crete to secure additional auxiliary troops for Licinius' army (Liv. 42.35.7). On Postumius, see Münzer, APF 213ff.; Lübker no. 3." .
