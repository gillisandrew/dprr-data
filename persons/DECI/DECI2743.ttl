<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6631> rdfs:label "Post Assertion Note: #6631" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Held the tribunate after Munatius Plancus Byrsa in 52 and before 44 (Cic. Phil. 13.27; cf. 11.13)." ;
	dprr:hasID 6631 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6105> rdfs:label "Post Assertion Note: #6105" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. One of Antony's officers who was captured by Octavian and released as a hint that accommodation was possible (App. BC 3.80, #, cf. Cic. Phil. 11.13; 13.27)." ;
	dprr:hasID 6105 .
