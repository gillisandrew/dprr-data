<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1663> rdfs:label "Post Assertion Note: #1663" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Marcellus against Hannibal at Canusium (Liv. 27.14.6-15).{288}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1662> rdfs:label "Post Assertion Note: #1662" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE s. v. \"Claudius,\" no. 220, and \"Decimius,\" no. 8) considers the battle described in Liv. 27.14-15 an invention. It may however be a skirmish which was magnified in importance. In any case the names of the officers involved are likely to be authentic." .
