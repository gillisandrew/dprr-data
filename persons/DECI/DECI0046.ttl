	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent at Menenius' request by the Plebs to the Senate to conclude the agreement (Dion. Hal. 6.88.4)." .
