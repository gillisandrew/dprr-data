	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 32.7.13; Nep. Cato 1.3. On Cato, see D.- G., no. 15; Lübker, no. 4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1860> rdfs:label "Post Assertion Note: #1860" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Quinctilius Varus, and fell in battle against Mago (Liv. 30.18.14-15). See note 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1859> rdfs:label "Post Assertion Note: #1859" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE) considers the death of this Tribune fictitious (see above, note 3), and would identify him with the Praetor of 198. But the Tribune and the Praetor need not be the same man." .
