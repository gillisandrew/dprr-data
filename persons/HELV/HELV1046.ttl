<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2267> rdfs:label "Post Assertion Note: #2267" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Manlius Vulso in Asia (Liv. 38.14.4-6, 20.9, 22.1, and 23.4; Polyb. 21.34.3-4)." .
