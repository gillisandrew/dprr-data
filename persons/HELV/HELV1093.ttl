<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7782> rdfs:label "Post Assertion Note: #7782" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He served as a tribune of the soldiers under Marcellus against Hannibal at Canusium (Liv. 27.12.16). See Suolahti, Junior Officers 308, 405. See below, on M. Licinius (20).\n" ;
	dprr:hasID 7782 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2111> rdfs:label "Post Assertion Note: #2111" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Sipontum (Liv. 34.45.3)." ;
	dprr:hasID 2111 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2079> rdfs:label "Post Assertion Note: #2079" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain (Act. Tr. Tol.). Won a victory over the Celtiberians while returning to Rome, and celebrated an ovatio (Liv. 34.10.1-5; Act. Tr., Degrassi 78f., 338f., 552)." ;
	dprr:hasID 2079 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2078> rdfs:label "Post Assertion Note: #2078" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "At 34.10.5-6 Livy mistakenly refers to Minucius as Helvius' successor. See Q. Fabius Buteo in 196, and Ap. Claudius Nero this year." ;
	dprr:hasID 2078 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2041> rdfs:label "Post Assertion Note: #2041" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain (see 195, Promagistrates), where he was detained by illness (Liv. 34.10.5-6)." ;
	dprr:hasID 2041 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2011> rdfs:label "Post Assertion Note: #2011" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Faced a serious revolt (Liv. 33.21.7-8; App. Ib. 39; see 195)." ;
	dprr:hasID 2011 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2010> rdfs:label "Post Assertion Note: #2010" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Six Praetors were elected this year for the first time (Liv. 32.27.6)." ;
	dprr:hasID 2010 .
