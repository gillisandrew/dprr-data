	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/2019> rdfs:label "Primary Source Reference: #2019" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Vell. II 2.2f." ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1947> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1609> rdfs:label "Post Assertion Note: #1609" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Opposed the election of Q. Fulvius Flaccus, who was Dictator and presiding officer, to the consulship of 209 (Liv. 27.6.1-11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1608> rdfs:label "Post Assertion Note: #1608" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The election took place at a time when it was feared a Carthaginian armada might still sail. These Tribunes therefore are probably the Tribunes of 210, not those of 209 who would enter office in December, and the Consuls in March." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1947> rdfs:label "Post Assertion: #1947" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/962> ;
