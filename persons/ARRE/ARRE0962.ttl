	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1609> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1608> ;
	dprr:hasOriginalText "C. Arrenius (1)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
