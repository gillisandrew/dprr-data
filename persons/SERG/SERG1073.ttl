<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1929> rdfs:label "Post Assertion Note: #1929" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "In both passages in Livy the reading of Bambergensis is Plancus, a cognomen otherwise unattested in the Sergian gens: hence the emendation Plautus." .
