<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7511> rdfs:label "Post Assertion Note: #7511" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 90. He held in his ergastulum in the Ager Gallicus the young M. Aurius of Larinum, who had been captured in the Social War (Cic. Cluent. 21, qui inter sicarios damnatus est). The praenomen shows that he did not belong to the patrician line. (RS, MS-RP 1.288)\n" .
