<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/621> rdfs:label "Primary Source Reference: #621" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Phil. II 27" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/612> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/600> rdfs:label "Primary Source Reference: #600" ;
	a dprr:PrimarySourceReference ;
