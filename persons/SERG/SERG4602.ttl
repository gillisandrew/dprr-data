<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7577> rdfs:label "Post Assertion Note: #7577" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator. One of the proscribed, restored by M. Antonius. Before the Actium campaign he was the only senator to vote against declaring him a public enemy (App. BC 4.45), or stripping him of his powers (Dio 50.4.3, and 6.1). (RS, MS-RP 1.288; TJC)\n" .
