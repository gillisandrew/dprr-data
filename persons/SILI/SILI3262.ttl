<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7781> rdfs:label "Post Assertion Note: #7781" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 43. See MRR 2.496. On the possibility that his name was Selicius, see Syme, Historia 13, 1964, 122123-RP 2.601, citing Cic. Att. 13.4, and CIL 12.294-299.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6959> rdfs:label "Post Assertion Note: #6959" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/4> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A prominent senator, juror in the trial of the tyrannicides in 43, who openly voted for acquittal (Plut. Brut. 27.3; App. BC 3.95; 4.27; IDio 46.49.5)." .
