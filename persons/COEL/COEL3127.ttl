	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6802> ;
	dprr:hasOriginalText "? C. Coelius (13) Caldus" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/16> ;
	dprr:hasDateStart -62 ;
	dprr:hasDateSourceText "ca. 80, before 61" ;
