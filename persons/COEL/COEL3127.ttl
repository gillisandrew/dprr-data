<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/7557> rdfs:label "Post Assertion: #7557" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
	dprr:isDateStartUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/3127> ;
