<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7644> rdfs:label "Post Assertion Note: #7644" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Son of the consul of 94. A praetor of uncertain date, probably also a promagistrate, since he is termed IMP on the coins of his nephew (RE no. 14). See Gruen, LGRR 164, note 2. See MRR 2.485, and Index, 549.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6803> rdfs:label "Post Assertion Note: #6803" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Decemvir before 80 (Grueber, CRRBM 1.475; cf. Bardt 30). See above, Augurs." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6802> rdfs:label "Post Assertion Note: #6802" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Augur before 61 (Grueber, CRRBM 1.475; cf. Bardt 23). See below, Quindecimviri sacris facuindis. Probably about 80 B. C." .
