<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7411> rdfs:label "Post Assertion Note: #7411" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus? or Prefect 87. See MRR 2.51, with the name P. Caelius. Change the name of this aged and ailing senator with a faithful dog to the one given above, and in MRR 2.51 add references to Plin. NH 8.144, Caelium senatorem; Plut. Soll. anim. 13.7, KA8oS; Aelian NA 7.10, #; see Syme, CPh 50, 1955, 134; Badian, Studies 90-96.\n" ;
	dprr:hasID 7411 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4051> rdfs:label "Post Assertion Note: #4051" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in command of Placentia by Octavius. Aged and ailing, he committed suicide rather than be captured by the forces of Cinna (Val. Max. 4.7.5)." ;
	dprr:hasID 4051 .
