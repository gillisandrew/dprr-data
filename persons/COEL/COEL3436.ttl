<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7663> rdfs:label "Post Assertion Note: #7663" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 51. Shackleton Bailey (CLF 1.404) reads the name as C. Coelius, not Caelius, in Fam. 8.8.7-8, and distinguishes him from C. Caelius Rufus, leg. pro pr. in Achaea, and tr. pl. desig. (on him, see above).\n" ;
	dprr:hasID 7663 .
