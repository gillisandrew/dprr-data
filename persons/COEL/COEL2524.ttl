	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably remained as Proquaestor in Cilicia until Sestius came to his province (see 50, Quaestors, and below, Promagistrates, on Sestius)." ;
