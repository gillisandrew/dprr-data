<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5452> rdfs:label "Post Assertion Note: #5452" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Cicero in Cilicia (Cic. Fam. 2.19; Att. 6.2.10, 4.1, and 5.3). Cicero left him in command of the province when he returned to Rome (Cic. Fam. 2.15.4; cf. Att. 6.6.3-4; 7.1.6)." ;
	dprr:hasID 5452 .
