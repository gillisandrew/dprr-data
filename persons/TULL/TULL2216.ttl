<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9104> rdfs:label "Post Assertion Note: #9104" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 753, footnote 433" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7573> rdfs:label "Post Assertion Note: #7573" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aed. pl. 65. In MRR 2.158, refer also to Cic. Att. 1.1.3. Procos. Asia 61-58. He was honored at Claros (Bull. Epig. 1958, no. 390; cf. AJA 62, 1958, 98; and on honors to him and others of the family at Samos, Bull. Epig. 1958, no. 390).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5487> rdfs:label "Post Assertion Note: #5487" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Cicero in Cilicia (Cic. Att. 5.21.6 and 9; 6.3.2-3, and 4.1; 7.1.1; Fam. 2.15.4; 16.1, and 3, and 4, and 5, and 6, prescripts)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5426> rdfs:label "Post Assertion Note: #5426" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under his brother in Cilicia; left in charge of eastern Cilicia while Marcus returned to winter in the western portion (Cic. Att. 5.1; 5.10.5, 11.4, 20.5, and 21.6 and 9 and 15; 6.2.1-2; Fam. 15.4.8-10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5370> rdfs:label "Post Assertion Note: #5370" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Caes. BG 7.90.7; Cic. Mil. 102; Schol. Bob. 124 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5309> rdfs:label "Post Assertion Note: #5309" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul. The camp at Aduatuca which was under his command was endangered when his failure to obey orders led to an attack by the Sugambri from across the Rhine (Caes. BG 6.32.7, and 35-42; Cic. Epp. fr. in GLK 1.126; cf. Dio 40.32.4-5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5267> rdfs:label "Post Assertion Note: #5267" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Cic. Att. 4.14.2; QF 2.10.4-5; 2.123.9, passim; Fam. 1.9.21). He shared in the expedition to Britain (Cic. Att. 4.15.10, cf. 17.6, and 18.5; QF 2.13.2, and 15.1; 3.1.10, and 25; 3.3.1), and went into winter-quarters among the Nervii, where he bravely sustained a severe siege, and probably saved the situation for Caesar in northern Gaul (Caes. BG 5.24.2, 38-52; Cic. Att. 4.19.2; QF 3.8.2; Liv. Per. 106; Plut. Caes. 24.2-3; App. Celt. 21; Polyaen. 8.23.6; Dio 40.7- 10; Oros. 6.10.2-9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5166> rdfs:label "Post Assertion Note: #5166" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey (see Promagistrates), in Sardinia whence he returned in June (Cic. QF 2.2.1 and 4, 3.7, 4.7, 5.3, and 6; Fam. 1.9.8-10; Scaur. 39)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5110> rdfs:label "Post Assertion Note: #5110" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey; served in Sardinia beginning in the autumn of 57 (Cic. QF 2.1.3; cf. 2.2.1, 3.7, 4.7, and 5.3; Fam. 1.9.9; Scaur. 39)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5059> rdfs:label "Post Assertion Note: #5059" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia, whence he returned in May (see 6 1, Promagistrates; Cic. QF 1.3; Att. 3.9.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5022> rdfs:label "Post Assertion Note: #5022" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (see 6 1, Promagistrates), whence he returned when his successor was sent in the spring of 58 (Cic. QF 1.1, and 2; Att. 2.6.2, and 15.4; Suet. Aug. 3.2; cf. Cic. Att. 3.9.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4980> rdfs:label "Post Assertion Note: #4980" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (see 61-59, Promagistrates; cf. Cic. QF 1. 1, and 2). On his administration, see Magie, Roman Rule in Asia Minor 1. 381-383; 2.1244, notes 12-14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4954> rdfs:label "Post Assertion Note: #4954" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (Cic. Div. 1.58; Att. 1.15.1; Planc. 100; Suet. Aug. 3.2; Macrob. Sat. 2.3.4). On his administration, see Cic. Att. 1.17.1, and 19.11; 6.6.3; Fam. 2.15.4; QF 1.1, and 2, esp. 1.1.2, on the prorogation of his command; Flacc. 33 and 49; Schol. Bob. 100 Stangl. See 60, and 59, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4895> rdfs:label "Post Assertion Note: #4895" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Planc. 95; cf. Att. 1.15.1, and 13.5. Crushed Catilinarian sympathizers in Bruttium (Oros. 6.6.7; cf. Dio 37.41). Presided at the trial of Archias (Cic. Arch. 3 and 32; Schol. Bob. 175 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4787> rdfs:label "Post Assertion Note: #4787" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. QF 1.2.7; Att. 1.4.1; Planc. 95." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4659> rdfs:label "Post Assertion Note: #4659" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He was absent from Rome in this and perhaps previous years (Cic. Att. 1.5.2and 8, cf. 8.1), hence Münzer conjectures that he held his quaestorship during this period (RE)." .
