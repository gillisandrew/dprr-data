<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/46> rdfs:label "Post Assertion Note: #46" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 2.19.1 (M. Manlius Tullus); Cic. Brut. 62; Dion. Hal. 5.52.1, and 57; 6.69.3; Chr. 354 (Cornuto et Longo); Fast. Hyd. (Camerino et Longo); so also Chr. Pasc.; Cassiod.; Zon. 7.13; Degrassi 88, 350f. Dion. Hal. records a war with Fidenae, and the suppression of a conspiracy in the city (as in 63 B.C.); and has Longus die at the Ludi Romani (5.52.1-57.5; Zon. 7.13)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/45> rdfs:label "Post Assertion Note: #45" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Note Fest. 180 L:...llius Tolerinus (RE no. 53)." .
