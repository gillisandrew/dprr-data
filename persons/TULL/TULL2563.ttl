	dprr:hasRelationshipReference <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/935> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/904> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/889> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/822> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/750> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/742> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/727> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/697> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/648> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/592> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/590> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/589> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/583> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/580> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/560> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/366> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/227> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1525> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1387> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1380> ;
