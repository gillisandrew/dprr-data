<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/284> rdfs:label "Post Assertion Note: #284" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "According to a doubtful story in Livy (3.65.1), these patrician consulars were coopted by the college of Tribunes." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/277> rdfs:label "Post Assertion Note: #277" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to negotiate with the plebeians who had seceded to the Aventine (Liv. 3.50.15-16; Ascon. 77 C)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/236> rdfs:label "Post Assertion Note: #236" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "In Fast. Cap. the names are preserved entire except Ca[p]itolin(us), and the filiation of Aternius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/235> rdfs:label "Post Assertion Note: #235" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Rep. 2.60; Liv. 3.31.5; Diod. 12.6.1; Fast. Cap.\n     ; Dion. Hal. 10.48.1; Plin. NH 7.101; Gell. 2.11.1; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; Degrassi 24f., 93, 364f. The Lex Aternia Tarpeia regulating payment of fines is dated to this consulship (Cic. Rep. 2.60; Gell. 11.1.2; Fest. 270 L; cf. Dion. Hal. 10.50.2; Plin. NH 18.11; 33.1.1; Rotondi 200)." .
