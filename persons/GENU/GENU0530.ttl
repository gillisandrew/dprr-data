<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/728> rdfs:label "Post Assertion Note: #728" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried, according to some annalists, a bill outlawing lending at interest (Liv. 7.42.1). Other plebiscites prohibited repetition of a magistracy within ten years, and the holding of more than one in the same year, and permitted both Consuls to be plebeians (Liv. 7.42.2; cf. App. BC 1.54; Tac. Ann. 6.16; Auct. Vir. Ill. 29.3; Zon. 7.25)." .
