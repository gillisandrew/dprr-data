<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/935> rdfs:label "Post Assertion Note: #935" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 10.1.1; Diod. 20.102.1; Fast. Cap. ([- - -C]n. f. Cn. n. Lentulus); Chr. 354 (Rufo et Adventinense); Fast. Hyd. (Lentulo et Abentesi); Chr. Pasc. ({Gr}); Cassiod.; see Degrassi 38f., 111, 424f. To this year are dated the colonies of Sora and Alba Fucens, the citizenship of Arpinum and Trebulanum, punishment for Frusino and the Hernici, and a minor expedition in Umbria (Liv. 10.1.1-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/934> rdfs:label "Post Assertion Note: #934" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "On Genucius' cognomen, see Fast. Cap. on 365, 363 and 362." .
