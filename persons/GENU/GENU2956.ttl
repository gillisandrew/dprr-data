	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praetor, at an uncertain but quite early date, who undertook a self-imposed exile rather than fulfil a portent that he should be king (Val. Max. 5.6.3; Plin. NH 11.123; Ovid Met. 15.565ff.; see RE 5.2565)." ;
