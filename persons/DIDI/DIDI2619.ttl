<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5915> rdfs:label "Post Assertion Note: #5915" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate in command of Caesar's fleet in Spain (Flor. 2.13.75). He was victorious over Attius Varus (see above), and was the one who sent Cn. Pompey's head to Caesar (Bell. Hisp. 37.2; Plut. Caes. 56.3; Flor. 2.13.75; App. BC 2.105; Dio 43.40.2), but fell in battle with the Lusitanians (Bell. Hisp. 40; cf. Dio 43.40.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5832> rdfs:label "Post Assertion Note: #5832" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar (see in 45, Flor. 2.13.75), who gave him command of a fleet against the Pompeians in Spain (Dio 43.14.2; cf. 45, Legates)." .
