<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2067> rdfs:label "Person Note: #2067" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Restauration (?) des nunmehrigen Apollo-Sosianus-Tempels am Marcellustheater und Ausschmückung mit einer Apollostatue und Niobegruppe (wohl nach 30 v. Chr.), die er sich während seiner syrischen Statthalterschaft in Seleukia (Kilikien) verschafft hatte." .
