<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2415> rdfs:label "Post Assertion Note: #2415" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fought successfully with the Corsicans and the Ilienses of Sardinia (Liv. 40.19.6-8, and 34.12-13). See Lübker no. 6." ;
	dprr:hasID 2415 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2414> rdfs:label "Post Assertion Note: #2414" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Mommsen (Str. 1.529) suggests that he, either in his praetorship or perhaps earlier as Tribune, was the M. Pinarius Rusca who proposed a Lex annalis (Cic. De Or. 2.261), but Nipperdey (Leg. Ann. 6) places the bill after the Lex Villia and refuses to identify the two Pinarii. See Niccolini, FTP 402." ;
	dprr:hasID 2414 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2409> rdfs:label "Post Assertion Note: #2409" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.18.2 Provinces and armies 40.18.3 and 5." ;
	dprr:hasID 2409 .
