	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The recently elected Pontifex who officiated at the dedication of a shrine of Libertas on the site of Cicero's house (Cic. Dom. 118 and 134-135 and 137; see L. R. Taylor, AJPh 63 [19421 396f.)." .
