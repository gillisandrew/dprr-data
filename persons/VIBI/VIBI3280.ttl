<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7478> rdfs:label "Post Assertion Note: #7478" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A senator, who was so injured in riots before Cicero's exile that he lost his life (Cic. Mil. 37). In Ascon. 32C, a report that he appeared in the disorders attending the death of Clodius is rightly rejected and the phrase inter quos C. Vibienus senator removed from the text (line 24).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6978> rdfs:label "Post Assertion Note: #6978" ;
