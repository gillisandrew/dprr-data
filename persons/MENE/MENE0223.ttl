	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/315> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/314> ;
	dprr:hasOriginalText "L. Menenius T. f. Agripp. n. Lanatus Pat. (16, cf. 10 and 18)" ;
