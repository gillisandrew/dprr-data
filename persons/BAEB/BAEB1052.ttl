	dprr:hasID 8430 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2238> rdfs:label "Post Assertion Note: #2238" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Wounded by Ligurians, he died at Massilia (Liv. 37.57.1-2; Oros. 4.20.24)." ;
	dprr:hasID 2238 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2237> rdfs:label "Post Assertion Note: #2237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 37.47.8 Provinces and armies Liv. 37.50.8-12." ;
	dprr:hasID 2237 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1868> rdfs:label "Post Assertion Note: #1868" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Scipio left him charge of the camp (Polyb. 15.4.1). He received the envoys, both Roman and Carthaginian, on their return from Rome (15.4.6). See above, Envoys, and Promagistrates." ;
	dprr:hasID 1868 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1865> rdfs:label "Post Assertion Note: #1865" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Carthage by Scipio to protest the violation of the armistice, and attacked on their return (Polyb. 15.2-3; Liv. 30.25; App. Lib. 34; Dio fr. 57.75; Zon. 9.13).{314}" ;
	dprr:hasID 1865 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1863> rdfs:label "Post Assertion Note: #1863" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The name Baebius is accepted in the text of Polyb. 15.1.3 by Büttner-Wobst. See Liv. 30.25.2, where it is also uncertain. This Baebius may be L. Baebius Dives, the Praetor of 189 (Münzer, RE)." ;
	dprr:hasID 1863 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1847> rdfs:label "Post Assertion Note: #1847" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Scipio apparently left him in charge of the camp pro praetore (Polyb. 15.4.1, {Gr}). See below, Legates." ;
	dprr:hasID 1847 .
