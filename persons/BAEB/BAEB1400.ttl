<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2751> rdfs:label "Post Assertion Note: #2751" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They returned to give a critical report on the military situation in Greece and Macedonia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2720> rdfs:label "Post Assertion Note: #2720" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "No title is recorded for any of these three officers, who may therefore, like Popillius, have been Tribunes of the Soldiers." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2719> rdfs:label "Post Assertion Note: #2719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chosen by the Consul Servilius at the request of the Consul-elect Aemilius Paullus to investigate military conditions\n     in Greece and Macedonia (Liv. 44.18.5-6; see 168, Legates)." .
