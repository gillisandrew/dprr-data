<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2790> rdfs:label "Post Assertion Note: #2790" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to assist Anicius in making a settlement in Illyria (Liv. 45.17.4, and 26.11-15)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2733> rdfs:label "Post Assertion Note: #2733" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cooperated with Paullus' army in Macedonia (Liv. 44.19.4, 21.3, 22.16, 30.1, 32.5-6, 35.8 and 13, and 46.3; Zon. 9.23), then secured the surrender of Perseus at Samothrace and brought him to Paullus (Liv. 45.5-6; Vell. 1.9.5; Plut. Aem. 26.1-5; Iustin. 33.2-5; Zon. 9.23). Cf. Fest. 188 L." .
