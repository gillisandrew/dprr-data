<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7921> rdfs:label "Post Assertion Note: #7921" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Promag. Sicily 209. His imperium in Sicily in Hiero's former kingdom was prorogued in 208 (Liv: 27.12.16, and 28.13-17).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1701> rdfs:label "Post Assertion Note: #1701" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to the wounded Consul Crispinus (Liv. 27.29.1-6). On Caesar, see above, Praetors." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1656> rdfs:label "Post Assertion Note: #1656" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Sicily (Liv. 27.7.12, and 16), with charge of Hiero's former realm (27.8.17).{287}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1602> rdfs:label "Post Assertion Note: #1602" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He appears at the beginning of the next year as Propraetor in Gaul (27.7.11; see note 1)." .
