	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commissioned by Otacilius to conduct the fleet back to Rome (Liv. 22.31.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1349> rdfs:label "Post Assertion Note: #1349" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Cincius is Hertz' emendation for the Mss readings circi and circa and Sura of the Editio Romana. Accepted by Conway and Walters, the name is not yet found in RE." .
