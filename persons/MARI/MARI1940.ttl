	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9050> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7059> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4084> ;
