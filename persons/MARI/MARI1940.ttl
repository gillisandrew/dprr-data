	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9051> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7059> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4099> ;
	dprr:hasPosition 2 ;
	dprr:hasOriginalText "? M. Marius Gratidianus (42)" ;
	dprr:hasOfficeXref "Pr. 85?" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
