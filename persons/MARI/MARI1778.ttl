<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9014> rdfs:label "Post Assertion Note: #9014" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "99? p. 746, footnote 249" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3640> rdfs:label "Post Assertion Note: #3640" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. Ib. 100; cf. Obseq. 44a." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3639> rdfs:label "Post Assertion Note: #3639" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Obsequens appears to place in 101 the pacification in Spain which Appian puts five years before the victory of Didius (in 97, Liv. Per. 70). Marius may have held the praetorship in 102 and continued as a promagistrate in 101, or, less probably, have been a Praetor in 101 and promptly succeeded by Dolabella in 100." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3609> rdfs:label "Post Assertion Note: #3609" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "As governor of a Spanish province, probably the Farther one, he subdued some Lusitanians with Celtiberian aid, and secured permission from the Senate to found a city for his allies (App. Ib. 100; cf. Obseq. 44a)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3608> rdfs:label "Post Assertion Note: #3608" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Appian dates Marius' action five years before the victory of Didius at Colenda, which probably took place in 97 (see 97, Promagistrates). Marius was probably the brother of the Consul who adopted his sister's son, M. Marius Gratidianus (Cic. Brut. 168; Leg. 3.36; Schol. Bern. on Lucan 2.173, p. 61 U)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/8015> rdfs:label "Post Assertion: #8015" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1778> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasProvinceOriginalExpanded "Hispania Ulterior" ;
	dprr:hasProvinceOriginal "HU" ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9014> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3609> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3608> ;
	dprr:hasOriginalText "M. Marius (22)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -102 ;
	dprr:hasDateSourceText "?" ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -102 .
