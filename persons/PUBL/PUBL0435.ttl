<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/556> rdfs:label "Post Assertion Note: #556" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Secured the conviction and execution of Manlius Capitolinus for treason (Liv. 6.19.5-7, cf. 18-20; Val. Max. 6.3.1; Plut. Cam. 36.5-7; Gell. 17.2.14, and 21.24; App. Ital. 9; Auct. Vir. Ill. 24; Zon. 7.24; cf. Diod. 15.35.3, who tells the story under 385). On the Lex Publilia de sponsu, see 327, Consuls." .
