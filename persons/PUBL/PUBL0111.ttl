<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/160> rdfs:label "Post Assertion Note: #160" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Secured passage of the bill to transfer elections of Tribunes to the Comitia Tributa and to increase their number to five (Liv. 2.55.10-58.2; Dion. Hal. 9.43-49; cf. Zon. 7.17; Rotondi 197). According to Diod. (11.68.7), the number was increased to four." ;
	dprr:hasID 160 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/156> rdfs:label "Post Assertion Note: #156" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed a bill to transfer the election of Tribunes from the Comitia Curiata to the Comitia Tributa (Liv. 2.56.1-5, cf. 55; Dion. Hal. 9.41-42.3)." ;
	dprr:hasID 156 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/155> rdfs:label "Post Assertion Note: #155" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "A praenomen, cf. Fast. Cap. for 400 and 399." ;
	dprr:hasID 155 .
