<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/2080> rdfs:label "Primary Source Reference: #2080" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Zon. 10 (5)" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2008> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1653> rdfs:label "Post Assertion Note: #1653" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed a bill to abrogate Marcellus' command (Liv. 27.20.11-21.4; Plut. Marc. 27). He is credited with the Lex Publicia de cereis (Macrob. Sat. 1.7.33). See Niccolini, FTP 98-100." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1652> rdfs:label "Post Assertion Note: #1652" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The inscription of C. Publicius Bibulus, Aedile of the Plebs (CIL 1(2).2.834), is in its present form a work of the late Republic (CIL, loc. cit.), but Tenney Frank has pointed out that the spelling Poplicio reveals that it is a clear case of restoration then (CPh 19 [1924] 78), and the inscription itself was much earlier. The aedileship however indicates that it cannot refer to this Tribune since the series of Aediles of the Plebs is known until 196 (Niccolini, FTP 99f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2008> rdfs:label "Post Assertion: #2008" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/988> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1653> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1652> ;
	dprr:hasOriginalText "C. Publicius Bibulus (*5)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
	dprr:hasDateStart -209 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -209 .
