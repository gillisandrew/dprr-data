<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7731> rdfs:label "Post Assertion Note: #7731" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor 143. See MRR 1.472. Refer also to Macrob. Sat. 1.6.30. In 1.487, with SIG(3) 688, refer also to Sherk, RDGE no. 10, 135 B.C. See above, on Tremellius (5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3114> rdfs:label "Post Assertion Note: #3114" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Named first in the list of witnesses to the S.C. de Prienensibus (SIG\n     688, 135 B.C.). It is certain that he attained the office (Varro RR 2.4.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3046> rdfs:label "Post Assertion Note: #3046" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 143, Quaestors, and note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3029> rdfs:label "Post Assertion Note: #3029" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "While serving under Licinius Nerva in Macedonia he crushed the rising of a pretender (Varro RR 2.4.1-2; Liv. Per. 53; Eutrop. 4.15; see note 2)." .
