<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2677> rdfs:label "Post Assertion Note: #2677" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Possibly in 175, 174, or 170, the three years when places in the college are in doubt. Seven in this family held this office in the succession of generations (Varro RR 2.4.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2607> rdfs:label "Post Assertion Note: #2607" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected to assign unoccupied lands in Liguria and Gaul to individual settlers, ten iugera each to Romans, three each to Latins (Liv. 42.4.3-4)." .
