	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8733> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7113> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4203> ;
	dprr:hasOriginalText "Sex. Nonius Suffenas (53)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -81 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
