	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1735> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1734> ;
	dprr:hasOriginalText "Q. Fabius Maximus Pat. (103)" ;
	dprr:hasOfficeXref "Cos. 213, Pr. 214" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/21> ;
	dprr:hasDateStart -207 ;
