	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 727" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1735> rdfs:label "Post Assertion Note: #1735" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Consul Livius to inform the Senate that they could safely withdraw the consular army from Gaul (Liv. 28.9.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1734> rdfs:label "Post Assertion Note: #1734" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE) is not certain of the identity of this Legate." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1703> rdfs:label "Post Assertion Note: #1703" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to the army at Venusia (Liv. 27.29.1-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1702> rdfs:label "Post Assertion Note: #1702" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Fabius' title is not given, nor does it appear that he remained with imperium." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1667> rdfs:label "Post Assertion Note: #1667" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by his father the Consul to bring the survivors of the army of Fulvius Centumalus (see 210, Promagistrates) to Sicily and bring back legions and ships formerly under Laevinus (Liv. 27.8.13)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1541> rdfs:label "Post Assertion Note: #1541" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sil. It. 12.479-482." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1540> rdfs:label "Post Assertion Note: #1540" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Possibly Fabius remained as Legate or Prefect with a few troops in Arpi (see Münzer, RE)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1473> rdfs:label "Post Assertion Note: #1473" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Claud. Quad. fr. 57 Peter; Liv. 24.43.5 and 9, cf. 44.7; 34.1.3; Fast. Cap., Degrassi 46f., 119, 446f.; cf. Fast. Fer. Lat., Degrassi 148f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Fabius, Val. Max. 2.2.4; and perhaps 3.1.5; Plut. Fab. 24; Apophth. Fab. 7. Fabius took over the command of the army in Apulia from his father, and re{263}captured Arpi (Liv. 24.44-47, cf. 25.15.1; Claud. Quad. fr. 57 Peter; Val. Max. 2.2.4; Frontin. Str. 3.9.2; Plut. Fab. 24; Apophth. Fab. 7; App. Hann. 31). Sempronius held command with minor successes at Luceria (Liv. 24.44.1, and 47.12; 25.1.5). See below, Dictator." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1446> rdfs:label "Post Assertion Note: #1446" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "With two legions he captured Acuca in Luceria and a fortified camp near Ardoneae (Liv. 24.11.2, 12.6, 20.8; cf. 44.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1444> rdfs:label "Post Assertion Note: #1444" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 24.9.4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1417> rdfs:label "Post Assertion Note: #1417" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 24.9.4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1387> rdfs:label "Post Assertion Note: #1387" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "With the survivors of Cannae at Canusium (Liv. 22.53.1-3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2094> rdfs:label "Post Assertion: #2094" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/879> ;
