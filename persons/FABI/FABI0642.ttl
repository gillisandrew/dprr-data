	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6981> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1110> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1109> ;
	dprr:hasPosition 0 ;
