<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1105> rdfs:label "Post Assertion Note: #1105" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The story is doubted (see RE no. 30), but can refer to historical persons, since, as Münzer suggests, it is possible that this Fabius might even be the father of the Cunctator (Plin. NH 7.133; Münzer RE 116, col. 1814f.); but see 265, note 1." ;
	dprr:hasID 1105 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1104> rdfs:label "Post Assertion Note: #1104" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An aedilicius who in 266 insulted the envoys of Apollonia,\n     was handed over to the city and returned by it (Val. Max. 6.6.5; Dio fr. 42; Zon. 8.7; cf. Liv. Per. 15)." ;
	dprr:hasID 1104 .
