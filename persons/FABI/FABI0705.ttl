<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1491> rdfs:label "Primary Source Reference: #1491" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plut. Ant. 54.2" ;
