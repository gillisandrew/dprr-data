<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2412> rdfs:label "Post Assertion Note: #2412" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ordered to levy emergency troops against the Ligurians, and then to dismiss them (Liv. 40.26.7, and 28.9). Gave the Senate's answer to Ligurian envoys when they asked for peace (40.34.10-11)." ;
	dprr:hasID 2412 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2409> rdfs:label "Post Assertion Note: #2409" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.18.2 Provinces and armies 40.18.3 and 5." ;
	dprr:hasID 2409 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2277> rdfs:label "Post Assertion Note: #2277" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Manlius Acidinus in Spain, probably but not certainly for all his term (Liv. 39.29.4)." ;
	dprr:hasID 2277 .
