	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (cistophori of Ephesus, Tralles, Apameia, and Laodiceia, Head, HN² 535, 576, 660, 666, 678; B.M. Catalogues, Mysia xxx f., Ionia 67f., Lydia cxl f. and 333f., Phrygia xxxiii, lxxiv)." .
