<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7648> rdfs:label "Post Assertion Note: #7648" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In RE s.v. Fabius, no. 17, the praetor of 58 and proconsul in Asia in 57 is identified with Caesar's leg., lieut. of 54-49. Caesar's legate was more probably the tribune of the plebs of 55 (MRR 2.217).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5092> rdfs:label "Post Assertion Note: #5092" ;
