<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1088> rdfs:label "Post Assertion Note: #1088" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap. (names entire); Vell. 1.14.7; Eutrop. 2.15; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; see Degrassi, 40f., 114, 430f. Claudius celebrated a triumph over Lucanians, Samnites, and possibly Bruttians (Act. Tr., Degrassi, 74f., 546; cf. Vell. 1.14.7, the colonization of Paestum)." ;
	dprr:hasID 1088 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1087> rdfs:label "Post Assertion Note: #1087" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Velleius calls him Fabius Dorso but Licinus is the only cognomen in Fast. Cap." ;
	dprr:hasID 1087 .
