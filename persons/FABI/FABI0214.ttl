	dprr:hasNoteText "Liv. 4.17.10, and 19.8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/306> rdfs:label "Post Assertion Note: #306" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See Conway-Walters ed., ad loc." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/305> rdfs:label "Post Assertion Note: #305" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.11.1\n     , and 21.12; Diod. 12.34.1; Chr. 354 (Vivullano et Helva); Fast. Hyd. (Vibulano et Helva), so also Chr. Pasc.; Cassiod.; cf. Auct. De Praenom. 3 (on Postumus); Degrassi 95, 368f. Enacted a measure to send a Latin colony to Ardea (Liv. 4.11.1-7; cf. Diod. 12.34.5)." .
