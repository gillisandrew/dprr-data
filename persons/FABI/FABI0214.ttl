<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/373> rdfs:label "Post Assertion Note: #373" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under the Dictator against Aequi and Volsci (Liv. 4.27-28); Geganius' title is not given." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/364> rdfs:label "Post Assertion Note: #364" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.25.2; Diod. 12.58.1; Chr. 354 (Vivullano et Faccinatore); Degrassi 95, 372f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/363> rdfs:label "Post Assertion Note: #363" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "On Fabius' filiation, see Münzer, RE nos. 162 and 165. On Folius' name. see Fast. Cap. on 318; {Gr} in Diod., who also has {Gr} for Sergius," .
