<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7648> rdfs:label "Post Assertion Note: #7648" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In RE s.v. Fabius, no. 17, the praetor of 58 and proconsul in Asia in 57 is identified with Caesar's leg., lieut. of 54-49. Caesar's legate was more probably the tribune of the plebs of 55 (MRR 2.217).\n" ;
	dprr:hasID 7648 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5582> rdfs:label "Post Assertion Note: #5582" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of Caesar in the Spanish campaign (Caes. BC 1.37, and 40, and 48; Dio 41.20.1-2; cf. Cic. Att. 8.3.7). See 55, note 2." ;
	dprr:hasID 5582 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5473> rdfs:label "Post Assertion Note: #5473" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Hirt. in Caes. BG 8.54.4; Cic. Att. 7.3.3). See 55, Tribunes of the Plebs." ;
	dprr:hasID 5473 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5409> rdfs:label "Post Assertion Note: #5409" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Hirt. in Caes. BG 8.6.3, 24.2, 27-33, 37.2; Oros. 6.11.17-19)." ;
	dprr:hasID 5409 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5357> rdfs:label "Post Assertion Note: #5357" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
