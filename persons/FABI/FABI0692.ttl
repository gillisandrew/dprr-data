<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1107> rdfs:label "Post Assertion Note: #1107" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Act. Tr. (names entire); Chr. 354 (Pera et Pistore); Fast. Hyd. (Fabio Pictore et Pecta); Chr. Pasc. ({Gr}); Cassiod.; see Degrassi, 74f., 115, 432f., 547. Both Consuls campaigned in Umbria and celebrated triumphs over Sassina, then in Calabria and celebrated second triumphs over the Sallentines and the Messapians (Act. Tr., Degrassi, 74f., 547; cf. Liv. Per. 15)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1089> rdfs:label "Post Assertion Note: #1089" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with Gurges as head to the court of Ptolemy Philadelphus (Dion. Hal. 20.14; Val. Max. 4.3.9; cf. Liv. Per. 14; Iustin. 18.2.9; Dio fr. 41; Zon. 8.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10082> rdfs:label "Post Assertion Note: #10082" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Sallentineis, Messapieisque. MRR I.201, Itgenshorst no. 124, Rich no. 123." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10081> rdfs:label "Post Assertion Note: #10081" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Sassinatibus. MRR I.201, Itgenshorst no. 123, Rich no. 122." .
