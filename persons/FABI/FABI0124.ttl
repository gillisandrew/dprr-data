	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/216> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/214> rdfs:label "Primary Source Reference: #214" ;
	a dprr:PrimarySourceReference ;
