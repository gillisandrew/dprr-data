	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 8.3.5. On Valerius, see Münzer, Gent. Val. 49, no. 49." ;
	dprr:hasID 743 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/712> rdfs:label "Post Assertion Note: #712" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 7.28.1; Diod. 16.66.1, under 348; Chr. 354 (Dorsuo et Rufo); Fast. Hyd. (Bursone et Camerino); Chr. Pasc. ({Gr}); Cassiod. See Degrassi 106, 406f. They captured Sora in a Volscian war (Liv. 7.28.6)." ;
	dprr:hasID 712 .
