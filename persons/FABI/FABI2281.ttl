<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4821> rdfs:label "Post Assertion Note: #4821" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried a law to limit the number of attendants upon candidates (Cic. Mur. 71; cf. Q. Cic. Comm. Pet. 37)." ;
	dprr:hasID 4821 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4820> rdfs:label "Post Assertion Note: #4820" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "4 It is not certain that the Lex Fabia was a tribunician bill. Niccolini (FTP 266) suggests a date in 64 because the Comm. Pet. (37), which was composed early in that year, makes no mention of the limitation." ;
	dprr:hasID 4820 .
