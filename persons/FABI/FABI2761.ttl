<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6206> rdfs:label "Post Assertion Note: #6206" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cassius left him in command of Damascus where he had dealings with Herod and Antigonus of Judaea (Joseph. AJ 14.295 and 297; BJ 1.236, with title #, and 239)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6131> rdfs:label "Post Assertion Note: #6131" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Damascus under Cassius (Joseph. AJ 14.295 and 297; BJ 1.236 and 239; see 42, Prefects). Cf. Cic. Fam. 12.15.7, on similar Prefects at Antioch." .
