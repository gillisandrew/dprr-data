<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/345> rdfs:label "Relationship Assertion Reference: #345" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Wenn die Lesung Numerius richtig ist kann er gut der Sohn von Q. Fabius Pictor (127) pr. 189 und Vater von N. Fabius Pictor (125) iiiv.mon. 126 sein." ;
	dprr:hasExtraInfo "Cic. Brut. 81" .
