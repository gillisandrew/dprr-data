<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8458> rdfs:label "Post Assertion Note: #8458" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 731, footnote 59" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2795> rdfs:label "Post Assertion Note: #2795" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with instructions from the Senate to assist Paullus in organizing Macedonia (Liv. 45.17.2-3, and 29-31). Claudius and Domitius went to Achaea to summon the Achaean leaders to Rome in person (Liv. 45.31.9-11; cf. Polyb. 30.13.8-11), and Fabius went to Lesbos to destroy Antissa and incorporate it with Methymna (Liv. 45.31.14)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2791> rdfs:label "Post Assertion Note: #2791" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Fabius' name is not preserved in Liv. 45.17.2, but the Labeo who was sent to Lesbos (Liv. 45.31.14) was almost certainly a member of the commission and the Consul of 183." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2466> rdfs:label "Post Assertion Note: #2466" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Q. Fabius Labeo succeeded L. Valerius Flaccus. On Valerius, see Münzer, Gent. Val. 39, no. 17." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2464> rdfs:label "Post Assertion Note: #2464" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Liv. 40.42.6 and 11-12." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2400> rdfs:label "Post Assertion Note: #2400" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His imperium in Liguria was prorogued (Liv. 40.1.3 and 8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2382> rdfs:label "Post Assertion Note: #2382" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to found Saturnia in the Ager Caletranus (Liv. 39.55.9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2365> rdfs:label "Post Assertion Note: #2365" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Off. 1.33; Attic. in Nep. Hann. 13; Liv. 39.45.1; Fast. Cap., Degrassi 48f., 122, 456f.; Obseq. 4; Chr. 354; Fast. Hyd.; Chr. Pasc.; Oros. 4.20.27; Cassiod. Both Consuls were assigned to Liguria (Liv. 39.45.3), but Marcellus was sent to oppose the settlement of Transalpine Gauls near Aquileia, and wanted to begin an Istrian war (Liv. 39.45.3, 54.1-4, 55.4-5, and 56.3-5; cf. Piso fr. 35 Peter- Plin. NH 3.131; Zon. 9.21)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2363> rdfs:label "Post Assertion Note: #2363" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Potentia and Pisaurum (Liv. 39.44.10; cf. Cic. Brut. 79)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2279> rdfs:label "Post Assertion Note: #2279" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Held command of the fleet at Patara of Lycia (Liv. 38.39.2; cf. Polyb. 21.43.3), and returned to celebrate a naval triumph (Liv. 37.60.6; 38.47.5; Act. Tr., Degrassi 80f., 554; cf. Inscr. Ital. 13.3.56, and L. R. Taylor, AJPh 62 [1941] 379; Grueber, CRRBM 2.264f.; Cesano, Stud. Num. 1.192f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2239> rdfs:label "Post Assertion Note: #2239" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Active on the coasts of Crete and Thrace (Liv. 37.60.1; 39.27.10; see 188, Promagistrates). He made offerings at Delos at this and later dates (I. de Délos 442 B, 103- ILS 8765; 1429 A, 19, {Gr}; 1441 A, 104; 1450 A, 66)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2237> rdfs:label "Post Assertion Note: #2237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 37.47.8 Provinces and armies Liv. 37.50.8-12." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2038> rdfs:label "Post Assertion Note: #2038" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They exacted, perhaps as Quaestores Urbani, from Augurs and Pontifices taxes which they had not paid during the war years (Liv. 33.42.2-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10070> rdfs:label "Post Assertion Note: #10070" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Naval Triumph ex Asia de rege Antiocho. MRR I.366, Itgenshorst no. 179, Rich no. 178." .
