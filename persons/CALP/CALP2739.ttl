<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8370> rdfs:label "Post Assertion Note: #8370" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 34, and 32, Promagistrates." ;
	dprr:hasID 8370 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6478> rdfs:label "Post Assertion Note: #6478" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Died while governor of Syria (App. BC 4.38; see 34, and 33, Promagistrates)." ;
	dprr:hasID 6478 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6437> rdfs:label "Post Assertion Note: #6437" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Syria from ca. 34-33 until his death in 33-32 (App. BC 4.38, without title; see PIR² 2.49, no. 253; Grant, From Imperium to Auctoritas 63)." ;
	dprr:hasID 6437 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6384> rdfs:label "Post Assertion Note: #6384" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An Envoy from Antony to Octavian at the end of 36 or early in 35 (App. BC 4.38; 5.132; cf. Horace, Sat. 1.10.86). See above, Promagistrates." ;
	dprr:hasID 6384 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6366> rdfs:label "Post Assertion Note: #6366" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. His name appears with the inscription Pr. Desig. on the coinage of the commanders of the fleet that Antony sent to Octavian's aid against Sextus Pompey (Grueber, CRRBM 2.510-514; see M. Grant, From Imperium to Auctoritas 43f., 52f.; and for his probable title, see below on M. Oppius Capito)." ;
	dprr:hasID 6366 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6182> rdfs:label "Post Assertion Note: #6182" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Commanded the advance guard of Brutus and Cassius on the march to Philippi (App. BC 4.104), and after the battle surrendered to Antony and entered his service (App. BC 4.136, where he is termed of equal rank with Messalla Corvinus; see below)." ;
	dprr:hasID 6182 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6100> rdfs:label "Post Assertion Note: #6100" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Served with Brutus in Macedonia (Cic. Ad Brut. 1.7.1, and 14.1), and was proscribed (App. BC 4.38). See 42, Legates." ;
	dprr:hasID 6100 .
