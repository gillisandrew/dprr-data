	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/10> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "ref. 547" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7606> rdfs:label "Post Assertion Note: #7606" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. suff. 23. Pro quaestore in Spain, under Pompey, 49. In MRR 2.261, and Index, 542, add a reference to Crawford, RRC 1.463, no. 446, 49 B.C. In MRR 2.261 the cross-reference is to 2.100, note 7 (75 B.C.).[47]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7336> rdfs:label "Post Assertion Note: #7336" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Officer in Sicily, legate? under Sex. Pompeius from late 43 to 36 (see MRR 2.479). No. 95 and; he should probably be identified, although there is no evidence that the Cos. suff. of 23 had the cognomen Frugi. If RE no. 95 was pro quaestore in Spain in 49, he may well, but not necessarily, have been quaestor in 50. He should be noted as Cos. suff. 23 in the Index, MRR 2.542.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6730> rdfs:label "Post Assertion Note: #6730" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 23. Considered to have been Quaestor in Sicily, listed by Grant (From Imperium to Auctoritas 26-29 and 31f.) as officer of Sextus Pompey during his possession of the island from the end of 43 to the autumn of 36. See Grueber, CRRBM 2.592." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5828> rdfs:label "Post Assertion Note: #5828" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He held command of the Moorish cavalry under Metellus Scipio in Africa (Bell. Afr. 3.1; 18. 1; cf. Tac. Ann. 2.43; and PIR² 2.57, no. 286)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5541> rdfs:label "Post Assertion Note: #5541" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor in Farther Spain (Grueber CRRBM 2.361; see PIR² 2.57, no. 286). See 75, note 7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4384> rdfs:label "Post Assertion Note: #4384" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor under Pompey in Spain (Grueber, CRRBM 2.360f.). See Legates, on Varro, and 49, Promagistrates, on Piso." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4383> rdfs:label "Post Assertion Note: #4383" ;
