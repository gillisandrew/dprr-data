<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1687> rdfs:label "Post Assertion Note: #1687" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ordered to remain in command in Etruria until the arrival of his successor (Hostilius Tubulus, Liv. 27.22.13)." ;
	dprr:hasID 1687 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1655> rdfs:label "Post Assertion Note: #1655" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor in Etruria (Liv. 27.7.10, and 21.6)." ;
	dprr:hasID 1655 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1613> rdfs:label "Post Assertion Note: #1613" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued, probably as Propraetor (Liv. 27.6.1; cf. 21.6) in Etruria (Liv. 26.28.6; cf. 27.7.10), though he was summoned to a brief command at Capua (27.6.1)." ;
	dprr:hasID 1613 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1553> rdfs:label "Post Assertion Note: #1553" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 26.3.9, 15.8, and 21.1. Commanded the citadel when Hannibal was near Rome (26.20.2). Celebrated the Ludi Apollinares (Liv. 26.23.3; Fest. 436, with praenomen M., and 438 L; see Grueber, CRRBM{273} 1.251ff., and 450ff.; Cesano, Stud. Num. 1.166f.). See also Gaius 4.19; Lange, 2.662; and Appendix, Tribunes of the Plebs." ;
	dprr:hasID 1553 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1552> rdfs:label "Post Assertion Note: #1552" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "As no Pr. Peregrinus is mentioned, Calpurnius probably combined the duties of both praetorships. See Mommsen, Str. 2.210, note 5." ;
	dprr:hasID 1552 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1551> rdfs:label "Post Assertion Note: #1551" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections and Provinces Liv. 25.41.12-13; armies: 26.1.9-13, cf. 28.10-12" ;
	dprr:hasID 1551 .
