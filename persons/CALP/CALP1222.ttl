<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8501> rdfs:label "Post Assertion Note: #8501" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 732" ;
	dprr:hasID 8501 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2440> rdfs:label "Post Assertion Note: #2440" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 40.35.1; Fast. Cap., Degrassi 48f., 122, 456f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Luscus' cognomen, Liv. 45.17.2; Fest. 360 L. Both Consuls were assigned the province of Liguria (Liv. 40.35.8, and 36.6; and on Postumius, 40.41.1-2 and 5-9). Calpurnius died early in the year (Liv. 40.37.1). On Postumius, see Lübker no. 6; Münzer, Bull. Com. 67 (1939) 27-30." ;
	dprr:hasID 2440 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2434> rdfs:label "Post Assertion Note: #2434" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Graviscae (Liv. 40.29.2; cf. on Claudius, Elogium, CIL 1\n     .1, p. 200- Inscr. Ital. 13.3.70a)." ;
	dprr:hasID 2434 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2353> rdfs:label "Post Assertion Note: #2353" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Farther Spain. Returned to celebrate a triumph (Liv. 39.42.2-3; cf. Degrassi 554). See 185, Praetors." ;
	dprr:hasID 2353 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2326> rdfs:label "Post Assertion Note: #2326" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Held command (Praetor, Liv. 39.30.1, and 31.4) in Farther Spain. He and his colleague Crispinus suffered a defeat and won a victory in central Spain (Liv. 39.30-31)." ;
	dprr:hasID 2326 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2308> rdfs:label "Post Assertion Note: #2308" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Liv. 39.21.4-5." ;
	dprr:hasID 2308 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2307> rdfs:label "Post Assertion Note: #2307" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 39.6.2 Provinces and armies Liv. 39.8.2." ;
	dprr:hasID 2307 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10004> rdfs:label "Post Assertion Note: #10004" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Lusitaneis, Celtibereisque. MRR I.376, Itgenshorst no. 183, Rich no. 182." ;
	dprr:hasID 10004 .
