<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7580> rdfs:label "Post Assertion Note: #7580" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator and praetorius of the period of the Social War (Plin. NH 33.21), therefore not no. 97. Being mentioned by his gentilicium, he was probably not one of the more distinguished Calpurnii, such as the Pisones. (RS, MS-RP 1.277-278).\n" ;
	dprr:hasID 7580 .
