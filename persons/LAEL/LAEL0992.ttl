	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8906> rdfs:label "Post Assertion Note: #8906" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 730" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7893> rdfs:label "Post Assertion Note: #7893" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 90. Leg., amb. 174-173. See MRR 1.405 and 409, no. d. On Laelius and this embassy, see P. Meloni, Perseo 129 and note 3.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2683> rdfs:label "Post Assertion Note: #2683" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent across the Alps to answer the complaints of the Gallic king Cincibilis regarding the misdeeds of the Consul Cassius in 171 (Liv. 43.5.7 and 10). An embassy of exceptional dignity." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2601> rdfs:label "Post Assertion Note: #2601" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Early in 173 these reported their failure to meet King Perseus and the Preparations for war in Macedonia (Liv. 42.2.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2566> rdfs:label "Post Assertion Note: #2566" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Macedonia to King Perseus (Liv. 41.22.3). See 173, Legates; and on Valerius, Münzer, Gent. Val. 51, no. 53." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2256> rdfs:label "Post Assertion Note: #2256" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued for a year in Gaul (Liv. 37.50.13; 38.36.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2200> rdfs:label "Post Assertion Note: #2200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Letters of the Scipios to towns of Asia: to Heraclea Pontica, Memnon 26.2, in FGrH 3B.349f.; to Heraclea under Latmus, SEG 2.566, and see Holleaux, RF 52 (1924) 29f.; to Colophon, SEG 4.567, and Holleaux, ib. 32f. See also at Aptara in Crete, Guarducci, I. Cret. 2.3.5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2199> rdfs:label "Post Assertion Note: #2199" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Phil. 11.17; Liv. 36.45.9; Fast. Cap., Degrassi 48f., 122, 454f.; Gell. 16.4.2; Eutrop. 4.4; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod. Scipio was assigned Greece as his province with permission to carry the war into Asia (Liv. 37.1.7-10, 2.2-3, and 4.1-4; Val. Max. 5.5.1). Making a truce in Greece, he went on to Asia to win a decisive victory over Antiochus at Magnesia (Liv. 37.6-7, 18.10, 25.8, and 33-44; cf. Polyb. 21.4-5, 8, and 11, and 13-15; Cic. Mur. 31; Phil. 11.17; Diod. 29.5-10; Frontin. Str. 4.7.30; Flor. 1.24.14-18; App. Syr. 23, and 28-29; Iustin. 31.7-8; Eutrop. 4.4; Zon. 9.20; cf. Oros. 4.20.22). He made offerings at Delos (I. de Délos 427; 428; 442 B, 85-86 and 101; 1429 B, 23 and 28, and ii 16; 1441 A, 106; 1450 A, 68; almost all in 190 and 189; comment. I. de Délos 2, pp. 166f.). See also SEG 1.440-4.567; 1.144 at Delphi; 2.566; I. Cret. 2.3.5; Memnon 26.2, in FGrH 3B.349f.\n     Laelius was assigned Italy, and held command in Gaul (Liv. 37.1.10, 46.10, and 47.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2028> rdfs:label "Post Assertion Note: #2028" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 33.24.2 Provinces and armies 33.26.1-4, and 43.7-8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2017> rdfs:label "Post Assertion Note: #2017" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 33.25.2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1885> rdfs:label "Post Assertion Note: #1885" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served with Scipio in Africa as quaestor extra sortem ex senatus consulto (Liv. 30.33.2). On his services as a cavalry commander at Zama, see Polyb. 15.9.8, 12.5, and 14.7; Liv. 30.33.2-35.2; Frontin. Str. 2.3.16; App. Lib. 41 and 44; Zon. 9.14; cf. Sil. It. 17.423-440." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1870> rdfs:label "Post Assertion Note: #1870" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Scipio in Africa (Polyb. 14.4.2-7, and 9.2-3; Liv. 30.9.1, 11-12, and 14.2-3; 30.33.2; App. Lib. 26, 28; Zon. 9.12-13; cf. Diod. 27.7; Val. Max. 6.9, ext. 7). See above, Envoys." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1867> rdfs:label "Post Assertion Note: #1867" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Rome by Scipio with Syphax and other captives (Liv. 30.16.1, and 17.1-5), then recalled to share the discussion of the terms of peace with the Carthaginians. Returned to Africa with their envoys (30.23.6, and 25.9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1828> rdfs:label "Post Assertion Note: #1828" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus classis, and in charge of the left wing of the fleet as Scipio crossed to Africa (Liv. 29.25.5-13, cf. 33.9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1825> rdfs:label "Post Assertion Note: #1825" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Scipio with attendants to negotiate with Syphax and spy on his camp (Frontin. Str. 1.1.3, cf. 2.1; cf. Liv. 30.4.1; Polyb. 14.1.13; see above, Promagistrates, on Scipio)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1794> rdfs:label "Post Assertion Note: #1794" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 209 and 204, Prefects, on Laelius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1793> rdfs:label "Post Assertion Note: #1793" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried out a raid on the coast of Africa, probably as Praefectus\n     classis (Liv. 29.1.14, 3.6-5.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1760> rdfs:label "Post Assertion Note: #1760" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Scipio in Spain (Liv. 28.28.14), and is mentioned in connection with the battle of Carmona (App. Ib. 25-26), and the operations against Iliturgi, Gades, and the Ilergetes under Indibilis (Liv. 28.19.9 and 18, 23.8, 30.3-31.2, 33.3 and 11; Polyb. 11.32-33; Sil. It. 16.576, 583)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1758> rdfs:label "Post Assertion Note: #1758" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Scipio with gifts to win the favor of King Syphax for Rome (Liv. 28.17.6-9, orator; App. Ib. 29)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1669> rdfs:label "Post Assertion Note: #1669" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus classis, with command of the fleet in the successful attack on New Carthage (Polyb. 10.9.1-5, cf. 12.1; Liv. 26.42.4-5, 43.1, 48.1-14, and 49.4; Sil. It. 15.217-219, 258-274; see above, on Scipio)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1665> rdfs:label "Post Assertion Note: #1665" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Returned to Rome with captives to report to the Senate Scipio's victory at New Carthage (Liv. 26.51.1-2; 27.7.1-4; Polyb. 10.18.2, and 19.8; cf. 37.6). See below, Prefects." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/3268> rdfs:label "Post Assertion: #3268" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/992> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2683> ;
	dprr:hasOriginalText "C. Laelius (2)" ;
	dprr:hasOfficeXref "Cos. 190, Pr. 196" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/11> ;
	dprr:hasDateStart -170 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -170 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/3154> rdfs:label "Post Assertion: #3154" ;
	a dprr:PostAssertion ;
