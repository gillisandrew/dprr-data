<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> rdfs:label "Post Assertion Note: #9805" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/25> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "p. 257-63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5717> rdfs:label "Post Assertion Note: #5717" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus classis (see 49, Prefects). He blockaded Oricum and attacked Brundisium. (Caes. BC 3.7, and 40.5, and 100). After Pharsalus, Antony granted both to him and to Cicero special right to be in Italy (Cic. Att. 11.7.2, cf. 14.1, and 15.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5611> rdfs:label "Post Assertion Note: #5611" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prefect, along with C. Valerius Triarius, of a part of Pompey's fleet recruited in Asia and Syria (Caes. BC 3.5.3, and 7.1; IGRP 3.1018, #; cf. PIR² 2.260, no. 26)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5569> rdfs:label "Post Assertion Note: #5569" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent in February by Pompey at Luceria to the Consuls at Capua to urge their retreat to Brundisium (Cic. Att. 8.11D.1, and 12A.3). See below, Prefects." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5233> rdfs:label "Post Assertion Note: #5233" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aided Gabinius when after his conviction for extortion he was treated too contemptuously by C. Memmius (Val. Max. 8. 1, abs. 3)." .
