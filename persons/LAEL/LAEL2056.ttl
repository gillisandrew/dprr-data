<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7443> rdfs:label "Post Assertion Note: #7443" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. 77 or 76. He served under Pompey in Spain and was killed in the battle at Lauro, in 77 if Obsequens is right in dating it to the consuls of that year (Sall. Hist. 2.31M, from Schol. Bob. On Cic. Flacc. 14, p. 98St; Frontin. Str. 2.5.31, from Livy; Obsequens 58; cf. Plut. Sert. 18; App. BC 1.109).[116x]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4359> rdfs:label "Post Assertion Note: #4359" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Pompey in Spain. Killed at the battle of Lauro (Sall. Hist. 2.31M; Frontin. Str. 2.5.31, from Livy; Obseq. 58, misdated)." .
