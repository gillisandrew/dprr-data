	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1093> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1092> ;
	dprr:hasOriginalText "L. ? Papirius L. f. M. n. Praetextatus Pat. (72)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/35> ;
	dprr:hasDateStart -272 ;
