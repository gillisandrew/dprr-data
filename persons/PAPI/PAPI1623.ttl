	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
	dprr:hasDateStart -131 ;
	dprr:hasDateEnd -131 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/4040> rdfs:label "Post Assertion: #4040" ;
