<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7534> rdfs:label "Post Assertion Note: #7534" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator, probably of the late second century. As T. Coponius of Tibur gained Roman citizenship by securing his condemnation he was very probably a senator (Cic. Balb. 53). See Badian, Gnomon 33, 1961, 493; M. C. Alexander, CPh 80, 1985, 20-32.[154]\n" ;
	dprr:hasID 7534 .
