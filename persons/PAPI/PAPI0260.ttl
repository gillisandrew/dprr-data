<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/472> rdfs:label "Primary Source Reference: #472" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. fam. V 3.1" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/463> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/377> rdfs:label "Post Assertion Note: #377" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Rep. 2.60 (with praenomina P. and C., respectively); Liv. 4.30.1; Diod. 12.72.1; Chr. 354 (Crasso et Iulo); Fast. Hyd. (Crasso et Iulio); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 95, 372f. Granted the Aequi a truce for eight years (Liv. 4.30.1-2), and carried a law commuting fines in live stock to cash (Cic. Rep. 2.60; Liv. 4.30.3; cf. Fest. 220 L)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/376> rdfs:label "Post Assertion Note: #376" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. has under this year the names of C. Papirius and L. Iunius, Cassiod. those of L. Papirius and L. Iulius Iullus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/463> rdfs:label "Post Assertion: #463" ;
	a dprr:PostAssertion ;
