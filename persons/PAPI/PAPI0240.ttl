<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/436> rdfs:label "Primary Source Reference: #436" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. div. II 83" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/430> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/377> rdfs:label "Post Assertion Note: #377" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Rep. 2.60 (with praenomina P. and C., respectively); Liv. 4.30.1; Diod. 12.72.1; Chr. 354 (Crasso et Iulo); Fast. Hyd. (Crasso et Iulio); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 95, 372f. Granted the Aequi a truce for eight years (Liv. 4.30.1-2), and carried a law commuting fines in live stock to cash (Cic. Rep. 2.60; Liv. 4.30.3; cf. Fest. 220 L)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/376> rdfs:label "Post Assertion Note: #376" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. has under this year the names of C. Papirius and L. Iunius, Cassiod. those of L. Papirius and L. Iulius Iullus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/346> rdfs:label "Post Assertion Note: #346" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.21.1; Diod. 12.46.1; Chr. 354 (Maluginense et Grasso), so also Fast. Hyd., and Chr. Pasc.; Cassiod.; Degrassi 95, 370f. Raided Veientane and Faliscan territory (Liv. 4.21.1-2). On Papirius, see Lübker no. 5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/345> rdfs:label "Post Assertion Note: #345" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "In Diod. the name is {Gr}; on the filiation, see Münzer's table in RE, col. 1290. L. Papirius only is named in Cassiod." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/7765> rdfs:label "Post Assertion: #7765" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
