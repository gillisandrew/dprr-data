<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1508> rdfs:label "Post Assertion Note: #1508" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cn Servilius Caepio succeeded C. Papirius Maso. On Papirius, see Lübker, no. 13." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1505> rdfs:label "Post Assertion Note: #1505" ;
	a dprr:PostAssertionNote ;
