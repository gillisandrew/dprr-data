	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Ohne verifizierbare historische Basis als Pontifex maximus für die - fiktive - unter oberpontifikaler Leitung erfolgende Wahl der Volkstribunen von 449 v. Chr. genannt. Konsul im Jahr 441. " .
