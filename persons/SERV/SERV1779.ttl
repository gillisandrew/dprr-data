<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9221> rdfs:label "Post Assertion Note: #9221" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 746" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3644> rdfs:label "Post Assertion Note: #3644" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Plut. Luc. 1.1; cf. Cic. Verr. 2.4.147; Acad. 2.1; Auct. Vir. Ill. 62.4; see 102, Praetors." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3643> rdfs:label "Post Assertion Note: #3643" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The augurate and the name Servilius are certain. The praenomen C. depends on identification with the Praetor of 102. The date of his accusation of Lucullus is probably 101 or very soon after it; that of his own condemnation is uncertain, but early in the careers of Lucius and Marcus Lucullus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3611> rdfs:label "Post Assertion Note: #3611" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Succeeding Lucullus, he too suffered reverses (Diod. 36.9; Flor. 2.7.9-11). He may probably be identified with the Augur named Servilius, who later, probably in 101, accused Lucullus of peculation and forced him into exile, and himself in turn after an interval received the same treatment from Lucullus' sons (Cic. Div. in Caec. 63; Verr. 2.4.147; Acad. 2.1; Off. 2.50; Prov. Cons. 22; Diod. 36.9; Plut. Luc. 1.1; Auct. Vir. Ill. 62.4; Ps.-Ascon. 203 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/4304> rdfs:label "Post Assertion: #4304" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1779> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3644> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3643> ;
	dprr:hasOriginalText "C. ? Servilius (12, cf. 11)" ;
	dprr:hasOfficeXref "Pr. 102 ?" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/16> ;
	dprr:hasDateStart -101 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -101 .
