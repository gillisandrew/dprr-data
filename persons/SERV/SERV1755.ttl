<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3539> rdfs:label "Post Assertion Note: #3539" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In Macedonia (Demitsas, 'H {Gr} 1.433, no. 372, at Thessalonica; cf. Cic. Att. 12.20.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3538> rdfs:label "Post Assertion Note: #3538" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Caepio's quaestorship is to be dated near the end of the second century. If Münzer is correct in identifying him with the father of Servillia, wife of Ap. Claudius Pulcher, Cos. 54 (Cic. Att. 12.20.2), Servilius died, while still young, in a shipwreck." .
