<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1762> rdfs:label "Primary Source Reference: #1762" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Sil It. VI 574ff." ;
