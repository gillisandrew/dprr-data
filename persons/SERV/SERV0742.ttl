<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1551> rdfs:label "Primary Source Reference: #1551" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plut. Cato min. 41.2" ;
