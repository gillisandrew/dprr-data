<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/173> rdfs:label "Primary Source Reference: #173" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Auct. vir. ill. 79.2" ;
