<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2009> rdfs:label "Person Note: #2009" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/12> ;
	dprr:hasNoteText "Münzer 1920:138-147; Richard 1968a:796, Anm. 1; Szemler 1974:74; Draper 1988:244-6." .
<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2008> rdfs:label "Person Note: #2008" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Im Jahr 208 Magister equitum des dictator comitiorum ludorumque faciendorum causa T. Manlius T. f. T. n. Torquatus. Im Konsulatsjahr richtete er mit dem Kollegen ludi votivi aus und führte auf der Grundlage eines Beschlusses des Pontifikalkollegiums, an dem er somit selbst mitgewirkt haben dürfte, Opfer zur Prodigienprokuration aus (203). Dedikation des Iuppiter-Tempels in insula (194); nach zahlreichen Todesfällen 180 als Pontifex maximus mit Piacularopfern beauftragt; im selben Jahr löst er den Streit um die Neubesetzung des Amtes des Rex sacrorum aus." .
<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2007> rdfs:label "Person Note: #2007" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/10> ;
	dprr:hasNoteText "Liv. 27,6,15 (Kooptation als Pontifex); 34,53,7 (Duumvir); 39,46,1, 40,37,2 (Oberpontifikat, piacula); 40,42,11 f. (doppelte Sukzession)." .
<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2006> rdfs:label "Person Note: #2006" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/9> ;
	dprr:hasNoteText "Um 240-180 v. Chr." .
