<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7479> rdfs:label "Post Assertion Note: #7479" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., amb. 145. Add as no. c in MRR 1.470. He was present as a Roman legate at the struggle and the settlement that attended the death of Ptolemy VI Philometor and the succession of Ptolemy VII Euergetes II (Physcon) (Joseph. Contra Apion 2.49-51; cf. Iustin. 38.8.2-4).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2897> rdfs:label "Post Assertion Note: #2897" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with three others to aid Ptolemy VII against Ptolemy VI and assist his return to Cyprus (Polyb. 33.11.6-7; cf. FOR 1.31, 172f.; Otto, ABAW 11 [1934] 113-123)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2522> rdfs:label "Post Assertion Note: #2522" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Senate by Manlius Vulso from Istria (Liv. 41.8.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2502> rdfs:label "Post Assertion Note: #2502" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Manlius Vulso in Istria (Liv. 41.8.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2461> rdfs:label "Post Assertion Note: #2461" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Q. Fulvius Flaccus in Hither Spain (Liv. 40.35.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2460> rdfs:label "Post Assertion Note: #2460" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Senate by Q. Fulvius Flaccus from Hither Spain (Liv. 40.35.3-7, and 36.1-5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2430> rdfs:label "Post Assertion Note: #2430" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served as a Legate under Q. Fulvius Flaccus in Spain (Liv. 40.35.3).{386}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2405> rdfs:label "Post Assertion Note: #2405" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
