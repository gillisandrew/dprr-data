	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Asia in or soon after his praetorship (Suet. Iul. 2. 1, praetor; Auct. Vir. Ill. 78.1)." .
