<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4246> rdfs:label "Post Assertion Note: #4246" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Asia, under whom Mitylene was captured (Suet. Iul. 2.1, with title Praetor; Auet. Vir. Ill. 78.1; of. Cic. Leg. Agr. 2.40; Liv. Per. 89; see 81, Legates, on Caesar). See Magie, Roman Rule in Asia Minor 1.246f.; 2.1124, note 41." .
