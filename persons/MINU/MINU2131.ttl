<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> rdfs:label "Post Assertion Note: #9805" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/25> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "p. 257-63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9267> rdfs:label "Post Assertion Note: #9267" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The list of senators in a dated inscription of this year (SIG(3) 747) provides good evidence for the names of a group of ex-magistrates, although it is not wholly conclusive because of the additions to the Senate by the reforms of Sulla." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9091> rdfs:label "Post Assertion Note: #9091" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 755, footnote 481" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6089> rdfs:label "Post Assertion Note: #6089" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent as Envoys from the Senate to Sextus Pompey in Massilia (Cic. Phil. 13.13; see Promagistrates, on Sextus Pompey). See 48, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5551> rdfs:label "Post Assertion Note: #5551" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably Propraetor (Praetor, Caes. BC 1.12.1). Driven from Iguvium by Curio (Caes. BC 1.12.1-3; Cic. Att. 7.13A.3, and 23.1; Lucan 2.463; Flor. 2.13.19)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5460> rdfs:label "Post Assertion Note: #5460" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Asia, whence he returned to Italy this year (Cic. Fam. 2.17.6; 2.18; 13.54, 55, and 57; Att. 6.1.3; cf. I. v. Priene 106; Milet 1.2.101, no. 3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5396> rdfs:label "Post Assertion Note: #5396" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor (Cic. Fam. 13.53, and 55, and 56) in Asia. See also Cic. Att. 5.13.2, and 20.10, and 21.14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5351> rdfs:label "Post Assertion Note: #5351" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Asia, certainly in 51 (Cic. Fam. 13.53-56), but probably in 52 since he returned to Rome in 50." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5040> rdfs:label "Post Assertion Note: #5040" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Fam. 13.57, prescript; cf. Att. 5.13.2; 6.1.13. See 52, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5038> rdfs:label "Post Assertion Note: #5038" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The following men held provincial governorships immediately after the passage in 52 of the Pompeian law which established an interval between the praetorship or consulship and a provincial command, and may therefore have held the praetorship before 57 (all the Praetors of 57 are known). It is however more probable that the law did not apply to magistrates in office in 53 and 52 (see 54, Praetors), hence these dates remain only as possibilities." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4902> rdfs:label "Post Assertion Note: #4902" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aided Cato against the proposal of Metellus Nepos to summon Pompey (Plut. Cat. Min. 27-28; Dio 37.43.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4491> rdfs:label "Post Assertion Note: #4491" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Grueber, CRRBM 2.364f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10438> rdfs:label "Post Assertion Note: #10438" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 5.139. Named alongside C. Fannius, Libo, Cassius Parmensis, Q. Nasidius, Saturninus, and Antistius as a senior and longstanding associate of Sextus Pompey, all in the East in 35. Following Sextus' downfall, all surrender to Antony." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10437> rdfs:label "Post Assertion Note: #10437" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Presumably with Sex. Pompey between his proscription and Pompey's downfall." .
