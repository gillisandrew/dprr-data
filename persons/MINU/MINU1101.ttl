<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2164> rdfs:label "Post Assertion Note: #2164" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They settled a colony at Vibo (Liv. 35.40.5-6)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2140> rdfs:label "Post Assertion Note: #2140" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Africa to arbitrate a boundary dispute between Carthage and Masinissa, they left it undecided (Liv. 34.62.16-18; Zon. 9.18; cf. App. Lib. 67)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2114> rdfs:label "Post Assertion Note: #2114" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Granted imperium for three years in order to colonize Bruttium (Liv. 34.53.1-2; cf. 35.40.6). See note 5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2014> rdfs:label "Post Assertion Note: #2014" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Faced a serious revolt (App. Ib. 39; see 196)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2010> rdfs:label "Post Assertion Note: #2010" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Six Praetors were elected this year for the first time (Liv. 32.27.6)." .
