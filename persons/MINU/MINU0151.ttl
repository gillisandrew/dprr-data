<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/276> rdfs:label "Primary Source Reference: #276" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Att. XII 23.3" ;
