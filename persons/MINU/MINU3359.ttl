<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2822> rdfs:label "Post Assertion Note: #2822" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Presided at the Senate meeting when permission was granted for free exercise of the cult of Isis at Delos (SIG\n     664)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2821> rdfs:label "Post Assertion Note: #2821" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The commentators in SIG(3) 664 believe that this inscription belongs to the earliest period of Athenian control in Delos. It must be dated after 166 since previous Praetors are known, and, if Minucius was Pr. Urbanus, after 165. Roussel and Launay on I. de Délos 4.1.1570 are less certain of the date:" .
