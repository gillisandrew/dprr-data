	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph in Monte Albano de Galleis, Liguribusque. MRR I.332-3, Itgenshorst no. 167, Rich no. 166." .
