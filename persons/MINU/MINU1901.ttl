<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4079> rdfs:label "Post Assertion Note: #4079" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed by the Consul Valerius as Legate in Fimbria's place, and left as Legatus pro praetore at Byzantium when Fimbria went on to Chalcedon. He was driven out by the mutineers (App. Mith. 52; Dio 30-35, fr. 104.4-5; see above, on Fimbria)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3913> rdfs:label "Post Assertion Note: #3913" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "ILS 8888. Since he was sixth on the list of Pompeius Strabo's staff at Asculum Cichorius suggests that he was a Quaestor (RS 142-144)." .
