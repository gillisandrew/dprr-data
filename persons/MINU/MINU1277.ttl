<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2444> rdfs:label "Post Assertion Note: #2444" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE no. 30 and no. 43) suggests that Molliculus was a nickname which replaced a regular cognomen, perhaps Augurinus. The praenomen Ti. does not appear among the Thermi and the Rufi and is found with the cognomen Augurinus." .
