	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with ten ships to Crete to compose strife there (Liv. 41.25.7). Perhaps no. 55, Q. Minucius Rufus, Cos. 197, Pr. 200 (Krug 49)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2138> rdfs:label "Post Assertion Note: #2138" ;
