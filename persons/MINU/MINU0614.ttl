<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1249> rdfs:label "Primary Source Reference: #1249" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Liv. XXXVIII 51.2" ;
