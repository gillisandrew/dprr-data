<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3617> rdfs:label "Post Assertion Note: #3617" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under C. Servilius in Sicily (Cic. Div. in Caec. 63; cf. Ps.-Ascon. 203 Stangl)." ;
	dprr:hasID 3617 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3616> rdfs:label "Post Assertion Note: #3616" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "If Ps.-Asconius is correct in his belief that Cicero in this passage gave his examples in the order of time, Philo's quaestorship should precede that of Scaurus, who was Consul in 108 (see 117, Quaestors), and the C. Servilius whom he wished to prosecute should be distinguished from the Praetor listed above. The cognomen Philo suggests that his nomen was either Veturius or Publilius." ;
	dprr:hasID 3616 .
