<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/317> rdfs:label "Primary Source Reference: #317" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Balb. 57" ;
