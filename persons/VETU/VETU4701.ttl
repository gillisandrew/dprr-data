	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 4.4.25. Proscribed, he fought his way to Sicily and found refuge with Sextus Pompey. There he continued to command forces against triumviral troops active on the island until he was killed in action against them." .
