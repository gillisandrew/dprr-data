	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 6.42.3; Fast. Cap. ([- -C]ossus II; [- -M]aluginens. II; [- -M]acerinus; and the rest entire); Chr. 354 (Cosso II et Grasso); Degrassi 32f., 104, 398f. On Valerius, see Münzer, Gent. Val. 37, no. 7." ;
	dprr:hasID 599 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/592> rdfs:label "Post Assertion Note: #592" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 6.38.2; Diod. 15.78.1; Fast. Cap. ([- -C]apitolin.; [- -M]alugin. VII; [- -Praet]extat. IIII; the rest entire); Chr. 354 (Capitolino et Structo); Degrassi 32f., 103f., 398f." ;
	dprr:hasID 592 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/591> rdfs:label "Post Assertion Note: #591" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. names only three Military Tribunes in this year, the first three in the list above. On the name of Quinctius, see also Fast. Cap. on 367." ;
	dprr:hasID 591 .
