	dprr:hasNoteText "See 50, and 48, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5712> rdfs:label "Post Assertion Note: #5712" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. He served under Caesar at Dyrrachium (Caes. BC 3.52)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5491> rdfs:label "Post Assertion Note: #5491" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (see 53, 51, and 48, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5430> rdfs:label "Post Assertion Note: #5430" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Hirt. in Caes. BG 8.46.4. Legate under Caesar in Gaul. See 53, Prefects, and 48, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5429> rdfs:label "Post Assertion Note: #5429" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "3 The reading of P adds the name Tullio after that of Vatinius. As Q. Cicero was in Cilicia it is possibly a mistake for Tullo and may refer to Volcatius, who was in Caesar's service in 53 and 48." .
