<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5315> rdfs:label "Post Assertion Note: #5315" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in charge of the guard at the bridge over the Rhine (Caes. BG 6.24.4). See Lübker no. 2." .
