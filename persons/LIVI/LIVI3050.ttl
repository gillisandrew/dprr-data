	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/29> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "1991 423. quaestor in Spain 41-27" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7698> rdfs:label "Post Assertion Note: #7698" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor in Spain, late Republic. Correct the praenomen to L. both in MRR 2.476, and the Index, 582. He should not be identified with the monetalis of Vesci, whose praenomen was C. (TJC)\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6697> rdfs:label "Post Assertion Note: #6697" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor in Spain in the late Republic (CIL 6.1446; cf. C. Livius named on coins of Vesci in Spain, Grant, From Imperium to Auctoritas 379f., who suggests a date ca. 40, and refers to L. Cella, named in Bell. Afr. 89.5, and the [GREEK] mentioned as a subordinate commander in Spain in that year by Appian in BC 5.54)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10526> rdfs:label "Post Assertion Note: #10526" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/27> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Hinard considers the L. Livii Ocellae as identical to the L. Cellae, a father and son in Africa in 46 spared when captured by Caesar (Cae. Bell. Afr. 89), the L. Iulii Mocillae, a praetorius and his son who after Philippi who were aided by Atticus (Nep. Att. 11.2), and the father as being L. Pella, a praetorius who in 42 was dismissed by Brutus from his service for having embezzled provincials (Plut. Brut. 35). Note also L. Livius Ocella, quaestor in Spain ca. 40, who is identified as the son (CIL 6.1446)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/7452> rdfs:label "Post Assertion: #7452" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/3050> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasProvinceOriginal "Spain" ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9818> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7698> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6697> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10526> ;
	dprr:hasOriginalText "C. Livius L. f. (26) Ocella" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/5> ;
	dprr:hasDateStart -41 ;
