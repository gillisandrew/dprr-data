<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1670> rdfs:label "Post Assertion Note: #1670" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Still Prefect of the garrison of Tarentum when Fabius recaptured it (Liv. 25.25.3-5; cf. Cic. De Or. 2.273; Sen. 11; Plut. Fab. 23; Apophth. Fab. 6). See above, Consuls." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1626> rdfs:label "Post Assertion Note: #1626" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Remained Prefect of the garrison in the citadel of Tarentum (Liv. 26.39.1-2, and 20-23; see 214, note 7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1582> rdfs:label "Post Assertion Note: #1582" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in command of the citadel of Tarentum until the town was recaptured in 209 (see 212 and 209, Prefects)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1547> rdfs:label "Post Assertion Note: #1547" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In command of the Roman garrison at Tarentum, where he kept the citadel though he lost the town (Polyb. 8.24-36, C. Livius; Liv. 25.7-11; Frontin. Str. 3.3.16, cf. 17.3; App. Hann. 32-33; cf. Cic. De Or. 2.273; Sen. 11; Plut. Fab. 23.3; Apophth. Fab. 6). See 214, note 7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1502> rdfs:label "Post Assertion Note: #1502" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably continued in charge of the Roman garrison at Tarentum (see 214, note 7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1470> rdfs:label "Post Assertion Note: #1470" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Laevinus to Tarentum to prevent its betrayal to Hannibal (Liv. 24.20.12-13; cf. Polyb. 8.26-36). See 213-209, Prefects." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1469> rdfs:label "Post Assertion Note: #1469" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "In Liv. 24.20.13 M. Livius is an emendation of 'ibis' in P and 'is' and 'his' in other Mss. Despite the discrepancies in the praenomen found in the sources, the circumstances support the identification of this appointee of Valerius Laevinus with the M. Livius Macatus of 27.34.7 (on the name, cf. Cic. De Or. 2.273; Sen. 11). Livius later became Prefect of the Roman garrison at Tarentum (Liv. 26.39; cf. 25.8.10, 9.6, and 10.3; Frontin. Str. 3.17.3, cf. 3.6; App. Hann. 32)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2025> rdfs:label "Post Assertion: #2025" ;
	a dprr:PostAssertion ;
