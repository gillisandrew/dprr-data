<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2695> rdfs:label "Post Assertion Note: #2695" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "M. Servilius succeeded C. Livius Salinator." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2693> rdfs:label "Post Assertion Note: #2693" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Liv. 43.11.13." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2271> rdfs:label "Post Assertion Note: #2271" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 38.35.1; Fast. Cap., Degrassi 48f., 122, 454f.; Obseq. 2; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Livius, SIG\n     611; cf. Holleaux, BCH 54 (1930) 40f., and Daux, Delphes 262. Livius was assigned to Gaul, and Valerius to Pisa and Liguria (Liv. 38.35.7-10, and 42.1; and on the foundation of Forum Livii, see RE s. v.). On Valerius, see Münzer, Gent. Val. 51, no. 53." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2217> rdfs:label "Post Assertion Note: #2217" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Headed an embassy to Prusias of Bithynia (Liv. 37.25.13-14; Polyb. 21.11.12)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2213> rdfs:label "Post Assertion Note: #2213" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Retained command of the fleet until succeeded by Aemilius Regillus (Liv. 37.2.10, and 8.6-14.4; App. Syr. 23-25), and after a mission to Lycia returned to Italy (Liv. 37.14.4-17.1). An offering at Delos (I. de Délos 442 B, line 86)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2174> rdfs:label "Post Assertion Note: #2174" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried the war to the Aegean and defeated the fleet of Antiochus (Liv. 36.3.4-6, and 41-45; cf. App. Syr. 20 and 22; Iustin. 31.6.7-8). On his offerings at Delos, see I. de Délos 439 A, 78; 442 B, 78 and 80; 1429 A, 20 and 30." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2170> rdfs:label "Post Assertion Note: #2170" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election 35.24.6 Provinces and armies Liv. 36.2.6-15." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2145> rdfs:label "Post Assertion Note: #2145" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded the cavalry under Cornelius Merula in Gaul (Liv. 35.5.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2005> rdfs:label "Post Assertion Note: #2005" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In command of the fleet until L. Flamininus succeeded him early in the year (Liv. 32.16.4; see 199, note 5, and below, note 6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1980> rdfs:label "Post Assertion Note: #1980" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commander of a fleet at Same (Liv. 32.16.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1979> rdfs:label "Post Assertion Note: #1979" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The appointment of Livius is not mentioned, nor is his identity completely certain. As his successor L. Flamininus is termed a Legatus, he is listed as one also. See 198, note 6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1879> rdfs:label "Post Assertion Note: #1879" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 30.26.11 Provinces 30.27.8, cf. 40.16-41.2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1804> rdfs:label "Post Assertion Note: #1804" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 29.38.8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1587> rdfs:label "Post Assertion Note: #1587" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C. Livius succeeded M. Pomponius Matho." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1584> rdfs:label "Post Assertion Note: #1584" ;
