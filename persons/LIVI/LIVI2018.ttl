<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4222> rdfs:label "Post Assertion Note: #4222" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Sertorius in Spain. He was defeated and killed at the passage through the Pyrenees by an officer of Annius, Calpurnius Lanarius (Sall. Hist. 1.96M; Plut. Sert. 7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4221> rdfs:label "Post Assertion Note: #4221" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "5 Cichorius (RS 256) points out that this is the only instance of the cognomen Salinator in the Julian gens, and shows that Iulius is often confused with Livius in Ms traditions. His view is accepted by Schulten (Sertorius 44f.). The praenomen appears on coins issued about 84 B.C. (Grueber, CRRBM 1.321)." .
