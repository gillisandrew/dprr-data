	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. urb. 28. He is named in a list of praetors of 28 (CIL 11.7412), and as curule aedile in CIL 6.31759-ILS 5921, cf. 7856, and in an inscription quoted by Pliny (NH 34.93). He should be listed as at least a senator by 31.\n" ;
	dprr:hasID 7601 .
