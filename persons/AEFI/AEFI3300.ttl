<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7371> rdfs:label "Post Assertion Note: #7371" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prefect in Samos, of uncertain date. He was honored with his wife Magilia in a Samian inscription with lettering of the first century B.C. (SEG 1.388). His daughter Aeficia Calvina was honored in Athens (IG 2(2) 4243; cf. Suet. Gramm. 3). (RS, CP) See now E. Rawson, LCM 4, 1979, 53-58; T. E. Kinsey, ibid. 79; E. Badian, ibid. 139-143; W. S. Watt, ibid. 167.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/7805> rdfs:label "Post Assertion: #7805" ;
