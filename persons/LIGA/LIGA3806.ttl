<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7597> rdfs:label "Post Assertion Note: #7597" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He served in Pompeian forces in Spain, Greece, and Africa in 49-46, and was an officer when he was released after capture in Spain in 49 upon promise not to serve against Caesar again (Bell. Afr. 64). His title is not attested. (TJC)\n" .
