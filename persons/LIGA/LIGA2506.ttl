<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7384> rdfs:label "Post Assertion Note: #7384" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Q. Ligarius yielded his command to P. Attius Varus in 49 (Cic. Lig. 20; see MRR 2.260), and so had continued as legatus into that year. His status until his capture in 46 (Bell. Afr. 89.2; Schol. Gron. 291St) is not attested. (TJC) See Syme, Historia 13, 1964, 118?RP 2.596.\n" ;
	dprr:hasID 7384 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5477> rdfs:label "Post Assertion Note: #5477" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Considius Longus in Africa, left in command when 9 Considius returned to Rome (Cic. Lig. 2, 4, 30, 34; Schol. Gron. 291 Stangl)." ;
	dprr:hasID 5477 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5414> rdfs:label "Post Assertion Note: #5414" ;
