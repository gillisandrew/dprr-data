	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor under Verres in eastern Sicily in 73, and mentioned in connection with the case of Heraclius in that year (Cic. Verr. 2.2.44). He probably did not continue (Verr. 2.2.49). See N. Marinone, AAT 100, 1965-1966, 219-252.\n" ;
	dprr:hasID 7611 .
