<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2355> rdfs:label "Post Assertion Note: #2355" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His province was Tarentum, where he continued to punish conspiracies among slaves, and completed his inquiry into the Bacchanals (Liv. 39.41.6-7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2354> rdfs:label "Post Assertion Note: #2354" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Livy (39.41.6) refers to him as Praetor." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2322> rdfs:label "Post Assertion Note: #2322" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Crushed a rising of slaves in Apulia (Liv. 39.29.8-9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2321> rdfs:label "Post Assertion Note: #2321" ;
