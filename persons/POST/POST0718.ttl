<http://romanrepublic.ac.uk/rdf/entity/PersonNote/10> rdfs:label "Person Note: #10" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Under RE no. 56 (cf. 48) Münzer holds, on the strength of Fast. Hyd. and Chr. Pasc., that the cognomen Albinus was in the name and preceded Megellus. It does not appear in Fast. Cap., which are preserved entire for the years 262 and 253." .
