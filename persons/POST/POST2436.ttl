<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/5888> rdfs:label "Post Assertion: #5888" ;
	a dprr:PostAssertion ;
	dprr:isDateStartUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2436> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5226> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5224> ;
	dprr:hasPosition 11 ;
	dprr:hasOriginalText "L. Postumius (*45)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -54 ;
	dprr:hasDateSourceText "by or before 54" ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
