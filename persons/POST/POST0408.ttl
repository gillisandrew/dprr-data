<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/814> rdfs:label "Primary Source Reference: #814" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Dio frg. 107.1 (XXX-XXXV)" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/805> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/745> rdfs:label "Primary Source Reference: #745" ;
	a dprr:PrimarySourceReference ;
