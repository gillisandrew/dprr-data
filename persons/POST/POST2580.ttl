<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasID 2 ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7355> rdfs:label "Post Assertion Note: #7355" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., envoy 48. Münzer (RE no. 8), on the basis of Cic. Fam. 6.12.2 and App. BC 2.58-60, would identify this friend of Caesar as not a Postumius at all but as C. Curtius (Rabirius) Postumus (Rabirius 6). This is accepted by Shackleton Bailey, Studies 60; CLF 2.392. Note also the Postumus associated with Matius in Att. 15.2.3; and Bell. Afr. 26.2, on Rabirius Postumus." ;
	dprr:hasID 7355 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5681> rdfs:label "Post Assertion Note: #5681" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Caesar sent him in haste to Brundisium to summon reinforcements to Epirus (App. BC 2.58-59; see D.-G. 3.440)." ;
	dprr:hasID 5681 .
