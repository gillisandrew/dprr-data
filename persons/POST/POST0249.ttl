	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. fam. IX 14.3 = Att. XIV 17a.3" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/456> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/453> rdfs:label "Primary Source Reference: #453" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. fam. II 19.2" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/447> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/370> rdfs:label "Post Assertion Note: #370" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated a triumph for a victory over the Aequi and Volsci at Algidus (Liv. 4.26-29, cf. 41.11; Ov. Fast. 6.723f.; Val. Max. 2.7.6; Plut. Cam. 2; Gell. 17.21.17; cf. Act. Tr., and Diod. 12.64.1-3). See Degrassi 95, 372f.; Lübker no. 25." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/369> rdfs:label "Post Assertion Note: #369" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Bandel (Dict. 23) and Münzer (RE s. v. \"Iulius\", no. 360) are inclined to follow Diod. 12.64.1-3 and place the dictatorship of Tubertus in 432. The two Iulii appear to have little to do, and the election of Consuls rather than Military Tribunes was more probably the work of a Dictator." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/362> rdfs:label "Post Assertion Note: #362" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.23.6. See Degrassi 95, 372f.; Lübker no. 25." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/361> rdfs:label "Post Assertion Note: #361" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "On the name of Postumius, see Liv. 4.23.6, and app. crit. ed. Conway and Walters." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10195> rdfs:label "Post Assertion Note: #10195" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Volsceis et Aequeis. MRR I.63, Itgenshorst p. 263, Rich no. 40." .
