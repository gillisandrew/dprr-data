<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7701> rdfs:label "Post Assertion Note: #7701" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praetor 90. See MRR 2.26. Münzer (RE no. 13) favors 91 as the date of his praetorship, and Albinus as his cognomen. If so, he would be a promagistrate or a legate when killed at Nola early in 90." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3842> rdfs:label "Post Assertion Note: #3842" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. Per. 73. Captured and slain by the Samnites at Nola (Liv. Per. 73; cf. App. BC 1.42)." .
