<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1079> rdfs:label "Primary Source Reference: #1079" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Gell. XV 13.6" ;
