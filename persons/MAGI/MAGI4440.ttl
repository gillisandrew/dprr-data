	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9235> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7382> ;
	dprr:hasPosition 0 ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -82 ;
	dprr:hasDateEnd -82 .
