<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5613> rdfs:label "Post Assertion Note: #5613" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus fabrum under Pompey (Caes. BC 1.24.4-5; Cic. Att. 9.7C.2; see above, Legates, Envoys)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5571> rdfs:label "Post Assertion Note: #5571" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Captured by Caesar, and immediately sent to Pompey at Brundisium with proposals for peace (Caes. BC 1.24.4- 5). According to Caesar (BC 1.26.2) he did not return, but elsewhere Caesar states that he returned with an unsatisfactory response (Caes. in Cic. Att. 9.7C.2, and 13A.1, cf. 13.8; Plut. Pomp. 63.2). See below, Prefects." .
