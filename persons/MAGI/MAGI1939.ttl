<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9235> rdfs:label "Post Assertion Note: #9235" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 748, footnote 302" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7382> rdfs:label "Post Assertion Note: #7382" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praetors by 82. See MRR 2.67. Sumner suggests that P. Magius (10), Tr. pl. 87 (MRR 2.47), colleague of M. Vergilius, may be one of the two sons of Minatus Magius of Aeclanum who became praetors before 81 when Sulla increased the number to eight (Vell. 2.16.3), and M. Magius Sarus, IIvir at Aeclanum (ILS 5318; ILLRP 523), may be the other (HSPh 74, 1968, 260-261).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4006> rdfs:label "Post Assertion Note: #4006" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A colleague of M. Vergilius (Cic. Brut. 179; see below)." .
