<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7880> rdfs:label "Post Assertion Note: #7880" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 71, Pr. by 69. See MRR 2.122, 132. Candidate for consulship of 66 (Val. Max. 3.8.3). See Wiseman, NM 237, no. 221.\n" ;
	dprr:hasID 7880 .
