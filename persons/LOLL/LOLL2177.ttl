	dprr:hasID 4592 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4589> rdfs:label "Post Assertion Note: #4589" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 The latest date possible under the Cornelian law." ;
	dprr:hasID 4589 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4538> rdfs:label "Post Assertion Note: #4538" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Rallied to bring aid to Sthenius and other victims of Verres in Sicily (Cic. Verr. 2.2.95-100; cf. Ps.-Ascon. 250 Stangl). Active in securing the support of Pompey for the restoration of the powers of the tribunate (Ps.-Ascon. 189, and 220 Stangl; cf. Cic. Verr. 1.45; Brut. 223; Sall. Hist. 4.43 M; Plut. Pomp. 21.4; App. BC 1.121; Schol. Gron. 328 Stangl, where he is mistakenly connected with the reform of the juries in 70)." ;
	dprr:hasID 4538 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4537> rdfs:label "Post Assertion Note: #4537" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "4 Niccolini (FTP 245-247) has seen that the date of the tribunate of Lollius is established by the case of Sthenius (Cic. Verr. 2.2.95-100), after December 72 and before the college of Tribunes in office at the time of the trial of Verres." ;
	dprr:hasID 4537 .
