<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3240> rdfs:label "Post Assertion Note: #3240" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Rotondi (304f.) places in 125 the terminus ante quem of the Lex Aebutia which probably limited greatly the application of the legis{511} actiones and increased that of formulae in litigation (Gaius 4.30; cf. Gell. 16.10.8). The date and office of Aebutius remain uncertain." ;
	dprr:hasID 3240 .
