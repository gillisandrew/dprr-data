<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9803> rdfs:label "Post Assertion Note: #9803" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cichorius identifies him as a Tribune of the Soldiers based on the list of members of the staff of Pompeius Strabo at Asculum (ILS 8888; RS 144-155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7500> rdfs:label "Post Assertion Note: #7500" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. mil.? Badian, Historia 12, 1963, 131, notes that he was not certainly a tr. mil. in the consilium of Pompeius Strabo (see MRR 2.35), and that Cichorius identifies him with the Aeb]utius (above) named in Gran. Lic. See Criniti, L'epigrafe di Asculum 117-119.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3928> rdfs:label "Post Assertion Note: #3928" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "16 Very probably the <Aeb>utius who fell with Octavius in 87 (Gran. Lic. 25B, Mommsen's emendation). Octavius' forces included six cohorts from the army of Pompeius Strabo." .
