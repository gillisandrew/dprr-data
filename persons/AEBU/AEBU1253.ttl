<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2607> rdfs:label "Post Assertion Note: #2607" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected to assign unoccupied lands in Liguria and Gaul to individual settlers, ten iugera each to Romans, three each to Latins (Liv. 42.4.3-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2532> rdfs:label "Post Assertion Note: #2532" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in Sardinia as Praetor (Propraetor ?) and assisted Gracchus (Liv. 41.15.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2517> rdfs:label "Post Assertion Note: #2517" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in command in Sardinia until 176 (Liv. 41.15.6, praetor)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2486> rdfs:label "Post Assertion Note: #2486" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Called for aid against a serious insurrection (Liv. 41.6.5-7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2485> rdfs:label "Post Assertion Note: #2485" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.59.4 (but only three names)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2380> rdfs:label "Post Assertion Note: #2380" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to found Mutina and Parma (Liv. 39.55.7-8). On Quinctius, see Lübker no. 8; Münzer, APF 117." .
