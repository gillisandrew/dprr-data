<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/230> rdfs:label "Primary Source Reference: #230" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Att. I 20.7" ;
