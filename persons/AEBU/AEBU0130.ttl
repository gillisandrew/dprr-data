<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/185> rdfs:label "Post Assertion Note: #185" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 3.6.1; Diod. 11.79.1; Fast. Cap. (S.'s name entire except Prisc[us]); Dion. Hal. 9.67.1; 10.7.5; Chr. 354 (Prisco et Helva); Fast. Hyd. (Prisco et Albo); Chr. Pasc. ({Gr}); Cassiod.; De{35}grassi 24f., 91, 360f. Both died in office during a pestilence (Liv. 3.6.8, and 7.6; Dion. Hal. 9.67.4, and 68.2; Oros. 2.12.3)." ;
	dprr:hasID 185 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/184> rdfs:label "Post Assertion Note: #184" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "In Diod. Servilius is given the paternal cognomen of Structus, which does not appear in Fast. Cap.; cf. Liv. 4.21.9; Degrassi 91. The cognomen of Aebutius appears as Albus in Fast. Hyd. and {Gr} in Diod. In Dion. Hal. 9.67.1 the name given is {Gr}, but the correct one is given at 10.7.5. Note also {Gr} in Chr. Pasc." ;
	dprr:hasID 184 .
