<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9803> rdfs:label "Post Assertion Note: #9803" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cichorius identifies him as a Tribune of the Soldiers based on the list of members of the staff of Pompeius Strabo at Asculum (ILS 8888; RS 144-155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7385> rdfs:label "Post Assertion Note: #7385" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator. An eques in 100 when he opposed Saturninus (Cic. Rab. Perd. 31; cf. Serv. ad Aen. 1.13), he became a senator later (Dio 37.26; cf. Auct. Vir. Ill. 73). Probably a tr. mil. in the consilium of Pompeius Strabo in 89 (see MRR 2.35, 38, note 15, 495; Cichorius, RS 151ff.; Criniti, L'Epigrafe di Asculum 116-117; Wiseman, NM 255, no. 353).[180]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3927> rdfs:label "Post Assertion Note: #3927" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "15 He may be identified with the Rabirius who was tried in 63 for the murder of Labienus in 100 (RS 151 f.; of. Cic. Rab. Perd. 8 and 31 and 36)." .
