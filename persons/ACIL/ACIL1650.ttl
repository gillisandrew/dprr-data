	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3283> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3282> ;
	dprr:hasOriginalText "? M'. Acilius Glabrio (37)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
	dprr:hasDateStart -122 ;
