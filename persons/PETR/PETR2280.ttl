<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8791> rdfs:label "Post Assertion Note: #8791" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 753, footnote 420" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6789> rdfs:label "Post Assertion Note: #6789" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sall. Cat. 59.6, which describes a career extending from 92 to 63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6777> rdfs:label "Post Assertion Note: #6777" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 64 Sall. Cat. 59.6, which describes a career which extended over the period from 92 to 63." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6765> rdfs:label "Post Assertion Note: #6765" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sall. Cat. 59.6, which describes a career between 92 and 64." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5847> rdfs:label "Post Assertion Note: #5847" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate (App. BC 2.95) in the Pompeian forces in Africa (Bell. Afr. 18-20; 24; of. App. BC 2.95; Dio 43.2). After the battle of Thapsus he died in a death pact with King Iuba (Bell. Afr. 91; 94; 97; Liv. Per. 114; Senec. Rhet. Suas. 7.3, and 14; Senec. Provid. 2.10; App. BC 2.100, and 101; Flor. 2.13.69; Dio 43.8.4; Eutrop. 6.23.2; Oros. 6.16.4; Schol. Bern. on Lucan, p. 331 Usener; Schol. Gron. 291 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5769> rdfs:label "Post Assertion Note: #5769" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An officer, probably a Legate, under Metellus Scipio in Africa (see 46, Legates). See Eutropius 6.23; Schol. Bern. on Lucan 1.39, p. 14 U." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5704> rdfs:label "Post Assertion Note: #5704" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He probably continued to serve as a Legate of Pompey (see 49, Legates). He was active in the Peloponnese and fled with Cato after Pharsalus (Dio 42.13.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5595> rdfs:label "Post Assertion Note: #5595" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus pro praetore under Pompey in Farther Spain (Caes. Be 1.37-38; Liv. Per. 110; Vell. 2.50.4; cf. Cic. Fam. 16.12.4; see 54-50, Legates). He joined Afranius in Nearer Spain and shared in his defeat and his surrender to Caesar (see above, on Afranius)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5480> rdfs:label "Post Assertion Note: #5480" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey in Spain (Vell. 2.48. 1; see 55, and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5419> rdfs:label "Post Assertion Note: #5419" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey in Spain (Vell. 2.48. 1; see 55 and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5365> rdfs:label "Post Assertion Note: #5365" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey in Spain (see 55, and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5305> rdfs:label "Post Assertion Note: #5305" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of Pompey in Spain (Vell. 2.48.1; see 55 and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5262> rdfs:label "Post Assertion Note: #5262" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Pompey in Spain (Yell. 2.48. 1; see 55, and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5213> rdfs:label "Post Assertion Note: #5213" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pompey's Legates were sent off to Spain immediately after he received the command, so before the end of 55 (Dio 39.39.4; cf. Vell. 2.48.1; Plut. Pomp. 53.1-2; App. BC 2.18; see 54, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4922> rdfs:label "Post Assertion Note: #4922" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under C. Antonius in the battle against Catiline (Sall. Cat. 59-60; cf. Cic. Sest. 12; Schol. Bob. 94, and 127 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4881> rdfs:label "Post Assertion Note: #4881" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served as a Legate under C. Antonius against the forces of Catiline in Etruria (Sall. Cat. 59.4-5; Schol. Bob. 94, and 127 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4813> rdfs:label "Post Assertion Note: #4813" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sall. Cat. 59.4-6; Val. Max. 2.4.6; cf. Plin. NH 33.53." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4812> rdfs:label "Post Assertion Note: #4812" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 Sallust makes clear that Petreius held the praetorship before 63, but there is no proof of Münzer's theory that the games given by Antonius, Murena, and Petreius form a series in which the silver of Antonius in 66 and Murena in 65 was surpassed by the gold of Petreius in 64 (Cic. Mur. 40; Val. Max.; Plin.)." .
