<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1816> rdfs:label "Relationship Assertion Reference: #1816" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die Stelle ist verdorben und aus Iulius Paris ergänzt. Nach Münzer könnte es sich bei diesem Q. Fabius um den Sohn des Servilianus handeln. Dann wäre (5) nicht nur mit Scipio befreundet, sondern auch nahe verwandt." ;
	dprr:hasExtraInfo "Val. Max. II 7.3" .
