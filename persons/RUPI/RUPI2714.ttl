<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7341> rdfs:label "Post Assertion Note: #7341" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praetor 43? See MRR 2.339. Porphyrio on Hor. Sat. 1.7, reports his service with P. Attius Varus in Africa in 49 (MRR 2.260), and his service with Brutus in Asia in 42 (MRR 2.361; Porphyr., Ps.-Acro, and Comm. Cruq. on Hor. Sat. 1.7). Probably the P. Rupilius P. f. Men. named in Cic. Fam. 13.9; cf. Shackleton Bailey, CLF 1.479. See Wiseman, NM 257, no. 366; Badian, Historia 13, 1964, 143.\n" ;
	dprr:hasID 7341 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6043> rdfs:label "Post Assertion Note: #6043" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Hor. Sat. 1.7. Termed Praetor in this year by Porphyrio and Acro on Hor. Sat. 1. 7. 1." ;
	dprr:hasID 6043 .
