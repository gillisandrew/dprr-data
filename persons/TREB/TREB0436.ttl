	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/558> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/557> ;
	dprr:hasPosition 6 ;
