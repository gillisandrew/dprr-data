<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2641> rdfs:label "Post Assertion Note: #2641" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "M. Valerius Messalla succeeded L. Aemilius Papus. Liv. 42.28.10-13. See Münzer, Gent. Val. 51, no. 53. Bardt (30) holds that his son, Consul 161, may have been the successor (cf. Münzer, Gent. Val. 52, no. 54)." ;
	dprr:hasID 2641 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2640> rdfs:label "Post Assertion Note: #2640" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "See 211, Decemviri sacris faciundis; Bardt 30. Papus may have succeeded M. Aemilius Lepidus who assumed this priesthood in 211." ;
	dprr:hasID 2640 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2601> rdfs:label "Post Assertion Note: #2601" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Early in 173 these reported their failure to meet King Perseus and the Preparations for war in Macedonia (Liv. 42.2.1-2)." ;
	dprr:hasID 2601 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2566> rdfs:label "Post Assertion Note: #2566" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Macedonia to King Perseus (Liv. 41.22.3). See 173, Legates; and on Valerius, Münzer, Gent. Val. 51, no. 53." ;
	dprr:hasID 2566 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2271> rdfs:label "Post Assertion Note: #2271" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 38.35.1; Fast. Cap., Degrassi 48f., 122, 454f.; Obseq. 2; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Livius, SIG\n     611; cf. Holleaux, BCH 54 (1930) 40f., and Daux, Delphes 262. Livius was assigned to Gaul, and Valerius to Pisa and Liguria (Liv. 38.35.7-10, and 42.1; and on the foundation of Forum Livii, see RE s. v.). On Valerius, see Münzer, Gent. Val. 51, no. 53." ;
	dprr:hasID 2271 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2127> rdfs:label "Post Assertion Note: #2127" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "SIG\n     601. See Münzer, Gent. Val. 51, no. 53." ;
	dprr:hasID 2127 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2120> rdfs:label "Post Assertion Note: #2120" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 34.54.2 Provinces and armies Liv. 34.55.6, and 56.9." ;
	dprr:hasID 2120 .
