	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate of Caesar, who was sent to occupy Sardinia (Caes. BC 1.30.2-3, and 31.1; Lucan 3.64, and Schol. Bern., p. 93 Usener; App. BC 2.40; Dio 41.18.1)." ;
