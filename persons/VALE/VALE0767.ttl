<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1210> rdfs:label "Post Assertion Note: #1210" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Varro in Gell. 17.21.43; Fast. Cap. (names entire); Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod., with Manlius for Mamilius; see Degrassi 42f., 117, 438f. On Valerius, see Münzer, Gent. Val. 48, no. 40." ;
	dprr:hasID 1210 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1206> rdfs:label "Post Assertion Note: #1206" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated a naval triumph pro praetore ex Sicilia (Act. Tr., Degrassi 76f., 549; cf. Val. Max. 2.8.2). See Münzer, Gent. Val. 48, no. 40." ;
	dprr:hasID 1206 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1196> rdfs:label "Post Assertion Note: #1196" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent as colleague with Catulus, and as the latter was wounded was actively in charge at the battle of the Aegates Islands (Val. Max. 2.8.2; Zon. 8.17, with the cognomen Flaccus). See Münzer, Gent. Val. 48, no. 40." ;
	dprr:hasID 1196 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10237> rdfs:label "Post Assertion Note: #10237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Naval Triumph ex Sicilia. MRR I.220, Itgenshorst no. 142, Rich no. 141." ;
	dprr:hasID 10237 .
