<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/52> rdfs:label "Post Assertion Note: #52" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Killed while serving under Postumius at Lake Regillus (Liv. 2.20. 1-3; Dion. Hal. 6.12.1). See 496, Legates; Münzer, Gent. Val. 18ff." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/43> rdfs:label "Post Assertion Note: #43" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the assembly of the Latins at Ferentinum to dissuade them from war (Dion. Hal. 5.50.3-51.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/27> rdfs:label "Post Assertion Note: #27" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Dion. Hal. 5.37.1; 6.12.1; Liv. 2.16.1; Chr. 354 (Voleto et Tuberto); Cassiod.; Degrassi 88, 348f. Both Consuls celebrated triumphs over the Sabines (Liv. 2.16.1; Dion. Hal. 5.37.1-39.4; 6.12.1; Act. Tr., Degrassi 64f., 535; Plut. Popl. 20.1-3; Eutrop. 1.11; and Auct. Vir. Ill. 15.1, L. Valerius; Zon. 7.13). On Valerius, see Münzer, Gent. Val. 18ff., on Postumius, Lübker no. 24." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/19> rdfs:label "Post Assertion Note: #19" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded sections of the Roman forces against Porsenna, either before the episode of Horatius (Dion. Hal. 5.22.5; cf. Plut. Popl. 16.3), or against raiders afterwards (Liv. 2.11.7-10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/17> rdfs:label "Post Assertion Note: #17" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "They receive no title in our sources, but this is the most suitable classification, on account of the admitted antiquity of the office (Mommsen, Str. 2.185ff.)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10249> rdfs:label "Post Assertion Note: #10249" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Sabineis. MRR I.7, Itgenshorst p. 262, Rich no. 17." .
