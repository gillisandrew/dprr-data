<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2270> rdfs:label "Post Assertion Note: #2270" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Established a Latin colony at Bononia (Liv. 37.57.7-8, cf. 47.2; Vell. 1.15). See 190, Special Commissions." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2232> rdfs:label "Post Assertion Note: #2232" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Created to supplement Placentia and Cremona (Liv. 37.46.10-11; see 189, Special Commissions)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2183> rdfs:label "Post Assertion Note: #2183" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 36.2.11 (pro praetore). See above, Praetors, on Lepidus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2154> rdfs:label "Post Assertion Note: #2154" ;
