	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Liv. 35.23.8-9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2149> rdfs:label "Post Assertion Note: #2149" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 35.10.11 Provinces and armies 35.20.8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2076> rdfs:label "Post Assertion Note: #2076" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fundanius and Valerius supported the abrogation of the Oppian law, while the two Iunii opposed it (Liv. 34.1.2-4, 2.6, and 5.1; Val. Max. 9.1.3; Zon. 9.17)." .
