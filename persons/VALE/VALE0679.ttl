<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1055> rdfs:label "Post Assertion Note: #1055" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The commander of the fleet attacked by the Tarentines (App. Samn. 7, 1, on Cornelius; Dio fr. 39.4, and Zon. 8.2, on L. Valerius; cf. Liv. Per. 12; Oros. 4.1.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1054> rdfs:label "Post Assertion Note: #1054" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "IIvir is the title in Livy, praefecti in Orosius; Appian omits it and Dio uses the word {Gr}. Weuilleumier (Tarente, 102) favors Cornelius, and believes that Valerius has been confused with P. Valerius Laevinus the conqueror of Heracleia in 280. Cf. Münzer, Gent. Val. 38, no. 13." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1374> rdfs:label "Post Assertion: #1374" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
