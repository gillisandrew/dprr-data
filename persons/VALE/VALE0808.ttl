<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1671> rdfs:label "Post Assertion Note: #1671" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued to serve, probably as Prefect, under Laevinus in Sicily (Liv. 27.7.16; see 210, Prefects)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1629> rdfs:label "Post Assertion Note: #1629" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus classis under the command of Laevinus; sent on a raid to Africa, he reported naval preparations to invade Italy (Liv. 27.5.1 and 8-15, cf. 7.3). An unacceptable nomination for Dictator (27.5.15)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1248> rdfs:label "Post Assertion Note: #1248" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap. (names entire); Fast. Hyd. (Maximo Messalla et Arustio); Chr. Pasc. ({Gr}); Cassiod.; see Degrassi 44f., 118, 440f. Chr. 354 reports the Consuls of 224 by mistake. On Valerius, see Münzer, Gent. Val. 51, no. 52." .
