<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2665> rdfs:label "Post Assertion Note: #2665" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded the left wing under Licinius at Callinicus (Liv. 42.58.12). See Münzer, Gent. Val. 47, no. 35." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2432> rdfs:label "Post Assertion Note: #2432" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Aemilius Paullus in Liguria (Liv. 40.27.3 and 7). See Münzer, Gent. Val. 47, no. 35." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2431> rdfs:label "Post Assertion Note: #2431" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Of three possible candidates, 1. Laevinus, Pr. 182, 2. Messalla, Cos. 188, and 3. Messalla, Cos. 161, the first seems most probable, cf. Münzer, Gent. Val. 60." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2395> rdfs:label "Post Assertion Note: #2395" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See Münzer, Gent. Val. 47, no. 35." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2390> rdfs:label "Post Assertion Note: #2390" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 39.51.5 Provinces and armies 40.1.1-2 and 4 and 7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2323> rdfs:label "Post Assertion Note: #2323" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Either he or the Consul of 210 was the Curule Aedile who was summoned to appear in a Praetor's court (Varro in Gell. 13.13.4; see Münzer, Gent. Val. 47, note 1)." .
