<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/719> rdfs:label "Post Assertion Note: #719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed because of prodigies to establish festivals (Liv. 7.28.7-8). See Degrassi 106, 406f. See Münzer, Gent. Val. 37, no. 9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/693> rdfs:label "Post Assertion Note: #693" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Received command of forces from the Consul Popillius (Liv. 7.23.3). See Münzer, Gent. Val. 37, no. 9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/673> rdfs:label "Post Assertion Note: #673" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 7.21.4; Diod. 16.52.1; Chr. 354 (Publicula et Rutillo II); Cassiod.; Degrassi 105, 404f. Marcius may be the author of the Lex Marcia adversus faeneratores (Gaius 4.23). On Valerius, see Münzer, Gent. Val. 37, no. 9." .
