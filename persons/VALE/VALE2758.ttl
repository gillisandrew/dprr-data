<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2296> rdfs:label "Person Note: #2296" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/13> ;
	dprr:hasNoteText "Schon von Cicero gelobt, wurde er von zahlreichen Zeitgenossen und späteren wie Seneca und Quintilian unter die großen römischen Redner gerechnet. Er unterhielt enge Beziehungen mit Ovid und Tibull." ;
	dprr:hasID 2296 .
