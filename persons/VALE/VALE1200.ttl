<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9853> rdfs:label "Post Assertion Note: #9853" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/23> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8491> rdfs:label "Post Assertion Note: #8491" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 733" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7370> rdfs:label "Post Assertion Note: #7370" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., amb. 173, no. c (MRR 1.409). Valerius and the other members of this embassy were sent to other cities and states as well, Pergamum, Syria, cities in Asia and perhaps in Cappadocia and Bithynia too: cf. in 172, Liv. 42.17.1 and 26.7-9 (MRR 1.414; see Meloni, Perseo 149, 163, 165, notes 2 and 3, and 166; Walbank, Comm. Polyb. 3.289).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2637> rdfs:label "Post Assertion Note: #2637" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 173, no. c. Returned from Greece with reports supporting Eumenes' charges against Perseus, and bringing Praxo from Delphi and L. Rammius of Brundisium as witnesses to the designs of the king (Liv. 42.17.1-9; cf. App. Mac. 11.7-8, with the name Herennius for Rammius; RE s. v. \"Herennius\" no. 1). See Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2603> rdfs:label "Post Assertion Note: #2603" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Early in 173 these reported the increase in factional strife in Aetolia (Liv. 42.2.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2600> rdfs:label "Post Assertion Note: #2600" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to King Perseus to observe conditions in Macedonia, and to Alexandria to renew Roman friendship with King Ptolemy (Liv. 42.6.4-5). On Valerius, see Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2568> rdfs:label "Post Assertion Note: #2568" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Aetolia to compose serious factional strife there and reported their inability to do so (Liv. 41.25.5-6, and 27.4). See 173, Legates; and on Valerius, Münzer, Gent. Val. 47, no. 36; on Popillius, Münzer, APF 216ff." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2526> rdfs:label "Post Assertion Note: #2526" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 41.17.5-6; Fast. Cap., Degrassi 48f., 122, 458f. He too made war in Liguria (Liv. 41.18.6-7 and 15). His right to conduct the election of his successors was questioned (Liv. 41.18.16), but the lacuna in Livy leaves us without knowledge of the result. See Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2510> rdfs:label "Post Assertion Note: #2510" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2509> rdfs:label "Post Assertion Note: #2509" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The points raised in note 1 regarding Scipio apply equally to Laevinus. Their praetorships and their provinces in 177 are both extremely suspect." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2506> rdfs:label "Post Assertion Note: #2506" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 41.8.1 Provinces 41.8.2-3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2475> rdfs:label "Post Assertion Note: #2475" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2473> rdfs:label "Post Assertion Note: #2473" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.44.2 Provinces 40.44.6-7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2269> rdfs:label "Post Assertion Note: #2269" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his half-brother Fulvius Nobilior in Greece, and was sent to Rome with the Aetolian envoys (Liv. 38.9.8, and 10.2; Polyb. 21.29.10-12, and 31.2). See Münzer, Gent. Val. 47, no. 36." .
