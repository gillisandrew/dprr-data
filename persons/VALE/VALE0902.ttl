<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1438> rdfs:label "Post Assertion Note: #1438" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus classis; in charge of the ships which captured the envoys of Philip and Hannibal, and of those which took them to Rome (Liv. 23.38.7-13; 23.34.4; see note 9 below; cf. Münzer, Gent. Val. 38, no. 16). Responsible for the defence of the Italian coast and scouting of the Illyrian one (Liv. 23.38.9-10)." ;
	dprr:hasID 1438 .
