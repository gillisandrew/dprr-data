	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Monetalis. In MRR 2.454, and Index, 628, refer also to Crawford, RRC 1.483-485, no. 474, 45 B.C. He is probably the Valerius Acisculus (93), a tr. pl. of this period who is named by Porphyry in his comment on Hor. Sat. 1.2.94.\n" ;
	dprr:hasID 7590 .
