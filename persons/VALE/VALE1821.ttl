	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9555> rdfs:label "Post Assertion Note: #9555" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/10> ;
