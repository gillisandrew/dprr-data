<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1964> rdfs:label "Post Assertion Note: #1964" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 31.50.7-10; 32.7.14. On Valerius, see Münzer, Gent. Val. 40, no. 19." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1673> rdfs:label "Post Assertion Note: #1673" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.8.4-10; Val. Max. 6.9.3. Appointed against his will as successor to C. Claudius (see 211), but proceded to establish the right of the Flamen to a seat in the Senate. Cf. Liv. 31.50.7; 32.7.14; Plut. RQ 113; Serv. ad Aen. 8.552. See Münzer, Gent. Val. 40, no. 19." .
