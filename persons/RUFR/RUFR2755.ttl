<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6153> rdfs:label "Post Assertion Note: #6153" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Tribune of the Plebs, and author of the Lex Rufrena regarding the placing of statues of the Divus Iulius in the municipia (CIL 12.2.797-ILS 73; CIL 12.2.798-ILS 73a). See Niccolini, FTP 444." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6122> rdfs:label "Post Assertion Note: #6122" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. A high officer in the army of Lepidus in Narbonese Gaul. who was also an active supporter of Antony (Cic. Fam. 10.21.4)." .
