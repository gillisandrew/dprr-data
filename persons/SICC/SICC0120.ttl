	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7594> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/164> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/163> ;
	dprr:hasPosition 5 ;
	dprr:hasOriginalText "Cn. Siccius (1, cf. Sicinius 4)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
	dprr:hasDateStart -470 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -470 .
