<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8207> rdfs:label "Post Assertion Note: #8207" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 454. In Gellius 2.11.1 the name is Sicinius.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/278> rdfs:label "Post Assertion Note: #278" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Murdered while serving under the Decemviri against the Sabines (Dion. Hal. 11.25.2; cf. 25-27, and 44.1; Liv. 3.43.1-7, and 51.7; Zon. 7.18)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/239> rdfs:label "Post Assertion Note: #239" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "According to Dion. Hal. (10.48.2-52.2), he secured the conviction of Romilius but gave up his enmity when the latter proposed an embassy to the Greek cities (see below, Legates; Liv. 3.31.7-8; Plin. NH 7.101; Gell. 2.11.1)." .
