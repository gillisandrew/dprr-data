<http://romanrepublic.ac.uk/rdf/entity/StatusAssertion/2874> rdfs:label "Status Assertion: #2874" ;
	a dprr:StatusAssertion ;
	dprr:isDateStartUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2741> ;
	dprr:hasStatus <http://romanrepublic.ac.uk/rdf/entity/Status/2> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasDateStart -45 ;
	dprr:hasDateEnd -30 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6492> rdfs:label "Post Assertion Note: #6492" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He held command of Antony's army before and at the time of the battle of Actium (Vell. 2.85.2; Plut. Ant. 63.3-4; 65.2). Antony in his flight ordered him to bring the army to Asia (Plut. Ant. 67.5), but he soon fled to Antony in Egypt while the army surrendered to Octavian (Plut. Ant. 68.3; Dio .51.1.4- 5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6465> rdfs:label "Post Assertion Note: #6465" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 37-34, Promagistrates. At the end of this year or early in 32 Antony ordered him to bring his forces from Armenia to Ephesus (Plut. Ant. 56.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6438> rdfs:label "Post Assertion Note: #6438" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He remained in command of Antony's army on the eastern frontier (see 37-35, and 33, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6405> rdfs:label "Post Assertion Note: #6405" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably remained in command of an army under Antony on the eastern frontier (cf. Plut. Ant. 56.1, in 32 B. C.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6368> rdfs:label "Post Assertion Note: #6368" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. In the spring of 36 he campaigned in Iberia and Albania (Dio 49.24.1; cf. Strabo 11.3.5), then joined Antony and took part in the Parthian expedition (Plut. Ant. 42.4, an incident in the retreat). He remained in command on the eastern frontier and in Armenia (Plut. Ant. 56.1, in 32)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6351> rdfs:label "Post Assertion Note: #6351" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Probably served under Antony in the East preparing for his spring campaign in Iberia and Albania (see Dio 49.24.1; and 36, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6267> rdfs:label "Post Assertion Note: #6267" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "One of the Antonian commanders who fled after the fall of Perusia (App. BC 5.50). See above, Consules Suffecti." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6257> rdfs:label "Post Assertion Note: #6257" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Sacerd., CIL 12.1, p. 60, no. III-ILS 9338, no. 3; Fast. Colot., Degrassi 273-275; Fast. Mag. Vic., ibid. 282, 287; Fast. Biond., ibid. 291f.; ibid. 135, 504f.; and on Balbus, CIL 10.3854-ILS 888; Plin. NH 7.136; Dio 48.32.2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6228> rdfs:label "Post Assertion Note: #6228" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "One of the Antonian commanders who fled in the spring of 40 after the fall of Perusia (App. BC 5.50), and therefore in command in Gaul or Italy in 41." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6102> rdfs:label "Post Assertion Note: #6102" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Lepidus as an officer of high rank, but no title is preserved (Cic. Fam. 10.21.4). An active supporter of Antony." .
