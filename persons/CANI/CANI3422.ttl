<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7467> rdfs:label "Post Assertion Note: #7467" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The officer sent in advance by Cato to Cyprus in 58 to take charge of the royal treasure and warn King Ptolemy not to fight (Plut. Cat. Min. 35.1, 37.1-3; Brut. 3). The suggestion that in view of his financial responsibilities he was a quaestor is made both in RE and by Wiseman (CQ 14, 1964, 123).\n" ;
	dprr:hasID 7467 .
