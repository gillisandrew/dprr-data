<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7369> rdfs:label "Post Assertion Note: #7369" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 60. In MRR 2.183, correct the gentilicium to M. Atius Balbus, the form which appears in inscriptions of Aricia (see CIL 14.2179, 2180), and is right for the maternal grandfather of Augustus (RS, CP). Wiseman, NM 216, no. 56, is sceptical of Suet. Aug. 4; cf. Cic. Phil. 3.16. See also Historia 14, 1965, 333-334, and Shackleton Bailey, CLA 1.374, on Att. 2.12.1.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5025> rdfs:label "Post Assertion Note: #5025" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Suet. Aug. 4.1; cf. Cic. Att. 2.12.1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4964> rdfs:label "Post Assertion Note: #4964" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Suet. Aug. 4, Praetor before 59; cf. Cic. Att. 2.12.1; Phil. 3.16. Klein (240f., no. 54) suggests that he became a governor of Sardinia." .
