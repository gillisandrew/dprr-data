<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7834> rdfs:label "Post Assertion Note: #7834" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Promag. Sardinia 38. See MRR 2.392. In the Index, delete the entry on p. 533; and on p. 535, emend the gentilicium Attius to Atius. (RS, CP)\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6325> rdfs:label "Post Assertion Note: #6325" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Patron and probably founder of the municipium of Uzelis in Sardinia, ca. 38 B. C. Hence Grant suggests that he was governor of Sardinia then (From Imperium to Auctoritas 149-153)." .
