<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9736> rdfs:label "Post Assertion Note: #9736" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Verres in Sicily, probably from 73-71 (Cic. Verr. 2.2.49, and 5.63)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7588> rdfs:label "Post Assertion Note: #7588" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus under Verres in Sicily, probably in 72, since he is mentioned in connection with T. Vettius and the trial of the nauarchi (Cic. Verr. 2.5.114). See now N. Marinone, AAT 100, 1965-66, 219252; and above, on Q. Caecilius Niger (101).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4516> rdfs:label "Post Assertion Note: #4516" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Verres in Sicily (see 73, Legates), but not certainly after the first year (Cic. Verr. 2.2.49)." .
