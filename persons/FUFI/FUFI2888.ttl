<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6442> rdfs:label "Post Assertion Note: #6442" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Held command through the winter at Siscia where he crushed a rising (see 35, Promagistrates). See PIR² 3.206, no. 509." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6408> rdfs:label "Post Assertion Note: #6408" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Augustus left him in command at Siscia in Pannonia where he crushed a winter uprising (Dio 49.38.1-3; cf. App. Illyr. 24; see 34, Promagistrates). See PIR² 3.206, no. 509." .
