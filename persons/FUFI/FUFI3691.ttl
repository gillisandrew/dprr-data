	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 91 or 90? For arguments based on Cic. Brut. 182, and 222 (ex accusatione M. Aquili diligentiae fructum ceperat) suggesting that, like his associates, he was a tribune of the plebs, see Sumner, AJPh 84, 1963, 350, note 57; cf. Gruen, RPCC 195, note 30.\n" ;
	dprr:hasID 7536 .
