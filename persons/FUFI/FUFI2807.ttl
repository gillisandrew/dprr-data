<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6272> rdfs:label "Post Assertion Note: #6272" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 41, Promagistrates. It remains uncertain whether his loss of the African provinces to Sextius and his suicide took place in late 41 or early in 40." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6233> rdfs:label "Post Assertion Note: #6233" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Octavian to take over command of the African provinces from T. Sextius (App. BC 5.26, #), who surrendered them at Lucius Antonius' command, but remained, and in 40 at Lucius' order recovered them, and drove Fuficius to suicide (App. BC 5.26; Dio 48.22; see 40, Promagistrates; Ganter 21f.)." .
