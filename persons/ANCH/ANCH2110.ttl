<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8763> rdfs:label "Post Assertion Note: #8763" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 755, footnote 466" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6746> rdfs:label "Post Assertion Note: #6746" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor in Macedonia, probably before 66 (I. v. Olymp. 328). See Index of Careers." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5243> rdfs:label "Post Assertion Note: #5243" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably continued this year as Proconsul in Macedonia (see 55, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5196> rdfs:label "Post Assertion Note: #5196" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (Cic. Fam. 13.40), in succession to Piso (Cic. Pis. 89). See Daux, Delphes 598, no. 10; cf. Pointow, Klio 15 (1918) 70, no. 99." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5124> rdfs:label "Post Assertion Note: #5124" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Sest. 113; Vat. 16; Schol. Bob. 135, 146 Stangl. See 55, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5005> rdfs:label "Post Assertion Note: #5005" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "One of the three Tribunes opposed to Caesar, Pompey, and Crassus (Cic. Sest. 113; Vat. 16; Dio 38.6.1; Schol. Bob. 135, and 146 Stangl)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4790> rdfs:label "Post Assertion Note: #4790" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "I. v. Olymp. 328. He is termed Proquaestor. The date of his quaestorship is a conjecture based on the dates of his tribunate (59) and his praetorship (56). See also 73, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4472> rdfs:label "Post Assertion Note: #4472" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Probably served under Antonius Creticus in Greece (SIG³ 748, from Gytheum; cf. Q. Ancharius, termed Proquaestor in I. v. Olymp. 328)." .
