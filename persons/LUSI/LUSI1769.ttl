<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3572> rdfs:label "Post Assertion Note: #3572" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his uncle Marius in Gaul. Made improper advances to a young soldier who killed him and was both acquitted and commended by Marius (Cic. Mil. 9, and Schol. Bob. 114 Stangl; Val. Max. 6.1.12; Quintil. Inst. Or. 3.11.14; Plut. Apophth. Mar. 3; cf. Cic. Inv. 2.124; Ps.-Cic. Ad Octavian. 10; Calp. Flacc. 3; Ps.-Quintil. Decl. 3 passim)." .
