	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Cluent. 147, cf. 126; see 67, Aediles, and notes 3 and 6. Naso was the Iudex for the trial of Clueutius (Cluent. 148)." .
