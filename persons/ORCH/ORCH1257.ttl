<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2398> rdfs:label "Post Assertion Note: #2398" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Macrobius dates this law in the third year after Cato's censorship (184) and in the twenty-second before the Lex Fannia (161)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2397> rdfs:label "Post Assertion Note: #2397" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "By decree of the Senate he carried a law to limit the number of guests at banquets\n     (Macrob. Sat. 3.17.2-3 and 5; Fest. 220, and 280f. L; Schol. Bob. 2.141 Stangl; cf. FOR 1.55-57, 187f.)." .
