<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8172> rdfs:label "Post Assertion Note: #8172" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 192. Pr. 194. In MRR 1.343, refer also to Liv. 34.53.4.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2225> rdfs:label "Post Assertion Note: #2225" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title given. According to Appian he took a leading part, during Scipio's illness, in the battle of Magnesia (App. Syr. 30-36; cf. Liv. 37.39.5; Plut. Apophth. Dom.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2179> rdfs:label "Post Assertion Note: #2179" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued as Proconsul in Gaul until succeeded by Nasica (Liv. 36.37.6).{354}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2148> rdfs:label "Post Assertion Note: #2148" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "On the doubts regarding Furius' achievements in the same area both as Pr. and as Cos., see 200, Praetors, and Münzer, RE." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2147> rdfs:label "Post Assertion Note: #2147" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Polyb. 21.32.13; Liv. 35.10.10; 38.11.9; Fast. Cap., Degrassi 48f., 121, 454f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Flamininus, CIL 1\n     .2.613- ILS 14; Cic. Sen. 42; Val. Max. 4.5.1. Flamininus was assigned Italy, Gaul, and the holding of the elections (Liv. 35.20.1-7, and 20.4-6), and Domitius a province outside of Italy in case of war with Antiochus (35.20.7), but otherwise Italy and the Gauls (35.20.2). Both were actively engaged in Italy, Flamininus against the Ligurians and Domitius against the Boii (35.22.3-4, and 40.2-4). On Flamininus, see Lübker no. 12." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2095> rdfs:label "Post Assertion Note: #2095" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Plin. NH 14.90." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2092> rdfs:label "Post Assertion Note: #2092" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 34.42.4 Provinces and armies Liv. 34.43.6-7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2032> rdfs:label "Post Assertion Note: #2032" ;
