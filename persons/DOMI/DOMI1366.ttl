<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8938> rdfs:label "Post Assertion Note: #8938" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 735, footnote 96" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7520> rdfs:label "Post Assertion Note: #7520" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. suff. 162. In MRR 1.422, add, with a query, a reference to a milestone near Venafro, CIL 1(2).2.822-ILLRP 460. Monetalis. In MRR 2.438, refer also to Crawford, RRC 1.218, no. 147, 189-180 B.C., who identifies him with the consul of 162.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2838> rdfs:label "Post Assertion Note: #2838" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., Degrassi 50f., 123, 462f.; Fast. Ant., ib. 160f.; Gran. Lic. 14f. (Bonn)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2795> rdfs:label "Post Assertion Note: #2795" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with instructions from the Senate to assist Paullus in organizing Macedonia (Liv. 45.17.2-3, and 29-31). Claudius and Domitius went to Achaea to summon the Achaean leaders to Rome in person (Liv. 45.31.9-11; cf. Polyb. 30.13.8-11), and Fabius went to Lesbos to destroy Antissa and incorporate it with Methymna (Liv. 45.31.14)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2751> rdfs:label "Post Assertion Note: #2751" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They returned to give a critical report on the military situation in Greece and Macedonia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2720> rdfs:label "Post Assertion Note: #2720" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "No title is recorded for any of these three officers, who may therefore, like Popillius, have been Tribunes of the Soldiers." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2719> rdfs:label "Post Assertion Note: #2719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chosen by the Consul Servilius at the request of the Consul-elect Aemilius Paullus to investigate military conditions\n     in Greece and Macedonia (Liv. 44.18.5-6; see 168, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2718> rdfs:label "Post Assertion Note: #2718" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 170, note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2670> rdfs:label "Post Assertion Note: #2670" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Domitius was Praetor by 165 at the latest and probably held the office in 170, since he is listed immediately after the consulars in the commission of ten members sent to Macedonia in 167 (see 167, Legates). It is possible however that the Domitius sent to Greece as a Legate in 169 was his father the Consul of 192 (see 169, Legates), as the commission is not listed completely in the order of seniority.{423}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2639> rdfs:label "Post Assertion Note: #2639" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cn. Domitius Ahenobarbus succeeded Q. Fulvius Flaccus. Liv. 42.28.10-13, Oppido adulescens sacerdos." .
