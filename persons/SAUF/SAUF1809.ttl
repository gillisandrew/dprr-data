<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3683> rdfs:label "Post Assertion Note: #3683" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "P. Canidius Crassus\n     In office on December 10, 100, during the disorders caused by Saturninus and Glaucia, he seized the Capitol, was the last of his group to surrender, and was killed in the Curia (App. BC 1.32; cf. Cic. Rab. Perd. 20; Oros. 5.17.8-9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3682> rdfs:label "Post Assertion Note: #3682" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "9 He entered office on December 5, 100 B. C. (Mommsen, Str. 1.606). See App. BC 1.32-33." .
