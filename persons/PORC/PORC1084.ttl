<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2066> rdfs:label "Post Assertion Note: #2066" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected this year for the first time (Liv. 33.42.1). On Porcius, see D.- G., no. 7; Lübker, no. 12.{339}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1966> rdfs:label "Post Assertion Note: #1966" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vetoed the ovatio granted by the Senate to L. Manlius Acidinus (Liv. 32.7.4). Perhaps he carried one of the Porcian laws (see Niccolini, FTP 424; below, Appendix). See D.- G., no. 7; Lübker, no. 12." .
