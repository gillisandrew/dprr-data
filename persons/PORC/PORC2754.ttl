<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6210> rdfs:label "Post Assertion Note: #6210" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An officer under Brutus and Cassius who perished at Philippi (Vell. 2.71.2; Plut. Brut. 49.5; 6at. Min. 73-74; App. BC 4.135; Zonar. 10.20)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6177> rdfs:label "Post Assertion Note: #6177" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His visit to the Cappadocian court may have been in the capacity of an Envoy from Cassius (Plut. Cat. Min. 73). See D.-G. 5. 212, no. 24." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6120> rdfs:label "Post Assertion Note: #6120" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. An officer under Brutus or Cassius (Cic. Ad Brut. 1.5.3, and 14.1), and probably a Legate when at the court of Cappadocia (Plut. Cat. Min. 73-74). See 42, Legates." .
