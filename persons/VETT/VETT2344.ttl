	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor under Verres in Sicily (Cic. Verr. 2.3.168, and 5.114)." ;
	dprr:hasID 4460 .
