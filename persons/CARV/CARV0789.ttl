<http://romanrepublic.ac.uk/rdf/entity/PersonNote/416> rdfs:label "Person Note: #416" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/13> ;
	dprr:hasNoteText "Ein Spurius Carvilius, einer seiner Freigelassenen, leitete schon vor dem ersten Konsulat eine Schreibschule, die die Verwendung des G-Lautes thematisierte." .
