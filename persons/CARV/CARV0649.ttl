<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1372> rdfs:label "Primary Source Reference: #1372" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Oros. IV 18.1" ;
