	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Q. Fulvius Flaccus succeeded Q. Aelius Paetus. On Paetus, see Liv. 22.35.2. Flaccus competed unsuccessfully for election as Pont. Max. in 212 (25.5.2-4), and died after 205 (28.45.2-7)." .
