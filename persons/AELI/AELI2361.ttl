<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7595> rdfs:label "Post Assertion Note: #7595" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 58. He vetoed, not a tribunicial proposal by his colleague Ninnius for recall of Cicero from exile (see MRR 2.195), but a decree of the Senate proposed by Ninnius on June 1, 57 (Cic. Sest. 68). See also Dom. 49; Har. Resp. 5.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5045> rdfs:label "Post Assertion Note: #5045" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Associated himself with Clodius against Cicero and vetoed Ninnius' proposal for Cicero's recall from exile (Cic. Sest. 68f., 94; Dom. 49; Har. Resp. 5)." .
