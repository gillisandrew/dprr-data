<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1037> rdfs:label "Post Assertion Note: #1037" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Honored with a statue in Rome by Thurians grateful for his action against a Lucanian leader (Plin. NH 34.22). See Weuilleumier, Tarente 100f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1036> rdfs:label "Post Assertion Note: #1036" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Mention at the end of Liv. Per. 11 of action against the Lucanians makes 285 a plausible date for this Tribune. He must follow the dictatorship of Hortensius and precede the consulship of Fabricius in 282." .
