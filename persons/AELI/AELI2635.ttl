<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9740> rdfs:label "Post Assertion Note: #9740" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/13> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
