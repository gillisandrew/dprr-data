<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/951> rdfs:label "Post Assertion Note: #951" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Plebeians added under the Ogulnian law (Liv. 10.9.2; and on Marcius, ILS 9338; Val. Max. 4.1.3; Plut. Cor. 1; on Minucius, see Grueber, CRRBM 1.135f.; Cesano, Stud. Num. 1.147f.)." ;
	dprr:hasID 951 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/832> rdfs:label "Post Assertion Note: #832" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 9.7.13. See Degrassi 108, 416f." ;
	dprr:hasID 832 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/831> rdfs:label "Post Assertion Note: #831" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "For Aelius Livy has Aemilius, but the cognomen Paetus indicates clearly the Aelian family." ;
	dprr:hasID 831 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/754> rdfs:label "Post Assertion Note: #754" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 8.15.1; Diod. 17.17.1; Chr. 354 (Peto et Longo); Fast. Hyd. (Festo et Longo); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 107, 410f. Both Consuls fought the Sidicini, Sulpicius opposed the election of a plebeian Praetor (Liv. 8.15.1-5 and 9)." ;
	dprr:hasID 754 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/753> rdfs:label "Post Assertion Note: #753" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Instead of Aelius, Diod. names by mistake L. Papirius, the Consul of 336." ;
	dprr:hasID 753 .
