<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasID 1 ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2146> rdfs:label "Post Assertion Note: #2146" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "To Castrum Frentinum under Tubero's law (Liv. 35.9.7-8; see 194, no. c.)." ;
	dprr:hasID 2146 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2132> rdfs:label "Post Assertion Note: #2132" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried a bill authorizing Latin colonies (Liv. 34.53.1-2; 35.9.7-8, P. in Mss).{348}" ;
	dprr:hasID 2132 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2131> rdfs:label "Post Assertion Note: #2131" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 194, note 5." ;
	dprr:hasID 2131 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2113> rdfs:label "Post Assertion Note: #2113" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Granted imperium for three years in order to colonize the Ager Thurinus (Liv. 34.53.1-2; cf. 35.9.7-8)." ;
	dprr:hasID 2113 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2112> rdfs:label "Post Assertion Note: #2112" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "The Measures authorizing nos. c. and d. were passed at the end of 194, so Tubero was a Tr. Pl. of 193. The elections to the commissions were held by Domitius the Pr. Urb. of 194 (Liv. 34.53.2). Note that Tubero was elected to a commission that he created." ;
	dprr:hasID 2112 .
