	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These three served as Legates under Q. Cicero in Asia (see 61, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4957> rdfs:label "Post Assertion Note: #4957" ;
