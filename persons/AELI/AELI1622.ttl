	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/99> ;
	dprr:hasDateStart -130 ;
	dprr:hasDateSourceText "uncertain, but before 129; before ca. 132 if tr. pl. then" ;
