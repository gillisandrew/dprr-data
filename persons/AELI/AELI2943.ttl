	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. Urbanus The Praetor who killed a portentous woodpecker and died shortly afterwards (Plin. NH 10.41; Frontin. Str. 4.5.14, with the names L. Aelius and Laelius; cf. Varro in Non. Marc. 518 L; Val. Max. 5.6.4, on the Pr. Aelius, who died at Cannae)." ;
	dprr:hasID 6559 .
