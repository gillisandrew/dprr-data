<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2552> rdfs:label "Post Assertion Note: #2552" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Hither Spain, whence he returned to celebrate a triumph (Act. Tr. Cap. and Urbisalv., Degrassi 80f., 338f., 555; cf. Liv. 41.26.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2537> rdfs:label "Post Assertion Note: #2537" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His imperium as Proconsul in Hither Spain was prorogued (Liv. 41.15.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2521> rdfs:label "Post Assertion Note: #2521" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in command in Hither Spain (Liv. 41.9.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2492> rdfs:label "Post Assertion Note: #2492" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See note 5. The Titinius who performed the duties of the urban praetorship in the absence of the Consuls (Liv. 41.6.4) must be distinguished from the commander in Spain. See 192, Tribunes of the Plebs." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2485> rdfs:label "Post Assertion Note: #2485" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.59.4 (but only three names)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2157> rdfs:label "Post Assertion Note: #2157" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vetoed the triumph demanded by Cornelius Merula (Liv. 35.8.9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2156> rdfs:label "Post Assertion Note: #2156" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "On the two Titinnii, see 178, Praetors." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10232> rdfs:label "Post Assertion Note: #10232" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph ex Hispania Citeriore. MRR I.402, Itgenshorst no. 195, Rich no. 194." .
