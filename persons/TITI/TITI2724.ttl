<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7549> rdfs:label "Post Assertion Note: #7549" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor 43. Sex. Titius is a frequent and probable emendation for the name as given in Cic. Phil. 13.28; cf. 6.10; see Sex. Titius (24), below; Shackleton Bailey, Studies 36-37. Note however the name Tittius in ILS 3397, and in IGRP 1.1024: #. (TJC, LRT)\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6055> rdfs:label "Post Assertion Note: #6055" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Brother (half-brother?) of T. Annius Cimber, and present as Quaestor in Antony's camp at Mutina (Cic. Phil. 13.28)." .
