<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7499> rdfs:label "Post Assertion Note: #7499" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator before 46. He had received his rank from Caesar before 46, when Metellus Scipio put his sons to death (Bell. Afr. 28.2, quorum patrem Caesar in senatum legerat; cf. Bell. Alex. 57.1). Probably from Spain, as his sons are called duo Titii Hispani. (RS, MS-RP 1.290)\n" .
