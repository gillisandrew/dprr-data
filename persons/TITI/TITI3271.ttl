<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/240> rdfs:label "Relationship Assertion Reference: #240" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die einzige namentliche Erwähnung (Cic. Att. IX 19,2) des Sohnes von Titinius legt nahe, dass dieser von einem Pontius adoptiert wurde. Dort wird er zwar nicht als Sohn des Titinius bezeichnet, wegen des Kontextes kommt aber sonst niemand in Frage." ;
	dprr:hasExtraInfo "Cic. Att. IX 19.2" .
