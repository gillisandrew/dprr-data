	dprr:hasNoteText "Served under Q. Cassius Longinus in Spain (Bell. Alex. 57.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5674> rdfs:label "Post Assertion Note: #5674" ;
