<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7516> rdfs:label "Post Assertion Note: #7516" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Officer under Licinius Nerva in Sicily, 104. A. Roes and W. Vollgraf identify the cantharos of Stevensweert as booty from this Sicilian war, and refer the inscription on it (M. Titini) to this officer (Mon. et Mem. Fondation Piot 46, 1952,61-67-AEpig. 1953, no. 156\n" .
