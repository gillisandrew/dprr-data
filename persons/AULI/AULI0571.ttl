<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1135> rdfs:label "Primary Source Reference: #1135" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Liv. XL 34.4" ;
