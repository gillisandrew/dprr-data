	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His province was Istria and Apulia. He returned from operations in Illyricum to charge King Gentius with aiding piracy and holding Roman citizens as prisoners (Liv. 40.42.1-4)." .
