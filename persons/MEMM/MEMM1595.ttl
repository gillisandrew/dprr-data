<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/11070> rdfs:label "Post Assertion: #11070" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1595> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3438> ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/17> ;
