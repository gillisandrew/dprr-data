<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8324> rdfs:label "Post Assertion Note: #8324" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These men were witnesses to the resolutions of the Senate reported by Caelius to Cicero in Fam. 8.8.5-6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7725> rdfs:label "Post Assertion Note: #7725" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg. f. c. in Africa, 46. In MRR 2.301 (cf. 490), refer also to Crawford, RRC 1.471, no. 461, 47-46 B.C., who suggests that his title was Legatus fisci castrensis (cf. ILS 1570).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6872> rdfs:label "Post Assertion Note: #6872" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/4> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 51 (Cic. Fam. 8.8.5). See 51, note." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6014> rdfs:label "Post Assertion Note: #6014" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Sextus Pompey in Spain (Grueber, CRRBM 2.372f.; Grant, From Imperium to Auctoritas 22)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5834> rdfs:label "Post Assertion Note: #5834" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Metellus Scipio in Africa (Grueber, CRRBM 2.573f.; cf. Auct. Bell. Afr. 89.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5438> rdfs:label "Post Assertion Note: #5438" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "It is apparent that these senators are arranged in the order of seniority. L. Villius Annalis therefore held the praetorship before 57, and L. Ateius Capito and M. Eppius were ex- Quaestors in 51." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5336> rdfs:label "Post Assertion Note: #5336" ;
