<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> rdfs:label "Post Assertion Note: #9805" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/25> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "p. 257-63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9040> rdfs:label "Post Assertion Note: #9040" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 745, footnote 209" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6614> rdfs:label "Post Assertion Note: #6614" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 76 Attained the highest offices (Cic. Off. 2.59). No specific proof that he attained the aedileship." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5316> rdfs:label "Post Assertion Note: #5316" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Succeeded by C. Scribonius Curio (11). Cic. Fam. 2.2, and 6; see 57, Pontifices." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4962> rdfs:label "Post Assertion Note: #4962" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "M. Licinius Crassus Dives and C. Scribonius Curio probably succeeded Q. Lutatius Catulus and D. Iunius Silanus (see Cic. Har. Resp. 12). See 57, Pontifices." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4508> rdfs:label "Post Assertion Note: #4508" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia. When succeeded by M. Lucullus, Curio returned to Rome and celebrated a triumph over the Dardani, probably in this year (Cic. Pis. 44 and 58; Eutrop. 6.2.2, and 5.2; see Degrassi 564)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4470> rdfs:label "Post Assertion Note: #4470" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (see 75-74, Promagistrates; Sall. Hist. 3.49-50 M), until he was succeeded by M. Lucullus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4430> rdfs:label "Post Assertion Note: #4430" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (see 75, Promagistrates). He apparently continued to carry on the war with the Thracians (Liv. Per. 95; Ammian. Marc. 29.5.22)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4391> rdfs:label "Post Assertion Note: #4391" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (Liv. Per. 92, and 95; Ruf. Fest. 7.5). Campaigned against the Dardani, and penetrated to the Danube (Sall. Hist. 2.80M; Liv. Per. 92; Flor. 1.39.6; Eutrop. 6.2.2; Ruf. Fest. 7.5; Oros. 5.23.20; Iordan. Rom. 216, p. 27M; see 74, and 73, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4336> rdfs:label "Post Assertion Note: #4336" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12.2.894, 895, 952; Cic. Brut. 216-222, and Quintil. Inst. Or. 11.3.129; Sall. Hist. 2.26M; Fast. Cap., Degrassi 56f. 130, 486f (Cn. Octavius M. f. Cn. n., C. Scr[ib]onius [C. f. - n.] Cur[io]); Fenestella fr. 18 Peter, with Lactant. Ira Dei 22; Pfin. NH 2. 100; Obseq. 59; Chr. 354 (Octavio et Curio); Fast. Hyd. (Octavio et Curione), so also Chr. Pasc.; Cassiod.; on Octavius, Cic. Fin. 2.93; Schol. Bob. 177 Stangl. Curio opposed the efforts of the Tribune Sicinius (see below) to restore the position of the tribunate (Cic. Brut. 216-222, and Quintil. Inst. Or. 11.3.129; Sall. Hist. 3.48.10M; Val. Max. 9.14.5; cf. Sall. Hist. 2.25M; Plin. NH 7.55), and proceeded before the end of the year to Macedonia as successor to the deceased Proconsul Ap. Claudius (Frontin. Str. 4.1.43; cf. Sall. Hist. 2.80M; Obseq. 59)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4235> rdfs:label "Post Assertion Note: #4235" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "3 As he was a candidate for the consulship of 77 but withdrew in favor of Mam. Aemilius Lepidus Livianus (Sall. Hist. 1.81 M), 80 is the latest date possible under the Cornelian law." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4095> rdfs:label "Post Assertion Note: #4095" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Assigned by Sulla the task of restoring Nicomedes of Bithynia and Ariobarzanes of Cappadocia to their thrones (App. Mith. 60; cf. Gran. Lic. 35B; Flor. 1.40.12; Memnon 35, in FGrH 3B.354)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4080> rdfs:label "Post Assertion Note: #4080" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Appointed by Sulla to take charge of the siege of the Athenian Acropolis (Plut. Sull. 14.7; App. Mith. 39; Pausan. 1.20.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3851> rdfs:label "Post Assertion Note: #3851" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Brut. 305, cf. 311; Ascon. In Corn. 74C; cf. Sisenna, fr. 44 Peter." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10208> rdfs:label "Post Assertion Note: #10208" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Dardaneis. MRR II.118, Itgenshorst no. 249, Rich no. 249." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/8041> rdfs:label "Post Assertion: #8041" ;
	a dprr:PostAssertion ;
