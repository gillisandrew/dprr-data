<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2944> rdfs:label "Post Assertion Note: #2944" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He proposed to free the Lusitanians sold into slavery by Ser. Sulpicius Galba (see 150), and to condemn Galba himself, but the latter, in spite of Cato's support for the measure, secured acquittal (Cic. Brut. 80 and 89; De Or. 1.227; Mur. 59; Att. 12.5b; Liv. Per. 49; Oxy. Per. 49, cf. Liv. 39.40.12; Val. Max. 8.1.2; cf. FOR 1.76f., 203f.; App. Ib. 60)." ;
	dprr:hasID 2944 .
