	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Set up by the Minucian law because of a shortage of silver (Liv. 23.21.6; cf. 24.18.12; 26.36.8)." .
