<http://romanrepublic.ac.uk/rdf/entity/DateInformation/1916> rdfs:label "Date Information: #1916" ;
	a dprr:DateInformation ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2422> ;
	dprr:hasValue -43 ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/27> ;
	dprr:hasNotes "possibly proscribed? Hinard 43 no. 34.\nHinard favours identifying the proscriptus 'Capito' with C. Ateius (7) Capito, but also raises the possibility that he was a Fonteius, Gabinius, Oppius, Sinnius, Velleius, or Vulteius" ;
	dprr:hasDateType <http://romanrepublic.ac.uk/rdf/entity/DateType/11> ;
	dprr:hasDateInterval "S" .
