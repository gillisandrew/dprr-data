<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7898> rdfs:label "Post Assertion Note: #7898" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Promag.? 41 and 40. See MRR 2.373, 381. Wiseman, probably rightly, considers him a legate of Mark Antony in Cisalpine Gaul (NM 215, no. 51).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6266> rdfs:label "Post Assertion Note: #6266" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 41, Promagistrates. Like other Antonian commanders he took to flight after the fall of Perusia (App. BC 5.50)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6227> rdfs:label "Post Assertion Note: #6227" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An officer of Antony, like Pollio and Ventidius, in command of troops in Gaul, and acted with them during and after the Perusine war (App. BC 5.33, cf. 50)." .
