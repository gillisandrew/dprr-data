<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/436> rdfs:label "Post Assertion Note: #436" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Postumius and was killed by the soldiers (Liv. 4.50.2; Zon. 7.20)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/435> rdfs:label "Post Assertion Note: #435" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Sextius, as given in the Mss of Livy, is corrected to the patrician form Sestius, since the first plebeian Quaestor was elected in 407 (Liv. 4.54.2)." .
