	dprr:hasBiblio "Hinard, F., Les proscriptions de la Rome républicaine. Rome, Italie : Ecole française de Rome ; Paris : Diffusion de Boccard, 1985." ;
	dprr:hasAbbreviation "Hinard 1985" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7408> rdfs:label "Post Assertion Note: #7408" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praef. Class. 43. The officer in charge of part of Cassius' fleet is called Sextilius Rufus. He should more probably be identified with the officer L. Rufus (Dio 47.31.3; see MRR 2.356) than with C. Sextilius Rufus (23). In MRR 2.356, add the words rather than the quaestor in Cyprus, ca. 49, C. Sextilius Rufus (23).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6133> rdfs:label "Post Assertion Note: #6133" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commanded one of the fleets which supported Cassius against Dolabella (Cic. Fam. 12.13.4, without the praenomen), and is probably to be identified with the L. Rufus who occupied Tarsus for him (Dio 47.31.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/6847> rdfs:label "Post Assertion: #6847" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2763> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7408> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6133> ;
	dprr:hasOriginalText "L. (or C.) Sextilius Rufus (24, cf. 23)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/39> ;
	dprr:hasDateStart -43 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasDateEnd -43 .
