<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/860> rdfs:label "Primary Source Reference: #860" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Dio XLI 57.4" ;
