	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7415> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3442> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3441> ;
	dprr:hasOriginalText "P. ? Sextius (1, cf. 9)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/5> ;
