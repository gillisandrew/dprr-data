	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus? In MRR 2.65, Leg., lieut. 83, refer also to Wiseman, NM 224, nos. 122 and 123.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4132> rdfs:label "Post Assertion Note: #4132" ;
