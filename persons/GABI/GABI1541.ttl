<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3087> rdfs:label "Post Assertion Note: #3087" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried the first law providing for voting by ballot (Cic. Leg. 3.35; Lael. 41; and cf. Leg. Agr. 2.4; Liv. Oxy. Per. 54)." ;
	dprr:hasID 3087 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3086> rdfs:label "Post Assertion Note: #3086" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "It is uncertain whether a Lex Gabinia prohibiting secret gatherings should be attributed to this or a later Gabinius (Porcius Latro, In Cat. 19, cited in Niccolini, FTP 140)." ;
	dprr:hasID 3086 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2998> rdfs:label "Post Assertion Note: #2998" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent early in the spring by Metellus from Macedonia to dissuade the Assembly of the Achaeans from war, but when insulted and disregarded, they departed, Papirius to Athens and Sparta, Gabinius to Naupactus, and the rest to Athens (Polyb. 38.12-13)." ;
	dprr:hasID 2998 .
