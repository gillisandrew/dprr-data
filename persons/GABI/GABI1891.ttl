<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3899> rdfs:label "Post Assertion Note: #3899" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "2 The praenomen is given in Div. in Caec. 64, and the mention of his condemnation in Arch. 9 identifies the person in both references. See Varro and Fenestella (fr. 18 Peter) in Laetant. Div. Inst. 1.6.14." .
