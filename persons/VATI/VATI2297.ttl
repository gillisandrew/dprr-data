<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2335> rdfs:label "Person Note: #2335" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Vatinius verstand sich selbst als Pythagoräer. Als Volkstribun erklärte er, sich nicht an augurale Beschränkungen zu halten." .
