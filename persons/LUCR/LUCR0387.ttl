<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/703> rdfs:label "Primary Source Reference: #703" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Planc. 51" ;
