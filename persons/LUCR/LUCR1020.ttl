<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8911> rdfs:label "Post Assertion Note: #8911" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 728" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1945> rdfs:label "Post Assertion Note: #1945" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent on missions to Carthage, to Masinissa, and to Vermina, Syphax's son (Liv. 31.11.4-18, and 19.1-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1889> rdfs:label "Post Assertion Note: #1889" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His command at Genua (Liv. 30.1.10) was probably prorogued for this year (30.27.9). See 203, note 4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1852> rdfs:label "Post Assertion Note: #1852" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The situation of one legion is left uncertain in the total of 20 and 16 for 203 and 202, respectively, as Livy describes them (30.2.7, and 27.10). It is correctly assigned by De Sanctis to Lucretius in both these years (3.2.540, note 149, 545, note 156; see Crake, 292-294)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1851> rdfs:label "Post Assertion Note: #1851" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued\n     with instructions to rebuild Genua, which Mago had destroyed (Liv. 30.1.9-10). See 204, Promagistrates.{313}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1819> rdfs:label "Post Assertion Note: #1819" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Gaul (Liv. 29.13.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1767> rdfs:label "Post Assertion Note: #1767" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Reported Mago's landing in Liguria and joined Livius against him (Liv. 28.46.12; 29.5.1-9; App. Hann. 54; Zon. 9.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1744> rdfs:label "Post Assertion Note: #1744" ;
