<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2661> rdfs:label "Post Assertion Note: #2661" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his brother the Praetor. He brought a fleet to Cephallenia (Liv. 42.48.6-10), then to Chalcis, entered Boeotia and besieged Haliartus until his brother's arrival (42.56.1-5).{419}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2618> rdfs:label "Post Assertion Note: #2618" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed a bill that the Censors should lease the public land in Campania, much of which had been occupied by private possessors (Liv. 42.19.1-2). See 173, on the Consul Postumius." .
