<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1666> rdfs:label "Primary Source Reference: #1666" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plut. Sulla 37.2" ;
