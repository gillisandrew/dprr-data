	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1171> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1174> rdfs:label "Primary Source Reference: #1174" ;
	a dprr:PrimarySourceReference ;
