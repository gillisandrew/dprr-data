<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7961> rdfs:label "Post Assertion Note: #7961" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See MRR 2.483. For the various dates suggested, ca. 100, ca. 43-42, ca. 38-36, see Schleussner, Legaten 231; RE 10.1280.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6782> rdfs:label "Post Assertion Note: #6782" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Termed Leg(atus) Sic(iliae) on coins, perhaps issued at Panormus under Sextus Pompey (see Grant, From Imperium to Auctoritas 29-31; Grueber, CRRBM 2.562 note; Minzer, RE). Perhaps to be identified with L. Iunius Silanus (165)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10509> rdfs:label "Post Assertion Note: #10509" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/27> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Perhaps L. Iunius (21a), under Sex. Pompey in Sicily" .
