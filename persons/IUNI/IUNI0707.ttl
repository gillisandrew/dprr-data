<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1160> rdfs:label "Post Assertion Note: #1160" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Postumius died in office, and Iunius abdicated (Fast. Cap., Degrassi, 42f., 116, 434f.). See Lübker no. 22 on Postumius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1107> rdfs:label "Post Assertion Note: #1107" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Act. Tr. (names entire); Chr. 354 (Pera et Pistore); Fast. Hyd. (Fabio Pictore et Pecta); Chr. Pasc. ({Gr}); Cassiod.; see Degrassi, 74f., 115, 432f., 547. Both Consuls campaigned in Umbria and celebrated triumphs over Sassina, then in Calabria and celebrated second triumphs over the Sallentines and the Messapians (Act. Tr., Degrassi, 74f., 547; cf. Liv. Per. 15)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10126> rdfs:label "Post Assertion Note: #10126" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Sallentineis, Messapieisque. MRR I.201, Itgenshorst no. 125, Rich no. 124." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10125> rdfs:label "Post Assertion Note: #10125" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Sassinatibus. MRR I.201, Itgenshorst no. 122, Rich no. 121." .
