<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/251> rdfs:label "Relationship Assertion Reference: #251" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cicero diskutiert hier mit Atticus die Auswahl von Tullias zukünftigem Ehemann. V 4,1 ist Servius, also Sulpicius Rufus im Gespräch, der durch Servilia zu erreichen sei. In V 21,14 taucht er als Postumias Sohn auf, der dem Kandidaten von Pontidia vorzuziehen sei. In VI 1,10 ist wieder von Servilias Bewerber die Rede, dem aber inzwischen Pontidias Kandidat vorgezogen wird. siehe dazu Shackleton Bailey, CLA III, 196; 238; 244" ;
	dprr:hasExtraInfo "Cic. Att. VI 1.10" .
