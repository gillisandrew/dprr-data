<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3964> rdfs:label "Post Assertion Note: #3964" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with Servilius to forbid Sulla's advance on Rome, but was exiled mistreated by the soldiers and sent back (Plut. Sull. 9.2). He was exiled under interdict by the victors, but escaped to Spain (App. BC 1.60; cf. Gran. Lic. 23B)." .
