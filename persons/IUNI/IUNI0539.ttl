<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/882> rdfs:label "Post Assertion Note: #882" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Founded a Latin colony at Saticula (Fest. 458 L; cf. Liv. 27.10.7; Vell. 1.14.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/806> rdfs:label "Post Assertion Note: #806" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 8.29.2, omits Brutus' praenomen D.; Diod. 18.2; Chr. 354 (Camello II et Bruto); Fast. Hyd. (Camillo et Bruto); so also Chr. Pasc.; Cassiod., with Brutus' praenomen D.; Degrassi 108, 414f. Furius commanded in Samnium until forced by illness to appoint a Dictator (Liv. 8.29.6-9). Iunius commanded against the Vestini, and captured Cutina and Cingilia (Liv. 8.29.6 and 11-14)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/750> rdfs:label "Post Assertion Note: #750" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 8.12.13. See Degrassi 107, 410f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/749> rdfs:label "Post Assertion Note: #749" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "On the name of Brutus, esp. the cognomen Scaeva, see Liv. 8.29.2." .
