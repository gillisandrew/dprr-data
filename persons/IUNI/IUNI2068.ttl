<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4413> rdfs:label "Post Assertion Note: #4413" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Presided over the Quaestio de veneficis in the cases of Scamander, Fabricius, and Oppianicus, but was condemned to a fine by the Tribune Quinctius for failing to comply with certain formalities (Cic. Cluent. 1.55, 59, 78, 84, 90-96, 103, 113, and 189; Verr. 1.29; 2.1.157; Ps.-Ascon. 216, and 255f. Stangl; Schol. Gron. 331, and 351 Stangl; Schol. on Pers. Sat. 2.19)." .
