	dprr:hasNoteText "Cic. Cluent. 79." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4375> rdfs:label "Post Assertion Note: #4375" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "3 Iunius was aedilicius and Iudex Quaestionis in 74 (Cic.), probably in the year following his aedileship. See 65, and 64, on Caesar." .
