	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 70. See MRR 2.492. Wiseman suggests that he was a brother of the L. Iunius Q. f. Lem. in the consilium of Pompeius Strabo in 89 (NM 236, no. 217; see Criniti, L'Epigrafe di Asculum 20, 141- 142).\n" ;
	dprr:hasID 7673 .
