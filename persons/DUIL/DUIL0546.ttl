<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/772> rdfs:label "Post Assertion Note: #772" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Led a colony to Cales (Liv. 8.16.13-14; cf. Vell. 1.14.3). On Quinctius, see Lübker no. 6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/760> rdfs:label "Post Assertion Note: #760" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Fam. 9.21.2; Liv. 8.16.1; Diod. 17.29.1; Chr. 354 (Crasso et Hella); Fast. Hyd. (Crasso et Dulillo); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 107, 410f. They carried on war with the Ausonii and the Sidicini (Liv. 8.16.1-3). See Lübker no. 6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/759> rdfs:label "Post Assertion Note: #759" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Papirius' name is given in full in Fast. Cap. on 330. For Duillius, Diod. has Kaeso Valerius." .
