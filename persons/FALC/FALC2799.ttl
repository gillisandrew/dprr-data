<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6222> rdfs:label "Post Assertion Note: #6222" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried a plebiscite providing that under any will the regular heirs should obtain not less than one-fourth of the estate (Dio 48.33.5, in a group of notices referring to 41; Jerome Chr. ad ann. 42, p. 158 Helm; cf. Isid. Orig. 5.15.2; CIL 11.419-ILS 6663; and in legal sources, Paulus in Dig. 35.2.1; Gaius 2.227, and 254; Paulus Sent. 3.8; 4.5.5; Ulpian 24.32; 25.14; Dig. 35.2; Cod. 6.50). See Niccolini, FTP 361." ;
	dprr:hasID 6222 .
