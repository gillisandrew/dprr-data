<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2312> rdfs:label "Post Assertion Note: #2312" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Farther Spain (Liv. 39.21.4). Killed during the siege of Hasta after a victory over the Lusitani (Liv. 39.21.4)." ;
	dprr:hasID 2312 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2302> rdfs:label "Post Assertion Note: #2302" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "As no successor was sent, his imperium in Farther Spain was probably prorogued (Liv. 38.42.5-6; cf. 39.7.6-7)." ;
	dprr:hasID 2302 .
