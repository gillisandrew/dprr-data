<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1472> rdfs:label "Post Assertion Note: #1472" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus socium; served under Laevinus at Apollonia (Liv. 24.40.8-17; Plut. Arat. 51; cf. Zon. 9.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1471> rdfs:label "Post Assertion Note: #1471" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Perhaps he is to be identified with the centurion Q. Navius who fought under Q. Fulvius Flaccus in the siege of Capua (Frontin. Str. 4.7.29; cf. Liv. 26.4.10, and 5.12-17; Val. Max. 2.3.3; see Münzer RE)." .
