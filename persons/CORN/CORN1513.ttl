	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die Stelle steht im Zusammenhang mit einer Statuengruppe, die Scipio Metellus auf dem Capitol errichten hat lassen. Dabei wurde die Inschrift für Scipio Serapio dem Standbild des Aemilianus zugeordnet." ;
	dprr:hasExtraInfo "Cic. Att. VI 1.17" .
