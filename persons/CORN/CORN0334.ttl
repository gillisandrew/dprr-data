	dprr:hasPosition 3 ;
	dprr:hasOriginalText "P. Cornelius (M. f. M. n.) Maluginensis Pat. (250, cf. 39)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/34> ;
