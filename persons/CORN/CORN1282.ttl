	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasID 1 ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2503> rdfs:label "Post Assertion Note: #2503" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Had charge of the Adriatic coast from Ancona to Tarentum (Liv. 41.1.3). See 180, 179.{397}" ;
	dprr:hasID 2503 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2480> rdfs:label "Post Assertion Note: #2480" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 180 and 178. Was probably in office during the intervening year." ;
	dprr:hasID 2480 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2462> rdfs:label "Post Assertion Note: #2462" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His refusal to abdicate this office prevented his inauguration as Rex sacrorum (Liv. 40.42.8-10)." ;
	dprr:hasID 2462 .
