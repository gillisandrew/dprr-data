	dprr:hasDateEnd -133 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/3794> rdfs:label "Post Assertion: #3794" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1504> ;
