	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Der Sohn des Africanus muss vor Magnesia in die Gefangenschaft bei Antiochos geraten sein, weil bei Polybios und Livius von Verhandlungen zwischen Africanus und Antiochos vor Magnesia die Rede ist, in denen Antiochos die Freilassung des jungen Scipio anbietet. Handelt es sich um ein bloßes Versehen von Plinius oder existierte eine solche Tradition?" ;
	dprr:hasExtraInfo "Plin. n.h. XXXV 22" .
