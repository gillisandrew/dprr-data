<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/327> rdfs:label "Primary Source Reference: #327" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Brut. 127" ;
