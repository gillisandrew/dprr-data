<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1637> rdfs:label "Primary Source Reference: #1637" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plut. Pomp. 1.1" ;
