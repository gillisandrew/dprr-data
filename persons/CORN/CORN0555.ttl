	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The only Pont. Max. in 120 years before 212 B.C. who had held no curule office (Liv. 25.5.4). Bardt (Priester 3) dates him between 332 and 304. See 304, Pontifices." ;
