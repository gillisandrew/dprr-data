<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1458> rdfs:label "Primary Source Reference: #1458" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plin. n.h. XXXV 91" ;
