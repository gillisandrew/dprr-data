	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/495> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/494> ;
	dprr:hasOriginalText "P. Cornelius - f. - n. (- - - - -) Pat. (39)" ;
	dprr:hasOfficeXref "Mil. Tr. c. p. 397 or 395" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/34> ;
	dprr:hasDateStart -394 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -394 .
