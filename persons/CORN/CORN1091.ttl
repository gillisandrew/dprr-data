<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8445> rdfs:label "Post Assertion Note: #8445" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 729" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2119> rdfs:label "Post Assertion Note: #2119" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Nep. Hann. 8.1; Liv. 34.54.1; Fast. Cap., Degrassi 48f., 121, 454f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; and on Minucius, Frontin. Str. 1.5.16. Merula was assigned the Gallic province and made war on the Boii (Liv. 34.55.6, and 56.12-13; 35.4-5, and 6.5-9), but was refused a triumph (Liv. 35.8). Minucius campaigned against the Ligurians, using Pisa as a base, but with little success (Liv. 34.55.6, and 56.3-7; 35.3.1-6, and 6.1-4, and 11.1-13; cf. FOR 1.167-169; Frontin. Str. 1.5.16; Oros. 4.20.17)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2110> rdfs:label "Post Assertion Note: #2110" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Tempsa (Liv. 34.45.3-5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1989> rdfs:label "Post Assertion Note: #1989" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Suppressed a conspiracy of slaves and Carthaginian hostages (Liv. 32.26.4-18)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1988> rdfs:label "Post Assertion Note: #1988" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "He is given the cognomen Lentulus by mistake in Liv. 32.26.8 and Zon. 9.16." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1986> rdfs:label "Post Assertion Note: #1986" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 32.7.13 Provinces and armies 32.8.5-8." .
