<http://romanrepublic.ac.uk/rdf/entity/PersonNote/686> rdfs:label "Person Note: #686" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Als Flamen Quirinalis stirbt Cornelius nach einer auf Licinius Macer zurückgehenden und von ihm erfundenen Nachricht laut Liv. 3,32,3 im Jahr 453 v. Chr. Licinius dürfte für das erste aufgestiegene Familienmitglied an eine Berufung aufgrund des Konsulats von 485 gedacht haben. " .
