	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/359> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/358> ;
	dprr:hasOriginalText "Ser. Cornelius - f. - n. Cossus Pat. (121)" ;
