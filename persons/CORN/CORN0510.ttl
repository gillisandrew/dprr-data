<http://romanrepublic.ac.uk/rdf/entity/PersonNote/602> rdfs:label "Person Note: #602" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Arvina wird als Fetiale in der historisch fiktiven Auslieferung des Vertragsurhebers der Pax Caudina genannt. Gerade weil Arvina, der Konsul von 343 und 332, Diktator 322, eine so herausragende Gestalt war, kann die Amtszuweisung für diese Erzählung leicht erfunden sein. " .
