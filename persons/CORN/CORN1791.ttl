	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph ex Hispania Ulteriore de Lusitaneis. MRR II.5, Itgenshorst no. 238, Rich no. 238." .
