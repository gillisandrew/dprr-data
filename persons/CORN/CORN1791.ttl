<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3703> rdfs:label "Post Assertion Note: #3703" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated on January 26 a triumph as Proconsul ex Hispania ulteriore de Lusitanis (Act. Tr., Degrassi 84f, 562)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3686> rdfs:label "Post Assertion Note: #3686" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain (Act. Tr. for 98, Degrassi 84f., 562). See 100, Praetors, and 98, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3647> rdfs:label "Post Assertion Note: #3647" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Dolabella celebrated a triumph ex Hispania Ulteriore de Lusitanis on January 26, 98 B.C. In all probability he held the praetorship in 100 and went to Spain either then or as Proconsul in 99. See 99, and 98. Promagistrates.{578}" .
