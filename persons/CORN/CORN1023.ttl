	dprr:hasNoteText "13.21.1" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2113> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/2242> rdfs:label "Primary Source Reference: #2242" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Fam. 13.2" ;
