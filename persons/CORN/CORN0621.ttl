<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/933> rdfs:label "Post Assertion Note: #933" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "As Pont. Max., was compelled by the people to lead the Aedile Flavius through the formula of dedication of the temple of Concord (Liv. 9.46.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/932> rdfs:label "Post Assertion Note: #932" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "If the pontiff's praenomen was P., he could be the Consul of 328, and the doubtful Dictator of 306; if Cn., he would be the father of the Consul of 298 (RE 343)." .
