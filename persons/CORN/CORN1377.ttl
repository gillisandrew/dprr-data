<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2857> rdfs:label "Post Assertion Note: #2857" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Didasc. Ter. Adelph.; Fast. Cap., Degrassi 50f., 123, 462f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Anicius, Cic. Brut. 287. Cethegus drained a portion of the Pomptine marshes (Liv. Per. 46)." .
