<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7589> rdfs:label "Post Assertion Note: #7589" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Procos. Illyria, ca. 61-60 (Cic. Fam. 13.42; see MRR 2.183, 191). On his province and date, see now Shackleton Bailey, CLF 1.353; and CLA 3.263 on Att. 6.3.6 for the suggestion that his nomen may have been Cornelius (cf. Cic. Div. 1.4).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5017> rdfs:label "Post Assertion Note: #5017" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Fam. 13.42. Perhaps governor of Illyricum, before Caesar. See 67, Promagistrates, on Rubrius, and note 12." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4966> rdfs:label "Post Assertion Note: #4966" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Illyricum in 59-58 at the latest (Cic. Fam. 13.42, Prescript, and mention of Byllis; cf. 13.41). See 67, Promagistrates, and note 12." .
