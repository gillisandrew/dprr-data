<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2562> rdfs:label "Post Assertion Note: #2562" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Censured by the Censors (Liv. 41.27.2; cf. Val. Max. 3.5.1; 4.5.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2561> rdfs:label "Post Assertion Note: #2561" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Valerius Maximus (4.5.3; 3.5.1) refers to a Cn. Scipio (an unworthy son of Africanus) who was elected Praetor through the favor of Cicereius his father's scribe, and was prevented by his relatives and friends (propinqui) from exercising his office (id egerunt ne aut sellam ponere aut ius dicere auderet). The person indicated is probably not Cn. Scipio (see 177, note 1) but L. Scipio, Praetor 174, while Cicereius became Praetor in 173." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2558> rdfs:label "Post Assertion Note: #2558" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Provinces and armies Liv. 41.21.1-3" .
