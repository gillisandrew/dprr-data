	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator. Asconius' remark that Q. Cornificius (7), consular candidate for 63, was tantum non primus in his family to win a magistracy, suggests that there was a previous senator of the name (Wiseman, CQ 14, 1964, 123).\n" .
