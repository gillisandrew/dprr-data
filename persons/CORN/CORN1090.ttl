<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8444> rdfs:label "Post Assertion Note: #8444" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 733" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7494> rdfs:label "Post Assertion Note: #7494" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Mention of a Cn. Cornelius, probably the above, in M. Guarducci, I. Cret. 2.3.5, suggests that he should be included in 190 B.C., in MRR 1.358-359, as one of the junior officers with the consul L. Scipio in Greece and Asia.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2539> rdfs:label "Post Assertion Note: #2539" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "L. Furius Philus succeeded Cn. Cornelius Scipio Hispallus.Liv. 41.16.4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2525> rdfs:label "Post Assertion Note: #2525" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 41.14.4 and 7, and 15.1-4; Fast. Cap., Degrassi 48f., 122, 458f. (reading [Cn. Cor]nelius C[n.] f., etc.); Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Petillius, Obseq. 9. Cornelius was assigned Pisa as his province, with charge of elections (Liv. 41.14.8-10, and 15.5), but died as a result of injuries suffered during the Latin Festival (Liv. 41.16.3-4; Fast. Cap.; Obseq. 9). Petillius held the election for a Consul Suffectus (Liv. 41.16.5 and 7, and 17.5-6; Fast. Cap.), then went to his province of Liguria, where he was slain in battle (Liv. 41.14.8-10, and 15.5, 17.6-18.16; cf. Val. Max. 1.5.9; 2.7.15; Frontin. Str. 4.1.46; Obseq. 9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2474> rdfs:label "Post Assertion Note: #2474" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in charge of the investigation of cases of poisoning (Liv. 40.44.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2473> rdfs:label "Post Assertion Note: #2473" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 40.44.2 Provinces 40.44.6-7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1984> rdfs:label "Post Assertion Note: #1984" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
