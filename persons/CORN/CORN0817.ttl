<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1564> rdfs:label "Post Assertion Note: #1564" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These were destroyed in turn by Carthaginian forces in southern Spain (Polyb. 10.6.2, and 7.1, cf. 8.38; Liv. 25.32-36; 26.2.5; Val. Max. 2.7.15; 3.7.1; Sil. It. 13.381-384; App. Ib. 16; Eutrop. 3.14; Oros. 4.17.12; Zon. 9.5; cf. Cic. Off. 1.61; 3.16; Rep. 1.1; Parad. 1.12; Sen. 75 and 82; Tusc. 1.89; ND 3.80; Schol. Ambros. 276 Stangl). On the chronology, see De Sanctis, 3.2.446, note 4." ;
	dprr:hasID 1564 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1528> rdfs:label "Post Assertion Note: #1528" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Spain (Liv. 25.3.6). See above, P. Scipio." ;
	dprr:hasID 1528 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1493> rdfs:label "Post Assertion Note: #1493" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Spain (see 217, note 10). See above, on P. Scipio." ;
	dprr:hasID 1493 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1455> rdfs:label "Post Assertion Note: #1455" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Spain (see 217, note 10). See above, on P. Scipio." ;
	dprr:hasID 1455 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1421> rdfs:label "Post Assertion Note: #1421" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Province: Spain; imperium prorogued (see 217, note 10). For his activities this year, see above, on P. Scipio." ;
	dprr:hasID 1421 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1380> rdfs:label "Post Assertion Note: #1380" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably Proconsul in Spain, see 217, note 10; and above, on P. Scipio." ;
	dprr:hasID 1380 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1348> rdfs:label "Post Assertion Note: #1348" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See above on P. Scipio; and Liv. 22.19-21; cf. Frontin. Str. 4.7.9." ;
	dprr:hasID 1348 .
