<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasID 1 ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2897> rdfs:label "Post Assertion Note: #2897" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent with three others to aid Ptolemy VII against Ptolemy VI and assist his return to Cyprus (Polyb. 33.11.6-7; cf. FOR 1.31, 172f.; Otto, ABAW 11 [1934] 113-123)." ;
	dprr:hasID 2897 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2896> rdfs:label "Post Assertion Note: #2896" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Presumably men of praetorian rank, but evidence is lacking." ;
	dprr:hasID 2896 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2842> rdfs:label "Post Assertion Note: #2842" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Egypt to induce Ptolemy VI to be reconciled again (see 163) with his brother and cede him Cyprus, but were put off by Ptolemy VI and stopped by a rising against Ptolemy VII in Cyrene (Polyb. 31.10.9-10, and 17-18; cf. 31.20.1-6). See Otto, ABAW 11 (1934) 95.{443}" ;
	dprr:hasID 2842 .
