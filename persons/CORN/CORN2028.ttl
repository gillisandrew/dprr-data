<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5761> rdfs:label "Post Assertion Note: #5761" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Legate, when his life was endangered by mutinous legions which he was bringing to Sicily for Caesar (Cic. Att. 11.21.2, and 22.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5697> rdfs:label "Post Assertion Note: #5697" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Commander of the camp as Legate under Caesar at Dyrrachium (Caes. BC 3.51.1), and commander of the right wing of Caesar's army at Pharsalus (Caes. BC 3.89.2, and 99.4; App. BC 2.76)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4780> rdfs:label "Post Assertion Note: #4780" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chr. 354 (Sulla et Peto). Sulla was elected by all the centuries (Cic. Sull. 91). Both were convicted of bribery, under the Calpurnian law (Cic. Sull. 11 and 49-50 and 8 1 ; Fin. 2.62; Sall. Cat. 18; Liv. Per. 10 1 ; Ascon. 75, and 88 C; Suet. Iul. 9; Dio 36.44.3-5; Schol. Bob. 78-79 Stangl). See Degrassi 131, 488." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4649> rdfs:label "Post Assertion Note: #4649" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 67, Promagistrates; and below, note 9" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4647> rdfs:label "Post Assertion Note: #4647" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "4 See note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4254> rdfs:label "Post Assertion Note: #4254" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Settled Sullan colonists at Pompeii (Cic. Sull. 60-62)." .
