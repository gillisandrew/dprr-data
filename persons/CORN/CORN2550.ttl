<http://romanrepublic.ac.uk/rdf/entity/PersonNote/801> rdfs:label "Person Note: #801" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/13> ;
	dprr:hasNoteText "43 v. Chr. gab er bei Spielen in Gades eine Praetexta Iter über Bürgerkriegserlebnisse; er verfaßte \"exegetische Schriften\" in mindestens 18 Büchern, u. a. über Hercules - dessen Keule er auch auf seinen Münzen darstellte - und den Hymenaeus." .
