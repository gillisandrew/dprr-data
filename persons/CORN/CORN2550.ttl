<http://romanrepublic.ac.uk/rdf/entity/PersonNote/802> rdfs:label "Person Note: #802" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
