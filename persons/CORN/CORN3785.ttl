<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7330> rdfs:label "Post Assertion Note: #7330" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "L. Sulla P. f., Cos. 5 B.C., was probably a son of this man and grandson of the consul designate for 65 (386), although he might possibly be descended from RE no. 385, the Catilinarian conspirator. It is unlikely that no. 387, who was a young man in 54 (Cic. QF 3.3.2, cf. Sulla 88-89, 62 B.C.) and alive in 46 (Fam. 15.17.2), failed to become a senator if he survived. (TJC)\n" ;
	dprr:hasID 7330 .
