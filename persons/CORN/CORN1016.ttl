	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/23> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9823> rdfs:label "Post Assertion Note: #9823" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/23> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9253> rdfs:label "Post Assertion Note: #9253" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 756, footnote 510" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8416> rdfs:label "Post Assertion Note: #8416" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 730" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7245> rdfs:label "Post Assertion Note: #7245" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Badian, noting the uncertain reading of the cognomen in ILS 864 (SCHIZIAM or FIIZIVM) and the early doubling of the consonant in caussa, suggests that the inscription may honor, not a Scipio, but L. Cornelius Sisenna (374), Pr. 78 and possibly procos. in Sicily in 77 (MRR 2.86, 90) (Gnomon 39, 1967, 94, note 1). See Degrassi, ILLRP 320, and Acta 5th Internat. Cong. Gr. and Lat. Epig. 169-170; and also Balsdon, Historia 21, 1972, 224-234.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2378> rdfs:label "Post Assertion Note: #2378" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "According to Valerius of Antium, they were also members of the embassy with flamininus (Liv. 39.56.7- fr. 49 Peter; cf. Plut. Flam. 21.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2314> rdfs:label "Post Assertion Note: #2314" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "According to Antias he was sent to Asia after his conviction to settle disputes between Antiochus and Eumenes, and there gained money to celebrate the games he had vowed in the war (Liv. 39.22.8-10; cf. Plin. NH 33.138). It is probable that he celebrated the games, but before his conviction in 184. The legateship, though possible, is extremely doubtful since the Scipios did not appear in the settlement of Asiatic affairs after 190." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2254> rdfs:label "Post Assertion Note: #2254" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated a triumph as Proconsul (Polyb. 21.24.16-17; Cic. Prov. Cons. 18; Liv. 37.58.6-59.6; 38.59.6; Act. Tr., Degrassi 80f., 554; Elog., CIL 1\n     .1, p. 194- Inscr. Ital. 13.3.15; Val. Max. 4.1.8, and ext. 9; 5.3.2, and 5.2; 8.1, damn. 1; Plin. NH 33.148; 35.22; Plut. Cat. Mai. 18.1; Gell. 6.19.3; Eutrop. 4.4; Ampel. 24; cf. Grueber, CRRBM 1.206; 2.267f.; Cesano, Stud. Num. 1 [1942] 191f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2200> rdfs:label "Post Assertion Note: #2200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Letters of the Scipios to towns of Asia: to Heraclea Pontica, Memnon 26.2, in FGrH 3B.349f.; to Heraclea under Latmus, SEG 2.566, and see Holleaux, RF 52 (1924) 29f.; to Colophon, SEG 4.567, and Holleaux, ib. 32f. See also at Aptara in Crete, Guarducci, I. Cret. 2.3.5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2199> rdfs:label "Post Assertion Note: #2199" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Phil. 11.17; Liv. 36.45.9; Fast. Cap., Degrassi 48f., 122, 454f.; Gell. 16.4.2; Eutrop. 4.4; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod. Scipio was assigned Greece as his province with permission to carry the war into Asia (Liv. 37.1.7-10, 2.2-3, and 4.1-4; Val. Max. 5.5.1). Making a truce in Greece, he went on to Asia to win a decisive victory over Antiochus at Magnesia (Liv. 37.6-7, 18.10, 25.8, and 33-44; cf. Polyb. 21.4-5, 8, and 11, and 13-15; Cic. Mur. 31; Phil. 11.17; Diod. 29.5-10; Frontin. Str. 4.7.30; Flor. 1.24.14-18; App. Syr. 23, and 28-29; Iustin. 31.7-8; Eutrop. 4.4; Zon. 9.20; cf. Oros. 4.20.22). He made offerings at Delos (I. de Délos 427; 428; 442 B, 85-86 and 101; 1429 B, 23 and 28, and ii 16; 1441 A, 106; 1450 A, 68; almost all in 190 and 189; comment. I. de Délos 2, pp. 166f.). See also SEG 1.440-4.567; 1.144 at Delphi; 2.566; I. Cret. 2.3.5; Memnon 26.2, in FGrH 3B.349f.\n     Laelius was assigned Italy, and held command in Gaul (Liv. 37.1.10, 46.10, and 47.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2190> rdfs:label "Post Assertion Note: #2190" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See above, Envoys." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2188> rdfs:label "Post Assertion Note: #2188" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Rome to report the victory at Thermopylae (Liv. 36.21.7-9). See 193, note 1; and I. de Délos 442 B, 89 and 90." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2122> rdfs:label "Post Assertion Note: #2122" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. CIL 1\n     .2.612- ILS 864; Cic. De Or. 2.280. On offerings at Delos (I. de Délos 442B, 89-90) he is termed {Gr}, but the reference is probably to 190 B.C. and his consulate." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2121> rdfs:label "Post Assertion Note: #2121" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Asiaticus is the cognomen which appears in Livy (37.58.6) and Fast. Cap. (190) after his victory at Magnesia; but Asiagenus or Asiagenes is found in Livy (39.44.1), Diod. (34.33.1), Eutrop. (4.4.3), and was used by later members of the family (ILS 8). Holleaux (Hermes 48 [1913] 95f.) would date his dedication at Delos this year, when he supposes Africanus went to the East from Africa (see Legates), since he is termed {Gr} -  praetor, and precedes the admirals of 192 and 191. See however 191, when he served as a praetorian Legate under Glabrio." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2120> rdfs:label "Post Assertion Note: #2120" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 34.54.2 Provinces and armies Liv. 34.55.6, and 56.9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2073> rdfs:label "Post Assertion Note: #2073" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aed. Cur. is the probable restoration in CIL 1\n     .1, p. 194- Inscr. Ital. 13.3.15. Elimination of the years when the Aediles are known leaves 195 the only probable date. See Seidel 31f.; and cf. Polyb. 10.4-5, and above, 213, note 4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2039> rdfs:label "Post Assertion Note: #2039" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elogium, CIL 1\n     .1, p. 194- Inscr. Ital. 13.3.15. The latest possible date (see 195, Aediles)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1897> rdfs:label "Post Assertion Note: #1897" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Scipio to bring the Carthaginian envoys to Rome (Liv. 30.38.4). On Veturius, see Lübker, no. 9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1869> rdfs:label "Post Assertion Note: #1869" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 204, and 202, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1827> rdfs:label "Post Assertion Note: #1827" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Guarded the right wing of the fleet as Scipio crossed to Africa (Liv. 29.25.10; see 205, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1826> rdfs:label "Post Assertion Note: #1826" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See Liv. 38.58.8, Legate in Spain and Africa." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1789> rdfs:label "Post Assertion Note: #1789" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under P. Scipio in Sicily; in command of the garrison at Messana (Liv. 29.7.2; on the title, see 38.58.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1759> rdfs:label "Post Assertion Note: #1759" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served as Legatus under his brother (Liv. 28.28.14)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1757> rdfs:label "Post Assertion Note: #1757" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Rome with captives to announce the capture of Spain (Liv. 28.17.1; cf. App. Ib. 29)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1738> rdfs:label "Post Assertion Note: #1738" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Was placed in charge of the attack on the Spanish town of Orongis by his brother P. Scipio; no title preserved (Liv. 28.3-4; Zon. 9.8; cf. Liv. 38.58.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1733> rdfs:label "Post Assertion Note: #1733" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his brother P. Scipio in Spain; sent to Rome with Hanno and other Carthaginian captives (Liv. 28.4.2-4; Zon. 9.8). See below, Lieutenants." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10048> rdfs:label "Post Assertion Note: #10048" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph ex Asia de rege Antiocho. MRR I.362, Itgenshorst no. 178, Rich no. 177." .
