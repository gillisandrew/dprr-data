	dprr:hasID 6808 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3091> rdfs:label "Post Assertion Note: #3091" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 1\n     .2.15- ILS 6. It is not known when he was coopted. See Bardt, Priester 30.{483}" ;
	dprr:hasID 3091 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3082> rdfs:label "Post Assertion Note: #3082" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 1\n     .2.15- ILS 6. Issued an edict expelling Chaldeans and Jews from the city of Rome (Val. Max. 1.3.2; cf. Liv. Oxy. Per. 54)." ;
	dprr:hasID 3082 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3056> rdfs:label "Post Assertion Note: #3056" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 1\n     .2.15. The latest probable date before his praetorship." ;
	dprr:hasID 3056 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2948> rdfs:label "Post Assertion Note: #2948" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Termed Tr. Mil. II in his Elogium (CIL 1\n     .2.15- ILS 6), the post he probably held when sent to Carthage to superintend the delivery of their weapons to the Romans (App. Lib. 80). See 150." ;
	dprr:hasID 2948 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2947> rdfs:label "Post Assertion Note: #2947" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "According to his Elogium (see above) he had already been Decemvir stlitibus iudicandis and Quaestor. It remains uncertain whether this was his first or his second appointment as Tribune of the Soldiers." ;
	dprr:hasID 2947 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2929> rdfs:label "Post Assertion Note: #2929" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elog., CIL 1\n     .2.15- ILS 6; see 149, Tribunes of the Soldiers." ;
	dprr:hasID 2929 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2925> rdfs:label "Post Assertion Note: #2925" ;
