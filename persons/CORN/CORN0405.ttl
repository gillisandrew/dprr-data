	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/530> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/529> ;
	dprr:hasOriginalText "P. Cornelius - f. - n. - - - - - Pat. (40)" ;
