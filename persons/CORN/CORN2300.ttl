<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9353> rdfs:label "Post Assertion Note: #9353" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/10> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "ref. 426" ;
	dprr:hasID 9353 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7340> rdfs:label "Post Assertion Note: #7340" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Monetalis 56 and quaestor 54. Sydenham dates his SC coins to 62 (CRR 146, nos. 882-884), but H. B. Mattingly to 54, holding that they refer to the celebration of the Ludi Victoriae Sullanae at Praeneste by the quaestor urbanus (NC 16, 1956, 200f.); but see Crawford, RRC 1.449-451, no. 426, who dates his coinage to 56. Enter this reference in MRR 2.437, and Index, 557.\n" ;
	dprr:hasID 7340 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5804> rdfs:label "Post Assertion Note: #5804" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 49-47, Promagistrates. He was captured, while fleeing to Spain, by Sittius and put to death (Bell. Afr. 87.8; 95; Liv. Per. 114; Suet. Iul. 75; Flor. 2.13.90; Eutrop. 6.23.2; Auct. Vir. Ill. 78.9; Oros. 6.15.5; cf. App. BC 2.100). See Legates, on Afranius." ;
	dprr:hasID 5804 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5746> rdfs:label "Post Assertion Note: #5746" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor pro praetore (see 49, and 48, Promagistrates), who probably kept his rank in Africa (see 46, Promagistrates)." ;
	dprr:hasID 5746 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5659> rdfs:label "Post Assertion Note: #5659" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor pro praetore (see 49, Promagistrates). He was active in Macedonia in 48, where he opposed Domitius Calvinus, and fled to Africa after Pharsalus (Dio 41.51.3; 42.13.3)." ;
	dprr:hasID 5659 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5546> rdfs:label "Post Assertion Note: #5546" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pro quaestore (Cic. Att. 9.1.4); Proquaestor pro praetore (IG 9.1.143–ILS 8778, #). The proposal to send him to Mauretania was vetoed (see Tribunes of the Plebs, Marcius Philippus). He recruited troops for Pompey and joined him in Epirus (Cic. Att. 8.3.7, and 12A.3; see 48, Promagistrates). On his title, see above, on L. Antonius." ;
	dprr:hasID 5546 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5505> rdfs:label "Post Assertion Note: #5505" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 57, Augurs. Elected before Lentulus Spinther." ;
	dprr:hasID 5505 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5498> rdfs:label "Post Assertion Note: #5498" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "A probable member of the college of Augurs on the eve of the death of Hortensius." ;
	dprr:hasID 5498 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5237> rdfs:label "Post Assertion Note: #5237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ascon. 20, 28 C; Grueber, CRRBM 1.489f." ;
	dprr:hasID 5237 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5121> rdfs:label "Post Assertion Note: #5121" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Augur before 57 (Dio 39.17; the lituus on his coins (ca. 64 B.C.) may refer to his father's office, Grueber, CRRBM 1.472)." ;
	dprr:hasID 5121 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4876> rdfs:label "Post Assertion Note: #4876" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Pompey, and was first over the wall at Jerusalem (Joseph. BJ 1.149 and 154; cf. AJ 14.66 and 73)." ;
	dprr:hasID 4876 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/9822> rdfs:label "Post Assertion: #9822" ;
