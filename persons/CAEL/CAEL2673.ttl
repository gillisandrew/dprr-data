	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His place in Cicero's list of Antony's supposed Senate in his camp at Mutina suggests that he held the aedileship in or very soon before 44 (Cic. Phil. 13.26)." .
