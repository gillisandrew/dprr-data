<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3856> rdfs:label "Post Assertion Note: #3856" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul (App. BC 1.48). After winning a victory, probably over the Paeligni, Caesar died while besieging Asculum (App.; cf. Liv. Per. 73, but in this passage Rossbach's reading Servius Sul\n     \n      is probably preferable)." ;
	dprr:hasID 3856 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3836> rdfs:label "Post Assertion Note: #3836" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Crushed a revolt of the Salluvii in Gallia Transalpina (Liv. Per. 73)." ;
	dprr:hasID 3836 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3835> rdfs:label "Post Assertion Note: #3835" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 It is possible that he had held the praetorship, and in 90 was a promagistrate in Gaul. See Promagistrates." ;
	dprr:hasID 3835 .
