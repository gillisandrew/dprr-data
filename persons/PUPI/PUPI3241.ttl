<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7493> rdfs:label "Post Assertion Note: #7493" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator. See MRR 2.495. Probably a praetorius by 129, as he is listed third in the large consilium in the SC de agro Pergameno (Sherk, RDGE no. 12, pp. 63-73). On his adoption of a Calpurnius Piso, see Cicero Dom. 35. On the date, see M'. Aquillius (10), above.[176]\n" ;
	dprr:hasID 7493 .
