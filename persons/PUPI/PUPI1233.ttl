<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2898> rdfs:label "Post Assertion Note: #2898" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Liguria when Massilia complained of attacks by the Oxybii and the Deciates (see above, Consuls), but were mistreated and Flaminius wounded (Polyb. 33.8-9; cf. Obseq. 17)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2369> rdfs:label "Post Assertion Note: #2369" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Placed in charge of a quaestio de Bacchanalibus (Liv. 40.19.10). See Lübker, no. 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2366> rdfs:label "Post Assertion Note: #2366" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 39.45.1-2 Provinces 39.45.4-5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2325> rdfs:label "Post Assertion Note: #2325" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 39.39.2. On Pupius, see Lübker no. 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2324> rdfs:label "Post Assertion Note: #2324" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy terms them Aediles (39.39.2), but during this period plebeians in odd numbered years can only be Aediles of the Plebs." .
