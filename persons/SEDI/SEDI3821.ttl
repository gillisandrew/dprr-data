	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 39, listed in the commission in the SC de Aphrodisiensibus (J. M. Reynolds, Aphrodisias and Rome 71). Badian suggests emending the name to (E)HO1OE, and that he was a younger brother of C. Hedius C. f. Thorus (ZPE 55, 1984, 111).\n" ;
	dprr:hasID 7565 .
