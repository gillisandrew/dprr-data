<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9200> rdfs:label "Post Assertion Note: #9200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 731" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2728> rdfs:label "Post Assertion Note: #2728" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cn. Octavius succeeded M. Claudius Marcellus. Liv. 44.18.7; Fest. 188 L." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2727> rdfs:label "Post Assertion Note: #2727" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Bardt (Priester 30) would prefer to identify the Decemvir s. f. with the Consul of 183." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2722> rdfs:label "Post Assertion Note: #2722" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Philippus in Macedonia (Liv. 44.3.2; see Xviri s. f. below)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2597> rdfs:label "Post Assertion Note: #2597" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Aetolian assembly at Delphi, he induced the warring factions to place hostages at Corinth, and then attended the Achaean assembly at Aegium (Liv. 42.5.10-6.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2596> rdfs:label "Post Assertion Note: #2596" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "M. is a probable restoration. The activities recorded favor the view that the Envoy was a consular and one or other of the two mutually indistinguishable Marcelli of this period, not no. 225, the Consul of 166, 155, and 152." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2418> rdfs:label "Post Assertion Note: #2418" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Gaul, but had already received a successor when summoned to aid Paullus in Liguria (Liv. 40.25.9, and 26.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2399> rdfs:label "Post Assertion Note: #2399" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His command in Gaul was prorogued, with additions to his army (Liv. 40.1.6). He consulted the Senate when Ligurians wished to surrender to him rather than to the Consuls (40.16.5-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2365> rdfs:label "Post Assertion Note: #2365" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Off. 1.33; Attic. in Nep. Hann. 13; Liv. 39.45.1; Fast. Cap., Degrassi 48f., 122, 456f.; Obseq. 4; Chr. 354; Fast. Hyd.; Chr. Pasc.; Oros. 4.20.27; Cassiod. Both Consuls were assigned to Liguria (Liv. 39.45.3), but Marcellus was sent to oppose the settlement of Transalpine Gauls near Aquileia, and wanted to begin an Istrian war (Liv. 39.45.3, 54.1-4, 55.4-5, and 56.3-5; cf. Piso fr. 35 Peter- Plin. NH 3.131; Zon. 9.21)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2318> rdfs:label "Post Assertion Note: #2318" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE) is inclined to identify the Consul of 183 with the Marcellus who became Praetor in 188." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2317> rdfs:label "Post Assertion Note: #2317" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 39.23.2 Provinces omitted in Livy." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2274> rdfs:label "Post Assertion Note: #2274" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Liv. 38.42.7; Dio fr. 61; Val. Max. 6.6.3" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2272> rdfs:label "Post Assertion Note: #2272" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 38.35.2 Provinces and armies 38.35.10." .
