<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1747> rdfs:label "Post Assertion Note: #1747" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor to protect Tarentum (Liv. 28.10.15, and 11.12; cf. Crake 286)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1746> rdfs:label "Post Assertion Note: #1746" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 208, note 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1721> rdfs:label "Post Assertion Note: #1721" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor (Liv. 27.43.2) at Tarentum and among the Sallentini (Liv. 27.36.13, 38.8, and 40.11-14). Sent Hasdrubal's messsengers to Nero (27.43.1-5).{296}" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1720> rdfs:label "Post Assertion Note: #1720" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 208, note 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1719> rdfs:label "Post Assertion Note: #1719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy omits the regular list of prorogations for this year with the exception of Q. Fulvius Flaccus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1680> rdfs:label "Post Assertion Note: #1680" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.29.6; cf. 27.36.13." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1679> rdfs:label "Post Assertion Note: #1679" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Flamen, a cognomen otherwise unknown, is rejected by Johnson and Hallward in the Oxford text of Livy 27.22.3 ad loc. (cf. Münzer RE), because to be one of the Flamens Q. Claudius must have been a patrician and could not have held the Tribunate of the Plebs in 218. The Praetor of this year and the Tribune of 218 however need not be the same person." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1678> rdfs:label "Post Assertion Note: #1678" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 27.21.5 Provinces 27.22.3." .
