	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1680> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1679> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1678> ;
	dprr:hasPosition 1 ;
	dprr:hasOriginalText "Q. Claudius (Flamen) (151, cf. 29)" ;
	dprr:hasOfficeXref "Tarentum" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
