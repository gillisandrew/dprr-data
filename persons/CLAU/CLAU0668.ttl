	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chr. 354 (Canina et Lepido); Fast. Hyd. (Lepido et Caecina); Chr. Pasc.; Cassiod. (C. Claudius et M. Aemilius); Degrassi 112, 428f." ;
	dprr:hasID 1035 .
