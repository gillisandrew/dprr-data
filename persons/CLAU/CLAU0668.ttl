	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Chr. 354 (Canina et Lepido); Fast. Hyd. (Lepido et Caecina); Chr. Pasc.; Cassiod. (C. Claudius et M. Aemilius); Degrassi 112, 428f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10011> rdfs:label "Post Assertion Note: #10011" ;
