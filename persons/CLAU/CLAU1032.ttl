<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8421> rdfs:label "Post Assertion Note: #8421" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 728" ;
	dprr:hasID 8421 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7578> rdfs:label "Post Assertion Note: #7578" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 202 (MRR 1.315), or (250), Pr. 181 (1.384) or (251), Pr. 178 (1.395). Leg., Amb. a, b, 172 (MRR 1.412, and see 415, notes 4-6). On these embassies, see Walbank, Comm. on Polyb. 3.294-295. In embassy b, correct T. to Ti.[55]\n" ;
	dprr:hasID 7578 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2630> rdfs:label "Post Assertion Note: #2630" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Asia and the islands to urge the allies, and particularly Rhodes, to join them against Perseus (Liv. 42.45.1-7; Polyb. 27.3.1-5; cf. App. Mac. 11.4), and reported the attitude of Rhodes to Rome (Polyb. 27.6.1). See no. a, and note 4. On Postumius, see Münzer, APF 213ff." ;
	dprr:hasID 2630 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2627> rdfs:label "Post Assertion Note: #2627" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy relates the activities of this embassy under the consular year 171, but in a Polybian passage (42.37ff.) which includes events that date from the autumn of 172 (De Sanctis 4.1.398f.). The phrase in Livy which places their return at the beginning of winter is contradicted by Polybius' statement that they carried on their negotiations during the winter (27.2.12; cf. Liv. 42.52.8, from Polybius)." ;
	dprr:hasID 2627 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1875> rdfs:label "Post Assertion Note: #1875" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 30.26.1; Fast. Cap., Degrassi 48f., 121 452f., cf. Fast. Fer. Lat., Degrassi 148f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod. Servilius was assigned Etruria (Liv. 30.27.6, cf. 1-2; Zon. 9.14), but had to stay at Rome (30.38.6), and finally appointed a Dictator to hold elections, and departed for his province (30.39.4). Claudius was assigned Africa with imperium equal to that of Scipio (Liv. 30.27.1-5), but through delay for preparations and because of storms failed to arrive there at all (Liv. 30.38.6-7, and 39.1-3; Zon. 9.14). On coins celebrating M. Servilius, see Grueber, CRRBM 1.179, 229, 469; Cesano, Stud. Num. 1.172f." ;
	dprr:hasID 1875 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1799> rdfs:label "Post Assertion Note: #1799" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent supplies of grain and clothing for Scipio's soldiers in Africa (Liv. 29.36.1-3)." ;
	dprr:hasID 1799 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1798> rdfs:label "Post Assertion Note: #1798" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 29.11.11 Provinces and armies 29.13.1-2, 5-6; cf. 30.1.7, and 2.3 and 5." ;
	dprr:hasID 1798 .
