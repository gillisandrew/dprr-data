<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8747> rdfs:label "Post Assertion Note: #8747" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 755, footnote 467" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7804> rdfs:label "Post Assertion Note: #7804" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 56. Procos. Asia 55-53. See MRR 2.218. He is honored in an inscription of Pergamum (IGRP 4.417; Tuchelt, Fruhe Denkmdler no. 200).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5281> rdfs:label "Post Assertion Note: #5281" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (see 55, and 54, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5244> rdfs:label "Post Assertion Note: #5244" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia, his command prorogued into 53 (Cic. Scaur. 35; see 55, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5200> rdfs:label "Post Assertion Note: #5200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Asia (cistophori of Ephesus, Pergamum, and Tralles, Head, HN² 576, 535, and 660; B. M. Cat., Mysia xxx f., Lydia cxl and 334; Cic. Scaur. 35; cf. Cic. Ait. 4.15.2, praetor, dated July 27, 54)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5125> rdfs:label "Post Assertion Note: #5125" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Attempted to prevent the removal of the tablet on the Capitol that recorded the law under which Cicero was banished (Dio 39.21.1-2; cf. Plut. Cic. 34)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5063> rdfs:label "Post Assertion Note: #5063" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A brother of P. Clodius had charge of Caesar’s troops in Italy early in 58 (Cic. Sest. 41), probably Gaius rather than Appius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4366> rdfs:label "Post Assertion Note: #4366" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Scaur. 34. The date of his inauguration into this priesthood must precede his father's death in 76 (see above, Promagistrates, on Ap. Claudius Pulcher)." .
