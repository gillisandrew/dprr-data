<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1474> rdfs:label "Post Assertion Note: #1474" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed by the Consul Sempronius to hold the elections (Liv. 25.2.3-5; Fast. Cap., Degrassi 46f., 119, 446f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1375> rdfs:label "Post Assertion Note: #1375" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Scipio held the comitia which elected Varro Consul (Liv. 22.34.11-35.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1255> rdfs:label "Post Assertion Note: #1255" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., names entire, Degrassi 44f., 118, 440f. On the enumeration of forces in Italy carried through at this time, see Fab. Pict. fr. 23 Peter, and Eutrop. 3.5; Polyb. 2.24; Diod. 25.13; Liv. Per. 20; Plin. NH 3.138." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1209> rdfs:label "Post Assertion Note: #1209" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Brut. 72; Sen. 50; Tusc. 1.3; Fast. Cap. (names entire); Gell. 17.21.42; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; see Degrassi 42f., 117, 438f. The year when translations of Greek plays were first presented in Rome (cic. Brut. 72; Sen. 50; Tusc. 1.3; Gell. 17.21.42)." .
