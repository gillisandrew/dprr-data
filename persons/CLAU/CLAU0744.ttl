<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1384> rdfs:label "Relationship Assertion Reference: #1384" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Plinius vermengt hier Vater P. cos. 249 [anno DV] und Sohn Ap., der tatsächlich der Enkel von Caecus war. Ap. kann auch nicht einfach verschrieben für P. sein, weil anno DV und Caeci nepote nicht in Übereinklang zu bringen sind." ;
	dprr:hasExtraInfo "Plin. n.h. XV 2" .
