	dprr:hasNoteText "Sent to protect the repopulated colonies of Cremona and Placentia (Liv. 28.11.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1742> rdfs:label "Post Assertion Note: #1742" ;
