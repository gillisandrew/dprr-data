	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "As the Claudii Aselli were plebeian (see 205, Aediles of the Plebs), the Praetors of 206, as well as 207, were all plebeians." .
