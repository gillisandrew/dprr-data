<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5639> rdfs:label "Post Assertion Note: #5639" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Q. Cassius Longinus in Farther Spain, but joined the mutinous troops and led them until Lepidus came to take command (Bell. Alex. 57-64; Dio 42.15-16, cf. 43.1.2; and 29.1). See PIR² 2.215, no. 926; De Laet no. 104." ;
	dprr:hasID 5639 .
