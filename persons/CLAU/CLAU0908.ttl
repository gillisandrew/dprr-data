<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2166> rdfs:label "Post Assertion: #2166" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/908> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
