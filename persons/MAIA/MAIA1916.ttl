<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9803> rdfs:label "Post Assertion Note: #9803" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cichorius identifies him as a Tribune of the Soldiers based on the list of members of the staff of Pompeius Strabo at Asculum (ILS 8888; RS 144-155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7446> rdfs:label "Post Assertion Note: #7446" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. mil.? 89 (see MRR 2.35). This is Cichorius' reading (RS 154f.); but Bang read the fragments of the letters as M. FAB[I] M. F. [SE]R (CIL 6.37045-ILS 8888). The reading remains uncertain. (RS, CP) See now Criniti, L'Epigrafe di Asculum 19 and note 24, 121-123, who reads M. [M]aia[ni(us] M. [F., Se]r(gia Tribu).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/4558> rdfs:label "Post Assertion: #4558" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1916> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9803> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7446> ;
	dprr:hasOriginalText "? M[aia]nius" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/10> ;
	dprr:hasDateStart -89 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasDateEnd -89 .
