<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5029> rdfs:label "Post Assertion Note: #5029" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Died before July, 59. Cicero, who was invited to serve in his place (Att. 2.19.4) but refused, described the position both as a quinquevirate (Prov. Cons. 41) and as a vigintivirate (Att. 9.2a.1; Vell. 2.45.2; Quintil. Inst. Or. 12.1.16)." ;
	dprr:hasID 5029 .
