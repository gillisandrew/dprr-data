	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Farther Spain (Cic. Vat. 12)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4848> rdfs:label "Post Assertion Note: #4848" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Kept the record of the evidence against the Catilinarian conspirators (Cic. Sull. 42)." .
