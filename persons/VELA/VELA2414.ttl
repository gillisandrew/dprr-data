<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7822> rdfs:label "Post Assertion Note: #7822" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Certainly an envoy, probably a Tr. mil. under Caesar in 56 (BG 3.7). See Syme, Historia 5, 1956, 209f.?RP 1.321; Suolahti, Junior Officers 314.\n" ;
	dprr:hasID 7822 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5159> rdfs:label "Post Assertion Note: #5159" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prefects or Tribunes of the Soldiers of equestrian rank, sent by Crassus (see Lieutenants) to collect grain from the Veneti, Esubii, and Curiosolites, but were arrested and held by them (Caes. BG 3.7.2-4, 8.2-4, 9.3, 10.2, and 16.4; Dio 39.40. 1; Oros. 6.8.6-7)." ;
	dprr:hasID 5159 .
