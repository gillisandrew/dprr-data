	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 1(2).2.838, and 839-ILS 8208. Probably the Monetalis of ca. 89 B. C. " .
