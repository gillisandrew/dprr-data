<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8701> rdfs:label "Post Assertion Note: #8701" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 747, footnote 260" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7233> rdfs:label "Post Assertion Note: #7233" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 94. Aedile ca. 97 (Cic. Planc. 19; see Syme, Historia 13, 1964, 158- 159-RP 2.607-608). Pr. 94. In MRR 2.12, refer also to Cic. Planc. 19. Procos. Macedonia, 93-87. His imperium may well have been pro consule, like that of his colleague Gellius Publicola in Asia in 93-92 (MRR 2.15). On his full name and his career, with a stemma of the family, see Syme, Historia 13, 1964, 156-166, esp. 158- 159-RP 2.605-616; Wiseman, NM 260, no. 388; and, explaining his long term in Macedonia, Badian, Studies 73-74.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4023> rdfs:label "Post Assertion Note: #4023" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (see 93-87, Promagistrates). His Legate Bruttius Sura checked the advance of" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3984> rdfs:label "Post Assertion Note: #3984" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (see 93-87, Promagistrates). Mithridates roused the Thracians against Macedonia and Greece, but Sentius repulsed them (Oros. 5.18.30; cf. Cic. Verr. 2.3.217; Pis. 84; Liv. Per. 76; Dio 30-35, fr. 101)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3917> rdfs:label "Post Assertion Note: #3917" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia, where he was troubled by Thracian invaders (Liv. Per. 74; Oros. 5.18.30). See 93-87, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3860> rdfs:label "Post Assertion Note: #3860" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (see 93-87, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3820> rdfs:label "Post Assertion Note: #3820" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (see 93-87, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3793> rdfs:label "Post Assertion Note: #3793" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia, where he suffered a defeat at the hands of the Thracians (Liv. Per. 70; see 93-87, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3771> rdfs:label "Post Assertion Note: #3771" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Macedonia (Cic. Pis. 84; Liv. Per. 70; Oros. 5.18.30; see 94, Praetors, and 93-87, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3770> rdfs:label "Post Assertion Note: #3770" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "5 He is termed Praetor by Cic., Liv., and Oros., though a promagistrate all the time. The evidence therefore favors an imperium pro praetore." .
