<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6116> rdfs:label "Post Assertion Note: #6116" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Served under Antony in the war about Mutina (Cic. Phil. 6.10; 10.22; 12.20; 13.2 and 27). Pontius Aquila drove him away from Pollentia (Cic. Phil. 11. 14; 13.27; Dio 46.38.3; Zonar. 10. 15)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5330> rdfs:label "Post Assertion Note: #5330" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A supporter of Clodius who was prominent in the disorders after his murder (Ascon. 31-52 Q passim; App. BC 2.21; Dio 40.49; cf. Cic. Mil. 12-13 and 47 and 90-91; Fam. 7.2.2-3; Att. 6. 1. 10; Schol. Bob. 115 Stangl). Immediately after his year in office Cicero prosecuted him under the law of Pompey de vi and sent him into exile (Cic. Fam. 7.2.2-3; Phil. 6.10; 13.27; Plut. Pomp. 55.5; Cat. Min. 48.4-5; Dio 40.55; cf. Val. Max. 6.2.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/6830> rdfs:label "Post Assertion: #6830" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2477> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6116> ;
	dprr:hasPosition 19 ;
	dprr:hasOriginalText "T. Munatius Plancus Bursa (32)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/12> ;
	dprr:hasDateStart -43 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasDateEnd -43 .
