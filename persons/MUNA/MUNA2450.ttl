	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (see 54, and 49, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5362> rdfs:label "Post Assertion Note: #5362" ;
