	dprr:hasNoteText "Legate under Caesar in Gaul (Caes. BG 5.24.3, and 25.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10167> rdfs:label "Post Assertion Note: #10167" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
