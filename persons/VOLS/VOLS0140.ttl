<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8035> rdfs:label "Post Assertion Note: #8035" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. pl. 461 ? 460-457? In MRR 1.37, refer also to Liv. 3.29.6. See R. M. Ogilvie, Comm. Liv. 421, 445.\n" ;
	dprr:hasID 8035 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/227> rdfs:label "Post Assertion Note: #227" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Re-elected for the fifth time (Liv. 3.29.8; Dion. Hal. 10.26.4). Secured passage of a bill to increase the number of the Tribunes to ten (Liv. 3.30.5-7; Dion. Hal. 10.26.4-30.6; cf. Zon. 7.17)." ;
	dprr:hasID 227 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/217> rdfs:label "Post Assertion Note: #217" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Re-elected (Liv. 3.24.9, and 25.4; Dion. Hal. 10.22.1). See note 2." ;
	dprr:hasID 217 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/216> rdfs:label "Post Assertion Note: #216" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Another tradition keeps Volscius continuously in office from 461 to 457. See these years." ;
	dprr:hasID 216 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/208> rdfs:label "Post Assertion Note: #208" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Tribunes of 460 were re-elected (Liv. 3.21.3; Dion. Hal. 10.19.3; cf. Val. Max. 4.1.4)." ;
	dprr:hasID 208 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/205> rdfs:label "Post Assertion Note: #205" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Tribunes of 461 were re-elected (Liv. 3.14.6, and 19.6; Dion. Hal. 10.8.5-13.7)." ;
	dprr:hasID 205 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/201> rdfs:label "Post Assertion Note: #201" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "According to Dion. Hal. (10.7.1), a member of the college of this year, but according to Livy (3.13.1), of one of several years earlier, his testimony did most to send Quinctius into exile (Liv. 3.13.1-3, and 24.3; Dion. Hal. 10.7.1-5)." ;
	dprr:hasID 201 .
