	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Received a prefecture from Cicero in order to attend to business in Cappadocia for Brutus (Cic Att. 6.1.4). See above, Tribunes of the Soldiers." .
