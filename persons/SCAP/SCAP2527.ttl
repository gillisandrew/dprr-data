	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He first accepted from Cicero, and then refused, this position while attending to business for Brutus in Cappadocia (Cic. Att. 6.3.5; cf. 6.1.4, a prefecture)." .
