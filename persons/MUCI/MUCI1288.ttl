	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., Degrassi 48f., 122, 458f.; Obseq. 10; Chr. 354; Oros. 4.20.34; Cassiod.; and on Lepidus, Cic. Prov. Cons. 20; Val. Max.{402} 4.2.1; 6.6.1; Fast. Hyd.; Chr. Pasc. Both consuls campaigned in Liguria and celebrated triumphs (Act. Tr. Cap. and Urbisalv., Degrassi 80f., 338f., 555; cf. Liv. 41.19.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2540> rdfs:label "Post Assertion Note: #2540" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Obsequens and Cassiodorus give Q. as the praenomen, confusing him with his brother, the Consul of 174." .
