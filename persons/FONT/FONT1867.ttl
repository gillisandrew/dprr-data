	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3833> rdfs:label "Post Assertion Note: #3833" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Font. 46-49; cf. Gell. 1.12.2; see above, Legates, Fonteius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3832> rdfs:label "Post Assertion Note: #3832" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "13 Fonteia, a sister of M. Fonteius, was a Vestal Virgin at the time of his trial about 69 B. C. (Cic. Font. 46-49), but a daughter of the Legate Fonteius, who was killed this year at Asculum (see above, Legates), must have begun her service while her father still lived (cf. Gell. 1. 12.2)." .
