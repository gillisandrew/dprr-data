<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2782> rdfs:label "Post Assertion Note: #2782" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably prorogued in Sardinia since his successor A. Manlius Torquatus was kept in Italy (Liv. 45.16.4; see 169, and 168, Praetors)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2740> rdfs:label "Post Assertion Note: #2740" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "When Papirius' province (see Praetors) was changed to Pr. Peregrinus, Capito's command in Sardinia was probably prorogued (Liv. 45.12.13; see 169)." .
