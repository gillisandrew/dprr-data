	dprr:hasNoteText "His imperium as Proconsul in Farther Spain was prorogued (Liv. 41.15.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2519> rdfs:label "Post Assertion Note: #2519" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in command in Farther Spain, since his imperium was prorogued in 178 (Liv. 41.15.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2490> rdfs:label "Post Assertion Note: #2490" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The presence in Spain in 177 of Fonteius Capito and Titinius Curvus indicates that they received the command as Praetors in 178 (Liv. 41.15.11)." .
