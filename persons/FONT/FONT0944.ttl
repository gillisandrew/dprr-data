	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Val. Max. VIII 5.4" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1913> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1577> rdfs:label "Post Assertion Note: #1577" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served in Spain under P. Scipio who left him in charge of the camp before setting out on his final expedition (Liv. 25.34.8, 36.12, 37.4; 26.17.3; cf. Frontin. Str. 1.5.12; 4.5.8, see note 8; and Münzer, RE nos. 14 and 27)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1576> rdfs:label "Post Assertion Note: #1576" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Despite the similarities in their situation the Fonteius mentioned in Livy may not be the same as the one in Frontinus, who is named C. Fonteius Crassus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1913> rdfs:label "Post Assertion: #1913" ;
	a dprr:PostAssertion ;
