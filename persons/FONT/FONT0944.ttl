	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1577> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1576> ;
	dprr:hasOriginalText "Ti. Fonteius (14, cf. 27)" ;
