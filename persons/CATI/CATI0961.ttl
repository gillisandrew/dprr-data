	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Left in charge of the camp, when the Consul Nero joined Livius (Liv. 27.43.12) against Hasdrubal." ;
