<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4669> rdfs:label "Post Assertion Note: #4669" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "This former Fimbrian deserted Mithridates for Lucullus, was placed in command in Gordyene, and was besieged there by Tigranes during the winter of 68-67 (Dio 36.8.2; cf. Plut. Luc. 34.6; Ps.-Ascon. 244 Stangl)." ;
	dprr:hasID 4669 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10447> rdfs:label "Post Assertion Note: #10447" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. Mith. 10.68, 10.70. Sent from Sertorius to Mithridates" ;
	dprr:hasID 10447 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10446> rdfs:label "Post Assertion Note: #10446" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. Mith. 10.68, 10.70. Dispatched again by Sertorius in 75 to act as a counselor to Mithridates. Still serving in 74." ;
	dprr:hasID 10446 .
