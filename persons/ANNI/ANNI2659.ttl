<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5949> rdfs:label "Post Assertion Note: #5949" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He could have shared in Antony's hasty assignment of praetorian provinces in the Senate meeting on November 28 (Cic. Phil. 3.26), and is termed a praetorius in Phil. 13.26 (delivered March 20, 43). See also Cic. Phil. 11.14; Vergil Catalept. 2; Suet. Aug. 86." .
