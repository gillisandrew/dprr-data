	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Considered to have been Quaestor in Sicily, listed by Grant (From Imperium to Auctoritas 26-29 and 31f.) as officer of Sextus Pompey during his possession of the island from the end of 43 to the autumn of 36. CIL 1(2).2, p. 764, no. 382 b;" .
