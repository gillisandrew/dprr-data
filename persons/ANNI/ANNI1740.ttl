<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7675> rdfs:label "Post Assertion Note: #7675" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Perhaps praetor in 83 or 82, he was proconsul in one, or probably both, Spanish provinces (two quaestors) in 82-81 (MRR 2.77). On his coinage there, see Crawford, RRC 1.381386, no. 366.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4211> rdfs:label "Post Assertion Note: #4211" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in one (or perhaps both) Spanish provinces (Grueber, CRRBM 2.352-356), and expelled Sertorius from them (Plut. Sert. 7). See above, Quaestors." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3492> rdfs:label "Post Assertion Note: #3492" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Metellus with four cohorts of Ligurians to Lepcis Magna (Sall. Iug. 77.4)." .
