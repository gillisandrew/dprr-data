<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7949> rdfs:label "Post Assertion Note: #7949" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. Pl. 215. On the passage and abrogation of the Lex Oppia (MRR 1.155 and 340), see now P. Culham, Latomus 41, 1982, 786-793.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1418> rdfs:label "Post Assertion Note: #1418" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sponsored the law restricting the extravagance of women (Liv. 34.1.1-3, 4.6, 10, and 20; Val. Max. 9.1.3; Tac. Ann. 3.33.4; Auct. Vir. Ill. 47.6; Oros. 4.20.14; cf. Plaut. Epid. 225-235), and possibly a law on the purchase of slaves (Val. Max. 7.6.1; cf. Liv. 22.61.2; 24.16, and 18; 25.6.21; 34.6.12; Macrob. Sat. 1.11.30)." .
