<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4468> rdfs:label "Post Assertion Note: #4468" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 74, Quaestors. Served under M. Cotta in Bithynia, who sent him home in disgrace, charging him with bribery and conspiracy (Cic. in Quintil. Inst. Or. 5.10.69, and 13.20-21 and 30; 11.1.67; Sall. Hist. 3.59-60 M; Dio 36.40.3; Ammian. Marc. 30.8.7). See 70, Promagistrates, on M. Cotta." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4419> rdfs:label "Post Assertion Note: #4419" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under M. Aurelius Cotta in Bithynia (Dio 36.40.3; see 73-71, Promagistrates)." .
