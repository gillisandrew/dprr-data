<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7683> rdfs:label "Post Assertion Note: #7683" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "If Veiento was also the cognomen of M. Perperna (5), Fabricius becomes merely one of the possible gentilicia of the legatus whom Bibulus left in command in Syria in 50 (MRR 2.253).[88]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5490> rdfs:label "Post Assertion Note: #5490" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Legate; left in command of Syria by Bibulus (Cic. Att. 7.3.5; cf. 4.17.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5489> rdfs:label "Post Assertion Note: #5489" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 The name Fabricius is added because the cognomen Veiento occurs only once again, this time in connection with it (RE 15, dated under Nero)." .
