<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4645> rdfs:label "Post Assertion Note: #4645" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Captured in his robes of office by the pirates (Plut. Pomp. 24.6; c Cic. Leg. Man. 32-33 and 53; App. Mith. 93). See below, on Sextillus" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4644> rdfs:label "Post Assertion Note: #4644" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "3 Plutarch's text has the name Bellinus, but Bellienus is a probable emendation to a name known in this period (RE). The year is uncertain but cannot be long before 67." .
