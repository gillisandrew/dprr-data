<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1066> rdfs:label "Primary Source Reference: #1066" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Gell. IV 20.10" ;
