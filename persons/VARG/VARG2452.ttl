	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate under Crassus who fell in battle near Carrhae (Plut. Crass. 28.1-2; Oros. 6.13.3). See Lübker no. 2." .
