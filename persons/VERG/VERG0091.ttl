<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2349> rdfs:label "Person Note: #2349" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Starb nach einer annalistischen Notiz in Liv. 3,7,6, die sich auf die auguralen Sukzessionslisten zurückführen läßt, die für diese frühe Zeit kaum historisch sind, 463 als Augur. Dieses Amt des Konsuls von 479 und Mitglied einer wichtigen Familie dürfte Produkt der auguralen Kompilation und kaum historisch sein. " ;
	dprr:hasID 2349 .
