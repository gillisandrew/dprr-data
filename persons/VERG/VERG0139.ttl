<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7896> rdfs:label "Post Assertion Note: #7896" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In MRR 1.37, refer also to Cic. Dom. 86. See R. M. Ogilvie, Comm. Liv. 419, on him and his five years in office as tr. pl.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/227> rdfs:label "Post Assertion Note: #227" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Re-elected for the fifth time (Liv. 3.29.8; Dion. Hal. 10.26.4). Secured passage of a bill to increase the number of the Tribunes to ten (Liv. 3.30.5-7; Dion. Hal. 10.26.4-30.6; cf. Zon. 7.17)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/217> rdfs:label "Post Assertion Note: #217" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Re-elected (Liv. 3.24.9, and 25.4; Dion. Hal. 10.22.1). See note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/208> rdfs:label "Post Assertion Note: #208" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Tribunes of 460 were re-elected (Liv. 3.21.3; Dion. Hal. 10.19.3; cf. Val. Max. 4.1.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/205> rdfs:label "Post Assertion Note: #205" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Tribunes of 461 were re-elected (Liv. 3.14.6, and 19.6; Dion. Hal. 10.8.5-13.7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/200> rdfs:label "Post Assertion Note: #200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prosecuted K. Quinctius and drove him into exile (Liv. 3.11.9-14.6, and 19.6; Dion. Hal. 10.2.1, and 6.1-8.5; cf. Auct. Vir. Ill. 17.1 for a different version). See Lübker no. 1." .
