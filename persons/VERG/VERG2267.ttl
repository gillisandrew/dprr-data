	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 753, footnote 432" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8393> rdfs:label "Post Assertion Note: #8393" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 69, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7324> rdfs:label "Post Assertion Note: #7324" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Combine the two notices in MRR 2.133, and 155, about his proquaestorship in Sicily. The date is uncertain, but falls more probably in the early 60s, as he held the praetorship in 62. Gundel (RE no. 3) rejects the identification of the propraetor in Sicily with the legate in Macedonia (RE no. 2) in 57-55. The officer at Thapsus in 46 (MRR 2.303) was an ex-praetor (Bell. Afr. 28.1).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5853> rdfs:label "Post Assertion Note: #5853" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An officer in the Pompeian forces in Africa, who had command of the garrison in Thapsus (Bell. Afr. 28.2; 44.1; 79; 86; 93.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5169> rdfs:label "Post Assertion Note: #5169" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Piso in Macedonia (Cic. Prov. Cons. 7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5113> rdfs:label "Post Assertion Note: #5113" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Piso in Macedonia (Cic. Prov. Cong. 7; possibly the Praetor of 62, Propr. in Sicily, 61-58)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5060> rdfs:label "Post Assertion Note: #5060" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Sicily (see 6 1, Promagistrates). Debarred by the terms of the law of Clodius from giving Cicero a refuge (Cic. Planc. 95-96)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5023> rdfs:label "Post Assertion Note: #5023" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Sicily (see 61, Promagistrates; cf. Cic. QF 1.2.7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4981> rdfs:label "Post Assertion Note: #4981" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Sicily (see 61-58, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4955> rdfs:label "Post Assertion Note: #4955" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Sicily (Cic. Planc. 96, praetor; Schol. Bob. 87 Stangl). See 60-58, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4897> rdfs:label "Post Assertion Note: #4897" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Planc. 95; cf. Bell. Afr. 28.1. See 61, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4787> rdfs:label "Post Assertion Note: #4787" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. QF 1.2.7; Att. 1.4.1; Planc. 95." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4773> rdfs:label "Post Assertion Note: #4773" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "IG 14.356, Proquaestor in Sicily. The date is uncertain, probably after Verres, and several years before his praetorship." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4612> rdfs:label "Post Assertion Note: #4612" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor in Sicily, honored by Halaesa (IG 14.356-IGRP 1.508)." .
