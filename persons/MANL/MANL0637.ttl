<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/954> rdfs:label "Post Assertion Note: #954" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 10.9.9 (Paetus); Fast. Cap. ([- -] f. Cn. [- -]); Act. Tr. (F.'s name entire); Chr. 354 (Petino et Torquato); Fast. Hyd. (Poetico et Torquato); Chr. Pasc. ({Gr}); Cassiod.; Degrassi 38f., 111, 424f. Fulvius captured Nequinum of Umbria (Liv. 10.10.1-5), and celebrated a triumph over Samnites (Sabines ?) and Nequinates (Act. Tr., Degrassi 72f., 543). Torquatus died in Etruria (Liv. 10.11.1-3)." ;
	dprr:hasID 954 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/953> rdfs:label "Post Assertion Note: #953" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer suggests the filiation T. f. T. n., a grandson of the Consul of 340." ;
	dprr:hasID 953 .
