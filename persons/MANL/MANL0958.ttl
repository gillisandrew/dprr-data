<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1971> rdfs:label "Post Assertion Note: #1971" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The triumph granted by the Senate upon his return from Spain was vetoed by a Tribune (Liv. 32.7.4). See 205-200, Promagistrates." ;
	dprr:hasID 1971 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1940> rdfs:label "Post Assertion Note: #1940" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Spain (Liv. 28.45.10; 29.13.7; see 205-201). Received a successor at the end of the year (Liv. 31.50.11)." ;
	dprr:hasID 1940 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1913> rdfs:label "Post Assertion Note: #1913" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued as Proconsul in Spain. The question of a successor was referred to the people (Liv. 30.41.4-5), but he was not elected until 200 (31.50.11)." ;
	dprr:hasID 1913 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1890> rdfs:label "Post Assertion Note: #1890" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued (as Proconsul) in Spain (Liv. 30.27.9, cf. 41.4-5)." ;
	dprr:hasID 1890 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1853> rdfs:label "Post Assertion Note: #1853" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Spain (Liv. 30.2.7; see 205 and 204, Promagistrates)." ;
	dprr:hasID 1853 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1820> rdfs:label "Post Assertion Note: #1820" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Proconsul in Spain (Liv. 29.13.7)." ;
	dprr:hasID 1820 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1777> rdfs:label "Post Assertion Note: #1777" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Continued in Spain with imperium pro consule (Liv. 28.45.10; 29.13.7). See above, on Cornelius Lentulus." ;
	dprr:hasID 1777 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1755> rdfs:label "Post Assertion Note: #1755" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Invested with command pro consule to succeed Scipio in Spain (Liv. 28.38.1, pro praetore; 29.13.7, pro consule; cf. Polyb. 11.33.8; Dio fr. 57.56; Zon. 9.11; see above, on Cornelius Lentulus)." ;
	dprr:hasID 1755 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1726> rdfs:label "Post Assertion Note: #1726" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In command of forces guarding the Appennine passes against Hasdrubal (Liv. 27.50.8, cf. 43.9; see Mommsen Str. 2.652, note 2)." ;
	dprr:hasID 1726 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1719> rdfs:label "Post Assertion Note: #1719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy omits the regular list of prorogations for this year with the exception of Q. Fulvius Flaccus." ;
	dprr:hasID 1719 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1700> rdfs:label "Post Assertion Note: #1700" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to observe the situation in Greece and Macedonia and attend the Olympic games (Liv. 27.35.3-4; cf. 28.7.14). On the chronology, see Walbank, Philip V of Macedon 304f.; De Sanctis 3.2.443; Walek-Czerneski, RPH 54 (1928) 13-17." ;
	dprr:hasID 1700 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1603> rdfs:label "Post Assertion Note: #1603" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.4.4." ;
	dprr:hasID 1603 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1600> rdfs:label "Post Assertion Note: #1600" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 26.23.1 Provinces and armies 26.28." ;
	dprr:hasID 1600 .
