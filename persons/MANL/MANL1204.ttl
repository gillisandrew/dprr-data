<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8492> rdfs:label "Post Assertion Note: #8492" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 731" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2471> rdfs:label "Post Assertion Note: #2471" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 40.43.4; Fast. Cap., Degrassi 48f., 122, 456f.; Plin. NH 35.14; Obseq. 7; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; and on Manlius,{392} who was by birth a brother of his colleague, Vell. 2.8.3; Cic. De Or. 2.260. Both Consuls were assigned Liguria (Liv. 40.44.3), where Fulvius transferred many Ligurians away from the mountains. He also prevented settlement in Italy of Transalpine Gauls (40.53.1-6; Flor. 1.19.5), then returned to Rome to celebrate a triumph (Liv. 40.59.1-3; Degrassi 555). Fulfilled a vow of temple and games (40.44.8-12, and 45.6) for his victory in Spain." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2435> rdfs:label "Post Assertion Note: #2435" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aquileia was founded in this year (Liv. 40.34.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2381> rdfs:label "Post Assertion Note: #2381" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to found Aquileia (Liv. 39.55.5-6; 40.34.3). On Manlius, see CIL 1\n     .2.621. See also 181 on this commission." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2374> rdfs:label "Post Assertion Note: #2374" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Transalpine Gauls to warn them to keep their people out of northern Italy (Liv. 39.54.11-54.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2327> rdfs:label "Post Assertion Note: #2327" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Hither Spain (see 187 and 186, Promagistrates). Returned to celebrate an ovatio (Liv. 39.29.4-7). See Degrassi 554." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2313> rdfs:label "Post Assertion Note: #2313" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Credited with a victory over the Celtiberi before the arrival of his successor (Liv. 39.21.6-10) in Hither Spain." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2304> rdfs:label "Post Assertion Note: #2304" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Apparently his imperium in Hither Spain was prorogued as no successor was sent (Liv. 38.42.5-6; cf. 39.7.6-7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2272> rdfs:label "Post Assertion Note: #2272" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 38.35.2 Provinces and armies 38.35.10." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10142> rdfs:label "Post Assertion Note: #10142" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ovation ex Hispania Citeriore. MRR I.373, Itgenshorst no. 182, Rich no. 181." .
