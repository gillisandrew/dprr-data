<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8449> rdfs:label "Post Assertion Note: #8449" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 729, footnote 45" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2288> rdfs:label "Post Assertion Note: #2288" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 189, Legates. Sent to collect funds from Oroanda (Liv. 38.37.11; cf. Polyb. 21.41.7), and to exact from Antiochus the oath ratifying the treaty (Liv. 38.39.1; Polyb. 21.43.1-2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2268> rdfs:label "Post Assertion Note: #2268" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under his brother Manlius Vulso in Asia (Liv. 38.20.7, 22.1, and 23.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2013> rdfs:label "Post Assertion Note: #2013" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Cic. Verr. 2.2.123, with the mistaken praenomen T." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2012> rdfs:label "Post Assertion Note: #2012" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Called Manlius Vulso in Liv. 32.27.7, and Manlius in 32.28.2. Cicero mentions a T. Manlius, Praetor, who by decree of the Senate brought colonists{335} from other towns of Sicily to Agrigentum. Münzer (RE) would prefer to identify him with L. Manlius Vulso rather than emend Cicero's text to C. Mamilius (Pr. 207; RE 5). Since the Leges Scipionis under which Agrigentum was governed assume the presence of the colonists this Manlius seems a bit late in date and Mamilius too early. Perhaps Scipio authorized the colonization and Manlius carried it out." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2010> rdfs:label "Post Assertion Note: #2010" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Six Praetors were elected this year for the first time (Liv. 32.27.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2009> rdfs:label "Post Assertion Note: #2009" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 32.27.7 Provinces Liv. 32.28.2 and 11" .
