<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3503> rdfs:label "Post Assertion Note: #3503" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed the bill to give Marius the command in Africa against Jugurtha (Sall. Iug. 73.7; cf. 82.2; and Elogium, above, on Marius). He is probably the Tribune who attacked Metellus upon his return (Gell. 7.11.2-3, C. Manlium, and cf. 12.9.4; Priscian 8.17, GLK 2.382, C. Manlio; cf. FOR 2.63f., 151)." ;
	dprr:hasID 3503 .
