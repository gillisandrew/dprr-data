<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/936> rdfs:label "Relationship Assertion Reference: #936" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die Adoption taucht nicht in Spinthers Namen auf. Andere Adoptionen, die Priesterschaften ermöglichen, schlagen sich sehr wohl in der Nomenklatur nieder (z.B. Veturius Sempronianus). Vielleicht ist die strenge der Nomenklatur aber auch lediglich eine Frage der Epoche, da wir 'freie' Nomenklaturen allgemein erst spät beobachten." ;
	dprr:hasExtraInfo "Dio XXXIX 17.1" .
