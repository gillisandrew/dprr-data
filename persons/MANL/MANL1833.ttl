<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7475> rdfs:label "Post Assertion Note: #7475" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Q(uaestor). Against Grueber (see MRR 2.13, 99 to 94 B.C.), Crawford dates his coins as quaestor to 113 or 112 (RRC 1.308, no. 295), and for his connections refers to the stemma prepared by J. F. Mitchell, Historia 15, 1966, 31, who, however, dates the quaestorship to 96.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3750> rdfs:label "Post Assertion Note: #3750" ;
