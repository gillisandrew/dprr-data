<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/936> rdfs:label "Primary Source Reference: #936" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Dio XLVII 8.5" ;
