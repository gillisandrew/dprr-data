<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/618> rdfs:label "Post Assertion Note: #618" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Clavi figendi causa, Liv. 7.3.4; Fast. Cap. ([- -] Imperiossus); Degrassi 32f., 104, 400f. His attempt to exceed his religious function (Liv. 7.3.9) or to stay in office beyond his legitimate time (Cic. Off. 3.112; Val. Max. 5.4.3) led to his prosecution in 362 (see 362, Tribunes of the Plebs)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/617> rdfs:label "Post Assertion Note: #617" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "On Manlius' filiation, see Cic. Off. 3.112, and Fast. Cap. on Manlius, the Cos. of 359; Münzer, RE no. 54." .
