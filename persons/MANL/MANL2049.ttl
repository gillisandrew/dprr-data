	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Verr. 1.30; Schol. Gron. 351 Stangl. Died before 66 (Cic. Cluent. 39)." .
