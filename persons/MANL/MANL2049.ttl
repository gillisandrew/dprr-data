<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7610> rdfs:label "Post Assertion Note: #7610" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See MRR 2.92, 132. Shackleton Bailey (Studies 5051) doubts if two such different personalities as those of the IIIvir Cap. Ca. 77(Cic. Cluent. 77), and of the Tr. Pl. desig. For 69 ( Verr. 1.30), could ;exist in the same person.\n" .
