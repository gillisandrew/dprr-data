<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4610> rdfs:label "Post Assertion Note: #4610" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Governor of Africa before 68, with the young Plancius on his staff (Cic. Planc. 27). See 67, Legates of Pompey." ;
