	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Verr. 2.3.123, probably Pr. Urbanus, since official letters from the Propraetor Metellus in Sicily to Consuls and Quaestors included one to him." ;
	dprr:hasID 4569 .
