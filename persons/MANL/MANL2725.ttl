<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6056> rdfs:label "Post Assertion Note: #6056" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor of the Consul Pansa, whose camp he prepared in good time at Forum Gallorum (App. BC 3.69). Pansa at his death transferred his troops to Manlius and he to Decimus Brutus (App. BC 3.76). He arrested the physician Glyco on suspicion of having poisoned Pansa (Cic. Ad Brut. 1.6.2; cf. Suet. Aug. 11.1; Tac. Ann. 1.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10477> rdfs:label "Post Assertion Note: #10477" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Nep. Att. 11.2. At Philippi, sent aid by his friend Atticus following the defeat." .
