<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/166> rdfs:label "Primary Source Reference: #166" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Auct. vir. ill. 68.1" ;
