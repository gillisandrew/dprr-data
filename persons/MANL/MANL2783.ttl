	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7251> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6191> ;
	dprr:hasOriginalText "? T. Manlius T. f. Sergia(nus) Pat. (64)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/12> ;
	dprr:hasDateStart -42 ;
