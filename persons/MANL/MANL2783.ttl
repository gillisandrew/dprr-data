<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/24> rdfs:label "Secondary Source: Taylor 1960" ;
	a dprr:SecondarySource ;
	dprr:hasName "LRT" ;
	dprr:hasBiblio "Taylor, L. R., The voting districts of the Roman Republic : the thirty-five urban and rural tribes. Rome : American Academy, 1960." ;
	dprr:hasAbbreviation "Taylor 1960" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7251> rdfs:label "Post Assertion Note: #7251" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Possibly a Leg., lieut. in Spain ca. 42. Against Kubitschek and Münzer, L. R. Taylor held that the forms Ser and Sergia On the coins issued by these two Manlii (MRR 2.444 and 365 resp.) represent the name of their tribe and are included to distinguish them from the patrician Manlii who used the praenomina A. and T., though not Q. (VDRR 229-230)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6191> rdfs:label "Post Assertion Note: #6191" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Named on a coin of Brutobriga in Spain; possibly, like Peducaeus and Livius in 40, a Legate (see 40, Legates; Grant, From Imperium to Auctoritas 381)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/6910> rdfs:label "Post Assertion: #6910" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
