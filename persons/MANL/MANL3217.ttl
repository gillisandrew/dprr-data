	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A senator of Cicero's generation (Cic. Brut. 245), who is probably to be identified with the man who was honored at Delos (BCH 3 [1879] 156f.; 36 [1912] 107) between 84 and 78, and perhaps attained the praetorship." ;
	dprr:hasID 6910 .
