	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7662> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3853> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3852> ;
	dprr:hasOriginalText "Q. Varius Severus Hibrida (*1)" ;
