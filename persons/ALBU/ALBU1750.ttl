<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9008> rdfs:label "Post Assertion Note: #9008" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "ca. 107.  p. 746, footnote 234" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7556> rdfs:label "Post Assertion Note: #7556" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. 105? Propr. Sardinia 104? See MRR 1.556, 560. Refer also to Lucilius (88-91M). Gruen suggests the dates 107 and 106, resp., for his two offices. See Wiseman, NM 210-211, no. 16, and Badian, Klio 66, 1984, 306-307; Gruen, TAPhA 95, 1964, 101-106.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3570> rdfs:label "Post Assertion Note: #3570" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Sardinia (Cic. Prov. Cons. 15). When refused a supplicatio by the Senate, he celebrated a triumph on his own responsibility in Sardinia and was condemned in Rome (Cic. Prov. Cons. 15; Div. in Caec. 63; Pis. 92; Off. 2.50; Tusc. 5.108; Scaur. 40)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3530> rdfs:label "Post Assertion Note: #3530" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 104, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10259> rdfs:label "Post Assertion Note: #10259" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph? ex Sardinia. Held in Sardinia, not granted by senate. MRR I.560. Not listed in Itgenshorst or Rich." .
