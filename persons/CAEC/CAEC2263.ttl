<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5146> rdfs:label "Post Assertion Note: #5146" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul (CIL12.2.761), probably of Sicily, since it is unlikely that the other province whose governor for this year remains unknown, Crete and Cyrene, would receive a governor with an imperium pro consule." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5072> rdfs:label "Post Assertion Note: #5072" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12.2.761; Cic. P. Red. in Sen. 22; Mil. 38; Ascon. 48 C." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4857> rdfs:label "Post Assertion Note: #4857" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elogium, CIL 12.2.761-ILS 880. Proposed a bill to restore civil rights to P. Autronius Paetus and P. Cornelius Sulla (Cic. Sull. 62-66, cf. Leg. Agr. 2.10; Dio 37.25.3). Promised to veto the bill of Rullus (see below)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4761> rdfs:label "Post Assertion Note: #4761" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12.2.761-ILS 880. The date is conjectural, based on the dates of his tribunate (63) and his praetorship (57)." .
