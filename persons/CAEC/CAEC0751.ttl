<http://romanrepublic.ac.uk/rdf/entity/PersonNote/312> rdfs:label "Person Note: #312" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Fertigstellung des Ops-Opifera-Tempels im zweiten Konsulat (247). Berühmt ist die Rettung des Palladiums aus dem brennenden Vestaheiligtum (241). Er trug einen Konflikt mit dem Flamen Martialis A. Postumius Albinus (Nr. 2817) über dessen Abwesenheit von Rom aus (242), der erste überlieferte Konflikt dieser Art." ;
	dprr:hasID 312 .
