<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6037> rdfs:label "Post Assertion Note: #6037" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pr. Urbanus and chief executive in place of the Consuls when they left the city and perished at Mutina (Cic. Fam. 10. 12.3, and 16. 1; Ad Brut. 2.5.3; Phil. 14.37; Val. Max. 5.2.10). He committed suicide when Octavian seized Rome (App. BC 3.92)." .
