<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7370> rdfs:label "Post Assertion Note: #7370" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., amb. 173, no. c (MRR 1.409). Valerius and the other members of this embassy were sent to other cities and states as well, Pergamum, Syria, cities in Asia and perhaps in Cappadocia and Bithynia too: cf. in 172, Liv. 42.17.1 and 26.7-9 (MRR 1.414; see Meloni, Perseo 149, 163, 165, notes 2 and 3, and 166; Walbank, Comm. Polyb. 3.289).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2600> rdfs:label "Post Assertion Note: #2600" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to King Perseus to observe conditions in Macedonia, and to Alexandria to renew Roman friendship with King Ptolemy (Liv. 42.6.4-5). On Valerius, see Münzer, Gent. Val. 47, no. 36." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/3153> rdfs:label "Post Assertion: #3153" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/1344> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7370> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2600> ;
	dprr:hasOriginalText "M. Caecilius Denter (50)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/11> ;
	dprr:hasDateStart -173 ;
