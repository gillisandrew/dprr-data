<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3443> rdfs:label "Post Assertion Note: #3443" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated as Proconsul a triumph ex Sardinia (Act. Tr., Degrassi 84f., 561; Vell. 2.8.2; Eutrop. 4.25.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3424> rdfs:label "Post Assertion Note: #3424" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Sardinia (see Act. Tr. for 111)." .
