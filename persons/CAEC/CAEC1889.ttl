	dprr:hasRelationshipReference <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/977> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/815> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/814> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/219> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1867> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/15> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/159> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/14> , <http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/1406> ;
