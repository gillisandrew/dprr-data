	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Führung eines mehrbändigen index, der wohl mit den commentarii der Pontifices identifiziert werden muß; darin Protokoll einer cena aditalis (70). Zwischen 72 und 64 v. Chr. dürfte er das Iseum Metellinum errichtet haben." .
