	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2631> rdfs:label "Post Assertion Note: #2631" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Apulia and Calabria to purchase grain for the fleet and the army (Liv. 42.27.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2607> rdfs:label "Post Assertion Note: #2607" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected to assign unoccupied lands in Liguria and Gaul to individual settlers, ten iugera each to Romans, three each to Latins (Liv. 42.4.3-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2605> rdfs:label "Post Assertion Note: #2605" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "He should not be identified with M. Caecilius Denter (see above, Legates)." .
