<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1487> rdfs:label "Post Assertion Note: #1487" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Indicted the Censors for making him an aerarius during his quaestorship (Liv. 24.43.1-3; see 214, Censors, and Quaestors)." ;
	dprr:hasID 1487 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1451> rdfs:label "Post Assertion Note: #1451" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Reduced to an aerarius by the Censors for wishing to abandon Italy after Cannae (Liv. 24.18.1-4, and 43.2-4; Val. Max. 2.9.7)." ;
	dprr:hasID 1451 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1450> rdfs:label "Post Assertion Note: #1450" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Although in the passages from Livy and Valerius Maximus this Caecilius Metellus is given three different praenomina, Münzer (RE), D.- G. (2.16-17), Sobeck (7) and Niccolini (F T P 93) agree that the correct one was probably Lucius (cf. Liv. 22.53.5)." ;
	dprr:hasID 1450 .
