<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7851> rdfs:label "Post Assertion Note: #7851" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 206. Leg., amb. 185. In MRR 1.373, on this embassy, refer also to Diod. 29.16. In the Index, 2.539, correct Cos. 205 to Cos. 206.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2384> rdfs:label "Post Assertion Note: #2384" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Polyb. 23.4.1-15; cf. Liv. 39.48.2-4" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2359> rdfs:label "Post Assertion Note: #2359" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They reported to the Senate at the beginning of 184 (Polyb. 22.11.1, and 12.5-10; Liv. 39.33.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2333> rdfs:label "Post Assertion Note: #2333" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to deal with disputes between Philip of Macedon and his neighbors in Greece and with complaints arising from his occupation of Aenus and Maronea (Polyb. 22.6; 23.2.7; Liv. 39.23.5-29.3, cf. 33.1; Pausan. 7.8.6). They also discussed the Achaean treatment of Sparta with the Achaean magistrates, who refused Metellus' request that they call an assembly (Polyb. 22.10; 23.4.7; Diod. 29.17; Pausan. 7.8.6, and 9.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2330> rdfs:label "Post Assertion Note: #2330" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy reports this embassy under the year 185, but the appointment could have been made late in the consular year 186. I accept Niese's dating (3.22, note 1). They could leave Rome in the spring, visit Tempe and Thessalonica, and be at Argos for the Nemean games in August (Polyb. 22.10.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1953> rdfs:label "Post Assertion Note: #1953" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 31.49.5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1923> rdfs:label "Post Assertion Note: #1923" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected through the Pr. Urbanus to assign land in Samnium and Apulia to veterans who had served under Scipio in Africa (Liv. 31.4.1-3, and 49.5). On Villius, see Lübker, no. 1, on Quinctius, no. 4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1824> rdfs:label "Post Assertion Note: #1824" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Was sent by the Senate with nine others besides a Praetor, two Tribunes, and an Aedile of the Plebs, to investigate the charges against Scipio and Pleminius (Liv. 29.20-22; Diod. 27.4; see 205, Legates, on Pleminius; and above, Consuls, Praetors, Tribunes of the Plebs, Aediles of the Plebs)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1772> rdfs:label "Post Assertion Note: #1772" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued to hold command in Bruttium (Liv. 28.45.9-11, and 46.3). Dismissed his army when appointed Dictator (Liv. 29.10.2-3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1763> rdfs:label "Post Assertion Note: #1763" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to hold the elections for 204 (Liv. 29.10.2-3, and 11.9-11; 30.23.3; 35.8.4; Fast. Cap., Degrassi 46f., 120, 450f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1741> rdfs:label "Post Assertion Note: #1741" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 28.9.18-10.2; Cic. Brut. 57; Fast. Cap., Degrassi 46f., 120, 450f.; Dio fr. 57.59; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; cf. Eutrop. 3.19. Both Consuls were assigned to face Hannibal in Bruttium and Lucania (Liv. 28.10.8, and 11.8-12.9; Dio fr. 56.59-60; Eutrop. 3.19, with the name Valerius; Zon. 9.11). On Veturius, see Lübker, no. 9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1736> rdfs:label "Post Assertion Note: #1736" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The envoys who brought to Rome news of the victory at the Metaurus (Liv. 27.51.3-6; cf. 28.9.19-20)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1713> rdfs:label "Post Assertion Note: #1713" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See above, Dictator." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1683> rdfs:label "Post Assertion Note: #1683" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.36.8, cf. 33.7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1651> rdfs:label "Post Assertion Note: #1651" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 27.21.9. On Servilius, see also Liv. 27.21.10; 30.19.6-9; on Caecilius, see note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1402> rdfs:label "Post Assertion Note: #1402" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Q. Caecilius Metellus succeeded P. Scantinius. Metellus died after 179 (Liv. 40.45.8-46.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1399> rdfs:label "Post Assertion Note: #1399" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Liv. 23.21.7." .
