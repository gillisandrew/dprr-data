<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/8399> rdfs:label "Post Assertion: #8399" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/2078> ;
