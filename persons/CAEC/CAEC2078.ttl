	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7130> ;
	dprr:hasPosition 0 ;
	dprr:hasOriginalText "Q. Caecilius C. f. Q. n. Metellus Creticus (87)" ;
	dprr:hasOfficeXref "Cos. 69" ;
