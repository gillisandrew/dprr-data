	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Senator in 44. One of Caesar's murderers (App. BC 2.113, 117; cf. Cic. Att. 15.17.2; 16.4.4). His brother was named Caecilius, a name which should be deleted from the entry in MRR 2.488.\n" ;
	dprr:hasID 7740 .
