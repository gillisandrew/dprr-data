<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2679> rdfs:label "Post Assertion Note: #2679" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prosecuted C. Lucretius Gallus successfully for his mistreatment of the allies in Greece in 171 (Liv. 43.8.2-10)." ;
	dprr:hasID 2679 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2678> rdfs:label "Post Assertion Note: #2678" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Possibly the Cn. Aufidius who reversed an old decree of the Senate and secured the passage of a law permitting importation of African beasts for the circus games (Plin. NH 8.64; cf. Liv. 44.18.8; RE s. v. \"Aufidius\" no. 5), but Niccolini (FTP 420) favors a date toward the end of the second century." ;
	dprr:hasID 2678 .
