<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6048> rdfs:label "Post Assertion Note: #6048" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In the debate in the Senate early in January he prevented action on Cicero's proposal to treat Antony as a public enemy by adjourning the Senate (App. BC 3.50-51, and 52; 4.17; cf. Cic. Phil. 6.2; 7.14; Dio, 46.29.2). The first victim in the proscriptions (Vell. 2.64.4; App. BC 4.17)." ;
	dprr:hasID 6048 .
