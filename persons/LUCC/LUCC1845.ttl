	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12.2.663, cf. 664." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8173> rdfs:label "Post Assertion Note: #8173" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. in Macedonia ca. 92. See MRR 2.19; CIL 1(2).2.663-ILS 4053-ILLRP 210.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3798> rdfs:label "Post Assertion Note: #3798" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "8 An inscription found in Samothrace, dated to July, 92, names L. Lucceius M. f. Leg. Lommatzsch, in CIL 11.2, p. 517, holds that Leg. is either a misreading of the name of a Roman tribe or that it is the title of a Legate, presumably a Legate of either Sentius in Macedonia or the current governor of Asia. Münzer (RE) believes that it is a title." .
