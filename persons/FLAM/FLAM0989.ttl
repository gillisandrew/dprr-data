	dprr:hasNoteText "Liv. 33.42.8." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1654> rdfs:label "Post Assertion Note: #1654" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Given charge by Scipio of the booty taken at New Carthage (Liv. 26.47.6, and 49.10; cf. Polyb. 10.19.1). On chronology, see De Sanctis 3.2.468f., note 38." .
