<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2435> rdfs:label "Post Assertion Note: #2435" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Aquileia was founded in this year (Liv. 40.34.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2381> rdfs:label "Post Assertion Note: #2381" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to found Aquileia (Liv. 39.55.5-6; 40.34.3). On Manlius, see CIL 1\n     .2.621. See also 181 on this commission." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2289> rdfs:label "Post Assertion Note: #2289" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 38.42.2; 39.6.1; Fast. Cap., Degrassi 48f., 122, 454f.; Val. Max. 6.6.3; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; Zon. 9.21; and on Lepidus, Polyb. 22.3.2; CIL 1\n     .2.617-620. Both Consuls were assigned to Liguria which they actively ravaged (Liv. 38.42.8-12; 39.1.1-2, and{368} 2.1-11). Lepidus was instructed to restore their arms to the Cenomani, who had been unjustly disarmed by Furius (see Praetors; Liv. 39.3.1-3), and built the Via Aemilia (Liv. 39.2.10; Strabo 5.1.11; cf. CIL 1(2).2.617-620). Flaminius reduced the Friniates and the Apuani, and built a road from Bononia to Arretium (Liv. 39.1.1-2, and 2.1-6).\n     \n      1" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2212> rdfs:label "Post Assertion Note: #2212" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued for a year in Hither Spain (Liv. 37.2.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2180> rdfs:label "Post Assertion Note: #2180" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Hither Spain (Liv. 36.2.9)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2158> rdfs:label "Post Assertion Note: #2158" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His imperium in Hither Spain was prorogued, where he stormed Licabrum (Liv. 35.20.11, and 22.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2123> rdfs:label "Post Assertion Note: #2123" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 35.2.1-9, and 7.7; Oros. 4.20.19." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2120> rdfs:label "Post Assertion Note: #2120" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 34.54.2 Provinces and armies Liv. 34.55.6, and 56.9." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2031> rdfs:label "Post Assertion Note: #2031" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
