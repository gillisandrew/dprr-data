<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7136> rdfs:label "Post Assertion Note: #7136" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus of Q. Sertorius in Spain (MRR 2.95, 121). Cichorius would identify this Tarquitius with the C. Tarquitius L. f. Fal. who was no. 37 in Pompeius Strabo's consilium in 89 (RS 167), and has been accepted by Münzer (RE), by L. R. Taylor, who explains the occurrence of the Falerna tribe in a Tarquinian family as due to a grant of Roman citizenship before the Social War (VDRR 257-258; Tarquinii was in Stellatina), and recently by Criniti, L'Epigrafe di Asculum 144-146. The problem of an Etruscan Tarquitius in the Falerna tribe led Heurgon to identify the two Tarquitii named above, and to assume that Annius' quaestor went over to Sertorius (Latomus 12, 1953, 407-408; Wiseman, NM 264, no. 420)." ;
	dprr:hasID 7136 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4532> rdfs:label "Post Assertion Note: #4532" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sall. Hist. 3.81, and 83 M; Diod. 37.22; see 76, Legates." ;
	dprr:hasID 4532 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4362> rdfs:label "Post Assertion Note: #4362" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Sertorius in Spain at the battle of Lauro (Frontin. Sir. 2.5.31, from Livy)." ;
	dprr:hasID 4362 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10436> rdfs:label "Post Assertion Note: #10436" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/27> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "probably joined with Perperna in 78/77, Officer (leg?) 76-assassination" ;
	dprr:hasID 10436 .
