<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6505> rdfs:label "Post Assertion Note: #6505" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Antony with King Amyntas of Galatia to Macedonia and Thrace to secure mercenary soldiers (Dio 50.13.8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6450> rdfs:label "Post Assertion Note: #6450" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Antony to carry on negotiations with the king of Armenia before his Armenian campaign (Dio 49.39.2- 3, on two missions)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6422> rdfs:label "Post Assertion Note: #6422" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Envoy of Antony in Judaea, he intrigued with Alexandra to secute Antony's favor and the high priesthood for the Jewish prince Aristobulus (Joseph. AJ 15.25-28)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6309> rdfs:label "Post Assertion Note: #6309" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Antony to Ventidius and Silo with instructions to support the restoration of Herod to Judaea (Josepoh. AJ 14.394; BJ 1.289 and 291)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6245> rdfs:label "Post Assertion Note: #6245" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Mark Antony to summon Cleopatra to Cilicia (Plut. Ant. 25)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10488> rdfs:label "Post Assertion Note: #10488" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vell. 2.84.2. Serving under Cassius, defects to Antony in 42." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10487> rdfs:label "Post Assertion Note: #10487" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vell. 2.84.2. Serving under Antony." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10486> rdfs:label "Post Assertion Note: #10486" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vell. 2.84.2, Sen. Clem. 1.10. Antonian officer who defects to Octavian before Actium." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10485> rdfs:label "Post Assertion Note: #10485" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Vell. 2.84.2. Serving under P. Dolabella, defects to Cassius in 43." .
