	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legates, envoys. Two brothers, probably officers, who were sent by Crassus at Carrhae in 53 to negotiate with the Parthian commander (Plut. Crass. 21.2)Add this notice in MRR 2.231. See J. Suolahti, Junior Officers 248, 284, 293, 385.\n" ;
	dprr:hasID 7603 .
