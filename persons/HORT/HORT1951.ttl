<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8094> rdfs:label "Post Assertion Note: #8094" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praetor -. Legatus in 86. In MRR 2.56, refer also to Gran. Lic., 35, 79 (ed. N. Criniti, 1981, p. 21)\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4094> rdfs:label "Post Assertion Note: #4094" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of Sulla (Gran. Lic. 35B). Repulsed the raids of Dardani and Maedi in Thrace (Gran. Lic.; see Promagistrates, on Sulla)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4077> rdfs:label "Post Assertion Note: #4077" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of Sulla (Plut. Sull. 17.7; Gran. Lic. 35B). Brought Sulla reinforcements before the battle of Chaeronea, and took an important part in the battle (Plut. Sull. 15.3-4; 17.7; 19.1-3; Memnon 32, in FGrH 3B.352f.; App. Mith. 43)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4033> rdfs:label "Post Assertion Note: #4033" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 86, Legates. He recruited forces for Sulla and joined him in the autumn." .
