<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9721> rdfs:label "Post Assertion Note: #9721" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Put to death at Sulla’s command along with Venuleius (Oros. 5.21.8, P. Laetorius; Flor. 2.9.26, without the praenomen; Val. Max. 9.2.1, M. Plaetorius). Münzer distinguishes him from the M. Laetorius who fled into exile with Marius in 88 (App. BC 1.60). See MRR 2.494." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6929> rdfs:label "Post Assertion Note: #6929" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/4> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A senator who was slain by Sulla in 82 (Val. Max. 9.2.1; cf. Flor. 2.9.26; Oros. 5.21.8, P. Laetorius)." .
