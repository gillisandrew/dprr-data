	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Monetalis. In MRR 2.453, and Index, 625, refer also to Crawford, RRC 1.323, no. 316, 105 B.C. Legatus in Spain, 79. See MRR 2.84, but read, \"Flor. 2.10.6; cf. Cic. Fin. 2.63-64.\"\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4278> rdfs:label "Post Assertion Note: #4278" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Caecilius Metellus Pius in Farther Spain. Defeated and killed at Consabura on the Anas by Sertorius (Plut. Sert. 12.3, #; Flor. 2.7.6; of. Cic. Fin. 2.63)." .
