	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Perhaps an officer in Caesar's guard when he set sentinels about Cicero's Puteolan villa on the occasion of Caesar's visit in December 45 (Cic. Att. 13.52.1). See also Phil. 13.3. (TJC) Lucullus' legate was perhaps his father (Shackleton Bailey, CLA 5.395), but see below on Sornatius (1).\n" ;
	dprr:hasID 7454 .
