<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7542> rdfs:label "Post Assertion Note: #7542" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut.? No title preserved. See MRR 2.352. Nephew of C. Cassius Longinus (59). Complete the name in MRR 2.352 in 43 and add it in 2.364, in 42 B.C., and the Index, 543. Refer also to App. BC 4.135, on his suicide after Philippi.[50]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6104> rdfs:label "Post Assertion Note: #6104" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. His uncle, C. Cassius, left him in Syria in command of one legion when he went to Asia to meet Brutus (App. BC 4.63, and cf. in 42, 4.135)." .
