	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., Degrassi 50f., 123, 460f.; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod.; cf. on Manlius, ILS 19. Cassius died in office (Fast. Cap.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2773> rdfs:label "Post Assertion Note: #2773" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Besides formal activities (Liv. 45.16.8) he tried to rouse the people to declare war on Rhodes but was stopped by a tribunician veto (Liv. 45.21.1-8; cf. Polyb. 30.4.5-6; Diod. 31.5.3)." .
