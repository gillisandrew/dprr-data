<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1792> rdfs:label "Post Assertion Note: #1792" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus (Liv. 29.8.5) pro praetore (29.6.9; see Mommsen, Str. 2.700, note 2). Scipio placed him in charge of Locri where he robbed the temple of Proserpina, and tortured and killed the Tribunes of the Soldiers Matienus and Sergius (Liv. 29.6-9, 16-22; Diod. 27.4; Val. Max. 1.1.21; cf. App. Hann. 55; Dio fr. 57.62; Zon. 9.11). See Lübker, p. 823." ;
	dprr:hasID 1792 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1778> rdfs:label "Post Assertion Note: #1778" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Termed Propraetor (Liv. 29.6.9) and Legatus (29.8.5). See below, Legates." ;
	dprr:hasID 1778 .
