<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6736> rdfs:label "Post Assertion Note: #6736" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Considered to have been Quaestor in Sicily, listed by Grant (From Imperium to Auctoritas 26-29 and 31f.) as officer of Sextus Pompey during his possession of the island from the end of 43 to the autumn of 36. See Grueber, CRRBM 1.238-240." ;
	dprr:hasID 6736 .
