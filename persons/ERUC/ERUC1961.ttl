<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4072> rdfs:label "Post Assertion Note: #4072" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. According to Juba (quoted in Plut. Sull. 16.8), he, and not Gabinius, saved Chaeronea from attack by the forces of Mithridates. He captured the post of Thurium above Chaeronea (Plut. Sull. 16.8; 18.1; cf. 17.4-6). Possibly Prefect of Chaeronea (Plut. Sull. 16.8)." ;
	dprr:hasID 4072 .
