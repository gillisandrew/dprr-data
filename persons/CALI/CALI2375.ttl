	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Caesar placed him in charge of Cisalpine Gaul, a command which he held until his death at Placentia, perhaps ca. 47 (Jerome, Chr. ad ann. 57, p. 154 Helm)." .
