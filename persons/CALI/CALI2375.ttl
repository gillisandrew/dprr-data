<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5691> rdfs:label "Post Assertion Note: #5691" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Caesar placed him in command of Cisalpine Gaul, a position which he held until his death, at Placentia perhaps in 47 (Jerome Chr. ad ann. 57, p. 154 Helm)." .
