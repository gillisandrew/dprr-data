<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3511> rdfs:label "Post Assertion Note: #3511" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Cassius in Gaul, the remnants of whose army he saved by giving hostages and half the baggage to the Tigurini, and was later accused of maiestas and went into exile (Auct. Ad Herenn. 1.25; 4.34; Cic. Leg. 3.36; Inv. 2.72-73; Caes. BG 1.14.7; Oros. 5.15.24, C. Publius). See Lübker no. 1." .
