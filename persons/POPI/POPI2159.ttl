<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7368> rdfs:label "Post Assertion Note: #7368" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. Mil. 71. Perhaps better dated with Münzer to 72; see above, on Julius Caesar (131). If he is the C. Popillius who was tr. Pl. in 68 (see MRR 2.138) he may have been quaestor in 70 or, like the three military tribunes of 69 (Cic. Verr. 1.30; MRR 2.133), he was already a senator before becoming a tr. Mil. (Syme, JRS 53, 1963, 55-60-RP 2.557-567; Sumner, Orators 136)." ;
	dprr:hasID 7368 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4555> rdfs:label "Post Assertion Note: #4555" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elected at the same time as Caesar but later in the election (Plut. Caes. 5. 1)." ;
	dprr:hasID 4555 .
