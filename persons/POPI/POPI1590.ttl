	dprr:hasOriginalText "P. Popillius C. f. P. n. Laenas (*10)" ;
	dprr:hasOfficeXref "Pr. by 135" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/3> ;
	dprr:hasDateStart -132 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -132 .
