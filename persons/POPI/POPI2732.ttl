	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "One of the murderers of Cicero (Plut. Cic. 48.1-2, #; though a centurion named Herennius actually killed him; Liv. Per. 120, a legionary soldier; Val. Max. 5.3.4)." .
