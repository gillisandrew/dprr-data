	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. Mil. 43. In MRR 2.350, refer also to App. BC 4.19-20; Seneca, Suas. 6.20; Contr. 7.2.8; Dio 47.11.1-2; Jerome, Chr. P. 156 Helm.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6087> rdfs:label "Post Assertion Note: #6087" ;
