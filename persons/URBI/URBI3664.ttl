	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Monetalis. Crawford (RRC 1.312-313, no. 299, 111 or 110 B.C.) reads, not Q(uaestores) Ur(bani), but Q. Ur(binius), and considers him a IIIvir monetalis along with Ap. Cl. and T. Mal. or Manl. See below, on C. Urbinus (2), RE 9A.995.\n" ;
	dprr:hasID 7574 .
