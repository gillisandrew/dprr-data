	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Metellus Pius in Farther Spain (Sall. Hist. 2.70M)." ;
	dprr:hasID 4422 .
