<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7237> rdfs:label "Post Assertion Note: #7237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor under Metellus Pius in Hisp. Ult. in 74? (see MRR 2.103), but in 75 if the return of Metellus Pius to Hisp. Ult. is correctly placed above in the autumn of 75 (see Cn. Pompeius Magnus, RE no. 31) (Sall. Hist. 2.70M, from Macrob. Sat. 3.13.6-9, with the spelling Urbinus). He is conjecturally identified with the Urbinus who was proscribed and saved by a slave who took his place (Macrob. Sat. 1.11.16); called Urbinius Panapio in Val. Max. (6.8.6; cf. Dio 47.10.2). (TJC) See Wiseman, NM 268, no. 453.\n" ;
	dprr:hasID 7237 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4422> rdfs:label "Post Assertion Note: #4422" ;
