<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> rdfs:label "Secondary Source: Broughton MRR II" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. II" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. II (99 B.C.-31 B.C.). Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR II" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3825> rdfs:label "Post Assertion Note: #3825" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "10 Cichorius' interpretation of this inscription remains uncertain both as to the meaning of the list and as to the restorations suggested for a number of the names. He is probably mistaken in suggesting C. Iulius L. f. Caesar, who was a commissioner ca. 100 (see 100, Special Commissions)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3824> rdfs:label "Post Assertion Note: #3824" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "This list, found at Vibo (CIL 10.44, and p. 1003), is interpreted by Cichorius (RS 116-125) to be a list of land commissioners appointed under the law of Livius Drusus." .
