	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Officer at Octavian's naval base at Lipara 37-36; see MRR 2.406. Grant (FITA 52-54) suggests that he was P. Alfenus Varus, Cos. A.D. 2, but Cadoux favors his father, Cos. suff. 39. (TJC)\n" ;
	dprr:hasID 7762 .
