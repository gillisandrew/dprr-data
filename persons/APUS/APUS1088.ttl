<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8434> rdfs:label "Post Assertion Note: #8434" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 730" ;
	dprr:hasID 8434 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2229> rdfs:label "Post Assertion Note: #2229" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Killed while serving under Livius Salinator in Lycia (Liv. 37.16.12; see note 2)." ;
	dprr:hasID 2229 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2228> rdfs:label "Post Assertion Note: #2228" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The careers of the Pr. of 196, the Legate of Scipio, and the officer under Livius in Lycia as given in RE 2 and 5 supplement each other. Notice of his death in Lycia marks an officer of some distinction, and the rest of Scipio's known Legates were ex-Praetors or ex-Consuls. One must assume that after collecting ships for Scipio he joined Livius in the Aegean." ;
	dprr:hasID 2228 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2222> rdfs:label "Post Assertion Note: #2222" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Collected transports for L. Scipio at Brundisium (Liv. 37.4.2). See no. b." ;
	dprr:hasID 2222 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2221> rdfs:label "Post Assertion Note: #2221" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The careers of the Pr. of 196, the Legate of Scipio, and the officer under Livius in Lycia as given in RE 2 and 5 supplement each other. Notice of his death in Lycia marks an officer of some distinction, and the rest of Scipio's known Legates were ex-Praetors or ex-Consuls. One must assume that after collecting ships for Scipio he joined Livius in the Aegean." ;
	dprr:hasID 2221 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2146> rdfs:label "Post Assertion Note: #2146" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "To Castrum Frentinum under Tubero's law (Liv. 35.9.7-8; see 194, no. c.)." ;
	dprr:hasID 2146 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2113> rdfs:label "Post Assertion Note: #2113" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Granted imperium for three years in order to colonize the Ager Thurinus (Liv. 34.53.1-2; cf. 35.9.7-8)." ;
	dprr:hasID 2113 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2112> rdfs:label "Post Assertion Note: #2112" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "The Measures authorizing nos. c. and d. were passed at the end of 194, so Tubero was a Tr. Pl. of 193. The elections to the commissions were held by Domitius the Pr. Urb. of 194 (Liv. 34.53.2). Note that Tubero was elected to a commission that he created." ;
	dprr:hasID 2112 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2028> rdfs:label "Post Assertion Note: #2028" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 33.24.2 Provinces and armies 33.26.1-4, and 43.7-8." ;
	dprr:hasID 2028 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1978> rdfs:label "Post Assertion Note: #1978" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Sulpicius in charge of part of the fleet in Greece (Liv. 31.44.1, and 45.1-47.3; cf. 32.16.5; App. Mac. 4; Zon. 9.15).{329}" ;
	dprr:hasID 1978 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1946> rdfs:label "Post Assertion Note: #1946" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Galba in Macedonia (Liv. 31.27.1-8; Zon. 9.15)." ;
	dprr:hasID 1946 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1906> rdfs:label "Post Assertion Note: #1906" ;
