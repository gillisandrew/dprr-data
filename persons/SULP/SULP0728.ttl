	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Poeneis et Sardeis. MRR I.206, Itgenshorst no. 131, Rich no. 130." .
