<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1522> rdfs:label "Primary Source Reference: #1522" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plut. Caes. 5.3" ;
