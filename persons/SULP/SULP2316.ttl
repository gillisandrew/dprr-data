<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9925> rdfs:label "Post Assertion Note: #9925" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/23> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "pp. 65-72" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8801> rdfs:label "Post Assertion Note: #8801" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 755, footnote 478" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6141> rdfs:label "Post Assertion Note: #6141" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Postponements of elections (Cic. Ad Brut. 1.5.4, and 14.1) prevented the appointment of successors until the hasty elections held at the end of the year by the Triumviri (see above, Consuls Suffecti, Praetors, Minucius; Dio 47.15.3-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6140> rdfs:label "Post Assertion Note: #6140" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Condemned under the Pedian law as one of Caesar's murderers, and not mentioned after 43 (Suet. Galba 3.2). See 50, Augurs." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6124> rdfs:label "Post Assertion Note: #6124" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Legate under Hirtius (cf. Cic. Phil. 13.33) in command of the Martian legion who fought at Forum Gallorum (Cic. Fam. 10.30). He probably went on to serve under Decimus Brutus (see Envoys) and was condemned under the Pedian law as one of Caesar's murderers (Suet. Galba 3.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6094> rdfs:label "Post Assertion Note: #6094" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by Decimus Brutus to bring despatches to the Senate (Cic. Fam. 11. 18. 1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5509> rdfs:label "Post Assertion Note: #5509" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A member of the college before 49 (Cic. Att. 9.9.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5498> rdfs:label "Post Assertion Note: #5498" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "A probable member of the college of Augurs on the eve of the death of Hortensius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5223> rdfs:label "Post Assertion Note: #5223" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Enabled his old commander Pomptinus to secure his triumph (Dio 39.65.2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5164> rdfs:label "Post Assertion Note: #5164" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (see 57, Legates, on his service during the winter of 57-56). He may have returned to Rome in 56." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5107> rdfs:label "Post Assertion Note: #5107" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Suet. Galba 3.2; Dio 39.5.2; cf. Caes. BG 8.56.4); and attempted in autumn of this year to subdue the tribes about the Great Saint Bernard pass (Caes. BG 3.1-6; Dio 39.5.2-4; Oros. 6.8.1-5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5065> rdfs:label "Post Assertion Note: #5065" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legates under Caesar in Gaul. The four unnamed Legates in Caesar's battle with Ariovistus probably were among these (BG 1.52. 1). See 57, Legates; and esp. D.-G. 3.696ff." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4984> rdfs:label "Post Assertion Note: #4984" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Titles not preserved. These three served, almost certainly as Legates, under C. Pomptinus in Transalpine Gaul (Dio 37.48.1-2; cf. on Sulpicius, 39.65.2). See 61, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4959> rdfs:label "Post Assertion Note: #4959" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "All three served under C. Pomptinus in Transalpine Gaul (Dio 37.47-48; and on Sulpicius, cf. 39.65.2), but their titles are not given." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4926> rdfs:label "Post Assertion Note: #4926" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a Legate under Pomptinus in Transalpine Gaul (Dio 37.47-48; cf. 39.65.1)." .
