	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See Badian, Historia 12, 1963, 140-141, on whether Ser. Sulpicius (95) Rufus or P. Servilius (67) Isauricus (more probably the former) is named in the SC quoted in Joseph. AJ 14.220; cf. L. R. Taylor, VDRR 257." ;
