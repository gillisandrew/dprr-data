<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2108> rdfs:label "Person Note: #2108" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Der herausragende Jurist und Interrex von 52 wird von Mitchell aufgrund seiner Theorie, die das Patriziat als priesterlichen Stand definiert sieht, zu Unrecht als Pontifex vindiziert:  Weder ist die theoretische Basis haltbar noch läßt sich ein zeitlich passender freier Platz im Pontifikalkollegium für den Konsul von 51 (63 scheiterte die Kandidatur) nachweisen. " ;
	dprr:hasID 2108 .
