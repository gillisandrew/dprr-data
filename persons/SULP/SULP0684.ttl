<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1443> rdfs:label "Primary Source Reference: #1443" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Plin. n.h. XXII 13" ;
