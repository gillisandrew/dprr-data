<http://romanrepublic.ac.uk/rdf/entity/PersonNote/28> rdfs:label "Person Note: #28" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 461. For discussion whether his praenomen was Ser. or P. see MRR 1.43, note 2, cf. 1.36; Münzer, RE no. 36; Ogilvie, Comm. Liv. 415, who holds that he was the envoy of 449 (see MRR 1.49; Liv. 3.50.15-16; Ascon. 77C)." .
