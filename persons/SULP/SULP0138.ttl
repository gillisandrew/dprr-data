	dprr:hasNoteText "Cic. Att. XIII 4.1" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/292> .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/246> rdfs:label "Primary Source Reference: #246" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Cic. Att. V 11.7" ;
