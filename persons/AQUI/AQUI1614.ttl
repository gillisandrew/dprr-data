<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9983> rdfs:label "Post Assertion Note: #9983" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph ex Asia. MRR I.509, Itgenshorst no. 216, Rich no. 216." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8639> rdfs:label "Post Assertion Note: #8639" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
