<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2948> rdfs:label "Person Note: #2948" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A partisan of Mark Antony, listed among other distinguished men, who died with his son after Actium (Dio 51.2.5-6; but cf. Suetonius [Aug. 13.2], who, without naming the victims, reverses the order of their deaths and dates them after Philippi). See PIR(2) 1.193, no. 989. (TJC)" .
