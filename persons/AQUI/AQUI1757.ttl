	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Ovation de serveis ex Sicilia. MRR II.2, 4n.10, Itgenshorst no. 237, Rich no. 237." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9544> rdfs:label "Post Assertion Note: #9544" ;
	a dprr:PostAssertionNote ;
