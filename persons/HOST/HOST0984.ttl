<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1816> rdfs:label "Post Assertion Note: #1816" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor at Capua (Liv. 29.13.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1775> rdfs:label "Post Assertion Note: #1775" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor at Capua (Liv. 28.45.10; 29.13.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1752> rdfs:label "Post Assertion Note: #1752" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor at Capua. See 207-204, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1724> rdfs:label "Post Assertion Note: #1724" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued, first for command at Tarentum, then Capua (Liv. 27.35.2 and 14, 36.13; cf. 28.10.15). Cf. Liv. 27.40.10-14." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1719> rdfs:label "Post Assertion Note: #1719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy omits the regular list of prorogations for this year with the exception of Q. Fulvius Flaccus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1690> rdfs:label "Post Assertion Note: #1690" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor in Etruria (Liv. 27.22.4 and 13), with instructions to guard against defection there (27.24.1-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1644> rdfs:label "Post Assertion Note: #1644" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "These texts make clear that at 27.7.11 the name of Hostilius has been inserted by mistake for that of Veturius as the successor of Laetorius in Gaul. See Liv. 27.10.12, on Veturius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1643> rdfs:label "Post Assertion Note: #1643" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Election Liv. 27.6.12 Provinces and armies 27.7.8-12, cf. 22.5-6Celebrated the Ludi Apollinares (Liv. 27.11.6, cf. 23.5).\n     {286}" .
