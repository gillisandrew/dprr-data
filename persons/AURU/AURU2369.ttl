	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., Lieut. 54. In MRR 2.225, add a reference to Athenaeus 6.273 b (#).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5254> rdfs:label "Post Assertion Note: #5254" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul. Killed by the Eburones in the revolt (Caes. BG 5.24.5, and 26.1-37.7; Liv. Per. 106; Plut. Caes. 24.1; Flor. 1.45.8; Dio 40.5-6; Oros. 6.10.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5207> rdfs:label "Post Assertion Note: #5207" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Caes. BG 4.22.5, and 38.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5100> rdfs:label "Post Assertion Note: #5100" ;
