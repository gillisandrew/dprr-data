<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9731> rdfs:label "Post Assertion Note: #9731" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He held a command in Syria before 43, when he was proscribed (App. B.C. 4.40). He may be identified with Caesar's legatein Gaul, C. AIntistius Reginus 939)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7681> rdfs:label "Post Assertion Note: #7681" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Reginus to whom Cicero refers in May 49 (Att. 10.21.1), perhaps as a naval commander, may be identified with Caesar's legatus in Gaul, 53-50 (TJC; RS, CP; Shackleton Bailey, CLA 4.203).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5471> rdfs:label "Post Assertion Note: #5471" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (see 52, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5407> rdfs:label "Post Assertion Note: #5407" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (see 52, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5355> rdfs:label "Post Assertion Note: #5355" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate under Caesar in Gaul (Caes. BG 7.83.3, and 90.6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5292> rdfs:label "Post Assertion Note: #5292" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legate of Caesar in Gaul (Caes. BG 6.1.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10455> rdfs:label "Post Assertion Note: #10455" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/27> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Hinard suggests a possible praetorship before his proscription" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10454> rdfs:label "Post Assertion Note: #10454" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Attested with Sextus Pompey in 35 and reported to have been with him for a long time. Presumably with Sextus since 42, when many proscripti fled to him." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10453> rdfs:label "Post Assertion Note: #10453" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 5.139. Hinard, following Gabba and Willems, identifies the proscriptus with the Antistius (3) named alongside C. Fannius, Libo, Cassius Parmensis, Q. Nasidius, Saturninus, and Thermus as a senior and longstanding associate of Sextus Pompey, all in the East in 35. Following Sextus' downfall, all surrender to Antony." .
