<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/335> rdfs:label "Post Assertion Note: #335" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Killed by the Fidenates at the command of Lars Tolumnius of Veii, and honored with statues on the Rostra (Cic. Phil. 9.4-5; Liv. 4.17.2-6; Plin. NH 34.23)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/334> rdfs:label "Post Assertion Note: #334" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "For Cloelius, Cicero has Cluvius; and for Antius, Pliny has Nautius, an early patrician name more likely to appear in accounts of this period; see Fast. Cap. on 458. Krug (5) places these under 426." .
