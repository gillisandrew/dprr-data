<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4660> rdfs:label "Post Assertion Note: #4660" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Since the return of Caesar, Quaestor under Antistius in Farther Spain, was ante tempus (Suet. Iul. 8), Antistius probably remained in his province through this year (see 69, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4608> rdfs:label "Post Assertion Note: #4608" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Propraetor in Farther Spain, under whom Iulius Caesar served as Quaestor (Vell. 2.43.4; Plut. Caes. 5.3, # cf. Suet. Iul. 7, praetor)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4607> rdfs:label "Post Assertion Note: #4607" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "9 See Quaestors, on Caesar. The date of Antistius' command in Spain depends on that of Caesar's quaestorship." .
