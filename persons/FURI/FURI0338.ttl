<http://romanrepublic.ac.uk/rdf/entity/PersonNote/1035> rdfs:label "Person Note: #1035" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/15> ;
	dprr:hasNoteText " Der nach dem Fragment einer wohl den (Augur)Auguren zuzuweisenden Sukzessionsliste im Jahr 390 kooptierte Priester ist eher als Q. Servilius Q. f. P. n. Fidenas (Nr. 3065) zu identifizieren. Im Jahr 403 war Furius bereits Tribunus militum consulari potestate. " .
