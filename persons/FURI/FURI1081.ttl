<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2589> rdfs:label "Post Assertion Note: #2589" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Accused of peculation in office by several communities of Spain, he went into exile at Tibur in 171 (Liv. 43.2.8-11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2583> rdfs:label "Post Assertion Note: #2583" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 41.28.5 Provinces 42.1.5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2292> rdfs:label "Post Assertion Note: #2292" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He illegally disarmed the Cenomani, whereupon the Consul Lepidus was instructed to restore them their arms, and forced the Praetor to leave his province (Liv. 39.3.1-3; Diod. 29.14, with the name corrupted to Fulvius)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2290> rdfs:label "Post Assertion Note: #2290" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 38.42.3 Provinces and armies Liv. 38.42.6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2164> rdfs:label "Post Assertion Note: #2164" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They settled a colony at Vibo (Liv. 35.40.5-6)" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2114> rdfs:label "Post Assertion Note: #2114" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Granted imperium for three years in order to colonize Bruttium (Liv. 34.53.1-2; cf. 35.40.6). See note 5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1950> rdfs:label "Post Assertion Note: #1950" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Purpurio in Gaul (Liv. 31.21.8; cf. CIL 1\n     .2.48-49)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1948> rdfs:label "Post Assertion Note: #1948" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Though the names of these Legates are doubted by Münzer (RE) because the details of the accounts are drawn from annalistic sources, some are indubitably historical (e. g. Laetorius, and Valerius), and all should be listed." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1921> rdfs:label "Post Assertion Note: #1921" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Rome to bring a report from M. Aurelius Cotta (Liv. 30.42.2-10; see above, on Cotta). See below, note 3." .
