	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In charge of the Adriatic coast from Ancona to Aquileia, and brought a fleet to Istria (Liv. 41.1.2-4)." ;
