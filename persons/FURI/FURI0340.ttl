	dprr:hasNoteText "Triumph de Galleis. MRR I.95, Itgenshorst p. 263, Rich no. 48." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10103> rdfs:label "Post Assertion Note: #10103" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
