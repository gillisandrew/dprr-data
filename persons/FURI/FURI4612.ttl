	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9079> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7127> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4371> ;
	dprr:hasOriginalText "L. Furius Pat.? (18, cf. 2) or L. Turius (2)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -75 ;
	dprr:hasDateEnd -75 .
