	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Selected by lot to remain in Hither Spain with imperium prorogued, when his successor Fabius Buteo died at Massilia (Liv. 42.4.2-3)." .
