	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Accused in 171 by peoples of Spain of peculation in office, he went into exile at Praeneste (Liv. 43.2.8-11)." .
