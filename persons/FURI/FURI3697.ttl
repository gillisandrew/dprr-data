	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A man of praetorian stock (stirpe praetoria) who fought as a gladiator in Caesar's games in 46 (Suet. Iul. 39.1). Not certainly a senator then or earlier. See above, on Fulvius Sepinus (108) (RS, MS-RP 1.281-282)\n" ;
	dprr:hasID 7637 .
