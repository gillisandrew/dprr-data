<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1251> rdfs:label "Post Assertion Note: #1251" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Val. Max. 6.1.7; Plut. Marc. 2.2-4." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1250> rdfs:label "Post Assertion Note: #1250" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Valerius Maximus calls Scantinius a Tribune of the Plebs, but Plutarch a fellow magistrate of Marcellus, who accused him of improper proposals to his son. In defence, Scantinius appealed to his personal inviolability, which indicates that he was a plebeian official, and was refused aid by all the college of Tribunes, which indicates that he was an Aedile rather than a Tribune (see Mommsen, Str. 1.289, note 2, and 706, note 4; 2.472, note 2, and 493, note 4; and on the accountability of the Aediles, Gell. 13.13). For the date, see on Marcellus above; and Seidel, Fast. Aed. 20." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1619> rdfs:label "Post Assertion: #1619" ;
	a dprr:PostAssertion ;
