<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/86> rdfs:label "Post Assertion Note: #86" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "They returned from Sicily with large supplies (Dion. Hal. 7.20.2-3, and 37.3; cf. Liv. 2.34.7; Plut. Cor. 16.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/81> rdfs:label "Post Assertion Note: #81" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Sicily for grain to relieve famine in Rome (Dion. Hal. 7.1.3, and 2.1; cf. Gellius fr. 20, and Licinius, fr. 12, Peter; Liv. 2.34.3). On Valerius, see Münzer, Gent. Val. 34, no. 2." .
