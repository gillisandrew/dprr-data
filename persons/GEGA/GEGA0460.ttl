	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/572> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/571> ;
	dprr:hasOriginalText "L. Geganius - f. - n. (Macerinus) Pat. (2)" ;
