	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate with instructions to the Consuls to collect the remnants of the armies of Sempronius Gracchus and Fulvius Flaccus (Liv. 25.22.2)." ;
	dprr:hasID 1536 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1341> rdfs:label "Post Assertion Note: #1341" ;
