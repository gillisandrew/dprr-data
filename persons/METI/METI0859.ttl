	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed the law to make Minucius co-Dictator with Fabius (see above, Dictator, on Minucius). On the Lex Metilia de fullonibus, see Niccolini, FTP 91; and above 220, Censors." ;
	dprr:hasID 1341 .
