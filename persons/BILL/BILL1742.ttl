	dprr:hasNoteText "I. de Delos 4.1.1710, before 100." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6689> rdfs:label "Post Assertion Note: #6689" ;
	a dprr:PostAssertionNote ;
