	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "I. de Delos 4.1.1632, before 100 B. C." ;
	dprr:hasID 6689 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3517> rdfs:label "Post Assertion Note: #3517" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul (CIL 1\n     .2.815), probably in Asia. See 107, Praetors and note 3.{554}" ;
	dprr:hasID 3517 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3498> rdfs:label "Post Assertion Note: #3498" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 1\n     .2.815; cf. I. de Délos 4.1.1710; Cio. Brut. 175." ;
	dprr:hasID 3498 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3497> rdfs:label "Post Assertion Note: #3497" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "This man is probably the Billienus who was excluded from the consulship by the series held by Marius (Cic. Brut. 175). If so, his praetorship should be dated about this time. According to I. de Délos 4.1.1710- CIG 2285B he was honored at Delos with the title of Legate, but in CIL 1(2).2.815 he is called a Proconsul. See 106, Promagistrates." ;
	dprr:hasID 3497 .
