<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2756> rdfs:label "Post Assertion Note: #2756" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to King Gentius by Claudius Centho, imprisoned as spies, but released when Gentius surrendered to Claudius' successor Anicius. Thereupon Perperna received the surrender of Gentius' family and was sent to Rome to report the victory (Liv. 44.27.11, 30.11, and 32.1-4; Plut. Aem. 13.1-2; App. Mac. 18; Illyr. 9; cf. IG 9.2.258).{431}" ;
	dprr:hasID 2756 .
