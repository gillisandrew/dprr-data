<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8762> rdfs:label "Post Assertion Note: #8762" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 754, footnote 438" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6769> rdfs:label "Post Assertion Note: #6769" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tribune of the Soldiers twice (Elogium, CIL 12.1, p. 199-Inscr. Ital. 13.3, no. 75-ILS 47), probably shortly before 70." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5018> rdfs:label "Post Assertion Note: #5018" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (Elogium, CIL 12.1, p. 199-Inscr. Ital. 13.3.75 b-ILS 47). Saluted as Imperator for his victory over the Bessi (Elogium; Vell. 2.59.2; Suet. Aug. 3.2; 94.5). See also Cic. QF 1.2.7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4976> rdfs:label "Post Assertion Note: #4976" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul in Macedonia (Elogium, CIL 12.1, p. 199-Inscr. Ital. 13.3.75b- ILS 47; Vell. 2.59.2; cf. Cic. Att. 2.1.12). While on his way to his province he crushed some remnants of the bands of Spartacus and of Catiline near Thurii (Suet. Aug. 3. 1; 7. 1). See 59-58, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4934> rdfs:label "Post Assertion Note: #4934" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elogium, CIL 12.1, p. 199-Inscr. Ital. 13.3.75b-ILS 47; Cic. QF 1.1.21; Vell. 2.59.1-2. See 60-58, Promagistrates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4855> rdfs:label "Post Assertion Note: #4855" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elogium, CIL 12.1, p. 199-Ingcr. Ital. 13.3.75b-ILS 47. See 64, Aediles." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4818> rdfs:label "Post Assertion Note: #4818" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12. 1, p. 199-Inscr. Ital. 13.3.75b-ILS 47; cf. Suet. Aug. 27. 1." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4817> rdfs:label "Post Assertion Note: #4817" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "3 The date of these aedileships is not securely attested, but since Octavius held the praetorship in 61, this is a probable year." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4455> rdfs:label "Post Assertion Note: #4455" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Elogium, CIL 12.1, p. 199-Inscr. Ital. 13.3.75b. See below, on his colleague Toranius." .
