	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He commanded a middle section of Antony's fleet at Actium (Plut. Ant. 65.2)." .
