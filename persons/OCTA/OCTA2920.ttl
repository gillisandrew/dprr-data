<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6497> rdfs:label "Post Assertion Note: #6497" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He commanded a middle section of Antony's fleet at Actium (Plut. Ant. 65.2)." ;
	dprr:hasID 6497 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10312> rdfs:label "Post Assertion Note: #10312" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.204 (MRR lists Octavius as promagistrate but admits that this admiral's title is not preserved, Suolahti has praefectus classis or legatus)." ;
	dprr:hasID 10312 .
