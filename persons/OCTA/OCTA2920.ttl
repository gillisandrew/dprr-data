	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.204 (MRR lists Octavius as promagistrate but admits that this admiral's title is not preserved, Suolahti has praefectus classis or legatus)." .
