<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9183> rdfs:label "Post Assertion Note: #9183" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 728, footnote 35" ;
	dprr:hasID 9183 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2185> rdfs:label "Post Assertion Note: #2185" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 192, Legates, no. b. Sent by Flamininus to Acarnania (Liv. 36.12.9)." ;
	dprr:hasID 2185 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2163> rdfs:label "Post Assertion Note: #2163" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to oppose Aetolian influence and rally the Greek communities against Antiochus (Liv. 35.23.5-8; note esp. Flamininus at Demetrias, 35.31, in Aetolia, 35.32-33, in Corinth, 35.34.1, and 39.1, and at the Achaean assembly, 35.48-50; and Villius' trip to Demetrias, 35.39; cf. Diod. 29.1; Plut. Flam. 15-17; Zon. 9.19). See also 191, Legates; and on Villius, Lübker, no. 1." ;
	dprr:hasID 2163 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2115> rdfs:label "Post Assertion Note: #2115" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Croton (Liv. 34.45.3-5)." ;
	dprr:hasID 2115 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1945> rdfs:label "Post Assertion Note: #1945" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent on missions to Carthage, to Masinissa, and to Vermina, Syphax's son (Liv. 31.11.4-18, and 19.1-6)." ;
	dprr:hasID 1945 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1914> rdfs:label "Post Assertion Note: #1914" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued as Propraetor at Scipio's wish (Liv. 30.41.6-8, and 44.13; 31.3.2-3)." ;
	dprr:hasID 1914 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1891> rdfs:label "Post Assertion Note: #1891" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His imperium in command of the fleet off Sicily was prorogued (Liv. 30.27.9, and 41.6-7, cf. 2.3-4). He also served under Scipio (Liv. 30.36.3-6; cf. App. Lib. 41 and 44, who has confused his position with that of Laelius at Zama; see above, Quaestors)." ;
	dprr:hasID 1891 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1856> rdfs:label "Post Assertion Note: #1856" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium as Praetor prorogued with command of a fleet to protect the coast of Sardinia (Liv. 30.2.4)." ;
	dprr:hasID 1856 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1821> rdfs:label "Post Assertion Note: #1821" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in command of a fleet (Liv. 29.13.5), with which he transported grain and clothing for Scipio's army in Africa (Liv. 29.36.1-3)." ;
	dprr:hasID 1821 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1768> rdfs:label "Post Assertion Note: #1768" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Captured some Carthaginian cargo ships (Liv. 28.46.14, cf. Coelius fr. 33 Peter, and Val. Ant. fr. 26 Peter; App. Hann. 54)." ;
	dprr:hasID 1768 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1744> rdfs:label "Post Assertion Note: #1744" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 28.38.11." ;
	dprr:hasID 1744 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1389> rdfs:label "Post Assertion Note: #1389" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "With Sempronius (see below), he led soldiers in a break through Hannibal's lines at Cannae (Frontin. Str. 4.5.7)." ;
	dprr:hasID 1389 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1388> rdfs:label "Post Assertion Note: #1388" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Though Octavius is mentioned only by Frontinus, Münzer (RE) sees no reason to reject the notice." ;
	dprr:hasID 1388 .
