<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2686> rdfs:label "Post Assertion Note: #2686" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Carni, Istri, and Iapydes to answer their complaints regarding the misdeeds of the Consul Cassius in 171 (Liv. 43.5.7 and 10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2685> rdfs:label "Post Assertion Note: #2685" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Livy's text reads C., not Cn., but no member of the family except Cn. Sicinius suitable in rank to head this embassy is known in this period." .
