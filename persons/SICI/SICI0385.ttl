	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Reelected with the rest of the college of 395 (Liv. 5.25.13, cf. 26.3; Plut. Cam. 9.1)." ;
