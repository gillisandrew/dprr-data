<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7531> rdfs:label "Post Assertion Note: #7531" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The officer (leg., lieut.?) under Sertorius in 76 (MRR 2.95) is perhaps to be identified with the young member (no. 40) of the consilium of Pompeius Strabo in 89, L. Insteius L. f. Fal. (Cichorius, RS 167; see Criniti, L'Epigrafe di Asculum 21, 150-151). (LRT)\n" ;
	dprr:hasID 7531 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4358> rdfs:label "Post Assertion Note: #4358" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Both served under Sertorius in Spain (Liv. 91, fr. 22W, with the name Herennuleius; see 75, Legates)." ;
	dprr:hasID 4358 .
