<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7763> rdfs:label "Post Assertion Note: #7763" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In MRR 2.421, he is better listed as a leg., lieut. or a praef. class., as in the Index, 2.574, than as a promagistrate. See Wiseman, NM 236, no. 216.\n" ;
	dprr:hasID 7763 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6496> rdfs:label "Post Assertion Note: #6496" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He commanded a middle section of Antony's fleet at Actium (Plut. Ant. 65.1; cf. Gardthausen 2.198, note 33)." ;
	dprr:hasID 6496 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6152> rdfs:label "Post Assertion Note: #6152" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tribune Designate in 43 (Cic. Phil. 13.26; cf. Phil. 12.20; and for his praenomen, Plut. Ant. 65.1)." ;
	dprr:hasID 6152 .
