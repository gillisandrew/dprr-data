<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6509> rdfs:label "Post Assertion Note: #6509" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His title is not preserved. He commanded a small squadron of ships which was attacked and routed by Sosius (Dio 50.14.1-2; see Promagistrates, on Sosius). See De Laet no. 371; PIR 3.295, no. 14:." ;
	dprr:hasID 6509 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10314> rdfs:label "Post Assertion Note: #10314" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/26> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "C.206 (MRR lists Tarius as legatus but admits that this naval commander's title is not preserved, Suolahti has praefectus classis)" ;
	dprr:hasID 10314 .
