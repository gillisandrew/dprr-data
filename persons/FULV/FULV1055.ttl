<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1883> rdfs:label "Post Assertion Note: #1883" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Subordinates of the Aediles were condemned for theft of treasury funds, with detriment to Lucullus' reputation (Liv. 30.39.6-7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1882> rdfs:label "Post Assertion Note: #1882" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Scipio's Legate, Q. Fulvius Gillo, returned to Africa late in 203 with the Carthaginian envoys (Liv. 30.25.9-10; cf. De Sanctis 3.2.587). This would not however differentiate him from the Q. Fulvius above, since in one case, L. Cornelius Lentulus in 205, the Curule Aedile was absent in Spain during his magistracy. See Münzer, RE." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/2254> rdfs:label "Post Assertion: #2254" ;
	a dprr:PostAssertion ;
