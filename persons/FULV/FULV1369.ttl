<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8568> rdfs:label "Post Assertion Note: #8568" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 736, footnote 107" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2867> rdfs:label "Post Assertion Note: #2867" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated as Proconsul a triumph over the Eleate Ligurians (Fast. Cap. and Urbisalv., Degrassi 82f., 338f., 557)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2862> rdfs:label "Post Assertion Note: #2862" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Cap., Degrassi 50f., 123, 462f.; Suet. Vit. Ter. 5; Chr. 354; Fast. Hyd.; Chr. Pasc.; Cassiod. Fulvius held command in Liguria (see 158); and both Consuls carried a bribery law (Liv. Per. 47)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2839> rdfs:label "Post Assertion Note: #2839" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The most probable date for Dolabella, who was Curule Aedile in 165. For Nobilior, who was Curule Aedile in 166, this is the latest possible date." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2810> rdfs:label "Post Assertion Note: #2810" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Andria of Terence was performed at the Ludi Megalenses under their charge, Didasc. Ter. And. (Donatus)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2648> rdfs:label "Post Assertion Note: #2648" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "In opposition to their colleagues they wished to refer the appeal of the veteran centurions against the levy to the magistrates in charge of the war rather than take cognizance of it themselves (Liv. 42.32.7-8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10099> rdfs:label "Post Assertion Note: #10099" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Liguribus Eleatibus. MRR I.446, Itgenshorst no. 205, Rich no. 204." .
