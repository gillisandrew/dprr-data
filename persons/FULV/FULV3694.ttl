<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7659> rdfs:label "Post Assertion Note: #7659" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Degrassi (ILLRP 340-ILS 5742) suggests that he made his announcement of the aqueduct at Caiatia to the pr. urbanus as Praefectus Capuam Cumas. Perhaps a son of Q. Fulvius Nobilior (95). Cos. 153.\n" ;
	dprr:hasID 7659 .
