<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1314> rdfs:label "Primary Source Reference: #1314" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Lucan. VI 795f." ;
