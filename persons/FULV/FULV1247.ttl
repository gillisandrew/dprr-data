<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2688> rdfs:label "Post Assertion Note: #2688" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Greece to investigate conditions in the Roman army, and returned in late February with a report of defeats and poor discipline (Liv. 43.11.2 and 9-11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2687> rdfs:label "Post Assertion Note: #2687" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The M. Fulvius (Nobilior or Flaccus ?) who was expelled from the Senate in 174 could not have been restored before 169. The present notice therefore attests the existence of another Fulvius Flaccus. See 180, note 3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2658> rdfs:label "Post Assertion Note: #2658" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to restrain the Consul Cassius from attempting to march through Illyria to Macedonia (Liv. 43.1.12)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2429> rdfs:label "Post Assertion Note: #2429" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served, probably as Legates, under the latter's brother in Hither Spain (Liv. 40.30.4, 31.1-9, and 32.5-8)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2428> rdfs:label "Post Assertion Note: #2428" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See Münzer, RE, loc. cit., on the difficulties in identifying this man and tracing his career. It is possible, however, but extremely unlikely, for him to be in Spain in 181 and in Liguria in 180. See 180." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2363> rdfs:label "Post Assertion Note: #2363" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Colonized Potentia and Pisaurum (Liv. 39.44.10; cf. Cic. Brut. 79)." .
