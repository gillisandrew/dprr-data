	dprr:hasNoteText "p. 257-63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8643> rdfs:label "Post Assertion Note: #8643" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 739" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3313> rdfs:label "Post Assertion Note: #3313" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 122, Tribunes of the Plebs; and note 5, below." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3308> rdfs:label "Post Assertion Note: #3308" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 122, Tribunes of the Plebs; and note 5, below." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3294> rdfs:label "Post Assertion Note: #3294" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cf. Plut. CG 10.2; 11.2; App. BC 1.24; but see also on Triumviri coloniis deducendis." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3284> rdfs:label "Post Assertion Note: #3284" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A consular who became a Tribune and Gracchus' chief supporter. According to Appian (BC 1.24), he went to Africa to aid in founding Colonia Iunonia, but Plutarch (CG 10.3; 11.2) has him remain to oppose Livius in Rome. See also App. BC 1.21, and 34; and note 5." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3271> rdfs:label "Post Assertion Note: #3271" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Carcopino (Autour des Gracques 277) believes that the Gracchan commission continued to function and, since he places the Rubrian law in 123, resolves the discrepancy between Appian (BC 1.23) and Plutarch (CG 10.3; 11.2) by having Fulvius go to Africa as a member of the commission in 123 and then stay in Rome while Gracchus in turn went to Africa in 122 (see 122, Tribunes of the Plebs). But it is probable that special commissions would be appointed for specific colonies; and it is not clear that the commission established by Tiberius Gracchus was involved." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3269> rdfs:label "Post Assertion Note: #3269" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul; celebrated a triumph over the Ligures, Vocontii and Salluvii (Act. Tr., Degrassi 82f., 559; Vell. 2.6.4; Plut. CG 15.1; 18.1;{515} cf. Liv. Per. 60; App. BC 1.34; Obseq. 30; see 125, Consuls; and 124-122, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3268> rdfs:label "Post Assertion Note: #3268" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Florus has confused this Flaccus with the Consul of 179." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3249> rdfs:label "Post Assertion Note: #3249" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proconsul (Act. Tr. for 123). Continued in command against the Salluvii (see 123, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3236> rdfs:label "Post Assertion Note: #3236" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Fast. Ant., Degrassi 162f. ([M.] Ful[- - - -]); Val. Max. 9.5.1; Frontin. Aq. 1.8; Obseq. 30; Chr. 354 (Hypseo et Flacco); Fast. Hyd. (Ipseo et Flacco), so also Chr. Pasc.; Phleg. Trall. Mir. 10; Oros. 5.11.1; Cassiod.; on Plautius, Val. Max. 9.5, ext. 4, in FOR 2.143; on Flaccus, Cic. Phil. 8.14; Vell. 2.6.4; and on his name, Act. Tr. for 123. See Degrassi 126, 470f. Flaccus proposed bills to grant citizenship to Italians (Val. Max. 9.5.1; App. BC 1.21), and to grant them the right of appeal (Val. Max.), but to divert him he was sent to aid Massilia against the Salluvii and the Vocontii (Liv. Per. 60; App. BC 1.34; Plut. CG 15.1; Obseq. 30; see 123, Promagistrates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3219> rdfs:label "Post Assertion Note: #3219" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The latest possible dates for their praetorships under the Lex Villia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3212> rdfs:label "Post Assertion Note: #3212" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Protests from the allies led Scipio Africanus to sponsor a measure to transfer the judicial functions of the commission to the Consul (App. BC 1.18-19; cf. FOR 1.120f., 240f.). Carbo and C. Gracchus, members of the commission, were suspected of responsibility for Scipio's sudden death (Cic. QF 2.3.3; De Or. 2.170; Mil. 16; Fat. 18; Fam. 9.21.3; Plut. CG 10.3-5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3200> rdfs:label "Post Assertion Note: #3200" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "After the deaths of Ap. Claudius and Crassus Mucianus (see 133-130), Fulvius Flaccus and Carbo succeeded to their places (CIL 1\n     .2.643-644; Liv. Per. 59; Vell. 2.6.4; Plut. CG 10.3; App. BC 1.18; Obseq. 28a; Auct. Vir. Ill. 65.4, with confusion of the names of Carbo and Crassus)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3123> rdfs:label "Post Assertion Note: #3123" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Lepidus Porcina in Hither Spain (App. Ib. 81)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3122> rdfs:label "Post Assertion Note: #3122" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Flaccus may possibly be identified with either C. Fulvius, Cos. 134, or M. Fulvius, Cos. 125 (RE 53 and 58, resp.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10092> rdfs:label "Post Assertion Note: #10092" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Liguribus, Vocontieis, Salluveisque. MRR I.514-5, Itgenshorst no. 217, Rich no. 217." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/7774> rdfs:label "Post Assertion: #7774" ;
	a dprr:PostAssertion ;
	dprr:isUncertain true ;
