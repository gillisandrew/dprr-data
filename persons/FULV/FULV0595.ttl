	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/882> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7133> ;
	dprr:hasOriginalText "P. Fulvius Longus (78)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/73> ;
	dprr:hasDateStart -313 ;
