	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Captured by the Boii (Liv. 21.59.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1305> rdfs:label "Post Assertion Note: #1305" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE, on Fulvius) admits that Fulvius and Lucretius may have been Quaestors in 217 instead of 218, but in his later article on Lucretius{241} omits the suggestion. He suggests that Fulvius, if he regained his freedom, may be C. Fulvius Flaccus, brother of the Consul of 212 (see 211 and 209, Legates)." .
