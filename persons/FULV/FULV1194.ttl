<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8490> rdfs:label "Post Assertion Note: #8490" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 732" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2441> rdfs:label "Post Assertion Note: #2441" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 40.37.6-7; Fast. Cap., Degrassi 48f., 122, 456f. His province was Liguria, whence he sent 7000 Apuani to Samnium (Liv. 40.41.3-4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2432> rdfs:label "Post Assertion Note: #2432" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Aemilius Paullus in Liguria (Liv. 40.27.3 and 7). See Münzer, Gent. Val. 47, no. 35." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2290> rdfs:label "Post Assertion Note: #2290" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Election Liv. 38.42.3 Provinces and armies Liv. 38.42.6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2247> rdfs:label "Post Assertion Note: #2247" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 38.35.6." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2246> rdfs:label "Post Assertion Note: #2246" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Münzer (RE nos. 60 and 61) has rightly distinguished the careers of Q. Fulvius Cn. f. M. n. Flaccus (60) and Q. Fulvius Q. f. M. n. Flaccus (61)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2004> rdfs:label "Post Assertion Note: #2004" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to the Senate by Flamininus along with the envoys of Philip and of the Greek allies of Rome (Polyb. 18.10.8; Liv. 32.36.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2003> rdfs:label "Post Assertion Note: #2003" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "These Envoys were sent in the late autumn but much of their activity would come within the consular year 198 (Liv. 32.36.6; 33.1.1; Polyb. 18.9.10, and 11.1)." .
