	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Val. Max. IX 7.2" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1862> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8882> rdfs:label "Post Assertion Note: #8882" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 727" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1518> rdfs:label "Post Assertion Note: #1518" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Disastrously defeated by Hannibal, though he escaped with some of his cavalry (Liv. 25.20-21; 26.1.9; 27.1.9; Sil. It. 12.467-472; 17.303-304; Oros. 4.16.17). See note 2." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1517> rdfs:label "Post Assertion Note: #1517" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "De Sanctis (3.2.459, note 28) considers the disaster to this Praetor a doublet of that to Cn. Fulvius Centumalus in 210 (Liv. 27.1.3-15), but Crake in an unpublished Johns Hopkins dissertation (pp. 187f., 279, 332) has pointed out that the loss of this army explains how Hannibal could evade his opponents and march on Rome, and that other explanations of the charge of perduellio against Fulvius (Liv. 26.2.7-12, cf. 6.1-6, and Val. Max. 2.8.3; 8.4.3) are unsatisfactory." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1862> rdfs:label "Post Assertion: #1862" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/924> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8882> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1518> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1517> ;
	dprr:hasPosition 3 ;
	dprr:hasOriginalText "Cn. Fulvius Flaccus (54)" ;
	dprr:hasOfficeXref "Apulia" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/42> ;
	dprr:hasDateStart -212 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -212 .
