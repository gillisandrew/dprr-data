	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Carried a law conceming Cisalpine Gaul (in 49?, see Niccolini, FTP 441; FIRA 1.169-175, no. 19)." .
