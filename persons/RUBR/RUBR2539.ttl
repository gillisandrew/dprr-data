<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7604> rdfs:label "Post Assertion Note: #7604" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Tr. Pl. ? 49? See MRR 2.259; Wiseman, CQ 14, 1964, 129; NM 256-257, no. 363. Wiseman suggests that since other known Rubrii were enemies of Caesar, the author of the Lex Rubria should be identified with L. Rubrius (12) of Casinum.\n" ;
	dprr:hasID 7604 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5529> rdfs:label "Post Assertion Note: #5529" ;
