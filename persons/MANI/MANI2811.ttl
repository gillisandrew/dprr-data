<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6246> rdfs:label "Post Assertion Note: #6246" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "An agent of Mark Antony, probably a procurator (App. BC 5.14), who was active in the preliminaries to the Perusine war, and was sent from Perusia to urge the Antonian commanders, Ventidius and Pollio, to hurry to his aid (App. BC 5.32, cf. 19, and 22, and 29, and 43, and 66; Martial 11.20)." .
