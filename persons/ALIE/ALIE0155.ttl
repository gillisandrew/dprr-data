<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/237> rdfs:label "Post Assertion Note: #237" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prosecuted Veturius (Cos. 455) and condemned him to a fine (Liv. 3.31.5-6; Dion. Hal. 10.48.3-4)." ;
	dprr:hasID 237 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/233> rdfs:label "Post Assertion Note: #233" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The Tribunes of 456 were reelected (Liv. 3.31.1; Dion. Hal. 10.33.1). Dion. Hal. names Icilius (10.33.1, and 40.1); and Livy, Alienus (3.31.5; cf. Dion. Hal. 10.48.3; see 454, Aediles)." ;
	dprr:hasID 233 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/231> rdfs:label "Post Assertion Note: #231" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 3.31.1; Dion. Hal. 10.33.1. See 455, Tribunes, and 454, Aediles." ;
	dprr:hasID 231 .
