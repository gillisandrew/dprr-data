	dprr:hasNoteText "Cos. Suff. 33. He celebrated a triumph ex Africa in 28 (Degrassi, Fast. Triumph., Inscr. Ital. 13.1.570f.).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6455> rdfs:label "Post Assertion Note: #6455" ;
