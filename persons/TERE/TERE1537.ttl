<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3012> rdfs:label "Post Assertion Note: #3012" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "The ten Legates sent to assist Mummius in Greece returned home in the spring (Polyb. 39.5.1; see 146, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2996> rdfs:label "Post Assertion Note: #2996" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "These and others up to ten in number were sent to assist Mummius in reorganizing Greece (I. v. Olymp. 321-324; Polyb. 39.1.1-4;{468} Cic. Att. 13.4.1, 5.1, 6a, 30.2, 32.3, and 33.3; Mur. 15, on Licinius; Pausan. 7.16.9.10). On Postumius, see Lübker no. 4." .
