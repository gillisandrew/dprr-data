	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "A Proquaestor under Pompey in Spain (Grueber, CRRBM 2.362f.). See above, on Cn. Piso; and 75, note 7." .
