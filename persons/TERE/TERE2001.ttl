<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8170> rdfs:label "Post Assertion Note: #8170" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Leg., lieut. with Murena in Asia. In MRR 2.72, read ILS 8773-ILLRP 369.\n" ;
	dprr:hasID 8170 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4186> rdfs:label "Post Assertion Note: #4186" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served as a Legate under Licinius Murena in Asia (SIG³ 745; ILS 8773; IGRP 1.843-IG 12.8.260; I. de Delos 4.1, no. 1698; cf. CIL 12.2.738). He was accused of extortion in Asia, twice prosecuted, and finally acquitted with Hortensius as patron (Cic. Div. in Caec. 24, and Ps.-Ascon. 193, and 213 Stangl; Verr. 1.17, and Schol. Gron. 349 Stangl; cf. Verr. 1.35 and 40 and 47; Ps.-Acro on Hor. Sat. 2.1.49)." ;
	dprr:hasID 4186 .
