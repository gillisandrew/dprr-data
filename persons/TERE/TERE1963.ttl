<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9805> rdfs:label "Post Assertion Note: #9805" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/25> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "p. 257-63" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9276> rdfs:label "Post Assertion Note: #9276" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/8> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No. 8, pp. 210-1 (dated 95/90)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9053> rdfs:label "Post Assertion Note: #9053" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 752, footnote 399" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8389> rdfs:label "Post Assertion Note: #8389" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 78, Legates." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8320> rdfs:label "Post Assertion Note: #8320" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "That these Legates continued in command for at least three years, and probably more, is indicated by the term of command of Gellius over his fleet (Cic. P. Red. ad Quir. 17, referring almost certainly to 63)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8319> rdfs:label "Post Assertion Note: #8319" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pompey's Legates in the war with the pirates (see 67, Legates) probably remained in their positions. L. Octavius may have substituted for the deceased L. Cornelius Sisenna." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7792> rdfs:label "Post Assertion Note: #7792" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Quaestor 85? Badian (Studies 230) would date his service in Liburnia in 85, suggesting service with Cinna before he went to Athens. Cf. MRR 2.57.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6796> rdfs:label "Post Assertion Note: #6796" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "III vir Capitalis?, probably between 95 and 90 (Gell. 13.12.6; see Cichorius, ES 200f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6662> rdfs:label "Post Assertion Note: #6662" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Varro in Gell. 13.12.6. Conjectures regarding the date vary from 87-81 (Niccolini, FTP 432f.) to after 70 (Cichorius, RS 201f.; Dahlmann, RE, Supb. 6.1176)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6603> rdfs:label "Post Assertion Note: #6603" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The date of his praetorship is uncertain but probably came soon after 76 (App. BC 4.47; Themist. p. 453 D; see Cichorius RS 203)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5936> rdfs:label "Post Assertion Note: #5936" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Caesar assigned him the task of assembling a library in Rome (Suet. Iul. 44.2; Isid. Orig. 6.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5602> rdfs:label "Post Assertion Note: #5602" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus of Pompey in Farther Spain (Caes. BC 2.17; Liv. Per. 110). His part was to send supplies to Afranius and Petreius, and their surrender to Caesar led to his (Caes. BC 1.38; 2.17-21; Auct. Bell. Alex. 58.2; Cic. Fam. 9.13. 1; Liv. Per. 110; Suet. Iul. 34.2; Plut. Caes. 36; Flor. 2.13.29; Dio 41.23-24; 43.36.3; Eutrop. 6.20.1-2; Oros. 6.15.7; Schol. Bern. on Lucan 4, p. 121 Usener). See 75, note 7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5484> rdfs:label "Post Assertion Note: #5484" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See 49, Legates. Probably a Legate under Pompey in Spain before 49." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5026> rdfs:label "Post Assertion Note: #5026" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Plin. NH 7.176; cf. Varro RR 1.2.10." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4807> rdfs:label "Post Assertion Note: #4807" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Other Legates appointed under the Gabinian and Manilian laws probably continued to serve under Pompey (see 67, and 66, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4741> rdfs:label "Post Assertion Note: #4741" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Held command in the Ionian sea from Delos to Sicily (Varro RR 2, proem. 6; App.; Flor.; Plin NH 3.101), and won the corona rostrata (Plin. NH 7.115; 16.7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4723> rdfs:label "Post Assertion Note: #4723" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "15 Under the Gabinian law Pompey was entitled to appoint Legates with praetorian imperium (App. Mith. 94; cf. SIG³ 750; Plut. Pomp. 26) to the number, according to Plutarch, of 15 (Pomp. 25; cf. Dio 36.37), according to Appian (Mith. 94), of 24; of that number we have the names of the 15 listed above, 13 of whom held command each in one of the 13 special areas designated by Pompey (see Zonar. 10.3). Their appointment may well have been extended in a number of cases with the extension of the term of Pompey's command under the Manilian law. At any rate Gellius was still in command of a fleet in 63 (Cic. P. Red. ad Quir. 17). See Mommsen, Str. 2.656, note 2; Th. Reinach, RPh 14 (1890) 150. On his Legates and plan of campaign, see P. Groebe, Klio 10 (1910) 374-389; H. A. Ormerod, Liverpool Annals of Art and Archaeology 10 (1923) 46-51." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4722> rdfs:label "Post Assertion Note: #4722" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Under Cn. Pompeius Magnus against the pirates:" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4399> rdfs:label "Post Assertion Note: #4399" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Almost certainly a Legate under Pompey in Spain against Sertorius (Sall. Hist. 2.69M; Varro RR 3.12.7). See Cichorius, RS 193f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4398> rdfs:label "Post Assertion Note: #4398" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "7 Cichorius (RS 193f.) suggests that after the death of Memmius (see 76, Quaestors) Varro became a Legatus pro quaestore (Grueber, CRRBM 2.362f., Varro proqu. Magn. procos.), and refers the coins with this title to this period. Mommsen, Grueber (loc. cit.) and, most recently, Sydenham (see Catalogue of his collection, p. 53, no. 337) attribute both them and the closely associated coins of Cn. Piso (see above, Promagistrates) to the period between 52 and 49 B.C. on the evidence of coin hoards. This seems reasonable in the case of Piso (see PIR² 2.57, no. 286), but in 49 Varro's title was Legatus pro praetore (see 49, Legates). The Proquaestor in Spain under Pompey, if correctly dated in 49, is probably another Varro." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4363> rdfs:label "Post Assertion Note: #4363" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Pompey in Spain for several years (Varro RR 3.12.7). See Cichorius, RS 193." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4304> rdfs:label "Post Assertion Note: #4304" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He may have served under Cosconius in Illyricum (Varro RR 2. 10. 8, of. 10.7 and 9; Cichorius, RS 191f.). See above, Promagistrates, on Cosconius." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4085> rdfs:label "Post Assertion Note: #4085" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Varro, Sat. Men. 478B (212, 8, Riese), inde caballum reduxi ad censorem. According to Cichorius (RS 219f.), he thus changed from the equestrian order to the senatorial in this censorship. As he attained the age of 30 in 86 he probably made the change as Quaestor Designatus for 85." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10430> rdfs:label "Post Assertion Note: #10430" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Varro RR 3.12.7. Hinard dates his tenure as legate in Spain to 76-71, not just 76-75 as in MRR. Varro writes 'many years' in Spain." .
