<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8859> rdfs:label "Post Assertion Note: #8859" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 726, footnote 22" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1955> rdfs:label "Post Assertion Note: #1955" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to supplement the colony of Venusia (Liv. 31.49.6; cf. Plut. Flam. 1.4, Narnia and Cosa). On Quinctius, see Lübker no. 11." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1954> rdfs:label "Post Assertion Note: #1954" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Plutarch confuses this commission with that for Narnia (see 199) and Cosa (refused in 199, Livy 32.2.7, but granted in 197-6, 33.24.8-9); and names Flaminius as its head (Flam. 1.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1945> rdfs:label "Post Assertion Note: #1945" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent on missions to Carthage, to Masinissa, and to Vermina, Syphax's son (Liv. 31.11.4-18, and 19.1-6)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1862> rdfs:label "Post Assertion Note: #1862" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "The accusations brought against Philip by the Greek envoys (Liv. 30.26.2-4) are probably late annalistic fabrications (Holleaux, CAH 8.156, note 1), but the names and the sending of an embassy may be based on archival material (Crake 155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1861> rdfs:label "Post Assertion Note: #1861" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent by the Senate to protest to Philip of Macedon against alleged violations\n     of his treaty with the Romans (Liv. 30.26.2-4; see 202 and 201, Legates)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1728> rdfs:label "Post Assertion Note: #1728" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Etruria as Propraetor (Liv. 27.35.2, and 36.13; 28.10.11)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1719> rdfs:label "Post Assertion Note: #1719" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Livy omits the regular list of prorogations for this year with the exception of Q. Fulvius Flaccus." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1693> rdfs:label "Post Assertion Note: #1693" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Invested with imperium pro praetore (Liv. 24.35.2), and sent to aid in curbing defection in Etruria (Liv. 27.24.1-9; cf. Mommsen, Str. 1.681, notes 1 and 6; 2.652, note 2)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1496> rdfs:label "Post Assertion Note: #1496" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Picenum (Liv. 24.44.5)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1461> rdfs:label "Post Assertion Note: #1461" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued in Picenum (Liv. 24.10.3, and 11.3)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1427> rdfs:label "Post Assertion Note: #1427" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Imperium prorogued (Liv. 23.25.11); sent to levy troops and garrison Picenum (Liv. 23.32.19, cf. 16)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1356> rdfs:label "Post Assertion Note: #1356" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Polyb. 3.106.1; Cic. Off. 3.114; Liv. 22.34-35; Fast. Cap., Degrassi 46f., 119, 444f., cf. Fast. Fer. Lat., Degrassi 149f.; Val. Max. 3.4.4.; Frontin. Str. 4.1.4; Plut. Fab. 14; Sil. It. 8.242ff.; App. Hann. 17; Dio 57.23; Zon. 9.1. Both engaged Hannibal at Cannae where Paullus fell while Varro escaped to Venusia (Polyb. 3.106-116; Liv. 22.38-50; cf. Cic. Off. 3.114; Sen. 75; Nep. Hann. 4.4; Hor. Carm. 1.12.38; Liv. 23.11.9; Val. Max. 3.4.4; Sil. It. 8-10; Plut. Aem. 2.2; Fab. 14-16; Flor. 1.22.15-18; App. Hann. 17-25; Dio fr. 57.23-25; Ampel. 46.5, cf. 28.4; Auct. Vir. Ill. 42.4; Eutrop. 3.10; Porphyr. ad Hor. Carm. 1.12.37; Schol. on Iuv. 2.155; 11.201; Lact. Inst. 2.16; Sid. Apoll. 7.556; Oros. 4.16.1-4; 5.5.7-8; Zon. 9.1; on Aemilius, Cic. Div. 2.71; ND 3.80; Tusc. 1.89; Sen. 61; Hor. Carm. 1.12.37f.; Vell. 1.9.3; Val. Max. 5.1, ext. 6; Frontin. Str. 4.5.5; Auct. Vir. Ill. 56.1; on Varro, Liv. 25.6.9; 26.3.2; Val. Max. 1.1.16; 3.4.4; 4.5.2). Varro collected the remnants of the army and led them to Canusium (Liv. 22.54.1-6, and 56.1-4; App. Hann. 26; Dio fr. 57.29; Zon. 9.2), was then summoned to Rome to receive the famous decree of thanks (Liv. 22.57.1, and 61.13-14; 25.6.7; Val. Max. 3.4.4, cf. 4.5.2; Frontin. Str. 4.5.6; Plut. Fab. 18; Sil. It. 10.606-639; Flor. 1.22.17; Schol. Iuv. 11.201; Oros. 5.5.9). Summoned a second time to Rome, he appointed a Dictator to make up the roll of the Senate (Liv. 23.22.10-11, and 23.9), and returned to Apulia." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1303> rdfs:label "Post Assertion Note: #1303" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 22.25.18, cf. 26.3." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1302> rdfs:label "Post Assertion Note: #1302" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Varro is tentatively placed in the fourth of the regular praetorian provinces of this period." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1284> rdfs:label "Post Assertion Note: #1284" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 22.26.3; Val. Max. 1.1.16; Lact. Inst. Div. 2.16. See 221, Aediles of the Plebs; Seidel, Fast. Aed. 21." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1283> rdfs:label "Post Assertion Note: #1283" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Note however CIL 1(2).2.24, for evidence that the two aedileships could be held in the opposite order." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1272> rdfs:label "Post Assertion Note: #1272" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 22.26.3, cf. 25-26, and 34.2; Val. Max. 1.1.16; 4.5.2; Lact. Inst. Div. 2.16. If he held the Aedileship of the Plebs before he became Curule Aedile (see 220), this year is the latest possible date (Seidel, Fast. Aed. 21)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1266> rdfs:label "Post Assertion Note: #1266" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 22.25.18. Both aedileships preceded his praetorship, and the quaestorship probably preceded them (see 221 and 220, Aediles), making 222 the latest possible date." .
