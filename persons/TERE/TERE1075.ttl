<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2050> rdfs:label "Post Assertion Note: #2050" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Ten Legati were appointed to assist Flamininus in arranging the peace with Philip and the settlement in Greece (Polyb. 18.42.5; Liv. 33.24.7, cf. 30.1, and 35.1-2). The following are known, and since Livy nowhere lists them in an official order, they are given in alphabetical order." ;
	dprr:hasID 2050 .
