<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6134> rdfs:label "Post Assertion Note: #6134" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "No title preserved. Though placed by Lepidus to guard the coast road along the Maritime Alps he admitted Antony's forces (Cic. Fam. 10.34.2; App. BC 3.83)." ;
	dprr:hasID 6134 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5119> rdfs:label "Post Assertion Note: #5119" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See L. R. Taylor, \"Caesar's Colleagues in the Pontifical College,\" AJPh 63 (1942) 385-412; and above, 73, 69, 63, 60, and 58, Pontifices." ;
	dprr:hasID 5119 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5050> rdfs:label "Post Assertion Note: #5050" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proposed to annul the law exiling Cicero on the ground that it was a privilegium (Cic. Att. 3.15.5), and attempted to draw Pompey away from his association with Caesar (Plut. Pomp. 49.3)." ;
	dprr:hasID 5050 .
