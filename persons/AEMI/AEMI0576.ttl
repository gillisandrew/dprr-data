<http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> rdfs:label "Secondary Source: Broughton MRR I" ;
	a dprr:SecondarySource ;
	dprr:hasName "The Magistrates of the Roman Republic, Vol. I" ;
	dprr:hasBiblio "Broughton, T. R. S., The Magistrates of the Roman Republic, Vol. I. Published by the American Philological Association. New York 1952." ;
	dprr:hasAbbreviation "Broughton MRR I" .
<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1147> rdfs:label "Primary Source Reference: #1147" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Liv. XLII 28.11" ;
	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1127> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/834> rdfs:label "Post Assertion Note: #834" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "He too failed to hold elections (Liv. 9.7.14; cf. Elog. 34 in CIL 1\n     , p. 200, and Inscr. Ital. 13.3.68; Degrassi 108, 416f.)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/833> rdfs:label "Post Assertion Note: #833" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Degrassi in Inscr. Ital. 13.3.68 opposes Mommsen's identification of Papus, the Dictator of this year, with Barbula of the Elogium, who is evidently a{152} brother of the Consul of 317 and 311, on the ground that Barbula appears to be a younger brother, and that he could have appeared in the missing portion of the Fasti between 292 and 285. See Degrassi 112." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/1127> rdfs:label "Post Assertion: #1127" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/576> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/834> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/833> ;
	dprr:hasOriginalText "M. Aemilius - f. - n. Papus Pat. (110)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/13> ;
	dprr:hasDateStart -321 ;
	dprr:hasDateSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasDateEnd -321 .
