<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10519> rdfs:label "Post Assertion Note: #10519" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 5.142. Deserts Sex. Pompey for the Antonian forces led by M. Titius. Scaurus' information was instrumental in securing Sextus' capture." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10518> rdfs:label "Post Assertion Note: #10518" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Dio 51.2.5. With Antony on Actium campaign. Captured after the battle and condemned to death, Octavian pardoned Scaurus for the sake of Scaurus' mother, Mucia Tertia." .
