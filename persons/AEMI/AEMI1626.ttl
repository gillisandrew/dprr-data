<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3226> rdfs:label "Post Assertion Note: #3226" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cic. Brut. 109; Fast. Ant., Degrassi 162f., 470f. ([L. Au]rel[- - - -]); Censorin. DN 17.11; Chr. 354 (Lepido et Horesten); Fast. Hyd. (Lepido et Oreste), so also Chr. Pasc.; Oros. 5.10.11; Cassiod.; on Orestes, Liv. Per. 60; Plut. CG 1.4; and on his name, Act. Tr. for 122. Orestes received command against rebels in Sardinia (Liv. Per. 60; Plut. CG 1.4; Auct. Vir. Ill. 72.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3206> rdfs:label "Post Assertion Note: #3206" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The latest dates possible for their praetorships under the Lex Villia." .
