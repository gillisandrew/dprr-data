<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9973> rdfs:label "Post Assertion Note: #9973" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph ex Macedonia et rege Perse. MRR I.433-4, Itgenshorst no. 200, Rich no. 199." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9972> rdfs:label "Post Assertion Note: #9972" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Liguribus Ingauneis. MRR I.384, Itgenshorst no. 186, Rich no. 185." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9971> rdfs:label "Post Assertion Note: #9971" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/31> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph? ex Hispania. MRR I.362, Itgenshorst no.177a (triumphus incertus). Not listed in Rich." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9843> rdfs:label "Post Assertion Note: #9843" ;
	a dprr:PostAssertionNote ;
