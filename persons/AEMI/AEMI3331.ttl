<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7388> rdfs:label "Post Assertion Note: #7388" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Pliny includes him in a list of sudden deaths (NH 7.181), in a passage taken from Verrius Flaccus, after the names of two senators and before that of C. Aufustius, cum in senatum iret. Possibly father of M. Aemilius Q. f. M. n. Lepidus (72). Cos. 78, or a son of M. Aemilius M. f. Q. n. Lepidus (73), the IIIvir r. p. c. (RS, MS-RP 1.273-274).\n" ;
	dprr:hasID 7388 .
