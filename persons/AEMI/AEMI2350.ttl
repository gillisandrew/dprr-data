<http://romanrepublic.ac.uk/rdf/entity/RelationshipAssertionReference/846> rdfs:label "Relationship Assertion Reference: #846" ;
	a dprr:RelationshipAssertionReference ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/11> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Die Verwandtschaft auf die sich bezieht ist unklar. cf. Cic. Att. VI 3,4 huc enim odiosa adferebantur de Curione,\nde Paulo. Paulus und Curio stehen in Ciceros Korrespondenz häufig in engem Zusammenhang. Dieser Zusammenhang könnte auch verwandtschaftlich gewesen sein." ;
	dprr:hasExtraInfo "Dio XL 63.5" .
