<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/6817> rdfs:label "Post Assertion Note: #6817" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/3> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Her fire, apparently extinguished, was miraculously relit (Dion. Hal. 2.68.3-5; Val. Max. 1.1.7; cf. Propert. 4.11.53-54; Grueber, CRRBM 1.448, note). Date and identification remain uncertain." ;
	dprr:hasID 6817 .
