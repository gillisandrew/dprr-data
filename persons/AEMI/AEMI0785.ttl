	dprr:hasNoteText "M. Aemilius Lepidus succeeded M. Aemilius Numida." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1591> rdfs:label "Post Assertion Note: #1591" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "See 236, Decemviri sacris faciundis. The Aemilius Numida who died this year may with probability be identified with the M'. Aemilius who was magister at the celebration of the Saecular Games in 236. On these games, see L. R. Taylor, AJPh 55 (1934) 105f." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1590> rdfs:label "Post Assertion Note: #1590" ;
