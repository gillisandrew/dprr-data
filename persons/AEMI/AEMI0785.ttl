	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Liv. 26.23.7." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1218> rdfs:label "Post Assertion Note: #1218" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Magister at the third celebration of the Saecular Games (CIL 1(2) .1, p. 29, fr. XLVI; Fast. Cap., fr. XLIX, Degrassi 62f., 142). On Numida, see 211, Decemviri s. f." .
