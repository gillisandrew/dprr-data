<http://romanrepublic.ac.uk/rdf/entity/PersonNote/173> rdfs:label "Person Note: #173" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
