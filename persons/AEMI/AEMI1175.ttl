<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8481> rdfs:label "Post Assertion Note: #8481" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/7> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "p. 731, footnote 58" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2253> rdfs:label "Post Assertion Note: #2253" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Celebrated a naval triumph as Propraetor (Liv. 37.58.3-4; 40.52.4-6; Act. Tr., Degrassi 80f., 553; Caes. Bass. in GLK 6.265; Macrob. Sat. 1.10.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2202> rdfs:label "Post Assertion Note: #2202" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Campaigned actively in the Aegean, and succeeded in destroying Antiochus' fleet at Myonnessus (Liv. 37.2.10, 4.5, 14-15, 17-19, 21.6-22, 26-32, and 47.3-4; cf. Polyb. 21.7-8, and 10; App. Syr. 26-27; cf. ILS 8765; M. Guarducci, I. Cret. 2.3.5). Vowed a temple to the Lares Permarini (Macrob. Sat. 1.10.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/2201> rdfs:label "Post Assertion Note: #2201" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/3> ;
	dprr:hasNoteText "Elections: Liv. 36.45.9 Provinces and armies Liv. 37.2.1 and 8-10." .
