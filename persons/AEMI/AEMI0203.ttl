<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9967> rdfs:label "Post Assertion Note: #9967" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/30> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph de Veientibus et Fidenatibus (It.), de Veientibus (R.). MRR I.67, Itgenshorst p. 263, Rich no. 42." ;
	dprr:hasID 9967 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9966> rdfs:label "Post Assertion Note: #9966" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/31> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Triumph? de Falisceis, Veientibus et Fidenatibus. MRR I.59, Itgenshorst p. 263 (triumphus incertus). Not listed in Rich." ;
	dprr:hasID 9966 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/390> rdfs:label "Post Assertion Note: #390" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Defeated Veii and Fidenae, recaptured the latter, and celebrated a triumph (Liv. 4.31-34; Diod. 12.80.6-8; Val. Max. 3.2.4; Frontin. Str. 2.4.19; Flor. 1.6.7; Auct. Vir. Ill. 25; Oros. 2.13.10; Lyd. Magg. 1.38; Degrassi 96, 374f., 539)." ;
	dprr:hasID 390 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/389> rdfs:label "Post Assertion Note: #389" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Aemilius' praenomen is given in Livy as M., and his cognomen in Diod. as {Gr}. Bandel (25) takes this to be the only authentic one among his three dictatorships. See 437 and 434." ;
	dprr:hasID 389 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/384> rdfs:label "Post Assertion Note: #384" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to investigate the participation of Fidenates in Veientane raids (Liv. 4.30.5-6).{66}" ;
	dprr:hasID 384 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/360> rdfs:label "Post Assertion Note: #360" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Appointed to face threats from Falerii and Etruria. Carried a measure to limit the censorship to one and one-half years (Liv. 4.23.5-24.9; 9.33.9, and 34.6-9; Degrassi 95, 372f.)." ;
	dprr:hasID 360 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/339> rdfs:label "Post Assertion Note: #339" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Credited with an important victory over Veii, Falerii, and Fidenae (Liv. 4.17.8-20.4, and 32.3; Eutrop. 1.19; Lyd. Magg. 1.36), and a triumph (Liv. 4.20.1-4; see above, Consul Suffectus, and Tribunes of the Soldiers)." ;
	dprr:hasID 339 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/333> rdfs:label "Post Assertion Note: #333" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.16.7-17.1; Diod. 12.38.1; Chr. 354 (Fidenato et Cincinnato); Degrassi 95, 370f." ;
	dprr:hasID 333 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/332> rdfs:label "Post Assertion Note: #332" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "In Diod. Aemilius' name appears as {Gr}, and Iulius' praenomen as {Gr}. Degrassi (95) considers that in Fast. Cap. Iulius' praenomen was more probably C. than L. Either is possible, see 447 and 435, Consuls (C. Iulius), and 430, Consuls (L. Iulius)." ;
	dprr:hasID 332 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/289> rdfs:label "Post Assertion Note: #289" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "The first elected Quaestors, the sixty-third year after the expulsion of the Tarquins (Tac. Ann. 11.22). On Valerius, see Münzer, Gent. Val. 35, no. 3." ;
	dprr:hasID 289 .
