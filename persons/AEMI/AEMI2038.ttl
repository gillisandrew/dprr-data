<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7786> rdfs:label "Post Assertion Note: #7786" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cos. 66. Proquaestor in an eastern province, probably Asia (I. de Delos 4.1.1659; MRR 2.86). See also I. Priene 244; Münzer, APF 180, 318-319." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4747> rdfs:label "Post Assertion Note: #4747" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "CIL 12.2.667, 958, 959; Cic. Cat. 1.15; Sull. 11; Sall. Cat. 18.2; Ascon. 59 C; Dio 36.42.3; Chr. 354 (Lepido et Tullo); Fast. Hyd. (Bulcacio et Tullo), so also Chr. Pasc.; Cassiod. (An-, or Cn., Lepidus), on Lepidus, Ascon. 79 C; and on Volcatius, Ascon. 28 C. See Degrassi 131, 488f. Volcatius refused to accept the candidacy of Catiline for the consulship of 65 (Ascon. 89 C)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4746> rdfs:label "Post Assertion Note: #4746" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 For the filiation M’. f., see I. de Delos 4.1.1659." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4589> rdfs:label "Post Assertion Note: #4589" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 The latest date possible under the Cornelian law." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4288> rdfs:label "Post Assertion Note: #4288" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Proquaestor in an eastern province (I. de Delos 4.1.1659) between 84 and 78 (the term of Nicanor, Kirchner, Prosop. Att. 2.121, no. 10705)." .
