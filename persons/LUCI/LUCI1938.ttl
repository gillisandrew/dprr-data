<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4005> rdfs:label "Post Assertion Note: #4005" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Thrown at Marius' command from the Tarpeian rock by P. Laenas, Tribune in 86 (Vell. 2.24.2; cf. Liv. Per. 80; Plut. Mar. 45.1; Dio 30-35, fr. 102.12)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4004> rdfs:label "Post Assertion Note: #4004" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "1 The name Licinius in Livy (# in Plutarch) is doubtful, since the praenomen Sextus does not appear in the Licinian family. The accounts in the other sources appear to refer to the same incident (see Münzer, RE, and Niccolini, FTP 235f.)." .
