<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/8070> rdfs:label "Post Assertion Note: #8070" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "See MRR 2.147, no. 1. Perhaps a praefectus classis in Crete in 68 (Dio 36.19.1).\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7646> rdfs:label "Post Assertion Note: #7646" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Legatus of Q. Metellus in Crete, 67. See MRR 2.147. Syme suggests that # in Dio 36.19 may be a mistake for # (RP 2.610). For the name see Cic. Att. 12.5.2; cf. Fam. 7.20.3. See also Wiseman, NM 280, no. 526.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4716> rdfs:label "Post Assertion Note: #4716" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Defeated at sea by Aristion (Dio 36.19.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/4715> rdfs:label "Post Assertion Note: #4715" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "14 In D-G. 2.42, Cn. Plancius is also listed, but he was only a miles under Metellus (Cic. Planc. 27)." .
