<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10415> rdfs:label "Post Assertion Note: #10415" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 4.129, Plut. Brut. 50.1-9, Plut. Ant. 69.1.. Af Philippi. After the defeat he bought Brutus time by telling some Antonian troops that he was Brutus and that he wished to surrender to their commander. His ruse revealed when in Antony's presence, Antony nonetheless accepted Lucilius into his own service, where he remained until Antony's end." ;
	dprr:hasID 10415 .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/10414> rdfs:label "Post Assertion Note: #10414" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/21> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "App. BC 4.129, Plut. Brut. 50.1-9, Plut. Ant. 69.1.. In Antony's service between Philippi and Antony's death." ;
	dprr:hasID 10414 .
