<http://romanrepublic.ac.uk/rdf/entity/PersonNote/2416> rdfs:label "Person Note: #2416" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "His praenomen, given as M. due to the incorrect identification of Cicero's client with the M. Curtius whom Cicero recommended to Caesar for a military tribunate in 54 (QF 2.14.3; 3.1.10), is established as C. by that of his freedman C. Curtius Mithres (Fam. 13.69.1). See Shackleton Bailey, Studies 33- 34." ;
	dprr:hasID 2416 .
