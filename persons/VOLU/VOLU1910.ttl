<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/9803> rdfs:label "Post Assertion Note: #9803" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Cichorius identifies him as a Tribune of the Soldiers based on the list of members of the staff of Pompeius Strabo at Asculum (ILS 8888; RS 144-155)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7366> rdfs:label "Post Assertion Note: #7366" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Probably a tr. mil. He was at Asculum in the consilium of Pompeius Strabo (ILS 8888; CIL 1(2).709, 6.37045). He might be the monetalis L. Vol. L. f. Strabo (see below, Vol(lumnius) [3 and  14]), and may be identified with the senator Volumnius, Cicero's friend (Fam. 7.32.1). See Criniti, L'Epigrafe di Asculum 113-114; and Suolahti, Junior Officers 313, 397.[223x]\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/3925> rdfs:label "Post Assertion Note: #3925" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "13 Possibly the father of the monetalis (but cf. Grueber, CRRBM 1.385, who reads Vol(teius)) and senator, Cicero's friend (RS 150)." .
