<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/7433> rdfs:label "Post Assertion Note: #7433" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/5> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praef. eq. 51. See MRR 2.246. These three entries should be amalgamated under the name C. Volusenus Quadratus. Together they represent the long and excellent service of a notable equestrian officer (Syme, RR 70f., and 355). (RS, CP) In MRR 2.246  read Volusenus for Volusius. See also Suolahti, Junior Officers 398.\n" .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5727> rdfs:label "Post Assertion Note: #5727" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Prefect of cavalry under Caesar (Caes. BC 3.60.4)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5436> rdfs:label "Post Assertion Note: #5436" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Praefectus equitum under Caesar in Gaul (Hirtius in Caes. BG 8.48; cf. 8.23.4-6; Dio 40.43.1)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5375> rdfs:label "Post Assertion Note: #5375" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to put Commius the Atrebatian to death (Hirt. in Caes. BG 8.23.4-6). See 51, Prefects." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/5158> rdfs:label "Post Assertion Note: #5158" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/2> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Caesar in Gaul (Caes. BG 3.5.2). For other Tribunes, see below, Legates, Envoys." .
