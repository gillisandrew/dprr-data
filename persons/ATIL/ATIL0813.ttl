<http://romanrepublic.ac.uk/rdf/entity/PrimarySourceReference/1690> rdfs:label "Primary Source Reference: #1690" ;
	a dprr:PrimarySourceReference ;
	dprr:hasNoteText "Pol. XVIII 35.9" ;
