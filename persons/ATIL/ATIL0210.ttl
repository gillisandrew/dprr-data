	dprr:forAssertion <http://romanrepublic.ac.uk/rdf/entity/PostAssertion/379> .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/297> rdfs:label "Post Assertion Note: #297" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Liv. 4.6.6-12, and 7.1; Diod. 12.32.1; Dion. Hal. 11.61.3; Chr. 354 (Siculo et Luscino); Degrassi 95, 368f. The first college elected to this{53} office. But after three months they abdicated because of flaws in the auspices at their election (Liv. 4.7.2-3; Dion. Hal. 11.62.1-2; cf. Zon. 7.19)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/296> rdfs:label "Post Assertion Note: #296" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/4> ;
	dprr:hasNoteText "Diod. omits Sempronius' cognomen; his filiation is inferred from Fast. Cap. on 416. For Cloelius, Liv. has Caecilius (but cf. 4.11.5), Dion. Hal. {Gr}, and Diod. {Gr}; while the cognomen Siculus is also preserved in Chr. 354. Atilius' cognomen appears as {Gr} in Dion. Hal. and Luscinus in Chr. 354." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertion/379> rdfs:label "Post Assertion: #379" ;
	a dprr:PostAssertion ;
	dprr:isAboutPerson <http://romanrepublic.ac.uk/rdf/entity/Person/210> ;
	dprr:hasSecondarySource <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasPostAssertionNote <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/297> , <http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/296> ;
	dprr:hasOriginalText "L. Atilius - f. - n. Luscus Pat. ? (41)" ;
	dprr:hasOffice <http://romanrepublic.ac.uk/rdf/entity/Office/34> ;
