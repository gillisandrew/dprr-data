<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1622> rdfs:label "Post Assertion Note: #1622" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Sent to Ptolemy and Cleopatra in Egypt to renew Rome's friendship (Liv. 27.4.10)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1575> rdfs:label "Post Assertion Note: #1575" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Served under Fulvius Flaccus at Capua (Liv. 26.6.1, and 33.5-7)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1480> rdfs:label "Post Assertion Note: #1480" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/1> ;
	dprr:hasNoteText "Received the knights from Capua who deserted Hannibal for Rome (Liv. 24.47.12-13)." .
<http://romanrepublic.ac.uk/rdf/entity/PostAssertionNote/1479> rdfs:label "Post Assertion Note: #1479" ;
	a dprr:PostAssertionNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/1> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/2> ;
	dprr:hasNoteText "Though the name of Atilius has fallen out of the Mss tradition at Liv. 24.43.6, Müller is undoubtedly correct in supplying it from 24.44.2. See Conway and Walters ad loc. Willems (1.328, no. 84) suggests the cognomen Serranus." .
