<http://romanrepublic.ac.uk/rdf/entity/PersonNote/274> rdfs:label "Person Note: #274" ;
	a dprr:PersonNote ;
	dprr:hasSecondarySourceForNote <http://romanrepublic.ac.uk/rdf/entity/SecondarySource/28> ;
	dprr:hasNoteType <http://romanrepublic.ac.uk/rdf/entity/NoteType/11> ;
	dprr:hasNoteText "Im Jahr 218 führte er die Vota decennalia an, im Jahr 216 war er an der Dedikation des Concordiatempels beteiligt." .
